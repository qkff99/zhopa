end

local function patch_gather_item()
	return patch_exported_function("gather_item", "pickup", function(original)
		return function(npc, ...)
			local st = storage_gather_state(npc)
			local item_id = st and tonumber(st.selected_id) or nil
			log(
				"stage [gather_item_before] npc [%s] selected [%s] targeted [%s] %s %s",
				named_id(npc),
				tostring(item_id or "-"),
				tostring(st and st.zhopa2_targeted_item_id or "-"),
				gather_state(npc),
				gather_detail(npc, item_id, st)
			)
			local result = { original(npc, ...) }
			log(
				"stage [gather_item_after] npc [%s] selected_before [%s] %s post_artifact [%s]",
				named_id(npc),
				tostring(item_id or "-"),
				gather_state(npc),
				item_id and artifact_state(item_id) or "artifact [-]"
			)
			return unpack(result)
		end
	end)
end

local function patch_gather_find()
	local gather = gather_mod()
	local eva = gather and (rawget(_G, "eva_gather_itm") or gather.eva_gather_itm) or nil
	if not eva then
		return false, "missing_eva_gather_itm"
	end
	return patch_table_method(eva, "find_valid_item", "gather", function(original)
		return function(self, ...)
			local npc = self and self.object or nil
			local st = self and self.st or nil
			local before_selected = st and tonumber(st.selected_id) or nil
			local before_targeted = st and tonumber(st.zhopa2_targeted_item_id) or nil
			local before_memory1 = st and st.memory and tonumber(st.memory[1]) or nil
			local result = { original(self, ...) }
			local after_selected = st and tonumber(st.selected_id) or nil
			local after_targeted = st and tonumber(st.zhopa2_targeted_item_id) or nil
			local after_memory1 = st and st.memory and tonumber(st.memory[1]) or nil
			if result[1] or before_targeted or after_targeted or before_selected ~= after_selected or before_memory1 ~= after_memory1 then
				local changed_from_target = before_targeted and after_selected and before_targeted ~= after_selected
				log(
					"stage [gather_find_after] result [%s] npc [%s] before_selected [%s] before_targeted [%s] before_memory1 [%s] after_selected [%s] after_targeted [%s] after_memory1 [%s] changed_from_target [%s] %s %s",
					tostring(result[1]),
					named_id(npc),
					tostring(before_selected or "-"),
					tostring(before_targeted or "-"),
					tostring(before_memory1 or "-"),
					tostring(after_selected or "-"),
					tostring(after_targeted or "-"),
					tostring(after_memory1 or "-"),
					bool_text(changed_from_target == true),
					after_selected and artifact_state(after_selected) or "artifact [-]",
					gather_detail(npc, after_selected, st)
				)
			end
			return unpack(result)
		end
	end)
end

local function patch_gather_evaluate()
	local gather = gather_mod()
	local eva = gather and (rawget(_G, "eva_gather_itm") or gather.eva_gather_itm) or nil
	if not eva then
		return false, "missing_eva_gather_itm"
	end
	return patch_table_method(eva, "evaluate", "gather_eval", function(original)
		return function(self, ...)
			local npc = self and self.object or nil
			local st = self and self.st or nil
			local interesting = st and (st.zhopa2_targeted_item_id or st.selected_id or st.nearest_id)
			local result = { original(self, ...) }
			if interesting or result[1] then
				log(
					"stage [gather_evaluate_after] result [%s] npc [%s] %s %s",
					tostring(result[1]),
					named_id(npc),
					gather_state(npc),
					gather_detail(npc, st and st.selected_id, st)
				)
			end
			return unpack(result)
		end
	end)
end

local function patch_gather_action()
	local gather = gather_mod()
	local act = gather and (rawget(_G, "act_gather_itm") or gather.act_gather_itm) or nil
	if not act then
		return false, "missing_act_gather_itm"
	end
	local ok_init, reason_init = patch_table_method(act, "initialize", "gather_action", function(original)
		return function(self, ...)
			local npc = self and self.object or nil
			local st = self and self.st or nil
			log(
				"stage [gather_initialize_before] npc [%s] %s %s",
				named_id(npc),
				gather_state(npc),
				gather_detail(npc, st and st.selected_id, st)
			)
			local result = { original(self, ...) }
			log(
				"stage [gather_initialize_after] npc [%s] %s %s",
				named_id(npc),
				gather_state(npc),
				gather_detail(npc, st and st.selected_id, st)
			)
			return unpack(result)
		end
	end)
	local ok_execute, reason_execute = patch_table_method(act, "execute", "gather_action", function(original)
		return function(self, ...)
			local npc = self and self.object or nil
			local st = self and self.st or nil
			local item_id = st and tonumber(st.selected_id) or nil
			local logged_before = item_id and should_log_gather_execute(npc, st, item_id)
			if logged_before then
				log(
					"stage [gather_execute_before] npc [%s] %s %s",
					named_id(npc),
					gather_state(npc),
					gather_detail(npc, item_id, st)
				)
			end
			local result = { original(self, ...) }
			if logged_before or (item_id and should_log_gather_execute(npc, st, item_id)) then
				log(
					"stage [gather_execute_after] npc [%s] %s %s result [%s]",
					named_id(npc),
					gather_state(npc),
					gather_detail(npc, st and st.selected_id, st),
					tostring(result[1] or "-")
				)
			end
			return unpack(result)
		end
	end)
	local ok_finalize, reason_finalize = patch_table_method(act, "finalize", "gather_action", function(original)
		return function(self, ...)
			local npc = self and self.object or nil
			local st = self and self.st or nil
			log(
				"stage [gather_finalize_before] npc [%s] %s %s",
				named_id(npc),
				gather_state(npc),
				gather_detail(npc, st and st.selected_id, st)
			)
			local result = { original(self, ...) }
			log(
				"stage [gather_finalize_after] npc [%s] %s",
				named_id(npc),
				gather_state(npc)
			)
			return unpack(result)
		end
	end)
	return ok_init == true and ok_execute == true and ok_finalize == true, tostring(reason_init or "-") .. "/" .. tostring(reason_execute or "-") .. "/" .. tostring(reason_finalize or "-")
end

function M.dump_all(reason)
	if not debug_print_enabled() then
		return false
	end
	local idx = idx_mod()
	local board = rawget(_G, "SIMBOARD")
	log(
		"stage [dump_begin] reason [%s] idx [%s] artifacts [%s] artifact_smart [%s] smart_buckets [%s] squads [%s]",
		tostring(reason or "-"),
		tostring(idx ~= nil),
		tostring(table_count(idx and idx.artifacts)),
		tostring(table_count(idx and idx.artifact_smart)),
		tostring(table_count(idx and idx.smart_artifacts)),
		tostring(table_count(board and board.squads))
	)
	if idx then
		local printed = 0
		for _, artifact_id in ipairs(sorted_keys(idx.artifacts)) do
			printed = printed + 1
			if printed > MAX_DUMP_ARTIFACTS then
				log("stage [dump_artifact_truncated] shown [%s] limit [%s]", tostring(printed - 1), tostring(MAX_DUMP_ARTIFACTS))
				break
			end
			log("stage [dump_artifact] %s", artifact_state(artifact_id))
		end
		for _, smart_id in ipairs(sorted_keys(idx.smart_artifacts)) do
			log("stage [dump_bucket] %s", smart_state(smart_id))
		end
	end
	if board and board.squads then
		local printed_squads = 0
		for _, squad_id in ipairs(sorted_keys(board.squads)) do
			local squad = safe_alife_object(squad_id) or board.squads[squad_id]
			if squad and squad.zhopa2_task == "ARTEFACT" then
				printed_squads = printed_squads + 1
				if printed_squads > MAX_DUMP_SQUADS then
					log("stage [dump_squad_truncated] shown [%s] limit [%s]", tostring(printed_squads - 1), tostring(MAX_DUMP_SQUADS))
					break
				end
				log("stage [dump_squad_task] %s", squad_state(squad))
			end
		end
	end
	log("stage [dump_end] reason [%s]", tostring(reason or "-"))
	return true
end

function M.install(source)
	local ok_index, reason_index = patch_index()
	local ok_artifacts, reason_artifacts = patch_artifacts()
	local ok_loot, reason_loot = patch_loot()
	local ok_prepare, reason_prepare = patch_prepare_gather()
	local ok_force, reason_force = patch_force_gather()
	local ok_gather_item, reason_gather_item = patch_gather_item()
	local ok_find, reason_find = patch_gather_find()
	local ok_eval, reason_eval = patch_gather_evaluate()
	local ok_action, reason_action = patch_gather_action()
	installed = ok_index == true and ok_artifacts == true and ok_loot == true and ok_prepare == true and ok_force == true and ok_gather_item == true and ok_find == true and ok_eval == true and ok_action == true
	if installed then
		log("stage [install] source [%s] result [true]", tostring(source or "-"))
	else
		log(
			"stage [install] source [%s] result [false] index [%s:%s] artifacts [%s:%s] loot [%s:%s] prepare [%s:%s] force [%s:%s] gather_item [%s:%s] gather_find [%s:%s] gather_eval [%s:%s] gather_action [%s:%s]",
			tostring(source or "-"),
			tostring(ok_index), tostring(reason_index or "-"),
			tostring(ok_artifacts), tostring(reason_artifacts or "-"),
			tostring(ok_loot), tostring(reason_loot or "-"),
			tostring(ok_prepare), tostring(reason_prepare or "-"),
			tostring(ok_force), tostring(reason_force or "-"),
			tostring(ok_gather_item), tostring(reason_gather_item or "-"),
			tostring(ok_find), tostring(reason_find or "-"),
			tostring(ok_eval), tostring(reason_eval or "-"),
			tostring(ok_action), tostring(reason_action or "-")
		)
	end
	if installed and AUTO_DUMP_ON_INSTALL and not dumped then
		dumped = true
		M.dump_all("install")
	end
	return installed
end

local function unregister_update()
	if UnregisterScriptCallback then
		pcall(UnregisterScriptCallback, "actor_on_update", M.actor_on_update)
	end
end

function M.actor_on_update()
	if installed then
		unregister_update()
		return
	end
	if next_try_tg and tg() > 0 and tg() < next_try_tg then
		return
	end
	attempts = attempts + 1
	if M.install("actor_on_update") then
		unregister_update()
		return
	end
	if attempts >= MAX_ATTEMPTS then
		log("stage [install_failed] attempts [%s]", tostring(attempts))
		unregister_update()
		return
	end
	next_try_tg = tg() > 0 and (tg() + RETRY_MS) or nil
end

function M.actor_on_first_update()
	if scheduled then
		return
	end
	scheduled = true
	next_try_tg = tg() > 0 and (tg() + DUMP_DELAY_MS) or nil
	if RegisterScriptCallback then
		if UnregisterScriptCallback then
			pcall(UnregisterScriptCallback, "actor_on_update", M.actor_on_update)
		end
		RegisterScriptCallback("actor_on_update", M.actor_on_update)
	else
		M.actor_on_update()
	end
end

function M.on_game_start()
	if not AUTO_PATCH_ENABLED then
		return
	end
	M.install("on_game_start")
	if installed then
		return
	end
	if not RegisterScriptCallback then
		return
	end
	if UnregisterScriptCallback then
		pcall(UnregisterScriptCallback, "actor_on_first_update", M.actor_on_first_update)
	end
	RegisterScriptCallback("actor_on_first_update", M.actor_on_first_update)
end

function actor_on_first_update()
	return M.actor_on_first_update()
end

function actor_on_update()
	return M.actor_on_update()
end

function on_game_start()
	return M.on_game_start()
end

_G.zhopa2_artifact_flow_diag = M

return M
