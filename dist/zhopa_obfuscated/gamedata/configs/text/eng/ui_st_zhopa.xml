    <string id="ui_mcm_zhopa_enabled">
        <text>ZHOPA: enable mod</text>
    </string>
    <string id="ui_mcm_zhopa_enabled_desc">
        <text>Turns all ZHOPA systems on or off.</text>
    </string>

    <string id="ui_mcm_zhopa_debug_hud_enabled">
        <text>Map: ZHOPA debug</text>
    </string>
    <string id="ui_mcm_zhopa_debug_hud_enabled_desc">
        <text>Shows ZHOPA debug markers on the map.</text>
    </string>

    <string id="ui_mcm_zhopa_explore_enabled">
        <text>Squads: travel to nearby maps</text>
    </string>
    <string id="ui_mcm_zhopa_explore_enabled_desc">
        <text>Allows squads to move between neighboring levels.</text>
    </string>
    <string id="ui_mcm_zhopa_smart_tasks_enabled">
        <text>Smart tasks: enable subsystem</text>
    </string>
    <string id="ui_mcm_zhopa_smart_tasks_enabled_desc">
        <text>Enables smart-driven priority tasks defined in zhopa_smart_tasklist.ltx.</text>
    </string>
    <string id="ui_mcm_zhopa_smart_tasks_control_enabled">
        <text>Smart tasks: control type</text>
    </string>
    <string id="ui_mcm_zhopa_smart_tasks_control_enabled_desc">
        <text>Allows control points to recruit and hold valid ZHOPA squads on configured smarts.</text>
    </string>
    <string id="ui_mcm_zhopa_smart_tasks_control_max_squads_per_faction">
        <text>Control: max squads per faction</text>
    </string>
    <string id="ui_mcm_zhopa_smart_tasks_control_max_squads_per_faction_desc">
        <text>Maximum number of claimed squads with the same identity that may hold or travel to one control smart.</text>
    </string>
    <string id="ui_mcm_zhopa_home_region_attachment_enabled">
        <text>Squads: remember home region</text>
    </string>
    <string id="ui_mcm_zhopa_home_region_attachment_enabled_desc">
        <text>Stores the first verified level as the squad home region for later logic.</text>
    </string>
    <string id="ui_mcm_zhopa_mutant_sim_enabled">
        <text>Mutants: participate in simulation</text>
    </string>
    <string id="ui_mcm_zhopa_mutant_sim_enabled_desc">
        <text>Main switch that enables mutant participation in ZHOPA task simulation.</text>
    </string>
    <string id="ui_mcm_zhopa_mutant_explore_enabled">
        <text>Mutants: cross-level explore</text>
    </string>
    <string id="ui_mcm_zhopa_mutant_explore_enabled_desc">
        <text>Allows mutants to receive explore tasks and move to neighboring levels.</text>
    </string>
    <string id="ui_mcm_zhopa_mutant_hunt_enabled">
        <text>Mutants: HUNT task</text>
    </string>
    <string id="ui_mcm_zhopa_mutant_hunt_enabled_desc">
        <text>Enables/disables HUNT tasks (day roam candidate, night forced behavior).</text>
    </string>

    <string id="ui_mcm_zhopa_artefact_enabled">
        <text>Squads: hunt for artefacts</text>
    </string>
    <string id="ui_mcm_zhopa_artefact_enabled_desc">
        <text>Allows squads to visit anomaly areas in search of artefacts.</text>
    </string>

    <string id="ui_mcm_zhopa_populate_enabled">
        <text>Squads: go to allies</text>
    </string>
    <string id="ui_mcm_zhopa_populate_enabled_desc">
        <text>Allows squads to travel to allied squads/camps on other levels.</text>
    </string>

    <string id="ui_mcm_zhopa_base_camping_enabled">
        <text>Squads: faction base camp</text>
    </string>
    <string id="ui_mcm_zhopa_base_camping_enabled_desc">
        <text>Allows one squad per faction on a level to stay at a safe base camp.</text>
    </string>

    <string id="ui_mcm_zhopa_base_camping_duration_game_hours">
        <text>Base camping duration (game hours)</text>
    </string>
    <string id="ui_mcm_zhopa_base_camping_duration_game_hours_desc">
        <text>How long squads should stay at base camp after arriving.</text>
    </string>

    <string id="ui_mcm_zhopa_base_filler_enabled">
        <text>Bases: base filler (camp squads)</text>
    </string>
    <string id="ui_mcm_zhopa_base_filler_enabled_desc">
        <text>Maintains one dedicated base-camper squad on each smart from [level_bases].</text>
    </string>

    <string id="ui_mcm_zhopa_base_filler_npc_min">
        <text>Base filler: minimum squad size</text>
    </string>
    <string id="ui_mcm_zhopa_base_filler_npc_min_desc">
        <text>Minimum number of NPCs in newly spawned base-filler camper squads.</text>
    </string>

    <string id="ui_mcm_zhopa_base_filler_npc_max">
        <text>Base filler: maximum squad size</text>
    </string>
    <string id="ui_mcm_zhopa_base_filler_npc_max_desc">
        <text>Maximum number of NPCs in newly spawned base-filler camper squads.</text>
    </string>

    <string id="ui_mcm_zhopa_base_filler_daily_respawn_game_hours">
        <text>Base filler: daily refill interval (h)</text>
    </string>
    <string id="ui_mcm_zhopa_base_filler_daily_respawn_game_hours_desc">
        <text>Missing base campers are respawned only after this many in-game hours.</text>
    </string>
    <string id="ui_mcm_zhopa_dynamic_bases_enabled">
        <text>Bases: dynamic owners</text>
    </string>
    <string id="ui_mcm_zhopa_dynamic_bases_enabled_desc">
        <text>Rebuilds vanilla base respawn sets at runtime from the smart's current owner plus friendly factions.</text>
    </string>

    <string id="ui_mcm_zhopa_service_filler_enabled">
        <text>Bases: service filler</text>
    </string>
    <string id="ui_mcm_zhopa_service_filler_enabled_desc">
        <text>Respawns one ZHOPA service NPC per missing role on already occupied bases only.</text>
    </string>

    <string id="ui_mcm_zhopa_service_filler_respawn_game_hours">
        <text>Service filler: respawn interval (game h)</text>
    </string>
    <string id="ui_mcm_zhopa_service_filler_respawn_game_hours_desc">
        <text>Minimum in-game delay before the same base is checked again for missing service NPCs.</text>
    </string>

    <string id="ui_mcm_zhopa_task_arrive_dist_cap_m">
        <text>Tasks: arrival radius (m)</text>
    </string>
    <string id="ui_mcm_zhopa_task_arrive_dist_cap_m_desc">
        <text>Distance threshold to consider that a squad has arrived at the target smart terrain.</text>
    </string>

    <string id="ui_mcm_zhopa_target_sync_enabled">
        <text>Targets: sync scripted/assigned</text>
    </string>
    <string id="ui_mcm_zhopa_target_sync_enabled_desc">
        <text>Synchronize scripted_target with assigned/current target state when ZHOPA sets or changes a target.</text>
    </string>

    <string id="ui_mcm_zhopa_online_intent_enforce_enabled">
        <text>Online: intent enforcement</text>
    </string>
    <string id="ui_mcm_zhopa_online_intent_enforce_enabled_desc">
        <text>Reasserts the assigned target for online squads when an active task drifts into idle or wandering state.</text>
    </string>

    <string id="ui_mcm_zhopa_patrol_enabled">
        <text>Squads: patrol smart terrains</text>
    </string>
    <string id="ui_mcm_zhopa_patrol_enabled_desc">
        <text>Allows one squad per faction on a level to patrol smart terrains in a loop.</text>
    </string>
    <string id="ui_mcm_zhopa_mutant_patrol_enabled">
        <text>Mutants: patrol smart terrains</text>
    </string>
    <string id="ui_mcm_zhopa_mutant_patrol_enabled_desc">
        <text>Allows mutants to receive patrol tasks on level smart terrains.</text>
    </string>

    <string id="ui_mcm_zhopa_trade_enabled">
        <text>Squads: trade with traders</text>
    </string>
    <string id="ui_mcm_zhopa_trade_enabled_desc">
        <text>Allows squads to trade at nearby traders.</text>
    </string>
    <string id="ui_mcm_zhopa_npc_faction_override_enabled">
        <text>NPC: runtime faction override</text>
    </string>
    <string id="ui_mcm_zhopa_npc_faction_override_enabled_desc">
        <text>Periodically remaps configured squad sections to target factions at runtime. Disabled by default; intended mainly for old saves.</text>
    </string>
    <string id="ui_mcm_zhopa_story_psy_watchdog_enabled">
        <text>Story: psi zombification watchdog</text>
    </string>
    <string id="ui_mcm_zhopa_story_psy_watchdog_enabled_desc">
        <text>In story mode, converts non-immune stalker squads entering active Brain Scorcher psi levels into zombied squads until Radar is disabled.</text>
    </string>
    <string id="ui_mcm_zhopa_loot_enabled">
        <text>Squads: loot corpses and items</text>
    </string>
    <string id="ui_mcm_zhopa_loot_enabled_desc">
        <text>Allows squads to loot corpses and pick up items.</text>
    </string>

    <string id="ui_mcm_zhopa_log_level">
        <text>Logs: verbosity</text>
    </string>
    <string id="ui_mcm_zhopa_log_level_desc">
        <text>0 disables file logging; 3 is normal; 4–5 for debugging.</text>
    </string>

    <string id="ui_mcm_zhopa_log_filter_active_level_only">
        <text>Logs: active level only</text>
    </string>
    <string id="ui_mcm_zhopa_log_filter_active_level_only_desc">
        <text>Write logs only for the currently loaded level (reduces noise).</text>
    </string>

    <string id="ui_mcm_zhopa_log_filter_active_level_drop_unknown">
        <text>Logs: drop unknown entries</text>
    </string>
    <string id="ui_mcm_zhopa_log_filter_active_level_drop_unknown_desc">
        <text>When active-level filtering is enabled, drop log lines without a level tag.</text>
    </string>

    <string id="ui_mcm_zhopa_offlevel_squad_update_skip_count">
        <text>Off-level squad update skip</text>
    </string>
    <string id="ui_mcm_zhopa_offlevel_squad_update_skip_count_desc">
        <text>For squads outside the actor's current level, skip this many consecutive ZHOPA squad updates before processing one.</text>
    </string>

    <string id="ui_mcm_zhopa_surge_check_cache_ms">
        <text>Surge check cache (ms)</text>
    </string>
    <string id="ui_mcm_zhopa_surge_check_cache_ms_desc">
        <text>How long surge/psi-storm state is cached before refreshing checks.</text>
    </string>

    <string id="ui_mcm_zhopa_smart_enemy_cache_ttl_ms">
        <text>Smarts: enemy cache TTL (ms)</text>
    </string>
    <string id="ui_mcm_zhopa_smart_enemy_cache_ttl_ms_desc">
        <text>How long ZHOPA caches enemy-near-smart checks.</text>
    </string>

    <string id="ui_mcm_zhopa_loot_scan_radius_m">
        <text>Loot: event radius (m)</text>
    </string>
    <string id="ui_mcm_zhopa_loot_scan_radius_m_desc">
        <text>How far recent loot events remain candidate-eligible outside direct visibility.</text>
    </string>

    <string id="ui_mcm_zhopa_loot_corpse_detect_dist_m">
        <text>Loot: corpse distance (m)</text>
    </string>
    <string id="ui_mcm_zhopa_loot_corpse_detect_dist_m_desc">
        <text>How close a corpse must be to be considered lootable.</text>
    </string>

    <string id="ui_mcm_zhopa_loot_event_ttl_s">
        <text>Loot: remember events (s)</text>
    </string>
    <string id="ui_mcm_zhopa_loot_event_ttl_s_desc">
        <text>How long squads remember recent loot events (corpse/item seen recently).</text>
    </string>

    <string id="ui_mcm_zhopa_loot_event_cap_total">
        <text>Loot: total event cap</text>
    </string>
    <string id="ui_mcm_zhopa_loot_event_cap_total_desc">
        <text>Hard cap for all remembered loot events combined (corpses + items).</text>
    </string>

    <string id="ui_mcm_zhopa_loot_event_cap_corpses">
        <text>Loot: corpse event cap</text>
    </string>
    <string id="ui_mcm_zhopa_loot_event_cap_corpses_desc">
        <text>Hard cap for remembered corpse events.</text>
    </string>

    <string id="ui_mcm_zhopa_loot_event_cap_items">
        <text>Loot: item event cap</text>
    </string>
    <string id="ui_mcm_zhopa_loot_event_cap_items_desc">
        <text>Hard cap for remembered ground-item events.</text>
    </string>
    <string id="ui_mcm_zhopa_loot_collect_during_surge">
        <text>Loot: collect during surge</text>
    </string>
    <string id="ui_mcm_zhopa_loot_collect_during_surge_desc">
        <text>If disabled, ZHOPA skips recording new loot events during surge/psi-storm.</text>
    </string>

    <string id="ui_mcm_zhopa_loot_collect_after_surge_grace_ms">
        <text>Loot: post-surge grace (ms)</text>
    </string>
    <string id="ui_mcm_zhopa_loot_collect_after_surge_grace_ms_desc">
        <text>Delay after surge end before ZHOPA resumes collecting new loot events.</text>
    </string>

    <string id="ui_mcm_zhopa_loot_patch_max_memory_size">
        <text>Loot patch: max memory size</text>
    </string>
    <string id="ui_mcm_zhopa_loot_patch_max_memory_size_desc">
        <text>Maximum remembered candidates per evaluator before trimming.</text>
    </string>

    <string id="ui_mcm_zhopa_loot_disable_near_actor_limit">
        <text>Loot near the player</text>
    </string>
    <string id="ui_mcm_zhopa_loot_disable_near_actor_limit_desc">
        <text>Allows squads to loot even near the player (may affect gameplay).</text>
    </string>

    <string id="ui_mcm_zhopa_loot_unlock_corpses">
        <text>Loot: unlock corpses</text>
    </string>
    <string id="ui_mcm_zhopa_loot_unlock_corpses_desc">
        <text>Try to unlock corpses before looting them.</text>
    </string>

    <string id="ui_mcm_zhopa_loot_protect_quest_corpses_enabled">
        <text>Loot: protect quest corpses</text>
    </string>
    <string id="ui_mcm_zhopa_loot_protect_quest_corpses_enabled_desc">
        <text>Prevents NPCs from looting corpses that carry quest items.</text>
    </string>

    <string id="ui_mcm_zhopa_loot_items_enabled">
        <text>Loot: pick up ground items</text>
    </string>
    <string id="ui_mcm_zhopa_loot_items_enabled_desc">
        <text>Allow squads to pick up loose items on the ground.</text>
    </string>

    <string id="ui_mcm_zhopa_loot_items_detect_dist_m">
        <text>Loot: item distance (m)</text>
    </string>
    <string id="ui_mcm_zhopa_loot_items_detect_dist_m_desc">
        <text>How far squads can detect loose items for pickup.</text>
    </string>

    <string id="ui_mcm_zhopa_loot_items_allow_unseen">
        <text>Loot: pick up unseen items</text>
    </string>
    <string id="ui_mcm_zhopa_loot_items_allow_unseen_desc">
        <text>Allows squads to pick up items even without line of sight (using loot events).</text>
    </string>

    <string id="ui_mcm_zhopa_rest_duration_game_hours">
        <text>Rest duration (game hours)</text>
    </string>
    <string id="ui_mcm_zhopa_rest_duration_game_hours_desc">
        <text>How long squads should rest after each task.</text>
    </string>
    <string id="ui_mcm_zhopa_mutant_rest_duration_game_hours">
        <text>Mutants: rest duration (game hours)</text>
    </string>
    <string id="ui_mcm_zhopa_mutant_rest_duration_game_hours_desc">
        <text>How long mutant squads rest after finishing a task.</text>
    </string>
    <string id="ui_mcm_zhopa_mutant_patrol_duration_game_hours">
        <text>Mutants: patrol duration (game hours)</text>
    </string>
    <string id="ui_mcm_zhopa_mutant_patrol_duration_game_hours_desc">
        <text>How long a mutant patrol phase lasts before task rotation.</text>
    </string>

    <string id="ui_mcm_zhopa_rest_fallback_stay_min_sec">
        <text>Rest: minimum (sec)</text>
    </string>
    <string id="ui_mcm_zhopa_rest_fallback_stay_min_sec_desc">
        <text>If calculated rest is shorter, it will be raised to this minimum (game seconds).</text>
    </string>

    <string id="ui_mcm_zhopa_rest_fallback_stay_max_sec">
        <text>Rest: maximum (sec)</text>
    </string>
    <string id="ui_mcm_zhopa_rest_fallback_stay_max_sec_desc">
        <text>If calculated rest is longer, it will be clamped to this maximum (game seconds).</text>
    </string>

    <string id="ui_mcm_zhopa_night_rest_enabled">
        <text>Night: night rest for squads</text>
    </string>
    <string id="ui_mcm_zhopa_night_rest_enabled_desc">
        <text>If enabled, squads can only receive NIGHT_REST at night: they go to a base and stay until morning.</text>
    </string>

    <string id="ui_mcm_zhopa_trade_max_squads_per_smart">
        <text>Trade: max squads per smart</text>
    </string>
    <string id="ui_mcm_zhopa_trade_max_squads_per_smart_desc">
        <text>How many squads can target the same trader smart terrain at once.</text>
    </string>

    <string id="ui_mcm_zhopa_trade_travel_timeout_ms">
        <text>Trade: travel timeout (ms)</text>
    </string>
    <string id="ui_mcm_zhopa_trade_travel_timeout_ms_desc">
        <text>If a squad fails to reach the trader within this time, ZHOPA will reroll the target.</text>
    </string>

    <string id="ui_mcm_zhopa_trade_axr_buy_all_enabled">
        <text>Trade: AXR buy all allowed items</text>
    </string>
    <string id="ui_mcm_zhopa_trade_axr_buy_all_enabled_desc">
        <text>When enabled, NPC buy loop in axr_trade_manager can purchase all allowed buy_sell sections, not ammo-only.</text>
    </string>

    <string id="ui_mcm_zhopa_fast_trading_enabled">
        <text>Fast trading: enabled</text>
    </string>
    <string id="ui_mcm_zhopa_fast_trading_enabled_desc">
        <text>If enabled, squads automatically go to trade after picking up sellable items.</text>
    </string>
    <string id="ui_mcm_zhopa_fast_trading_delay_ms">
        <text>Fast trading: delay (ms)</text>
    </string>
    <string id="ui_mcm_zhopa_fast_trading_delay_ms_desc">
        <text>Delay before checking inventory after item pickup (to avoid desync).</text>
    </string>
    <string id="ui_mcm_zhopa_fast_trading_cooldown_ms">
        <text>Fast trading: cooldown (ms)</text>
    </string>
    <string id="ui_mcm_zhopa_fast_trading_cooldown_ms_desc">
        <text>Minimum time between automatic trade missions for the same squad.</text>
    </string>

    <string id="ui_mcm_zhopa_group_tasks_story">
        <text>Story Events</text>
    </string>
    <string id="ui_mcm_zhopa_story_events_enabled">
        <text>Story events: enable subsystem</text>
    </string>
    <string id="ui_mcm_zhopa_story_events_enabled_desc">
        <text>Enables story-driven high-priority squad tasks that can preempt smart tasks.</text>
    </string>
    <string id="ui_mcm_zhopa_story_events_north_migration_enabled">
        <text>Story events: North migration</text>
    </string>
    <string id="ui_mcm_zhopa_story_events_north_migration_enabled_desc">
        <text>After the first shutdown of the Brain Scorcher in story mode, selected human ZHOPA squads migrate north to safe base smarts.</text>
    </string>
    <string id="ui_mcm_zhopa_story_events_north_migration_percent">
        <text>North migration: selected squads (%)</text>
