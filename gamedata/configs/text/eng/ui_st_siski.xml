    </string>

    <string id="ui_mcm_siski_af_hunter_count_desc">
        <text>How many artifact hunter squads to keep per level (0 disables).</text>
    </string>
    <string id="ui_mcm_siski_af_hunter_campfire_desc">
        <text>Allows hunter spawn at campfires if no suitable smart is found near the anomaly.</text>
    </string>

