    <string id="ui_mcm_siski_spawn_safe_radius_desc">
        <text>Radius used to check for danger/enemies around a spawn point.</text>
    </string>

    <string id="ui_mcm_siski_activities_enabled_desc">
        <text>Enables extra AI activities: looting and trading.</text>
    </string>
    <string id="ui_mcm_siski_loot_gather_speed_desc">
        <text>Multiplier for looting speed.</text>
    </string>
    <string id="ui_mcm_siski_trade_time_desc">
