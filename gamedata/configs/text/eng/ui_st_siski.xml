    <string id="ui_mcm_siski_max_loot_weight_desc">
        <text>Maximum loot weight a squad will try to pick up before switching tasks.</text>
    </string>
    <string id="ui_mcm_siski_spawn_cooldown_desc">
        <text>Cooldown between reinforcement cycles. Higher values spawn less often.</text>
    </string>
    <string id="ui_mcm_siski_spawn_min_dist_desc">
