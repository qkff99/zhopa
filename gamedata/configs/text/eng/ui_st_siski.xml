    <string id="ui_mcm_siski_debug_enabled_desc">
        <text>Enables extended SISKI logging. May reduce performance and spam the log.</text>
    </string>
    <string id="ui_mcm_siski_debug_hud_enabled_desc">
        <text>Shows a debug HUD table with active brains and tasks.</text>
    </string>
    <string id="ui_mcm_siski_debug_offline_logging_desc">
        <text>Logs offline AI decisions. Can be very noisy.</text>
    </string>
    <string id="ui_mcm_siski_debug_dump_key_desc">
        <text>Key to dump SISKI state (brains/memory) into the log.</text>
    </string>
    <string id="ui_mcm_siski_spawn_enabled_desc">
        <text>Enables SISKI population control and reinforcement spawning. Disabling keeps only existing squads.</text>
    </string>
    <string id="ui_mcm_siski_protector_story_to_trader_desc">
        <text>Pins story NPCs to trader community to prevent wandering.</text>
    </string>
    <string id="ui_mcm_siski_protector_sections_to_trader_desc">
        <text>Pins NPCs from protector_pinned_sections (traders/techs/medics/guides) to trader community.</text>
    </string>
    <string id="ui_mcm_siski_alife_vanilla_squads_desc">
        <text>Attaches SISKI brains to squads spawned by the game/other mods (if their section is allowed). May increase load.</text>
    </string>

