	</string>
    <string id="ui_mcm_dynamic_alife_squad_help_chance">
		<text>Help Signal Chance (%)</text>
	</string>
    <string id="ui_mcm_dynamic_alife_squad_help_radius">
		<text>Help Signal Radius (m)</text>
	</string>
