<?xml version="1.0" encoding="windows-1251"?>
<string_table>
	<string id="ui_mcm_dynamic_alife_title">
		<text>R.E.Z.N.Y.A. (Ruthless Ecological Zone Network)</text>
	</string>
    <string id="ui_mcm_menu_dynamic_alife">
		<text>R.E.Z.N.Y.A.</text>
	</string>
    
	<string id="ui_mcm_dynamic_alife_enabled">
		<text>Enable R.E.Z.N.Y.A.</text>
	</string>
	<string id="ui_mcm_dynamic_alife_enabled_desc">
		<text>If enabled, offline squads will travel between smart terrains to simulate activity.</text>
	</string>
	<string id="ui_mcm_dynamic_alife_show_hud">
		<text>Show Debug HUD (REZNYA HUD)</text>
	</string>
	<string id="ui_mcm_dynamic_alife_debug_log">
		<text>Enable Debug Logs</text>
	</string>
	<string id="ui_mcm_dynamic_alife_idle_time">
		<text>Idle Time at Point (min)</text>
	</string>
	<string id="ui_mcm_dynamic_alife_squad_chance">
		<text>Movement Probability (%)</text>
	</string>
	<string id="ui_mcm_dynamic_alife_squad_chance_desc">
		<text>Chance for a squad to be selected for random travel in each cycle.</text>
	</string>
    <string id="ui_mcm_dynamic_alife_artifact_weight">
		<text>Anomaly Interest</text>
	</string>
    <string id="ui_mcm_dynamic_alife_trade_weight">
		<text>Target Preference: Traders</text>
	</string>
	<string id="ui_mcm_dynamic_alife_aggressive_bootstrap">
		<text>Aggressive Bootstrap (Fast Start)</text>
	</string>
    <string id="ui_mcm_dynamic_alife_aggressive_bootstrap_desc">
		<text>If current population is low, aggressively spawn squads at game start/level load to fill the Zone. May cause small stutter on load.</text>
	</string>
	<string id="ui_mcm_dynamic_alife_max_dist">
		<text>Max Travel Distance (m)</text>
	</string>
    
    <string id="ui_mcm_dynamic_alife_relations_enabled">
		<text>Enable Per-Level Relations (reznya_relations.ltx)</text>
	</string>
    <string id="ui_mcm_dynamic_alife_relations_enabled_desc">
		<text>If enabled, applies faction relation overrides defined in configs/plugins/reznya_relations.ltx.</text>
	</string>
    
    <!-- Populations -->
	<string id="ui_mcm_dynamic_alife_target_pop_stalkers">
		<text>Target Stalker Population</text>
	</string>
    <string id="ui_mcm_dynamic_alife_target_pop_monsters">
		<text>Target Mutant Population</text>
	</string>
    
    <string id="ui_mcm_dynamic_alife_global_sim">
		<text>Global R.E.Z.N.Y.A. (Sim All Levels)</text>
	</string>
    <string id="ui_mcm_dynamic_alife_global_sim_desc">
		<text>If enabled, population management (spawn/evict) runs for ALL levels in the Zone, not just the actor's current level. Warning: Higher CPU usage.</text>
	</string>
	<string id="ui_mcm_dynamic_alife_exclude_communities">
		<text>Excluded Factions</text>
	</string>
    <string id="ui_mcm_dynamic_alife_reincarnation_chance">
		<text>Extinct Faction Respawn Chance (%)</text>
	</string>
    <string id="ui_mcm_dynamic_alife_reincarnation_chance_desc">
		<text>Probability (Weight) that the system will attempt to respawn a faction currently missing from the level.</text>
	</string>
    
    <!-- Monsters Separator -->
    <string id="ui_mcm_dynamic_alife_separator_monsters">
		<text>Mutant Behaviors</text>
	</string>
    <string id="ui_mcm_dynamic_alife_monster_hunting_chance">
		<text>Monster Hunting Chance (%)</text>
	</string>
    <string id="ui_mcm_dynamic_alife_monster_hunting_chance_desc">
		<text>Chance for monsters to actively hunt nearby stalker squads instead of roaming aimlessly.</text>
	</string>
    <string id="ui_mcm_dynamic_alife_night_chimera_count">
		<text>Night Chimeras per Level</text>
