local M = {}

M.TASK_REST = "REST"
M.TASK_EXPLORE = "EXPLORE"
M.TASK_FORCE_EXIT = "FORCE_EXIT"
M.TASK_POPULATE = "POPULATE"
M.TASK_BASE_CAMPING = "BASE_CAMPING"
M.TASK_PATROL = "PATROL"
M.TASK_NIGHT_REST = "NIGHT_REST"
M.TASK_ARTEFACT = "ARTEFACT"
M.TASK_TRADE = "TRADE"
M.TASK_HUNT = "HUNT"
M.TASK_REVENGE = "REVENGE"
M.TASK_STORY_NORTH_MIGRATION = "STORY_NORTH_MIGRATION"

local ACTOR_TARGET_ID = AC_ID or 0
local REVENGE_GOODWILL = -3000
local REVENGE_RELATION_SCOPE_REFRESH_MS = 1000
local REVENGE_RELATION_SCOPE_MAX_SQUADS = 32
local REVENGE_RELATION_SCOPE_MAX_MEMBERS = 128
local TASK_SELECT_ATTEMPTS = 2
local ASSIGNMENTS_PER_FRAME = 1
local HUNT_NO_TARGET_COOLDOWN_SEC = 20
local SURGE_CHECK_CACHE_MS = 250
local TARGET_VALID_CACHE_MS = 500
local REST_TRADE_RETRY_MS = 5000
local BASE_CAMPING_TRADE_RETRY_MS = 30000
local TRADE_DEBUG_THROTTLE_MS = 10000
local TRADE_DIAGNOSTIC_LOGGING_ENABLED = false
local surge_cache_active = false
local surge_cache_next = 0
local now_ms
local trade_debug_throttle = {}
local cfg_require_attempted = false
local actor_revenge_relation_scopes = {}

local function cfg()
	local c = rawget(_G, "zhopa2_cfg")
	if not c and not cfg_require_attempted and require then
		cfg_require_attempted = true
		pcall(require, "zhopa2_cfg")
		c = rawget(_G, "zhopa2_cfg")
	end
	return c
end

local function perception()
	local p = rawget(_G, "zhopa2_perception")
	if not p and require then
		pcall(require, "zhopa2_perception")
		p = rawget(_G, "zhopa2_perception")
	end
	return p
end

