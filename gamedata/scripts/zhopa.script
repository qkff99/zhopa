    call_bound_method_fast("board_index.on_smart_terrain_update", "board_index", "board_index", "on_smart_terrain_update", "board_index.on_smart_terrain_update", smart, ctx)
    if wants_smart_update("smart_tasks", smart, ctx) then
        call_bound_method_fast("smart_tasks.on_smart_terrain_update", "smart_tasks", "smart_tasks", "on_smart_terrain_update", "smart_tasks.on_smart_terrain_update", smart, ctx)
    end
    if wants_smart_update("mutants", smart, ctx) then
        call_bound_method_fast("mutants.on_smart_terrain_update", "mutants", "mutants", "on_smart_terrain_update", "mutants.on_smart_terrain_update", smart, ctx)
    end
    if wants_smart_update("base_filler", smart, ctx) then
        call_bound_method_fast("base_filler.on_smart_terrain_update", "base_filler", "base_filler", "on_smart_terrain_update", "base_filler.on_smart_terrain_update", smart, ctx)
    end
    if wants_smart_update("dynamic_bases", smart, ctx) then
        call_bound_method_fast("dynamic_bases.on_smart_terrain_update", "dynamic_bases", "dynamic_bases", "on_smart_terrain_update", "dynamic_bases.on_smart_terrain_update", smart, ctx)
    end
    if wants_smart_update("service_filler", smart, ctx) then
        call_bound_method_fast("service_filler.on_smart_terrain_update", "service_filler", "service_filler", "on_smart_terrain_update", "service_filler.on_smart_terrain_update", smart, ctx)
    end
    if wants_smart_update("smart_service_slot_doctor", smart, ctx) then
        call_bound_method_fast("smart_service_slot_doctor.on_smart_terrain_update", nil, "smart_service_slot_doctor", "on_smart_terrain_update", "smart_service_slot_doctor.on_smart_terrain_update", smart, ctx)
    end
end

local function module_needs_npc_update(module_name)
    local module = zhopa and zhopa[module_name] or nil
    local fn = module and module.needs_npc_update or nil
    if type(fn) ~= "function" then
        return true
    end
    local ok, res = pcall(fn)
    if ok then
        return res == true
    end
    if zhopa and zhopa.log and zhopa.log.error then
        zhopa.log.error("CORE", "%s.needs_npc_update failed: %s", tostring(module_name), tostring(res))
    end
    return true
end

local function route_npc_update(npc)
    if module_needs_npc_update("loot") then
        call_bound_method_fast("loot.on_npc_update", nil, "loot", "on_npc_update", "loot.on_npc_update", npc)
    end
    if module_needs_npc_update("loot_patch") then
        call_bound_method_fast("loot_patch.on_npc_update", nil, "loot_patch", "on_npc_update", "loot_patch.on_npc_update", npc)
    end
    if module_needs_npc_update("smart_service_slot_doctor") then
        call_bound_method_fast("smart_service_slot_doctor.on_npc_update", nil, "smart_service_slot_doctor", "on_npc_update", "smart_service_slot_doctor.on_npc_update", npc)
