local function read_debug_hud_enabled()
    if runtime_enabled_now() ~= true then
        return false
    end
    local runtime_cfg = zhopa and zhopa.runtime_cfg
    if runtime_cfg and runtime_cfg.get then
        return runtime_cfg.get("debug_hud_enabled", false) == true
    end
    if not (zhopa.config and zhopa.config.get) then return false end
    local ok, enabled = safe_call("zhopa.config.get(debug_hud)", zhopa.config.get, "debug_hud_enabled", false)
    if ok then return enabled == true end
    return false
end

local function refresh_debug_hud_enabled()
    debug_hud_enabled_value = read_debug_hud_enabled() == true
    return debug_hud_enabled_value
end

debug_hud_enabled = function()
    return debug_hud_enabled_value == true
end

local function apply_runtime_fixes()
    if smart_terrain and smart_terrain.smart_terrain and smart_terrain.smart_terrain.smart_terrain_squad_count then
        local original_count_func = smart_terrain.smart_terrain.smart_terrain_squad_count

        smart_terrain.smart_terrain.smart_terrain_squad_count = function(self, squad)
            if not squad then return 0 end
            if not squad.get_script_target then
                return 0
            end
            return original_count_func(self, squad)
        end
        if zhopa.log and zhopa.log.info then
            zhopa.log.info("CORE", "Applied runtime patch: smart_terrain_squad_count (Safety Wrapper)")
        end
    end
end

function Core:__init()
    self.config_refresh_tg = 0
    self.offlevel_skip_counter_by_sid = {}
    self.offlevel_skip_cfg_value = 0
    self.offlevel_skip_cfg_next_tg = 0
    self.squad_tick_next_tg_by_sid = {}
    self.master_enabled_prev = nil
end

function Core:_reset_offlevel_skip_counters()
    self.offlevel_skip_counter_by_sid = {}
    self.offlevel_skip_cfg_next_tg = 0
    self.squad_tick_next_tg_by_sid = {}
end

function Core:_refresh_runtime_cfg(reason)
    if zhopa.runtime_cfg and zhopa.runtime_cfg.refresh then
        safe_call("zhopa.runtime_cfg.refresh", zhopa.runtime_cfg.refresh, reason or "core")
    end
end

function Core:_get_offlevel_squad_update_skip_count()
    local now = (time_global and time_global()) or 0
    if now < (tonumber(self.offlevel_skip_cfg_next_tg) or 0) then
        return tonumber(self.offlevel_skip_cfg_value) or 0
    end
    local value = read_offlevel_squad_update_skip_count()
    self.offlevel_skip_cfg_value = value
    self.offlevel_skip_cfg_next_tg = now + OFFLEVEL_SKIP_CFG_CACHE_MS
    return value
end

function Core:_forget_offlevel_skip_counter(squad_id)
    local sid = tonumber(squad_id) or nil
    if not sid then
        return
    end
    if self.offlevel_skip_counter_by_sid then
        self.offlevel_skip_counter_by_sid[sid] = nil
    end
    if self.squad_tick_next_tg_by_sid then
        self.squad_tick_next_tg_by_sid[sid] = nil
    end
end

function Core:_should_skip_offlevel_squad_update(squad, entry)
    local skip_count = self:_get_offlevel_squad_update_skip_count()
    if skip_count <= 0 or not squad then
        return false
    end

    local sid = tonumber(squad.id) or nil
    if not sid then
        return false
    end

    local actor_level = current_actor_level_name()
    local squad_level = type(entry) == "table" and entry.level or nil
    if type(squad_level) ~= "string" or squad_level == "" then
        squad_level = now_level_name_by_gvid(tonumber(squad.m_game_vertex_id) or 0)
    end
    if type(actor_level) ~= "string" or actor_level == "" or type(squad_level) ~= "string" or squad_level == "" then
        self:_forget_offlevel_skip_counter(sid)
        return false
    end

    if actor_level == squad_level then
        self:_forget_offlevel_skip_counter(sid)
        return false
    end

    local counters = self.offlevel_skip_counter_by_sid
    local current = (counters and tonumber(counters[sid])) or 0
    local next_count = current + 1
    if next_count <= skip_count then
        counters[sid] = next_count
        return true
    end

    counters[sid] = nil
    return false
end

function Core:_refresh_master_enabled(reason)
    self:_refresh_runtime_cfg(reason or "enabled")
    self.master_enabled_prev = master_enabled_now() == true
    return self.master_enabled_prev == true
end

function Core:_sync_log_level()
    if not (can_run("config") and zhopa.log and zhopa.log.set_level) then
        return
    end
    if zhopa.runtime_cfg and zhopa.runtime_cfg.num then
        zhopa.log.set_level(zhopa.runtime_cfg.num("log_level", zhopa.log.LEVEL_OFF, zhopa.log.LEVEL_OFF, 5))
    elseif zhopa.config and zhopa.config.get then
        local ok_lvl, lvl = safe_call("zhopa.config.get(log_level)", zhopa.config.get, "log_level", zhopa.log.LEVEL_OFF)
        if ok_lvl and tonumber(lvl) then zhopa.log.set_level(tonumber(lvl)) end
    end
end

function Core:_is_enabled()
    if self.master_enabled_prev == nil then
        return self:_refresh_master_enabled("lazy_enabled")
    end
    return self.master_enabled_prev == true
end

function Core:_should_run_no_delta_squad_tick(squad, entry)
    local sid = tonumber(squad and squad.id) or tonumber(entry and entry.squad_id) or nil
    if not sid then
        return false
    end

    local current = entry and entry.tasks and entry.tasks.current or nil
    if type(current) ~= "table" then
        return true
    end

    local dirty = entry and entry.dirty or nil
    if type(dirty) == "table"
        and (dirty.task == true
            or dirty.smart == true
            or dirty.level == true
            or dirty.community == true
            or dirty.identity == true)
    then
        return true
    end

    local params = type(current.params) == "table" and current.params or nil
    if params
        and (params.fast_trade_trigger == true
            or params.online_force_rebuild == true
            or params.target_sync_due == true
            or params.trade_done_state ~= nil)
    then
        return true
    end

    local now = (time_global and time_global()) or 0
    local next_by_sid = self.squad_tick_next_tg_by_sid or {}
    self.squad_tick_next_tg_by_sid = next_by_sid
    local next_tg = tonumber(next_by_sid[sid]) or 0
    if now < next_tg then
        return false
    end
    next_by_sid[sid] = now + NO_DELTA_SQUAD_TICK_MS
    return true
end

function Core:_bootstrap_enabled_runtime(source)
    clear_route_cache()
    refresh_debug_hud_enabled()
    apply_runtime_fixes()

    if zhopa.xr_conditions_patch and zhopa.xr_conditions_patch.apply then
        safe_call("zhopa.xr_conditions_patch.apply(" .. tostring(source or "bootstrap") .. ")", zhopa.xr_conditions_patch.apply)
    end

    if zhopa.tasks and zhopa.tasks.on_first_update then
        safe_call("zhopa.tasks.on_first_update", zhopa.tasks.on_first_update)
    end
    if can_run("dynamic_bases") then
        if zhopa.dynamic_bases and zhopa.dynamic_bases.on_first_update then
            safe_call("zhopa.dynamic_bases.on_first_update", zhopa.dynamic_bases.on_first_update)
        elseif zhopa.log and zhopa.log.warn then
            zhopa.log.warn("CORE", "DYNAMIC_BASES_UNAVAILABLE stage=%s", tostring(source or "bootstrap"))
        end
    end
    if can_run("base_filler") then
        if zhopa.base_filler and zhopa.base_filler.on_first_update then
            safe_call("zhopa.base_filler.on_first_update", zhopa.base_filler.on_first_update)
        elseif zhopa.log and zhopa.log.warn then
            zhopa.log.warn("CORE", "BASE_FILLER_UNAVAILABLE stage=%s", tostring(source or "bootstrap"))
        end
    end
    if can_run("service_filler") then
        if zhopa.service_filler and zhopa.service_filler.on_first_update then
            safe_call("zhopa.service_filler.on_first_update", zhopa.service_filler.on_first_update)
        elseif zhopa.log and zhopa.log.warn then
            zhopa.log.warn("CORE", "SERVICE_FILLER_UNAVAILABLE stage=%s", tostring(source or "bootstrap"))
        end
    end
    if can_run("axr_task_patch") then
        if zhopa.axr_task_patch and zhopa.axr_task_patch.apply then
            safe_call("zhopa.axr_task_patch.apply", zhopa.axr_task_patch.apply)
        elseif zhopa.log and zhopa.log.warn then
            zhopa.log.warn("CORE", "AXR_TASK_PATCH_UNAVAILABLE stage=%s", tostring(source or "bootstrap"))
        end
    end
    if zhopa.loot_patch and zhopa.loot_patch.apply then
        safe_call("zhopa.loot_patch.apply", zhopa.loot_patch.apply)
    end

    route_actor_first_update()
end

function Core:_on_game_start()
    if not can_run("core") then return end

    if RegisterScriptCallback then
        RegisterScriptCallback("actor_on_first_update", zhopa.core.on_first_update)
        RegisterScriptCallback("on_option_change", zhopa.core.on_option_change)
        RegisterScriptCallback("server_entity_on_register", zhopa.core.on_server_entity_register)
        RegisterScriptCallback("server_entity_on_unregister", zhopa.core.on_server_entity_unregister)
        RegisterScriptCallback("squad_on_first_update", zhopa.core.on_squad_first_update)
        RegisterScriptCallback("squad_on_update", zhopa.core.on_squad_update)
        RegisterScriptCallback("squad_on_npc_creation", zhopa.core.on_squad_npc_creation)
        RegisterScriptCallback("save_state", zhopa.core.save_state)
        RegisterScriptCallback("load_state", zhopa.core.load_state)
        RegisterScriptCallback("squad_on_enter_smart", zhopa.core.on_squad_enter_smart)
        RegisterScriptCallback("squad_on_leave_smart", zhopa.core.on_squad_leave_smart)
        RegisterScriptCallback("squad_on_after_level_change", zhopa.core.on_squad_after_level_change)
        RegisterScriptCallback("smart_terrain_on_update", zhopa.core.on_smart_terrain_update)
        RegisterScriptCallback("npc_on_update", zhopa.core.on_npc_update)
        RegisterScriptCallback("npc_on_item_take", zhopa.core.on_npc_item_take)
        RegisterScriptCallback("npc_on_item_drop", zhopa.core.on_npc_item_drop)
        RegisterScriptCallback("npc_on_death_callback", zhopa.core.on_npc_death)
        RegisterScriptCallback("actor_on_item_drop", zhopa.core.on_actor_item_drop)
        RegisterScriptCallback("squad_on_npc_death", zhopa.core.on_squad_npc_death)
    end
end

function Core:_on_first_update()
    if not can_run("core") then return end

    self:_reset_offlevel_skip_counters()
    local enabled = self:_refresh_master_enabled("first_update")
    refresh_debug_hud_enabled()
    self:_sync_log_level()

    if zhopa.log and zhopa.log.info then
        zhopa.log.info("CORE", "ZHOPA %s started enabled=%s", tostring(zhopa.version), tostring(enabled))
    end
    if enabled ~= true then
        return
    end

    self:_bootstrap_enabled_runtime("first_update")
end

function Core:_on_option_change()
    if not can_run("core") then return end

    if can_run("config") and zhopa.config and zhopa.config.clear_mcm_cache then
        safe_call("zhopa.config.clear_mcm_cache", zhopa.config.clear_mcm_cache)
    end
    self:_reset_offlevel_skip_counters()

    local prev_enabled = self.master_enabled_prev == true
    local enabled = self:_refresh_master_enabled("option_change")
    refresh_debug_hud_enabled()
    clear_route_cache()
    self:_sync_log_level()

    if enabled == true and prev_enabled ~= true then
        self:_bootstrap_enabled_runtime("option_enable")
    end

    route_option_change()

    if zhopa.log and zhopa.log.info then
        zhopa.log.info("CORE", "OPTION_CHANGE_RELOADED enabled=%s prev=%s", tostring(enabled), tostring(prev_enabled))
    end
end

function Core:_save_state(m_data)
    if can_run("debug_hud") and debug_hud_enabled() and zhopa.debug_hud and zhopa.debug_hud.on_save_state then
        safe_call("zhopa.debug_hud.on_save_state", zhopa.debug_hud.on_save_state)
    end
    if can_run("memory") and zhopa.memory and zhopa.memory.save_state then
        safe_call("zhopa.memory.save_state", zhopa.memory.save_state, m_data)
    end
    if can_run("dynamic_bases") and zhopa.dynamic_bases and zhopa.dynamic_bases.save_state then
        safe_call("zhopa.dynamic_bases.save_state", zhopa.dynamic_bases.save_state, m_data)
    end
    if can_run("base_filler") and zhopa.base_filler and zhopa.base_filler.save_state then
        safe_call("zhopa.base_filler.save_state", zhopa.base_filler.save_state, m_data)
    end
    if can_run("service_filler") and zhopa.service_filler and zhopa.service_filler.save_state then
        safe_call("zhopa.service_filler.save_state", zhopa.service_filler.save_state, m_data)
    end

    route_save_state(m_data)
end

function Core:_load_state(m_data)
    self:_reset_offlevel_skip_counters()
    self.master_enabled_prev = self:_refresh_master_enabled("load_state")
    refresh_debug_hud_enabled()
    clear_route_cache()
    self:_sync_log_level()
    if can_run("memory") and zhopa.memory and zhopa.memory.load_state then
        safe_call("zhopa.memory.load_state", zhopa.memory.load_state, m_data)
    end
    if can_run("dynamic_bases") and zhopa.dynamic_bases and zhopa.dynamic_bases.load_state then
        safe_call("zhopa.dynamic_bases.load_state", zhopa.dynamic_bases.load_state, m_data)
    end
    if can_run("base_filler") and zhopa.base_filler and zhopa.base_filler.load_state then
        safe_call("zhopa.base_filler.load_state", zhopa.base_filler.load_state, m_data)
    end
    if can_run("service_filler") and zhopa.service_filler and zhopa.service_filler.load_state then
        safe_call("zhopa.service_filler.load_state", zhopa.service_filler.load_state, m_data)
    end
    route_load_state(m_data)
end

function Core:_on_squad_npc_death(squad, npc, killer_npc, killer_squad)
    if self:_is_enabled() ~= true then
        return
    end
    route_squad_npc_death(squad, npc, killer_npc, killer_squad)
end

function Core:_on_squad_npc_creation(squad, npc, smart)
    if self:_is_enabled() ~= true then
        return
    end
    route_squad_npc_creation(squad, npc, smart)
end

function Core:_on_squad_first_update(squad)
    if self:_is_enabled() ~= true then
        return
    end
    local entry = nil
    if can_run("memory") then
        entry = update_memory_snapshot(squad, "squad_on_first_update")
    end
    route_squad_first_update(squad, entry)
end

function Core:_on_squad_update(squad)
    if self:_is_enabled() ~= true then
        return
    end
    local entry = nil
    local changed = false
    if can_run("memory") then
        entry, changed = update_memory_snapshot(squad, "squad_on_update")
        if not self:_should_skip_offlevel_squad_update(squad, entry) and (changed == true or self:_should_run_no_delta_squad_tick(squad, entry)) then
            dispatch_direct_squad_fsm(squad, "squad_on_update", entry)
        end
    end
    route_squad_update(squad, entry, changed)
end

function Core:_on_squad_enter_smart(squad, smart)
    if self:_is_enabled() ~= true then
        return
    end
    local entry = nil
    if can_run("memory") then
        entry = update_memory_snapshot(squad, "squad_on_enter_smart")
        if entry and zhopa.memory and zhopa.memory.mark_arrived_to_target then
            safe_call("zhopa.memory.mark_arrived_to_target", zhopa.memory.mark_arrived_to_target, squad and squad.id, smart, "squad_on_enter_smart")
        end
    end
    route_squad_enter_smart(squad, smart, entry)
end

function Core:_on_squad_leave_smart(squad, smart)
    if self:_is_enabled() ~= true then
        return
    end
    local entry = nil
    if can_run("memory") then
        entry = update_memory_snapshot(squad, "squad_on_leave_smart")
        if entry and zhopa.memory and zhopa.memory.mark_left_target then
            safe_call("zhopa.memory.mark_left_target", zhopa.memory.mark_left_target, squad and squad.id, smart, "squad_on_leave_smart")
        end
    end
    route_squad_leave_smart(squad, smart, entry)
end

function Core:_on_squad_after_level_change(squad, old_level, new_level)
    if self:_is_enabled() ~= true then
        return
    end
    local entry = nil
    if can_run("memory") then
        entry = update_memory_snapshot(squad, "squad_on_after_level_change")
        if entry and zhopa.memory and zhopa.memory.mark_level_changed then
            safe_call("zhopa.memory.mark_level_changed", zhopa.memory.mark_level_changed, squad and squad.id, old_level, new_level, "squad_on_after_level_change")
        end
    end
    route_squad_after_level_change(squad, old_level, new_level, entry)
end

function Core:_on_server_entity_unregister(se_obj, type_name)
    if type(type_name) == "string" and type_name == "sim_squad_scripted" then
        self:_forget_offlevel_skip_counter(se_obj and se_obj.id or nil)
    end
    if self:_is_enabled() ~= true then
        return
    end
    route_server_entity_unregister(se_obj, type_name)
end

function Core:_on_server_entity_register(se_obj, type_name)
    if self:_is_enabled() ~= true then
        return
    end
    route_server_entity_register(se_obj, type_name)
end

function Core:_on_smart_terrain_update(smart)
    if self:_is_enabled() ~= true then
        return
    end
    route_smart_terrain_update(smart, build_smart_update_ctx(smart))
end

function Core:_on_npc_update(npc)
    if self:_is_enabled() ~= true then
        return
    end
    route_npc_update(npc)
end

function Core:_on_npc_item_take(npc, item)
    if self:_is_enabled() ~= true then
        return
    end
    route_npc_item_take(npc, item)
end

function Core:_on_npc_item_drop(npc, item)
    if self:_is_enabled() ~= true then
        return
    end
    route_npc_item_drop(npc, item)
end

function Core:_on_npc_death(victim, who)
    if self:_is_enabled() ~= true then
        return
    end
    route_npc_death(victim, who)
end

function Core:_on_actor_item_drop(item)
    if self:_is_enabled() ~= true then
        return
    end
    route_actor_item_drop(item)
end

function Core:_on_task_current_changed(payload)
    route_task_current_changed(payload)
end

function Core:_on_trade_service_result(squad_id, npc_id, smart_name, source, phase, status, reason)
    route_trade_service_result(squad_id, npc_id, smart_name, source, phase, status, reason)
end

local inst = Core.new and Core.new() or setmetatable({}, Core)
if not inst.config_refresh_tg then
    Core.__init(inst)
end

inst.can_run = can_run
inst.is_enabled = function() return inst:_is_enabled() end
inst.on_game_start = function() return inst:_on_game_start() end
inst.on_first_update = function() return inst:_on_first_update() end
inst.on_option_change = function() return inst:_on_option_change() end
inst.save_state = function(m_data) return inst:_save_state(m_data) end
inst.load_state = function(m_data) return inst:_load_state(m_data) end
inst.on_squad_npc_death = function(squad, npc, killer_npc, killer_squad) return inst:_on_squad_npc_death(squad, npc, killer_npc, killer_squad) end
inst.on_squad_npc_creation = function(squad, npc, smart) return inst:_on_squad_npc_creation(squad, npc, smart) end
inst.on_squad_first_update = function(squad) return inst:_on_squad_first_update(squad) end
inst.on_squad_update = function(squad) return inst:_on_squad_update(squad) end
inst.on_squad_enter_smart = function(squad, smart) return inst:_on_squad_enter_smart(squad, smart) end
inst.on_squad_leave_smart = function(squad, smart) return inst:_on_squad_leave_smart(squad, smart) end
inst.on_squad_after_level_change = function(squad, old_level, new_level) return inst:_on_squad_after_level_change(squad, old_level, new_level) end
inst.on_server_entity_unregister = function(se_obj, type_name) return inst:_on_server_entity_unregister(se_obj, type_name) end
inst.on_server_entity_register = function(se_obj, type_name) return inst:_on_server_entity_register(se_obj, type_name) end
inst.on_smart_terrain_update = function(smart) return inst:_on_smart_terrain_update(smart) end
inst.on_npc_update = function(npc) return inst:_on_npc_update(npc) end
inst.on_npc_item_take = function(npc, item) return inst:_on_npc_item_take(npc, item) end
inst.on_npc_item_drop = function(npc, item) return inst:_on_npc_item_drop(npc, item) end
inst.on_npc_death = function(victim, who) return inst:_on_npc_death(victim, who) end
inst.on_actor_item_drop = function(item) return inst:_on_actor_item_drop(item) end
inst.on_task_current_changed = function(payload) return inst:_on_task_current_changed(payload) end
inst.on_trade_service_result = function(squad_id, npc_id, smart_name, source, phase, status, reason) return inst:_on_trade_service_result(squad_id, npc_id, smart_name, source, phase, status, reason) end

zhopa.core = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_core

-- BEGIN module zhopa_safe
zhopa_bundle_module = function()
zhopa = zhopa or {}
zhopa.safe = zhopa.safe or {}

local tostring = _G.tostring
local tonumber = _G.tonumber
local pcall = _G.pcall
local xpcall = _G.xpcall
local time_global = _G.time_global

local safe = zhopa.safe

local debug_traceback = (debug and debug.traceback) and debug.traceback or nil

local RUNTIME = {
    last_cfg_tg = 0,
    warn_ms = 350,
}

local function now_tg()
    return (time_global and time_global()) or 0
end

local function is_valid_server_id(id)
    id = tonumber(id) or 0
    return id > 0 and id ~= 65535
end

function safe.safe_call(tag, fn, ...)
    if fn == nil then
        return false, "nil_fn"
    end

    local function handler(err)
        local tostring = tostring
        if zhopa and zhopa.log and zhopa.log.error then
            zhopa.log.error("SAFE", "%s: %s", tostring(tag), tostring(err))
        end
        if debug_traceback then
            return debug_traceback(tostring(err), 2)
        end
        return tostring(err)
    end

    local start_tg = now_tg()

    local ok, a, b, c, d = xpcall(fn, handler, ...)
    local dt = now_tg() - start_tg
    if dt > RUNTIME.warn_ms then
        if zhopa and zhopa.log and zhopa.log.warn then
            zhopa.log.warn("SAFE", "Slow call %s: %d ms", tostring(tag), tonumber(dt) or 0)
        end
    end
    return ok, a, b, c, d
end

function safe.safe_id(obj)
    if not obj then return nil end
    local ok, res = pcall(function() return obj:id() end)
    return ok and res or nil
end

function safe.safe_name(obj)
    if not obj then return nil end
    local ok, res = pcall(function() return obj:name() end)
    return ok and res or nil
end

function safe.safe_section(obj)
    if not obj then return nil end
    local ok, res = pcall(function() return obj:section() end)
    if ok and res then return res end
    ok, res = pcall(function() return obj:section_name() end)
    return ok and res or nil
end

function safe.safe_position(obj)
    if not obj then return nil end
    local ok, res = pcall(function() return obj:position() end)
    if ok and res then
        return res
    end
    ok, res = pcall(function() return obj.position end)
    return ok and res or nil
end

function safe.safe_level_vertex_id(obj)
    if not obj then return nil end
    local ok, res = pcall(function() return obj:level_vertex_id() end)
    return ok and res or nil
end

function safe.safe_game_vertex_id(obj)
    if not obj then return nil end
    local ok, res = pcall(function() return obj:game_vertex_id() end)
    return ok and res or nil
end

function safe.is_alive(obj)
    if not obj then return false end

    local ok_id, id = pcall(function() return obj:id() end)
    if not ok_id then return false end

    if is_valid_server_id(id) and alife then
        local ok_se, se_obj = pcall(function() return alife():object(id) end)
        if ok_se and not se_obj then
            local ok_lvl, lvl_obj = pcall(function()
                return level and level.object_by_id and level.object_by_id(id)
            end)
            if not (ok_lvl and lvl_obj) then
                return false
            end
        end
    end

    local is_valid_type = false
    pcall(function()
        if IsStalker and IsStalker(obj) then is_valid_type = true end
        if IsMonster and IsMonster(obj) then is_valid_type = true end
        if obj.clsid and obj:clsid() == clsid.script_actor then is_valid_type = true end
    end)
    if not is_valid_type then return false end

    local ok, res = pcall(function() return obj:alive() end)
    return ok and res and true or false
end

function safe.safe_community(se_obj)
    if not se_obj then return nil end
    local ok, res = pcall(function() return se_obj:community() end)
    return ok and res or nil
end

function safe.safe_squad_community(se_squad)
    if not (se_squad and alife) then return nil end
    local ok_cid, cid = pcall(function() return se_squad:commander_id() end)
    cid = ok_cid and tonumber(cid) or nil
    if cid and cid > 0 and cid ~= 65535 then
        local se_commander = nil
        local storage = db and db.storage and db.storage[cid] or nil
        if storage and storage.object then
            se_commander = storage.object
        elseif level and level.object_by_id then
            local ok_online, online_obj = pcall(function() return level.object_by_id(cid) end)
            if ok_online and online_obj then
                se_commander = online_obj
            end
        end

        if not se_commander then
            local ok_server, server_obj = pcall(function() return alife():object(cid) end)
            if ok_server and server_obj then
                se_commander = server_obj
            end
        end

        if se_commander then
            local community = safe.safe_community(se_commander)
            if type(community) == "string" and community ~= "" then
                return community
            end
        end
    end

    local ok_pid, pid = pcall(function() return se_squad.player_id end)
    if ok_pid and type(pid) == "string" and pid ~= "" then
        return pid
    end

    local ok_faction, faction = pcall(function() return se_squad.faction end)
    if ok_faction and type(faction) == "string" and faction ~= "" then
        return faction
    end

    ok_faction, faction = pcall(function() return se_squad:faction() end)
    if ok_faction and type(faction) == "string" and faction ~= "" then
        return faction
    end

    return nil
end
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_safe

-- BEGIN module zhopa_log
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local setmetatable = _G.setmetatable
local tonumber = _G.tonumber
local tostring = _G.tostring
local io = _G.io
local time_global = _G.time_global
local level = _G.level
local string_match = string.match


local Logger = zhopa.class("Logger")
Logger.__index = Logger

local LEVEL_OFF = 0
local LEVEL_ERROR = 1
local LEVEL_WARN = 2
local LEVEL_INFO = 3
local LEVEL_DEBUG = 4
local LEVEL_TRACE = 5

local string_format = string.format

local function now_tg()
    return (time_global and time_global()) or 0
end

local function level_name(lvl)
    if lvl == LEVEL_ERROR then return "ERROR" end
    if lvl == LEVEL_WARN then return "WARN" end
    if lvl == LEVEL_INFO then return "INFO" end
    if lvl == LEVEL_DEBUG then return "DEBUG" end
    if lvl == LEVEL_TRACE then return "TRACE" end
    return "OFF"
end

local function truncate_file(path)
    if not (io and io.open and type(path) == "string" and path ~= "") then
        return false
    end
    local f = io.open(path, "w")
    if not f then
        return false
    end
    f:close()
    return true
end

function Logger:__init()
    self.current_level = LEVEL_OFF
    self.log_file = "zhopa.log"
    self.buffer = {}
    self.buffer_len = 0
    self.last_flush_tg = 0
    self.flush_interval_ms = 1500
    self.flush_size = 64
    self.filter_active_level_only = false
    self.filter_drop_unknown_level = false
    self.filter_cfg_next_tg = 0
    truncate_file(self.log_file)
end

function Logger:_set_level(lvl)
    local v = tonumber(lvl)
    if not v then return end
    if v < LEVEL_OFF then v = LEVEL_OFF end
    if v > LEVEL_TRACE then v = LEVEL_TRACE end
    self.current_level = v
    if v == LEVEL_OFF then
        self.buffer = {}
        self.buffer_len = 0
    end
end

function Logger:_get_level()
    return self.current_level
end

function Logger:_set_file(filename)
    if type(filename) ~= "string" or filename == "" then return end
    self.log_file = filename
end

function Logger:_flush()
    if self.buffer_len == 0 then return end
    local f = io and io.open and io.open(self.log_file, "a") or nil
    if not f then
        self.buffer = {}
        self.buffer_len = 0
        return
    end
    for i = 1, self.buffer_len do
        f:write(self.buffer[i])
    end
    f:close()
    self.buffer = {}
    self.buffer_len = 0
end

function Logger:_flush_public()
    if zhopa and zhopa.timers and zhopa.timers.cancel then
        pcall(zhopa.timers.cancel, "zhopa_log", "flush")
    end
    pcall(self._flush, self)
end

function Logger:_schedule_flush()
    if not (zhopa and zhopa.timers and zhopa.timers.schedule) then
        return
    end
    if zhopa.timers.has and zhopa.timers.has("zhopa_log", "flush") then
        return
    end
    local delay = tonumber(self.flush_interval_ms) or 0
    if delay < 0 then delay = 0 end
    pcall(zhopa.timers.schedule, "zhopa_log", "flush", delay, function()
        self.last_flush_tg = now_tg()
        self:_flush_public()
        return true
    end)
end

function Logger:_emit(module, lvl, fmt, ...)
    if self.current_level == LEVEL_OFF then return end
    if lvl > self.current_level then return end

    local tg = now_tg()
    if tg >= (tonumber(self.filter_cfg_next_tg) or 0) then
        self.filter_cfg_next_tg = tg + 500
        local cfg = zhopa and zhopa.config and zhopa.config.get or nil
        if type(cfg) == "function" then
            self.filter_active_level_only = cfg("log_filter_active_level_only", false) == true
            self.filter_drop_unknown_level = cfg("log_filter_active_level_drop_unknown", false) == true
        else
            self.filter_active_level_only = false
            self.filter_drop_unknown_level = false
        end
    end

    local line = nil
    if fmt == nil then
        line = ""
    elseif select("#", ...) > 0 then
        local ok, res = pcall(string_format, fmt, ...)
        line = ok and res or tostring(fmt)
    else
        line = tostring(fmt)
    end

    if self.filter_active_level_only then
        local active = nil
        if level and type(level.name) == "function" then
            local ok, res = pcall(function() return level.name() end)
            if ok and type(res) == "string" and res ~= "" then
                active = res
            end
        end
        if active then
            local lvl_s = nil
            lvl_s = string_match(line, "level=([%w_]+)") or lvl_s
            lvl_s = string_match(line, "target_level=([%w_]+)") or lvl_s
            lvl_s = string_match(line, "cur_level=([%w_]+)") or lvl_s
            lvl_s = string_match(line, "level_name=([%w_]+)") or lvl_s
            lvl_s = string_match(line, " lvl=([%w_]+)") or lvl_s
            if lvl_s then
                if lvl_s ~= active then
                    return
                end
            elseif self.filter_drop_unknown_level then
                return
            end
        end
    end

    local prefix = string_format("[%d][%s][%s] ", tg, level_name(lvl), tostring(module or "ZHOPA"))
    self.buffer_len = self.buffer_len + 1
    self.buffer[self.buffer_len] = prefix .. line .. "\n"

    if self.buffer_len >= self.flush_size then
        self.last_flush_tg = tg
        pcall(self._flush, self)
        if zhopa and zhopa.timers and zhopa.timers.cancel then
            pcall(zhopa.timers.cancel, "zhopa_log", "flush")
        end
    else
        self:_schedule_flush()
    end
end

function Logger:_error(module, fmt, ...)
    self:_emit(module, LEVEL_ERROR, fmt, ...)
end

function Logger:_warn(module, fmt, ...)
    self:_emit(module, LEVEL_WARN, fmt, ...)
end

function Logger:_info(module, fmt, ...)
    self:_emit(module, LEVEL_INFO, fmt, ...)
end

function Logger:_debug(module, fmt, ...)
    self:_emit(module, LEVEL_DEBUG, fmt, ...)
end

function Logger:_trace(module, fmt, ...)
    self:_emit(module, LEVEL_TRACE, fmt, ...)
end

local inst = Logger.new and Logger.new() or setmetatable({}, Logger)
if not inst.current_level then
    Logger.__init(inst)
end

inst.LEVEL_OFF = LEVEL_OFF
inst.LEVEL_ERROR = LEVEL_ERROR
inst.LEVEL_WARN = LEVEL_WARN
inst.LEVEL_INFO = LEVEL_INFO
inst.LEVEL_DEBUG = LEVEL_DEBUG
inst.LEVEL_TRACE = LEVEL_TRACE

inst.set_level = function(lvl) return inst:_set_level(lvl) end
inst.get_level = function() return inst:_get_level() end
inst.set_file = function(filename) return inst:_set_file(filename) end
inst.flush = function() return inst:_flush_public() end
inst.error = function(module, fmt, ...) return inst:_error(module, fmt, ...) end
inst.warn = function(module, fmt, ...) return inst:_warn(module, fmt, ...) end
inst.info = function(module, fmt, ...) return inst:_info(module, fmt, ...) end
inst.debug = function(module, fmt, ...) return inst:_debug(module, fmt, ...) end
inst.trace = function(module, fmt, ...) return inst:_trace(module, fmt, ...) end

zhopa.log = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_log

-- BEGIN module zhopa_heli_guard_patch
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local tostring = _G.tostring
local pcall = _G.pcall
local alife_object = _G.alife_object

local function log_warn(fmt, ...)
    if zhopa.log and zhopa.log.warn then
        zhopa.log.warn("HELI_PATCH", fmt, ...)
    end
end

local function has_respawn_counter_entry(se_obj)
    if not se_obj then
        return true
    end
    local respawn_id = se_obj.respawn_point_id
    local prop_section = se_obj.respawn_point_prop_section
    if not (respawn_id and type(prop_section) == "string" and prop_section ~= "" and prop_section ~= "nil") then
        return true
    end
    local smart = alife_object and alife_object(respawn_id) or nil
    if not smart then
        return true
    end
    return type(smart.already_spawned) == "table"
        and type(smart.already_spawned[prop_section]) == "table"
end

local function clear_stale_respawn_counter_ref(se_obj, source)
    if not se_obj or has_respawn_counter_entry(se_obj) then
        return false
    end

    log_warn(
        "skip stale heli respawn counter cleanup source=%s heli=%s smart_id=%s prop=%s",
        tostring(source or "-"),
        tostring(se_obj.id or "-"),
        tostring(se_obj.respawn_point_id or "-"),
        tostring(se_obj.respawn_point_prop_section or "-")
    )
    se_obj.respawn_point_id = nil
    se_obj.respawn_point_prop_section = nil
    return true
end

local function apply_se_heli_patch()
    local cls = rawget(_G, "se_heli")
    if type(cls) ~= "table" or type(cls.on_unregister) ~= "function" then
        return false
    end
    if cls.__zhopa_heli_guard_patch_applied == true then
        return true
    end

    local original = cls.on_unregister
    cls.on_unregister = function(self)
        if self then
            clear_stale_respawn_counter_ref(self, "se_heli")
        end
        return original(self)
    end
    cls.__zhopa_heli_guard_patch_applied = true
    return true
end

local function apply_bind_heli_patch()
    local cls = rawget(_G, "heli_binder")
    if type(cls) ~= "table" or type(cls.check_health) ~= "function" then
        return false
    end
    if cls.__zhopa_heli_guard_patch_applied == true then
        return true
    end

    local original = cls.check_health
    cls.check_health = function(self, ...)
        local object = self and self.object or nil
        local object_id = object and object.id and object:id() or nil
        local se_obj = object_id and alife_object and alife_object(object_id) or nil
        if se_obj then
            clear_stale_respawn_counter_ref(se_obj, "bind_heli")
        end
        return original(self, ...)
    end
    cls.__zhopa_heli_guard_patch_applied = true
    return true
end

local function apply_patch()
    local patched = false
    if apply_se_heli_patch() then
        patched = true
    end
    if apply_bind_heli_patch() then
        patched = true
    end
    return patched
end

local function master_enabled()
    if zhopa and zhopa.config and zhopa.config.get then
        local ok_enabled, enabled = pcall(function() return zhopa.config.get("enabled", true) end)
        if ok_enabled then
            return enabled == true
        end
    end
    return true
end

local function on_game_start()
    if master_enabled() == true then
        return apply_patch()
    end
    return false
end

local inst = {
    apply = apply_patch,
    on_game_start = on_game_start,
    on_option_change = on_game_start,
}

zhopa.heli_guard_patch = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_heli_guard_patch


-- BEGIN module zhopa_config
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local setmetatable = _G.setmetatable
local tonumber = _G.tonumber
local tostring = _G.tostring
local ini_file = _G.ini_file
local time_global = _G.time_global

local MCM_NIL = {}
local LTX_NIL = {}


local Config = zhopa.class("Config")
Config.__index = Config

function Config:__init()
    self.ini = nil
    self.ini_path = "zhopa_settings.ltx"
    self.blacklists_ini = nil
    self.blacklists_ini_path = "zhopa_smart_blacklists.ltx"
    self.smart_task_ini = nil
    self.smart_task_ini_path = "zhopa_smart_tasklist.ltx"
    self.last_mcm_read_tg = 0
    self.mcm_cache_ms = 400
    self.mcm_cache = {}
    self.mcm_path_cache = {}
    self.value_cache_ms = 500
    self.value_cache = {}
    self.line_cache = {}
    self.line_cache_ms = 5000
    self.section_cache = {}
    self.section_cache_ms = 5000
    self.section_kv_cache = {}
    self.section_kv_cache_ms = 5000
    self.smart_blacklists_cache_ms = 5000
    self.smart_blacklists_cache = {
        tg = 0,
        levels = {},
        global_set = nil,
        faction_levels = {},
        faction_smarts = {},
        section_levels = {},
        section_smarts = {},
    }
    self.smart_task_cache = {
        tasktype_by_smart = nil,
        allowed_tokens_by_tasktype = {},
        mode_by_tasktype_smart = {},
        whitelist_tokens_by_tasktype_smart = {},
        blacklist_tokens_by_tasktype_smart = {},
    }
    self.runtime_overrides = {}
    self.bool_keys = {
        enabled = true,
        debug_hud_enabled = true,
        explore_enabled = true,
        smart_tasks_enabled = true,
        smart_tasks_control_enabled = true,
        story_events_enabled = true,
        story_events_north_migration_enabled = true,
        story_psy_watchdog_enabled = true,
        mutant_sim_enabled = true,
        mutant_explore_enabled = true,
        mutant_hunt_enabled = true,
        artefact_enabled = true,
        populate_enabled = true,
        base_camping_enabled = true,
        base_filler_enabled = true,
        patrol_enabled = true,
        mutant_patrol_enabled = true,
        trade_enabled = true,
        loot_enabled = true,
        loot_disable_near_actor_limit = true,
        loot_unlock_corpses = true,
        loot_collect_during_surge = true,
        loot_protect_quest_corpses_enabled = true,
        loot_items_enabled = true,
        loot_items_allow_unseen = true,
        night_rest_enabled = true,
        target_sync_enabled = true,
        online_intent_enforce_enabled = true,
        log_filter_active_level_only = true,
        log_filter_active_level_drop_unknown = true,
        trade_axr_buy_all_enabled = true,
        npc_faction_override_enabled = true,
    }
end

function Config:_get_mcm_path(key)
    if type(key) ~= "string" or key == "" then
        return nil
    end
    if self.mcm_path_cache[key] ~= nil then
        return self.mcm_path_cache[key] or nil
    end

    local schema = zhopa and zhopa.mcm_schema or nil
    if not (type(schema) == "table" and type(schema.get_path) == "function") then
        zhopa_require_external("zhopa_mcm_schema")
        schema = zhopa and zhopa.mcm_schema or nil
    end

    local path = nil
    if type(schema) == "table" and type(schema.get_path) == "function" then
        local ok, res = pcall(schema.get_path, key)
        if ok and type(res) == "string" and res ~= "" then
            path = res
        end
    end

    self.mcm_path_cache[key] = path or false
    return path
end

function Config:_tg()
    return (time_global and time_global()) or 0
end

function Config:_get_ini()
    if self.ini then return self.ini end
    if ini_file then
        local ok, res = pcall(function() return ini_file(self.ini_path) end)
        if ok then self.ini = res end
    end
    return self.ini
end

function Config:_get_blacklists_ini()
    if self.blacklists_ini then return self.blacklists_ini end
    if ini_file then
        local ok, res = pcall(function() return ini_file(self.blacklists_ini_path) end)
        if ok then self.blacklists_ini = res end
    end
    return self.blacklists_ini
end

function Config:_get_smart_task_ini()
    if self.smart_task_ini then return self.smart_task_ini end
    if ini_file then
        local ok, res = pcall(function() return ini_file(self.smart_task_ini_path) end)
        if ok then self.smart_task_ini = res end
    end
    return self.smart_task_ini
end

function Config:_read_ltx_raw(key)
    local i = self:_get_ini()
    if not i then return nil end
    local ok, res = pcall(function()
        if i:line_exist("zhopa", key) then
            return i:r_string("zhopa", key)
        end
        return nil
    end)
    if not ok or res == nil then return nil end

    if res == "true" then return true end
    if res == "false" then return false end
    local n = tonumber(res)
    if n ~= nil then return n end
    return res
end

function Config:_normalize_value(key, v)
    if v == nil then return nil end
    if type(v) == "string" then
        if v == "true" then return true end
        if v == "false" then return false end
        local n = tonumber(v)
        if n ~= nil then v = n end
    end
    if (key == "enabled") or (type(key) == "string" and string.sub(key, -8) == "_enabled") or (self.bool_keys and self.bool_keys[key]) then
        if v == true or v == false then return v end
        if type(v) == "number" then
            if v == 0 then return false end
            if v == 1 then return true end
        end
    end
    return v
end

function Config:_read_mcm(key)
    if not (ui_mcm and ui_mcm.get) then return nil end
    local now = self:_tg()
    if now > self.last_mcm_read_tg + self.mcm_cache_ms then
        self.mcm_cache = {}
        self.last_mcm_read_tg = now
    end
    if self.mcm_cache[key] ~= nil then
        if self.mcm_cache[key] == MCM_NIL then
            return nil
        end
        return self.mcm_cache[key]
    end

    local res = nil
    local full = self:_get_mcm_path(key)
    if full then
        local ok1, r1 = pcall(function() return ui_mcm.get(full) end)
        if ok1 and r1 ~= nil then
            res = r1
        end
    end

    if res ~= nil then
        res = self:_normalize_value(key, res)
        self.mcm_cache[key] = res
        return res
    end
    self.mcm_cache[key] = MCM_NIL
    return nil
end

function Config:_parse_csv(s)
    if type(s) ~= "string" then return {} end
    local string_gmatch = string.gmatch
    local string_gsub = string.gsub
    local out = {}
    local n = 0
    for token in string_gmatch(s, "([^,]+)") do
        local t = string_gsub(token, "^%s*(.-)%s*$", "%1")
        if t ~= "" then
            n = n + 1
            out[n] = t
        end
    end
    return out
end

function Config:_get_ltx_cached(key, default)
    if type(key) ~= "string" or key == "" then return default end

    local now = self:_tg()
    local cached = self.value_cache[key]
    if cached and cached.tg and (now < (cached.tg + self.value_cache_ms)) then
        if cached.value == LTX_NIL then
            return default
        end
        return cached.value
    end

    local value = self:_read_ltx_raw(key)
    if value == nil then
        self.value_cache[key] = { tg = now, value = LTX_NIL }
        return default
    end

    self.value_cache[key] = { tg = now, value = value }
    return value
end

function Config:_read_line_csv(section_name, key)
    local i = self:_get_ini()
    if not (i and section_name and key) then return {} end
    local ok, res = pcall(function()
        if i:line_exist(section_name, key) then
            return i:r_string(section_name, key)
        end
        return nil
    end)
    if not (ok and res) then return {} end
    return self:_parse_csv(res)
end

function Config:_get_line_csv(section_name, key)
    if not (type(section_name) == "string" and section_name ~= "" and type(key) == "string" and key ~= "") then
        return {}
    end

    local cache_key = section_name .. "|" .. key
    local now = self:_tg()
    local cached = self.line_cache[cache_key]
    if cached and cached.tg and (now < (cached.tg + self.line_cache_ms)) and cached.list ~= nil then
        return cached.list
    end

    local list = self:_read_line_csv(section_name, key)
    self.line_cache[cache_key] = { tg = now, list = list }
    return list
end

function Config:_read_section_list(section)
    local i = self:_get_ini()
    if not (i and section) then return {} end
    local string_sub = string.sub
    local string_gsub = string.gsub
    local ok_exist, exist = pcall(function() return i:section_exist(section) end)
    if not (ok_exist and exist) then return {} end

    local ok_cnt, cnt = pcall(function() return i:line_count(section) end)
    cnt = ok_cnt and tonumber(cnt) or nil
    if not cnt or cnt <= 0 then return {} end

    local out = {}
    local n = 0
    for idx = 0, cnt - 1 do
        local ok_line, k, v = pcall(function() return i:r_line(section, idx) end)
        if ok_line then
            local name = nil
            if type(k) == "string" and k ~= "" then
                name = k
            elseif type(v) == "string" and v ~= "" then
                name = v
            end
            if name then
                name = string_gsub(name, "^%s*(.-)%s*$", "%1")
                if name ~= "" and string_sub(name, 1, 1) ~= ";" then
                    n = n + 1
                    out[n] = name
                end
            end
        end
    end
    return out
end

function Config:_get_section_list(section)
    if type(section) ~= "string" or section == "" then return {} end
    local now = self:_tg()
    local c = self.section_cache[section]
    if c and c.tg and (now < (c.tg + self.section_cache_ms)) and c.list ~= nil then
        return c.list
    end

    local list = self:_read_section_list(section)
    if not list or #list == 0 then
        self.section_cache[section] = { tg = now, list = {}, set = nil }
        return {}
    end

    self.section_cache[section] = { tg = now, list = list, set = nil }
    return list
end

function Config:_read_section_kv_map(section)
    local i = self:_get_ini()
    if not (i and type(section) == "string" and section ~= "") then return {} end

    local ok_exist, exist = pcall(function() return i:section_exist(section) end)
    if not (ok_exist and exist) then return {} end

    local ok_cnt, cnt = pcall(function() return i:line_count(section) end)
    cnt = ok_cnt and tonumber(cnt) or nil
    if not cnt or cnt <= 0 then return {} end

    local string_gsub = string.gsub
    local out = {}
    for idx = 0, cnt - 1 do
        local ok_line, result, k, v = pcall(function() return i:r_line(section, idx) end)
        if ok_line and result then
            local key = type(k) == "string" and string_gsub(k, "^%s*(.-)%s*$", "%1") or ""
            local value = type(v) == "string" and string_gsub(v, "^%s*(.-)%s*$", "%1") or ""
            if key ~= "" and string_gsub(key, "^%s*;.*$", "") ~= "" then
                value = string_gsub(value, "%s*;.*$", "")
                value = string_gsub(value, "^%s*(.-)%s*$", "%1")
                if value ~= "" then
                    out[key] = value
                end
            end
        end
    end
    return out
end

function Config:_get_section_kv_map(section)
    if type(section) ~= "string" or section == "" then return {} end
    local now = self:_tg()
    local c = self.section_kv_cache[section]
    if c and c.tg and (now < (c.tg + self.section_kv_cache_ms)) and c.map ~= nil then
        return c.map
    end

    local map = self:_read_section_kv_map(section)
    self.section_kv_cache[section] = { tg = now, map = map or {} }
    return map or {}
end

function Config:_get_section_set(section)
    if type(section) ~= "string" or section == "" then return nil end
    local now = self:_tg()
    local c = self.section_cache[section]
    if c and c.tg and (now < (c.tg + self.section_cache_ms)) and c.set ~= nil then
        return c.set
    end

    local list = self:_get_section_list(section)
    if not list or #list == 0 then
        self.section_cache[section] = { tg = now, list = {}, set = nil }
        return nil
    end

    local set = {}
    for i = 1, #list do
        set[list[i]] = true
    end
    self.section_cache[section] = { tg = now, list = list, set = set }
    return set
end

function Config:_get(key, default)
    if key == nil then return default end
    if self.runtime_overrides and self.runtime_overrides[key] ~= nil then
        return self.runtime_overrides[key]
    end
    local m = self:_read_mcm(key)
    if m ~= nil then return m end
    return self:_get_ltx_cached(key, default)
end

function Config:_set_runtime_override(key, value)
    if key == nil then return end
    self.runtime_overrides = self.runtime_overrides or {}
    self.runtime_overrides[key] = value
    self.value_cache = {}
end

function Config:_clear_runtime_override(key)
    if not self.runtime_overrides then return end
    if key == nil then
        self.runtime_overrides = {}
        self.value_cache = {}
        return
    end
    self.runtime_overrides[key] = nil
    self.value_cache = {}
end

function Config:_clear_mcm_cache()
    self.mcm_cache = {}
    self.last_mcm_read_tg = 0
    self.value_cache = {}
    self.smart_task_cache = {
        tasktype_by_smart = nil,
        allowed_tokens_by_tasktype = {},
        mode_by_tasktype_smart = {},
        whitelist_tokens_by_tasktype_smart = {},
        blacklist_tokens_by_tasktype_smart = {},
    }
end

function Config:_get_anomaly_smarts(level_name)
    return self:_get_line_csv("anomaly_smarts", level_name)
end

function Config:_get_level_bases(level_name)
    return self:_get_line_csv("level_bases", level_name)
end

function Config:_get_level_bases_levels()
    return self:_get_section_list("level_bases")
end

function Config:_get_trade_smarts(level_name)
    return self:_get_line_csv("trade_smarts", level_name)
end

function Config:_read_smart_task_section_list(section)
    local i = self:_get_smart_task_ini()
    if not (i and section) then return {} end
    local string_sub = string.sub
    local string_gsub = string.gsub
    local ok_exist, exist = pcall(function() return i:section_exist(section) end)
    if not (ok_exist and exist) then return {} end

    local ok_cnt, cnt = pcall(function() return i:line_count(section) end)
    cnt = ok_cnt and tonumber(cnt) or nil
    if not cnt or cnt <= 0 then return {} end

    local out = {}
    local seen = {}
    local n = 0
    for idx = 0, cnt - 1 do
        local ok_line, k, v = pcall(function() return i:r_line(section, idx) end)
        if ok_line then
            local name = nil
            if type(k) == "string" and k ~= "" then
                name = k
            elseif type(v) == "string" and v ~= "" then
                name = v
            end
            if name then
                name = string_gsub(name, "%s*;.*$", "")
                name = string_gsub(name, "^%s*(.-)%s*$", "%1")
                if name ~= "" and string_sub(name, 1, 1) ~= ";" then
                    local lower_name = string.lower(name)
                    if seen[lower_name] ~= true then
                        seen[lower_name] = true
                        n = n + 1
                        out[n] = lower_name
                    end
                end
            end
        end
    end
    return out
end

function Config:_read_smart_task_section_kv_map(section)
    local i = self:_get_smart_task_ini()
    if not (i and type(section) == "string" and section ~= "") then return {} end

    local ok_exist, exist = pcall(function() return i:section_exist(section) end)
    if not (ok_exist and exist) then return {} end

    local ok_cnt, cnt = pcall(function() return i:line_count(section) end)
    cnt = ok_cnt and tonumber(cnt) or nil
    if not cnt or cnt <= 0 then return {} end

    local string_gsub = string.gsub
    local string_lower = string.lower
    local out = {}
    for idx = 0, cnt - 1 do
        local ok_line, result, k, v = pcall(function() return i:r_line(section, idx) end)
        if ok_line and result then
            local key = type(k) == "string" and string_gsub(k, "^%s*(.-)%s*$", "%1") or ""
            local value = type(v) == "string" and string_gsub(v, "^%s*(.-)%s*$", "%1") or ""
            if key ~= "" and string_gsub(key, "^%s*;.*$", "") ~= "" then
                key = string_lower(key)
                value = string_gsub(value, "%s*;.*$", "")
                value = string_gsub(value, "^%s*(.-)%s*$", "%1")
                if value ~= "" then
                    out[key] = string_lower(value)
                end
            end
        end
    end
    return out
end

function Config:_read_smart_task_line_csv(section_name, key)
    local i = self:_get_smart_task_ini()
    if not (i and section_name and key) then return {} end
    local ok, res = pcall(function()
        if i:line_exist(section_name, key) then
            return i:r_string(section_name, key)
        end
        return nil
    end)
    if not (ok and res) then return {} end
    local list = self:_parse_csv(res)
    if not list or #list == 0 then
        return {}
    end

    local out = {}
    local seen = {}
    local string_gsub = string.gsub
    local string_lower = string.lower
    local n = 0
    for idx = 1, #list do
        local token = list[idx]
        if type(token) == "string" then
            token = string_gsub(token, "%s*;.*$", "")
            token = string_lower(string_gsub(token, "^%s*(.-)%s*$", "%1"))
            if token ~= "" and seen[token] ~= true then
                seen[token] = true
                n = n + 1
                out[n] = token
            end
        end
    end
    return out
end

function Config:_read_smart_task_kv(section_name, key)
    local i = self:_get_smart_task_ini()
    if not (i and section_name and key) then return nil end
    local ok, res = pcall(function()
        if i:line_exist(section_name, key) then
            return i:r_string(section_name, key)
        end
        return nil
    end)
    if not (ok and type(res) == "string") then
        return nil
    end
    local value = string.lower((string.gsub(res, "^%s*(.-)%s*$", "%1")))
    if value == "" then
        return nil
    end
    return value
end

function Config:_get_smart_task_map()
    local cache = self.smart_task_cache
    if type(cache.tasktype_by_smart) == "table" then
        return cache.tasktype_by_smart
    end
    local map = self:_read_smart_task_section_kv_map("zhopa_smart_tasks")
    cache.tasktype_by_smart = map or {}
    return cache.tasktype_by_smart
end

function Config:_get_smart_task_type(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil
    end
    local map = self:_get_smart_task_map()
    local key = string.lower((string.gsub(smart_name, "^%s*(.-)%s*$", "%1")))
    local tasktype = map and map[key] or nil
    if type(tasktype) == "string" and tasktype ~= "" then
        return tasktype
    end
    return nil
end

function Config:_get_smart_task_allowed_tokens(tasktype)
    if type(tasktype) ~= "string" or tasktype == "" then
        return {}
    end
    local key = string.lower((string.gsub(tasktype, "^%s*(.-)%s*$", "%1")))
    local cache = self.smart_task_cache.allowed_tokens_by_tasktype
    if cache[key] ~= nil then
        return cache[key]
    end
    local list = self:_read_smart_task_section_list("zhopa_smart_task_" .. key)
    cache[key] = list or {}
    return cache[key]
end

function Config:_get_smart_task_mode(tasktype, smart_name)
    if type(tasktype) ~= "string" or tasktype == "" then
        return nil
    end
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil
    end
    local task_key = string.lower((string.gsub(tasktype, "^%s*(.-)%s*$", "%1")))
    local smart_key = string.lower((string.gsub(smart_name, "^%s*(.-)%s*$", "%1")))
    local cache_key = task_key .. "|" .. smart_key
    local cache = self.smart_task_cache.mode_by_tasktype_smart
    if cache[cache_key] ~= nil then
        return cache[cache_key] or nil
    end
    local value = self:_read_smart_task_kv("zhopa_smart_task_" .. task_key .. "_mode", smart_key)
    cache[cache_key] = value or false
    return cache[cache_key] or nil
end

function Config:_get_smart_task_blacklist_tokens(tasktype, smart_name)
    if type(tasktype) ~= "string" or tasktype == "" then
        return {}
    end
    if type(smart_name) ~= "string" or smart_name == "" then
        return {}
    end
    local task_key = string.lower((string.gsub(tasktype, "^%s*(.-)%s*$", "%1")))
    local smart_key = string.lower((string.gsub(smart_name, "^%s*(.-)%s*$", "%1")))
    local cache_key = task_key .. "|" .. smart_key
    local cache = self.smart_task_cache.blacklist_tokens_by_tasktype_smart
    if cache[cache_key] ~= nil then
        return cache[cache_key]
    end
    local list = self:_read_smart_task_line_csv("zhopa_smart_task_" .. task_key .. "_blacklist", smart_key)
    cache[cache_key] = list or {}
    return cache[cache_key]
end

function Config:_get_smart_task_whitelist_tokens(tasktype, smart_name)
    if type(tasktype) ~= "string" or tasktype == "" then
        return {}
    end
    if type(smart_name) ~= "string" or smart_name == "" then
        return {}
    end
    local task_key = string.lower((string.gsub(tasktype, "^%s*(.-)%s*$", "%1")))
    local smart_key = string.lower((string.gsub(smart_name, "^%s*(.-)%s*$", "%1")))
    local cache_key = task_key .. "|" .. smart_key
    local cache = self.smart_task_cache.whitelist_tokens_by_tasktype_smart
    if cache[cache_key] ~= nil then
        return cache[cache_key]
    end
    local list = self:_read_smart_task_line_csv("zhopa_smart_task_" .. task_key .. "_whitelist", smart_key)
    cache[cache_key] = list or {}
    return cache[cache_key]
end

function Config:_read_section_kv(section, key)
    if not (section and key) then return nil end
    local bl = self:_get_blacklists_ini()
    if bl then
        local ok, res = pcall(function()
            if bl:line_exist(section, key) then
                return bl:r_string(section, key)
            end
            return nil
        end)
        if ok and res ~= nil then
            return res
        end
    end

    local i = self:_get_ini()
    if not i then return nil end
    local ok, res = pcall(function()
        if i:line_exist(section, key) then
            return i:r_string(section, key)
        end
        return nil
    end)
    return ok and res or nil
end

function Config:_blacklists_cache_touch()
    local now = self:_tg()
    local c = self.smart_blacklists_cache
    if type(c) ~= "table" or type(c.tg) ~= "number" or now > (c.tg + self.smart_blacklists_cache_ms) then
        self.smart_blacklists_cache = {
            tg = now,
            levels = {},
            global_set = nil,
            global_levels = {},
            faction_levels = {},
            faction_smarts = {},
            section_levels = {},
            section_smarts = {},
        }
        return self.smart_blacklists_cache
    end
    return c
end

function Config:_normalize_faction_key(name)
    if type(name) ~= "string" then return nil end
    local string_gsub = string.gsub
    local string_lower = string.lower
    local key = string_lower(string_gsub(name, "^%s*(.-)%s*$", "%1"))
    if key == "" then return nil end
    if key == "mutant" or key == "mutants" or key == "monsters" then
        key = "monster"
    end

    local alias = self:_get_faction_alias(key)
    if type(alias) == "string" and alias ~= "" then
        alias = string_lower(string_gsub(alias, "^%s*(.-)%s*$", "%1"))
        if alias ~= "" then
            key = alias
        end
    end
    if key == "mutant" or key == "mutants" or key == "monsters" then
        key = "monster"
    end
    return key
end

function Config:_normalize_section_key(name)
    if type(name) ~= "string" then return nil end
    local string_gsub = string.gsub
    local string_lower = string.lower
    local key = string_lower(string_gsub(name, "^%s*(.-)%s*$", "%1"))
    if key == "" then return nil end
    return key
end

function Config:_parse_blacklist_value(raw)
    if type(raw) ~= "string" then return nil end
    local string_gsub = string.gsub
    local string_lower = string.lower
    raw = string_gsub(raw, "%s*;.*$", "")
    raw = string_gsub(raw, "^%s*(.-)%s*$", "%1")
    if raw == "" then return nil end
    if string_lower(raw) == "all" then
        return { all = true }
    end
    local list = self:_parse_csv(raw)
    if not list or #list == 0 then
        return nil
    end
    local set = {}
    for i = 1, #list do
        set[list[i]] = true
    end
    return { set = set }
end

function Config:_get_smart_blacklists_rule(level_name)
    if type(level_name) ~= "string" or level_name == "" then return nil end
    local c = self:_blacklists_cache_touch()
    if c.levels[level_name] ~= nil then
        return c.levels[level_name] or nil
    end
    local raw = self:_read_section_kv("zhopa_smart_blacklists", level_name)
    local parsed = self:_parse_blacklist_value(raw)
    c.levels[level_name] = parsed or false
    return parsed
end

function Config:_get_smart_blacklists_global_set()
    local c = self:_blacklists_cache_touch()
    if c.global_set ~= nil then
        return c.global_set or nil
    end
    local raw = self:_read_section_kv("zhopa_smart_blacklists", "*") or self:_read_section_kv("zhopa_smart_blacklists", "global")
    local parsed = self:_parse_blacklist_value(raw)
    local set = parsed and parsed.set or nil
    c.global_set = set or false
    return set
end

function Config:_is_level_globally_blacklisted(level_name)
    if type(level_name) ~= "string" or level_name == "" then return false end
    local c = self:_blacklists_cache_touch()
    if c.global_levels[level_name] ~= nil then
        return c.global_levels[level_name] == true
    end

    local raw = self:_read_section_kv("zhopa_global_level_blacklists", level_name)
    local blocked = false
    if type(raw) == "string" then
        local string_gsub = string.gsub
        local string_lower = string.lower
        raw = string_gsub(raw, "%s*;.*$", "")
        raw = string_lower(string_gsub(raw, "^%s*(.-)%s*$", "%1"))
        blocked = raw ~= "" and raw ~= "0" and raw ~= "false" and raw ~= "off" and raw ~= "no"
    end
    c.global_levels[level_name] = blocked == true
    return blocked == true
end

function Config:_get_faction_level_blacklist_rule(faction)
    local key = self:_normalize_faction_key(faction)
    if not key then return nil end

    local c = self:_blacklists_cache_touch()
    if c.faction_levels[key] ~= nil then
        return c.faction_levels[key] or nil
    end

    local raw = self:_read_section_kv("zhopa_faction_level_blacklists", key)
    local parsed = self:_parse_blacklist_value(raw)
    c.faction_levels[key] = parsed or false
    return parsed
end

function Config:_get_faction_smart_blacklist_rule(faction)
    local key = self:_normalize_faction_key(faction)
    if not key then return nil end

    local c = self:_blacklists_cache_touch()
    if c.faction_smarts[key] ~= nil then
        return c.faction_smarts[key] or nil
    end

    local raw = self:_read_section_kv("zhopa_faction_smart_blacklists", key)
    local parsed = self:_parse_blacklist_value(raw)
    c.faction_smarts[key] = parsed or false
    return parsed
end

function Config:_get_section_level_blacklist_rule(section_name)
    local key = self:_normalize_section_key(section_name)
    if not key then return nil end

    local c = self:_blacklists_cache_touch()
    if c.section_levels[key] ~= nil then
        return c.section_levels[key] or nil
    end

    local raw = self:_read_section_kv("zhopa_section_level_blacklists", key)
    local parsed = self:_parse_blacklist_value(raw)
    c.section_levels[key] = parsed or false
    return parsed
end

function Config:_get_section_smart_blacklist_rule(section_name)
    local key = self:_normalize_section_key(section_name)
    if not key then return nil end

    local c = self:_blacklists_cache_touch()
    if c.section_smarts[key] ~= nil then
        return c.section_smarts[key] or nil
    end

    local raw = self:_read_section_kv("zhopa_section_smart_blacklists", key)
    local parsed = self:_parse_blacklist_value(raw)
    c.section_smarts[key] = parsed or false
    return parsed
end

function Config:_get_faction_alias(name)
    local i = self:_get_ini()
    if not (i and name) then return nil end
    local ok, res = pcall(function()
        if i:line_exist("faction_aliases", name) then
            return i:r_string("faction_aliases", name)
        end
        return nil
    end)
    if ok and res and res ~= "" then return res end
    return nil
end

local inst = Config.new and Config.new() or setmetatable({}, Config)
if not inst.ini_path then
    Config.__init(inst)
end

inst.get = function(key, default) return inst:_get(key, default) end
inst.get_anomaly_smarts = function(level_name) return inst:_get_anomaly_smarts(level_name) end
inst.get_level_bases = function(level_name) return inst:_get_level_bases(level_name) end
inst.get_level_bases_levels = function() return inst:_get_level_bases_levels() end
inst.get_trade_smarts = function(level_name) return inst:_get_trade_smarts(level_name) end
inst.get_smart_task_map = function() return inst:_get_smart_task_map() end
inst.get_smart_task_type = function(smart_name) return inst:_get_smart_task_type(smart_name) end
inst.get_smart_task_allowed_tokens = function(tasktype) return inst:_get_smart_task_allowed_tokens(tasktype) end
inst.get_smart_task_mode = function(tasktype, smart_name) return inst:_get_smart_task_mode(tasktype, smart_name) end
inst.get_smart_task_whitelist_tokens = function(tasktype, smart_name) return inst:_get_smart_task_whitelist_tokens(tasktype, smart_name) end
inst.get_smart_task_blacklist_tokens = function(tasktype, smart_name) return inst:_get_smart_task_blacklist_tokens(tasktype, smart_name) end
inst.get_section_list = function(section) return inst:_get_section_list(section) end
inst.get_section_kv_map = function(section) return inst:_get_section_kv_map(section) end
inst.get_section_set = function(section) return inst:_get_section_set(section) end
inst.get_level_smarts = function(level_name) return inst:_get_section_list("level_smarts_" .. tostring(level_name)) end
inst.get_faction_alias = function(name) return inst:_get_faction_alias(name) end
inst.get_smart_blacklists_rule = function(level_name) return inst:_get_smart_blacklists_rule(level_name) end
inst.get_smart_blacklists_global_set = function() return inst:_get_smart_blacklists_global_set() end
inst.is_level_globally_blacklisted = function(level_name) return inst:_is_level_globally_blacklisted(level_name) end
inst.get_faction_level_blacklist_rule = function(faction) return inst:_get_faction_level_blacklist_rule(faction) end
inst.get_faction_smart_blacklist_rule = function(faction) return inst:_get_faction_smart_blacklist_rule(faction) end
inst.get_section_level_blacklist_rule = function(section_name) return inst:_get_section_level_blacklist_rule(section_name) end
inst.get_section_smart_blacklist_rule = function(section_name) return inst:_get_section_smart_blacklist_rule(section_name) end
inst.set_runtime_override = function(key, value) return inst:_set_runtime_override(key, value) end
inst.clear_runtime_override = function(key) return inst:_clear_runtime_override(key) end
inst.clear_mcm_cache = function() return inst:_clear_mcm_cache() end
inst.get_mcm_path = function(key) return inst:_get_mcm_path(key) end

zhopa.config = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_config

-- BEGIN module zhopa_runtime_cfg
zhopa_bundle_module = function()
zhopa = zhopa or {}
zhopa.runtime_cfg = zhopa.runtime_cfg or {}

local M = zhopa.runtime_cfg

local type = _G.type
local tonumber = _G.tonumber
local tostring = _G.tostring
local pcall = _G.pcall

local DEFAULTS = {
    enabled = true,
    debug_hud_enabled = false,
    log_level = 0,
    offlevel_squad_update_skip_count = 0,
    surge_check_cache_ms = 250,
    smart_enemy_cache_ttl_ms = 1000,

    story_events_enabled = true,
    story_events_north_migration_enabled = true,
    story_events_north_migration_percent = 33,
    story_psy_watchdog_enabled = true,

    explore_enabled = true,
    artefact_enabled = true,
    populate_enabled = true,
    base_camping_enabled = true,
    patrol_enabled = true,
    night_rest_enabled = true,
    trade_enabled = true,
    trade_max_squads_per_smart = 3,
    trade_travel_timeout_ms = 600000,

    smart_tasks_enabled = true,
    smart_tasks_control_enabled = true,
    smart_tasks_control_max_squads_per_faction = 1,

    mutant_sim_enabled = true,
    mutant_explore_enabled = true,
    mutant_hunt_enabled = true,
    mutant_patrol_enabled = true,
    mutant_rest_duration_game_hours = 0.25,
    mutant_patrol_duration_game_hours = 1.0,

    base_filler_enabled = false,
    base_filler_npc_min = 5,
    base_filler_npc_max = 8,
    base_filler_daily_respawn_game_hours = 24,
    dynamic_bases_enabled = true,
    service_filler_enabled = true,
    service_filler_respawn_game_hours = 6,

    rest_duration_game_hours = 0.25,
    rest_fallback_stay_min_sec = 900,
    rest_fallback_stay_max_sec = 1800,
    base_camping_duration_game_hours = 1,
    task_arrive_dist_cap_m = 5,
    target_sync_enabled = true,
    online_intent_enforce_enabled = true,

    fast_trading_enabled = true,
    fast_trading_delay_ms = 500,
    fast_trading_cooldown_ms = 60000,

    loot_enabled = true,
    loot_items_enabled = true,
    loot_items_detect_dist_m = 35,
    loot_scan_radius_m = 35,
    loot_corpse_detect_dist_m = 35,
    loot_patch_max_memory_size = 48,
}

local function normalize_bool(value, default)
    if value == true or value == false then
        return value
    end
    local n = tonumber(value)
    if n ~= nil then
        return n ~= 0
    end
    if type(value) == "string" then
        if value == "true" then return true end
        if value == "false" then return false end
    end
    return default == true
end

local function read_config_value(key, default)
    if not (zhopa.config and zhopa.config.get) then
        return default
    end
    local ok, value = pcall(zhopa.config.get, key, default)
    if ok then
        return value
    end
    return default
end

function M.refresh(reason)
    local values = {}
    for key, default in pairs(DEFAULTS) do
        values[key] = read_config_value(key, default)
    end
    M.values = values
    M.reason = tostring(reason or "-")
    M.version = (tonumber(M.version) or 0) + 1
    return values
end

function M.get(key, default)
    if type(M.values) ~= "table" then
        M.refresh("lazy")
    end
    local value = M.values and M.values[key]
    if value == nil then
        return default
    end
    return value
end

function M.bool(key, default)
    return normalize_bool(M.get(key, default), default)
end

function M.num(key, default, min_v, max_v)
    local value = tonumber(M.get(key, default)) or tonumber(default) or 0
    if min_v ~= nil and value < min_v then
        value = min_v
    end
    if max_v ~= nil and value > max_v then
        value = max_v
    end
    return value
end

M.refresh("load")
zhopa.runtime_cfg = M
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_runtime_cfg

-- BEGIN module zhopa_board_index
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local setmetatable = _G.setmetatable
local tonumber = _G.tonumber
local tostring = _G.tostring
local rawget = _G.rawget
local alife = _G.alife
local game_graph = _G.game_graph
local pairs = _G.pairs
local next = _G.next
local net_packet = _G.net_packet
local clsid = rawget(_G, "clsid") or {}
local table_sort = _G.table and _G.table.sort or nil


local BoardIndex = zhopa.class("BoardIndex")
BoardIndex.__index = BoardIndex

local CLSID_LEVEL_CHANGER = tonumber(clsid and clsid.level_changer) or 94
local CLSID_LEVEL_CHANGER_S = tonumber(clsid and clsid.level_changer_s) or 95

local function get_board()
    return rawget(_G, "SIMBOARD")
end

local function is_valid_server_id(id)
    id = tonumber(id) or 0
    return id > 0 and id ~= 65535
end

local function safe_call(tag, fn, ...)
    local safe = zhopa and zhopa.safe
    if safe and safe.safe_call then
        return safe.safe_call(tag, fn, ...)
    end
    return pcall(fn, ...)
end

local BOARD_GVID_LEVEL_CACHE_MS = 1000
local board_gvid_level_cache = {}

local function now_level_name_by_gvid(gvid)
    gvid = tonumber(gvid) or nil
    if not (gvid and alife and game_graph) then
        return nil
    end
    local now = (time_global and time_global()) or 0
    local cached = board_gvid_level_cache[gvid]
    if type(cached) == "table" and now <= (tonumber(cached.tg) or 0) + BOARD_GVID_LEVEL_CACHE_MS then
        return cached.value
    end
    local ok, level_name = pcall(function()
        local gv = game_graph():vertex(gvid)
        if not gv then
            return nil
        end
        return alife():level_name(gv:level_id())
    end)
    if ok and type(level_name) == "string" and level_name ~= "" then
        board_gvid_level_cache[gvid] = { value = level_name, tg = now }
        return level_name
    end
    board_gvid_level_cache[gvid] = { value = nil, tg = now }
    return nil
end

local function ensure_level_set(map, level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return nil
    end
    local bucket = map[level_name]
    if type(bucket) ~= "table" then
        bucket = {}
        map[level_name] = bucket
    end
    return bucket
end

local function set_level_value(map, level_name, value)
    if value == nil then
        return false
    end
    local bucket = ensure_level_set(map, level_name)
    if type(bucket) ~= "table" then
        return false
    end
    if bucket[value] == true then
        return false
    end
    bucket[value] = true
    return true
end

local function unset_level_value(map, level_name, value)
    local bucket = map[level_name]
    if type(bucket) ~= "table" or value == nil or bucket[value] ~= true then
        return false
    end
    bucket[value] = nil
    if next(bucket) == nil then
        map[level_name] = nil
    end
    return true
end

local function build_sorted_bucket_array(bucket, numeric)
    local out = {}
    if type(bucket) ~= "table" then
        return out
    end
    for key, ok in pairs(bucket) do
        if ok == true then
            out[#out + 1] = key
        end
    end
    if table_sort then
        if numeric == true then
            table_sort(out, function(a, b)
                return (tonumber(a) or 0) < (tonumber(b) or 0)
            end)
        else
            table_sort(out, function(a, b)
                return tostring(a) < tostring(b)
            end)
        end
    end
    return out
end

local function config_ref()
    local cfg = zhopa and zhopa.config or nil
    if type(cfg) == "table" then
        return cfg
    end
    return nil
end

local function normalize_view_opts(opts_or_fn)
    if type(opts_or_fn) == "function" then
        return { filter_fn = opts_or_fn }
    end
    if type(opts_or_fn) == "table" then
        return opts_or_fn
    end
    return nil
end

local function smart_blacklists_rule(level_name)
    local cfg = config_ref()
    if not (cfg and cfg.get_smart_blacklists_rule) then
        return nil
    end
    local res = cfg.get_smart_blacklists_rule(level_name)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function smart_blacklists_global_set()
    local cfg = config_ref()
    if not (cfg and cfg.get_smart_blacklists_global_set) then
        return nil
    end
    local res = cfg.get_smart_blacklists_global_set()
    if type(res) == "table" then
        return res
    end
    return nil
end

local function faction_level_blacklists_rule(community)
    local cfg = config_ref()
    if not (cfg and cfg.get_faction_level_blacklist_rule) then
        return nil
    end
    local res = cfg.get_faction_level_blacklist_rule(community)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function is_level_globally_blacklisted(level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    local cfg = config_ref()
    if not (cfg and cfg.is_level_globally_blacklisted) then
        return false
    end
    return cfg.is_level_globally_blacklisted(level_name) == true
end

local function faction_smart_blacklists_rule(community)
    local cfg = config_ref()
    if not (cfg and cfg.get_faction_smart_blacklist_rule) then
        return nil
    end
    local res = cfg.get_faction_smart_blacklist_rule(community)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function section_level_blacklists_rule(section_name)
    local cfg = config_ref()
    if not (cfg and cfg.get_section_level_blacklist_rule) then
        return nil
    end
    local res = cfg.get_section_level_blacklist_rule(section_name)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function section_smart_blacklists_rule(section_name)
    local cfg = config_ref()
    if not (cfg and cfg.get_section_smart_blacklist_rule) then
        return nil
    end
    local res = cfg.get_section_smart_blacklist_rule(section_name)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function is_level_blacklisted_for_context(level_name, community, section_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    if is_level_globally_blacklisted(level_name) then
        return true
    end

    local rule = faction_level_blacklists_rule(community)
    if rule and rule.all == true then
        return true
    end
    local set = rule and rule.set or nil
    if set and set[level_name] then
        return true
    end

    local s_rule = section_level_blacklists_rule(section_name)
    if s_rule and s_rule.all == true then
        return true
    end
    local s_set = s_rule and s_rule.set or nil
    if s_set and s_set[level_name] then
        return true
    end

    return false
end

local function is_smart_blacklisted_for_context(level_name, smart_name, community, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    if is_level_blacklisted_for_context(level_name, community, section_name) then
        return true
    end

    local gset = smart_blacklists_global_set()
    if gset and gset[smart_name] then
        return true
    end

    local rule = smart_blacklists_rule(level_name)
    if rule and rule.all == true then
        return true
    end
    local set = rule and rule.set or nil
    if set and set[smart_name] then
        return true
    end

    local f_rule = faction_smart_blacklists_rule(community)
    if f_rule and f_rule.all == true then
        return true
    end
    local f_set = f_rule and f_rule.set or nil
    if f_set and f_set[smart_name] then
        return true
    end

    local s_rule = section_smart_blacklists_rule(section_name)
    if s_rule and s_rule.all == true then
        return true
    end
    local s_set = s_rule and s_rule.set or nil
    if s_set and s_set[smart_name] then
        return true
    end

    return false
end

local function merge_unique_arrays(primary, secondary)
    local out = {}
    local seen = {}

    local function append_from(src)
        for i = 1, (src and #src or 0) do
            local item = src[i]
            if item ~= nil and not seen[item] then
                seen[item] = true
                out[#out + 1] = item
            end
        end
    end

    append_from(primary)
    append_from(secondary)
    return out
end

local function append_level_edge(map, source_level, dest_level)
    if type(source_level) ~= "string" or source_level == "" then
        return
    end
    if type(dest_level) ~= "string" or dest_level == "" then
        return
    end
    if source_level == dest_level then
        return
    end
    local bucket = map[source_level]
    if type(bucket) ~= "table" then
        bucket = {}
        map[source_level] = bucket
    end
    bucket[dest_level] = true
end

local function edge_sets_to_arrays(src)
    local out = {}
    for level_name, set in pairs(src or {}) do
        if type(level_name) == "string" and level_name ~= "" and type(set) == "table" then
            local arr = {}
            for other_level, ok in pairs(set) do
                if ok == true and type(other_level) == "string" and other_level ~= "" then
                    arr[#arr + 1] = other_level
                end
            end
            if table_sort then
                table_sort(arr)
            end
            out[level_name] = arr
        end
    end
    return out
end

local function make_state_packet(sobj)
    if not (sobj and net_packet) then
        return nil
    end
    local ok, stpk = pcall(function()
        return net_packet()
    end)
    if not (ok and stpk and stpk.w_begin and stpk.r_seek and sobj.STATE_Write) then
        return nil
    end
    local ok_write = pcall(function()
        stpk:w_begin(0)
        sobj:STATE_Write(stpk)
        stpk:r_seek(2)
    end)
    if not ok_write then
        return nil
    end
    return stpk
end

local function skip_cse_alife_object_properties(stpk)
    if not stpk then
        return false
    end
    local ok = pcall(function()
        stpk:r_u16()
        stpk:r_float()
        stpk:r_s32()
        stpk:r_s32()
        stpk:r_s32()
        stpk:r_stringZ()
        stpk:r_s32()
        stpk:r_s32()
    end)
    return ok
end

local function skip_cse_shape_properties(stpk)
    if not stpk then
        return false
    end
    local ok = pcall(function()
        local shape_count = tonumber(stpk:r_u8()) or 0
        for _ = 1, shape_count do
            local shape_type = tonumber(stpk:r_u8()) or 0
            if shape_type == 0 then
                stpk:r_vec3()
                stpk:r_float()
            else
                stpk:r_vec3()
                stpk:r_vec3()
                stpk:r_vec3()
                stpk:r_vec3()
            end
        end
    end)
    return ok
end

local function skip_cse_alife_space_restrictor_properties(stpk)
    if not stpk then
        return false
    end
    local ok = pcall(function()
        stpk:r_u8()
    end)
    return ok
end

local utils_stpk_loaded = nil

local function get_utils_stpk()
    if utils_stpk_loaded ~= nil then
        return utils_stpk_loaded or nil
    end
    local mod = rawget(_G, "utils_stpk")
    if type(mod) ~= "table" and require then
        pcall(require, "utils_stpk")
        mod = rawget(_G, "utils_stpk")
    end
    utils_stpk_loaded = type(mod) == "table" and mod or false
    return utils_stpk_loaded or nil
end

local function get_level_changer_data_fallback(sobj)
    local stpk = make_state_packet(sobj)
    if not stpk then
        return nil
    end
    local ok = skip_cse_alife_object_properties(stpk)
        and skip_cse_shape_properties(stpk)
        and skip_cse_alife_space_restrictor_properties(stpk)
    if not ok then
        return nil
    end
    local out = {}
    local ok_parse = pcall(function()
        out.dest_game_vertex_id = stpk:r_u16()
        out.dest_level_vertex_id = stpk:r_s32()
        out.dest_position = stpk:r_vec3()
        out.dest_direction = stpk:r_vec3()
        out.dest_level_name = stpk:r_stringZ()
        out.dest_graph_point = stpk:r_stringZ()
        out.silent_mode = stpk:r_u8()
    end)
    return ok_parse and out or nil
end

local function get_level_changer_data(sobj)
    local utils = get_utils_stpk()
    if utils and utils.get_level_changer_data then
        local ok, data = pcall(utils.get_level_changer_data, sobj)
        if ok and type(data) == "table" then
            return data
        end
    end
    return get_level_changer_data_fallback(sobj)
end

local function is_base_smart(smart)
    local props = smart and smart.props or nil
    return type(props) == "table" and (tonumber(props.base) or 0) > 0
end

local function is_respawn_base_smart(smart)
    if not is_base_smart(smart) then
        return false
    end
    return smart.respawn_point == true and type(smart.respawn_params) == "table"
end

local function level_from_object(obj)
    if not obj then return nil end
    return now_level_name_by_gvid(tonumber(obj.m_game_vertex_id) or 0)
end

local function is_level_name(value)
    return type(value) == "string" and value ~= ""
end

local function object_name(obj)
    if not obj then
        return nil
    end
    local raw_name = obj.name
    if type(raw_name) == "string" and raw_name ~= "" then
        return raw_name
    end
    local ok_name, res_name = pcall(function()
        return obj:name()
    end)
    if ok_name and type(res_name) == "string" and res_name ~= "" then
        return res_name
    end
    return nil
end

local function create_runtime()
    return {
        smart_by_name = {},
        smarts_by_level = {},
        base_smarts_by_level = {},
        respawn_base_smarts_by_level = {},
        smart_level_by_name = {},
        smart_name_by_id = {},
        smart_revision_by_level = {},
        squad_revision_by_level = {},
        topology_revision_by_level = {},
        live_hydrated = false,
        squads_by_level = {},
        squad_level_by_id = {},
        neighbors_by_level = {},
        transition_edges_by_level = {},
        level_changer_edges_by_id = {},
        diag = {
            callback_hits = {},
            stats = {},
            failures = {},
            recent_squad_no_level = {},
            recent_squad_no_id = {},
            recent_smart_no_level = {},
            recent_smart_no_name = {},
            last_squad_upsert = nil,
            last_smart_upsert = nil,
            last_level_move = nil,
            last_register = nil,
            last_unregister = nil,
        },
        view_cache = {
            smarts_by_level = {},
            base_smarts_by_level = {},
            respawn_base_smarts_by_level = {},
            squads_by_level = {},
        },
    }
end

local function ensure_diag(runtime)
    if type(runtime) ~= "table" then
        return nil
    end
    local diag = runtime.diag
    if type(diag) ~= "table" then
        diag = {}
        runtime.diag = diag
    end
    if type(diag.callback_hits) ~= "table" then
        diag.callback_hits = {}
    end
    if type(diag.stats) ~= "table" then
        diag.stats = {}
    end
    if type(diag.failures) ~= "table" then
        diag.failures = {}
    end
    if type(diag.recent_squad_no_level) ~= "table" then
        diag.recent_squad_no_level = {}
    end
    if type(diag.recent_squad_no_id) ~= "table" then
        diag.recent_squad_no_id = {}
    end
    if type(diag.recent_smart_no_level) ~= "table" then
        diag.recent_smart_no_level = {}
    end
    if type(diag.recent_smart_no_name) ~= "table" then
        diag.recent_smart_no_name = {}
    end
    return diag
end

local function diag_inc(dst, key)
    if type(dst) ~= "table" or type(key) ~= "string" or key == "" then
        return
    end
    dst[key] = (tonumber(dst[key]) or 0) + 1
end

function BoardIndex:__init()
    self.RUNTIME = create_runtime()
end

function BoardIndex:_diag_callback(name)
    local diag = self.RUNTIME and self.RUNTIME.diag or nil
    if not (diag and type(diag.callback_hits) == "table") then
        return
    end
    diag_inc(diag.callback_hits, name)
end

function BoardIndex:_diag_stat(name)
    local diag = self.RUNTIME and self.RUNTIME.diag or nil
    if not (diag and type(diag.stats) == "table") then
        return
    end
    diag_inc(diag.stats, name)
end

function BoardIndex:_diag_fail(name)
    local diag = self.RUNTIME and self.RUNTIME.diag or nil
    if not (diag and type(diag.failures) == "table") then
        return
    end
    diag_inc(diag.failures, name)
end

function BoardIndex:_diag_last(name, payload)
    local diag = self.RUNTIME and self.RUNTIME.diag or nil
    if not diag or type(name) ~= "string" or name == "" then
        return
    end
    diag[name] = payload
end

function BoardIndex:_diag_push(list_name, payload, limit)
    local diag = ensure_diag(self.RUNTIME)
    if not diag or type(list_name) ~= "string" or list_name == "" then
        return
    end
    local list = diag[list_name]
    if type(list) ~= "table" then
        list = {}
        diag[list_name] = list
    end
    list[#list + 1] = payload
    limit = tonumber(limit) or 12
    while #list > limit do
        table.remove(list, 1)
    end
end

function BoardIndex:_resolve_squad_level(id, squad, fallback_ref)
    local level_name = level_from_object(squad)
    if is_level_name(level_name) then
        return level_name, "squad"
    end

    if type(fallback_ref) == "string" then
        if is_level_name(fallback_ref) then
            return fallback_ref, "fallback_level"
        end
    elseif fallback_ref ~= nil then
        local fallback_level = level_from_object(fallback_ref)
        if is_level_name(fallback_level) then
            return fallback_level, "fallback_object"
        end
    end

    local prev_level = self.RUNTIME.squad_level_by_id[tonumber(id) or -1]
    if is_level_name(prev_level) then
        return prev_level, "runtime_prev"
    end

    return nil, nil
end

function BoardIndex:_invalidate_view_cache(kind, level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return
    end
    local vc = self.RUNTIME.view_cache or nil
    if type(vc) ~= "table" then
        return
    end
    if kind == "squad" then
        local bucket = vc.squads_by_level
        if type(bucket) == "table" then
            bucket[level_name] = nil
        end
        return
    end
    for _, cache_name in pairs({
        "smarts_by_level",
        "base_smarts_by_level",
        "respawn_base_smarts_by_level",
    }) do
        local bucket = vc[cache_name]
        if type(bucket) == "table" then
            bucket[level_name] = nil
        end
    end
end

function BoardIndex:_bump_revision(kind, level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return
    end
    if kind == "topology" then
        local revs = self.RUNTIME.topology_revision_by_level
        revs[level_name] = (tonumber(revs[level_name]) or 0) + 1
        return
    end
    if kind == "squad" then
        local revs = self.RUNTIME.squad_revision_by_level
        revs[level_name] = (tonumber(revs[level_name]) or 0) + 1
        self:_invalidate_view_cache("squad", level_name)
        return
    end
    local revs = self.RUNTIME.smart_revision_by_level
    revs[level_name] = (tonumber(revs[level_name]) or 0) + 1
    self:_invalidate_view_cache("smart", level_name)
end

function BoardIndex:_mark_revision_union(kind, old_map, new_map)
    local marked = {}
    for level_name in pairs(old_map or {}) do
        if not marked[level_name] then
            marked[level_name] = true
            self:_bump_revision(kind, level_name)
        end
    end
    for level_name in pairs(new_map or {}) do
        if not marked[level_name] then
            marked[level_name] = true
            self:_bump_revision(kind, level_name)
        end
    end
end

function BoardIndex:_rebuild_neighbors()
    local neighbor_sets = {}
    local function merge_edges(src)
        for level_name, set in pairs(src or {}) do
            if type(level_name) == "string" and level_name ~= "" and type(set) == "table" then
                for other_level, ok in pairs(set) do
                    if ok == true and type(other_level) == "string" and other_level ~= "" and other_level ~= level_name then
                        append_level_edge(neighbor_sets, level_name, other_level)
                        append_level_edge(neighbor_sets, other_level, level_name)
                    end
                end
            end
        end
    end
    merge_edges(self.RUNTIME.transition_edges_by_level)
    local neighbors = edge_sets_to_arrays(neighbor_sets)
    self:_mark_revision_union("topology", self.RUNTIME.neighbors_by_level, neighbors)
    self.RUNTIME.neighbors_by_level = neighbors
end

function BoardIndex:_set_level_changer_entry(level_changer)
    local changer_id = tonumber(level_changer and level_changer.id) or nil
    if not changer_id then
        return false
    end
    local source_level = level_from_object(level_changer)
    local data = get_level_changer_data(level_changer)
    local dest_level = type(data) == "table" and data.dest_level_name or nil
    if type(source_level) ~= "string" or source_level == "" then
        return false
    end
    if type(dest_level) ~= "string" or dest_level == "" then
        return false
    end
    if source_level == dest_level then
        return false
    end

    local prev = self.RUNTIME.level_changer_edges_by_id[changer_id]
    if type(prev) == "table" then
        local old_source = prev.source_level
        local old_dest = prev.dest_level
        local bucket = self.RUNTIME.transition_edges_by_level[old_source]
        if type(bucket) == "table" then
            bucket[old_dest] = nil
            if next(bucket) == nil then
                self.RUNTIME.transition_edges_by_level[old_source] = nil
            end
        end
    end

    append_level_edge(self.RUNTIME.transition_edges_by_level, source_level, dest_level)
    self.RUNTIME.level_changer_edges_by_id[changer_id] = {
        source_level = source_level,
        dest_level = dest_level,
    }
    self:_rebuild_neighbors()
    return true
end

function BoardIndex:_remove_level_changer_entry(level_changer)
    local changer_id = tonumber(level_changer and level_changer.id or level_changer) or nil
    if not changer_id then
        return false
    end
    local prev = self.RUNTIME.level_changer_edges_by_id[changer_id]
    self.RUNTIME.level_changer_edges_by_id[changer_id] = nil
    if type(prev) ~= "table" then
        return false
    end
    local bucket = self.RUNTIME.transition_edges_by_level[prev.source_level]
    if type(bucket) == "table" then
        bucket[prev.dest_level] = nil
        if next(bucket) == nil then
            self.RUNTIME.transition_edges_by_level[prev.source_level] = nil
        end
    end
    self:_rebuild_neighbors()
    return true
end

function BoardIndex:_upsert_smart_from_object(smart, source)
    local smart_name = object_name(smart)
    if type(smart_name) ~= "string" or smart_name == "" then
        self:_diag_fail("upsert_smart:no_name")
        self:_diag_fail("upsert_smart:no_name:" .. tostring(source or "-"))
        self:_diag_push("recent_smart_no_name", {
            source = source,
            smart_id = tonumber(smart and smart.id) or nil,
            gvid = tonumber(smart and smart.m_game_vertex_id) or nil,
        }, 16)
        self:_diag_last("last_smart_upsert", {
            source = source,
            result = "no_name",
            smart_id = tonumber(smart and smart.id) or nil,
            gvid = tonumber(smart and smart.m_game_vertex_id) or nil,
        })
        return false
    end

    local prev = self.RUNTIME.smart_by_name[smart_name]
    local next_gvid = tonumber(smart and smart.m_game_vertex_id) or tonumber(prev and prev.gvid) or nil
    local next_level = next_gvid and now_level_name_by_gvid(next_gvid) or (prev and prev.level) or nil
    if type(next_level) ~= "string" or next_level == "" then
        self:_diag_fail("upsert_smart:no_level")
        self:_diag_fail("upsert_smart:no_level:" .. tostring(source or "-"))
        self:_diag_push("recent_smart_no_level", {
            source = source,
            smart_name = smart_name,
            smart_id = tonumber(smart and smart.id) or tonumber(prev and prev.id) or nil,
            gvid = next_gvid,
        }, 16)
        self:_diag_last("last_smart_upsert", {
            source = source,
            result = "no_level",
            smart_name = smart_name,
            smart_id = tonumber(smart and smart.id) or tonumber(prev and prev.id) or nil,
            gvid = next_gvid,
        })
        return false
    end

    local has_props = type(smart and smart.props) == "table"
    local has_respawn_meta = smart and (smart.respawn_point ~= nil or smart.respawn_params ~= nil) or false
    local next_is_base = has_props and is_base_smart(smart) or (prev and prev.is_base == true) or false
    local next_is_respawn_base = (has_props or has_respawn_meta) and is_respawn_base_smart(smart) or (prev and prev.is_respawn_base == true) or false
    local next_id = tonumber(smart and smart.id) or tonumber(prev and prev.id) or nil

    local old_level = prev and prev.level or nil
    local old_id = tonumber(prev and prev.id) or nil
    local old_is_base = prev and prev.is_base == true or false
    local old_is_respawn_base = prev and prev.is_respawn_base == true or false

    if prev
        and old_id == next_id
        and old_level == next_level
        and tonumber(prev.gvid) == next_gvid
        and old_is_base == (next_is_base == true)
        and old_is_respawn_base == (next_is_respawn_base == true)
    then
        return false
    end

    local changed_old_level = false
    local changed_new_level = false

    if old_id and old_id ~= next_id and self.RUNTIME.smart_name_by_id[old_id] == smart_name then
        self.RUNTIME.smart_name_by_id[old_id] = nil
    end

    if type(old_level) == "string" and old_level ~= "" and old_level ~= next_level then
        changed_old_level = unset_level_value(self.RUNTIME.smarts_by_level, old_level, smart_name) or changed_old_level
        changed_old_level = unset_level_value(self.RUNTIME.base_smarts_by_level, old_level, smart_name) or changed_old_level
        changed_old_level = unset_level_value(self.RUNTIME.respawn_base_smarts_by_level, old_level, smart_name) or changed_old_level
    elseif old_level == next_level then
        if old_is_base ~= next_is_base then
            if next_is_base then
                changed_new_level = set_level_value(self.RUNTIME.base_smarts_by_level, next_level, smart_name) or changed_new_level
            else
                changed_new_level = unset_level_value(self.RUNTIME.base_smarts_by_level, next_level, smart_name) or changed_new_level
            end
        end
        if old_is_respawn_base ~= next_is_respawn_base then
            if next_is_respawn_base then
                changed_new_level = set_level_value(self.RUNTIME.respawn_base_smarts_by_level, next_level, smart_name) or changed_new_level
            else
                changed_new_level = unset_level_value(self.RUNTIME.respawn_base_smarts_by_level, next_level, smart_name) or changed_new_level
            end
        end
    end

    changed_new_level = set_level_value(self.RUNTIME.smarts_by_level, next_level, smart_name) or changed_new_level
    if next_is_base then
        changed_new_level = set_level_value(self.RUNTIME.base_smarts_by_level, next_level, smart_name) or changed_new_level
    else
        changed_new_level = unset_level_value(self.RUNTIME.base_smarts_by_level, next_level, smart_name) or changed_new_level
    end
    if next_is_respawn_base then
        changed_new_level = set_level_value(self.RUNTIME.respawn_base_smarts_by_level, next_level, smart_name) or changed_new_level
    else
        changed_new_level = unset_level_value(self.RUNTIME.respawn_base_smarts_by_level, next_level, smart_name) or changed_new_level
    end

    self.RUNTIME.smart_by_name[smart_name] = {
        id = next_id,
        level = next_level,
        gvid = next_gvid,
        is_base = next_is_base == true,
        is_respawn_base = next_is_respawn_base == true,
        last_source = type(source) == "string" and source or nil,
    }
    self.RUNTIME.smart_level_by_name[smart_name] = next_level
    if next_id then
        self.RUNTIME.smart_name_by_id[next_id] = smart_name
    end

    if changed_old_level and old_level and old_level ~= next_level then
        self:_bump_revision("smart", old_level)
    end
    if changed_new_level then
        self:_bump_revision("smart", next_level)
    end
    self:_diag_stat("upsert_smart:ok")
    self:_diag_last("last_smart_upsert", {
        source = source,
        result = "ok",
        smart_name = smart_name,
        smart_id = next_id,
        gvid = next_gvid,
        level = next_level,
        is_base = next_is_base == true,
        is_respawn_base = next_is_respawn_base == true,
    })
    return true
end

function BoardIndex:_remove_smart_by_name(smart_name, source)
    if type(smart_name) ~= "string" or smart_name == "" then
        self:_diag_fail("remove_smart:bad_name")
        return false
    end
    local prev = self.RUNTIME.smart_by_name[smart_name]
    self.RUNTIME.smart_by_name[smart_name] = nil
    local level_name = type(prev) == "table" and prev.level or self.RUNTIME.smart_level_by_name[smart_name]
    local smart_id = tonumber(type(prev) == "table" and prev.id or nil) or nil
    self.RUNTIME.smart_level_by_name[smart_name] = nil
    if smart_id and self.RUNTIME.smart_name_by_id[smart_id] == smart_name then
        self.RUNTIME.smart_name_by_id[smart_id] = nil
    else
        for id, name in pairs(self.RUNTIME.smart_name_by_id or {}) do
            if name == smart_name then
                self.RUNTIME.smart_name_by_id[id] = nil
            end
        end
    end

    local changed = false
    if type(level_name) == "string" and level_name ~= "" then
        changed = unset_level_value(self.RUNTIME.smarts_by_level, level_name, smart_name) or changed
        changed = unset_level_value(self.RUNTIME.base_smarts_by_level, level_name, smart_name) or changed
        changed = unset_level_value(self.RUNTIME.respawn_base_smarts_by_level, level_name, smart_name) or changed
        if changed then
            self:_bump_revision("smart", level_name)
        end
    end
    if changed then
        self:_diag_stat("remove_smart:ok")
    else
        self:_diag_fail("remove_smart:miss")
    end
    return changed
end

function BoardIndex:_upsert_squad_from_object(sid, squad, source, fallback_ref)
    local id = tonumber(sid or (squad and squad.id)) or nil
    if not id then
        self:_diag_fail("upsert_squad:no_id")
        self:_diag_fail("upsert_squad:no_id:" .. tostring(source or "-"))
        self:_diag_push("recent_squad_no_id", {
            source = source,
            sid = tonumber(sid) or nil,
            name = object_name(squad),
            gvid = tonumber(squad and squad.m_game_vertex_id) or nil,
            smart_id = tonumber(squad and squad.smart_id) or nil,
        }, 16)
        self:_diag_last("last_squad_upsert", {
            source = source,
            result = "no_id",
            gvid = tonumber(squad and squad.m_game_vertex_id) or nil,
        })
        return false
    end
    local level_name, level_source = self:_resolve_squad_level(id, squad, fallback_ref)
    if not is_level_name(level_name) then
        self:_diag_fail("upsert_squad:no_level")
        self:_diag_fail("upsert_squad:no_level:" .. tostring(source or "-"))
        self:_diag_push("recent_squad_no_level", {
            source = source,
            sid = id,
            name = object_name(squad),
            gvid = tonumber(squad and squad.m_game_vertex_id) or nil,
            smart_id = tonumber(squad and squad.smart_id) or nil,
        }, 16)
        self:_diag_last("last_squad_upsert", {
            source = source,
            result = "no_level",
            sid = id,
            name = object_name(squad),
            gvid = tonumber(squad and squad.m_game_vertex_id) or nil,
            smart_id = tonumber(squad and squad.smart_id) or nil,
        })
        return false
    end
    local prev_level = self.RUNTIME.squad_level_by_id[id]
    local changed_old_level = false
    local changed_new_level = false
    if type(prev_level) == "string" and prev_level ~= "" and prev_level ~= level_name then
        changed_old_level = unset_level_value(self.RUNTIME.squads_by_level, prev_level, id) or changed_old_level
    end
    changed_new_level = set_level_value(self.RUNTIME.squads_by_level, level_name, id) or changed_new_level
    self.RUNTIME.squad_level_by_id[id] = level_name
    if changed_old_level and prev_level and prev_level ~= level_name then
        self:_bump_revision("squad", prev_level)
    end
    if changed_new_level then
        self:_bump_revision("squad", level_name)
    end
    self:_diag_stat("upsert_squad:ok")
    self:_diag_last("last_squad_upsert", {
        source = source,
        result = "ok",
        sid = id,
        gvid = tonumber(squad and squad.m_game_vertex_id) or nil,
        smart_id = tonumber(squad and squad.smart_id) or nil,
        level = level_name,
        level_source = level_source,
    })
    return true
end

function BoardIndex:_remove_squad_by_id(sid, source)
    local id = tonumber(sid) or nil
    if not id then
        self:_diag_fail("remove_squad:no_id")
        return false
    end
    local level_name = self.RUNTIME.squad_level_by_id[id]
    self.RUNTIME.squad_level_by_id[id] = nil
    if type(level_name) ~= "string" or level_name == "" then
        self:_diag_fail("remove_squad:no_level")
        return false
    end
    local changed = unset_level_value(self.RUNTIME.squads_by_level, level_name, id)
    if changed then
        self:_bump_revision("squad", level_name)
        self:_diag_stat("remove_squad:ok")
    else
        self:_diag_fail("remove_squad:miss")
    end
    return changed
end

function BoardIndex:_move_squad_level(sid, new_level, source)
    local id = tonumber(sid) or nil
    local level_name = type(new_level) == "string" and new_level ~= "" and new_level or nil
    if not id or not level_name then
        self:_diag_fail("move_squad:bad_args")
        self:_diag_last("last_level_move", {
            source = source,
            result = "bad_args",
            sid = id,
            level = level_name,
        })
        return false
    end
    local prev_level = self.RUNTIME.squad_level_by_id[id]
    local changed_old_level = false
    local changed_new_level = false
    if type(prev_level) == "string" and prev_level ~= "" and prev_level ~= level_name then
        changed_old_level = unset_level_value(self.RUNTIME.squads_by_level, prev_level, id) or changed_old_level
    end
    changed_new_level = set_level_value(self.RUNTIME.squads_by_level, level_name, id) or changed_new_level
    self.RUNTIME.squad_level_by_id[id] = level_name
    if changed_old_level and prev_level and prev_level ~= level_name then
        self:_bump_revision("squad", prev_level)
    end
    if changed_new_level then
        self:_bump_revision("squad", level_name)
    end
    if changed_old_level or changed_new_level then
        self:_diag_stat("move_squad:ok")
    else
        self:_diag_fail("move_squad:no_change")
    end
    self:_diag_last("last_level_move", {
        source = source,
        result = (changed_old_level or changed_new_level) and "ok" or "no_change",
        sid = id,
        prev_level = prev_level,
        level = level_name,
    })
    return changed_old_level or changed_new_level
end

function BoardIndex:_on_server_entity_register(se_obj, type_name)
    self:_diag_callback("server_entity_on_register")
    self:_diag_callback("server_entity_on_register:" .. tostring(type_name or "-"))
    self:_diag_last("last_register", {
        type_name = type_name,
        id = tonumber(se_obj and se_obj.id) or nil,
        name = object_name(se_obj),
        gvid = tonumber(se_obj and se_obj.m_game_vertex_id) or nil,
    })
    if type(type_name) ~= "string" then return end
    if type_name == "se_smart_terrain" and se_obj then
        self:_upsert_smart_from_object(se_obj, "server_entity_on_register")
    elseif (type_name == "se_level_changer" or type_name == "level_changer" or type_name == "level_changer_s") and se_obj then
        local ok_class, class_id = safe_call("se_level_changer:clsid", function()
            return se_obj:clsid()
        end)
        class_id = ok_class and tonumber(class_id) or nil
        if class_id == CLSID_LEVEL_CHANGER or class_id == CLSID_LEVEL_CHANGER_S or class_id == nil then
            self:_set_level_changer_entry(se_obj)
        end
    end
end

function BoardIndex:_on_server_entity_unregister(se_obj, type_name)
    self:_diag_callback("server_entity_on_unregister")
    self:_diag_callback("server_entity_on_unregister:" .. tostring(type_name or "-"))
    self:_diag_last("last_unregister", {
        type_name = type_name,
        id = tonumber(se_obj and se_obj.id) or nil,
        name = object_name(se_obj),
        gvid = tonumber(se_obj and se_obj.m_game_vertex_id) or nil,
    })
    if type(type_name) ~= "string" then return end
    if type_name == "se_smart_terrain" and se_obj then
        self:_remove_smart_by_name(object_name(se_obj), "server_entity_on_unregister")
    elseif (type_name == "se_level_changer" or type_name == "level_changer" or type_name == "level_changer_s") and se_obj then
        self:_remove_level_changer_entry(se_obj)
    elseif type_name == "sim_squad_scripted" and se_obj then
        self:_remove_squad_by_id(se_obj.id, "server_entity_on_unregister")
    end
end

function BoardIndex:_on_squad_first_update(squad)
    self:_diag_callback("squad_on_first_update")
    self:_upsert_squad_from_object(squad and squad.id or nil, squad, "squad_on_first_update")
end

function BoardIndex:_on_squad_update(squad, entry, changed)
    local sid = tonumber(squad and squad.id) or tonumber(type(entry) == "table" and entry.squad_id or nil) or nil
    if changed ~= true and type(entry) == "table" then
        local dirty = entry.dirty
        if type(dirty) == "table"
            and dirty.level ~= true
            and dirty.smart ~= true
            and dirty.identity ~= true
        then
            return
        end
    end
    local level_name = type(entry) == "table" and entry.level or nil
    if not is_level_name(level_name) then
        level_name = now_level_name_by_gvid(tonumber(squad and squad.m_game_vertex_id) or 0)
    end
    if sid and level_name and self.RUNTIME.squad_level_by_id[sid] == level_name then
        return
    end
    self:_diag_callback("squad_on_update")
    self:_upsert_squad_from_object(sid, squad, "squad_on_update")
end

function BoardIndex:_on_squad_enter_smart(squad, smart)
    self:_diag_callback("squad_on_enter_smart")
    self:_upsert_squad_from_object(squad and squad.id or nil, squad, "squad_on_enter_smart", smart)
    self:_upsert_smart_from_object(smart, "squad_on_enter_smart")
end

function BoardIndex:_on_squad_leave_smart(squad, smart)
    self:_diag_callback("squad_on_leave_smart")
    self:_upsert_squad_from_object(squad and squad.id or nil, squad, "squad_on_leave_smart", smart)
    self:_upsert_smart_from_object(smart, "squad_on_leave_smart")
end

function BoardIndex:_on_squad_after_level_change(squad, old_level, new_level)
    self:_diag_callback("squad_on_after_level_change")
    local sid = squad and squad.id or nil
    if sid then
        local level_name = type(new_level) == "string" and new_level ~= "" and new_level or level_from_object(squad)
        if type(level_name) == "string" and level_name ~= "" then
            self:_move_squad_level(sid, level_name, "squad_on_after_level_change")
        end
    end
end

function BoardIndex:_on_smart_terrain_update(smart)
    self:_diag_callback("smart_terrain_on_update")
    self:_upsert_smart_from_object(smart, "smart_terrain_on_update")
end

function BoardIndex:_on_bootstrap()
    self:_diag_callback("bootstrap")
    self:_hydrate_live_runtime("bootstrap")
    if next(self.RUNTIME.neighbors_by_level or {}) == nil
        and next(self.RUNTIME.transition_edges_by_level or {}) ~= nil
    then
        self:_rebuild_neighbors()
    end
end

function BoardIndex:_hydrate_live_runtime(source)
    if self.RUNTIME.live_hydrated == true then
        return false
    end

    local board = get_board()
    if not board then
        return false
    end

    local hydrated_any = false

    local smarts_by_names = board.smarts_by_names
    if type(smarts_by_names) == "table" then
        for _, smart in pairs(smarts_by_names) do
            if smart and self:_upsert_smart_from_object(smart, source or "hydrate_runtime") then
                hydrated_any = true
            end
        end
    end

    local squads = board.squads
    if type(squads) == "table" then
        for sid_key, squad_ref in pairs(squads) do
            local sid = tonumber(sid_key) or tonumber(type(squad_ref) == "table" and squad_ref.id or nil)
            local squad = type(squad_ref) == "table" and squad_ref or nil
            if is_valid_server_id(sid) and not squad then
                local ok_obj, se_squad = pcall(function()
                    local sim = alife and alife() or nil
                    return sim and sim:object(sid) or nil
                end)
                squad = ok_obj and se_squad or nil
            end
            if is_valid_server_id(sid) and squad and self:_upsert_squad_from_object(sid, squad, source or "hydrate_runtime") then
                hydrated_any = true
            end
        end
    end

    local sim_objs = rawget(_G, "simulation_objects")
    local registry = sim_objs and sim_objs.object_registry or nil
    local registry_size = tonumber(sim_objs and sim_objs.object_registry_size) or 0
    if type(registry) == "table" and registry_size > 0 then
        for i = 1, registry_size do
            local se_obj = registry[i]
            if se_obj then
                local ok_class, class_id = safe_call("hydrate_level_changer:clsid", function()
                    return se_obj:clsid()
                end)
                class_id = ok_class and tonumber(class_id) or nil
                if class_id == CLSID_LEVEL_CHANGER or class_id == CLSID_LEVEL_CHANGER_S then
                    if self:_set_level_changer_entry(se_obj) then
                        hydrated_any = true
                    end
                end
            end
        end
    end

    self.RUNTIME.live_hydrated = true
    return hydrated_any
end

function BoardIndex:_materialize_level_bucket(cache_name, revision_kind, map, level_name, numeric)
    if type(level_name) ~= "string" or level_name == "" then
        return {}
    end
    local vc = self.RUNTIME.view_cache or {}
    local group = vc[cache_name]
    if type(group) ~= "table" then
        group = {}
        vc[cache_name] = group
        self.RUNTIME.view_cache = vc
    end
    local rev_map = revision_kind == "squad" and self.RUNTIME.squad_revision_by_level or self.RUNTIME.smart_revision_by_level
    local rev = tonumber(rev_map[level_name]) or 0
    local cached = group[level_name]
    if type(cached) == "table" and tonumber(cached.rev) == rev and type(cached.items) == "table" then
        return cached.items
    end
    local items = build_sorted_bucket_array(map[level_name], numeric == true)
    group[level_name] = { rev = rev, items = items }
    return items
end

function BoardIndex:_filter_level_smart_view(level_name, list, opts_or_fn)
    local opts = normalize_view_opts(opts_or_fn)
    if type(list) ~= "table" then
        return {}
    end
    if not opts then
        return list
    end

    local community = opts.community
    local section_name = opts.section_name
    local filter_fn = type(opts.filter_fn) == "function" and opts.filter_fn or nil
    if is_level_blacklisted_for_context(level_name, community, section_name) then
        return {}
    end

    local out = {}
    local out_n = 0
    for i = 1, #list do
        local smart_name = list[i]
        if type(smart_name) == "string"
            and smart_name ~= ""
            and (not is_smart_blacklisted_for_context(level_name, smart_name, community, section_name))
        then
            local keep = true
            if filter_fn then
                local ok_call, res = pcall(filter_fn, smart_name, level_name)
                keep = ok_call and res == true or false
            end
            if keep then
                out_n = out_n + 1
                out[out_n] = smart_name
            end
        end
    end
    return out
end

function BoardIndex:_get_level_smarts(level_name, opts_or_fn)
    local runtime_list = self:_materialize_level_bucket("smarts_by_level", "smart", self.RUNTIME.smarts_by_level, level_name, false)
    local cfg = config_ref()
    local cfg_list = cfg and cfg.get_level_smarts and cfg.get_level_smarts(level_name) or nil
    local merged = merge_unique_arrays(cfg_list, runtime_list)
    return self:_filter_level_smart_view(level_name, merged, opts_or_fn)
end

function BoardIndex:_get_base_smarts(level_name, opts_or_fn)
    local runtime_list = self:_materialize_level_bucket("base_smarts_by_level", "smart", self.RUNTIME.base_smarts_by_level, level_name, false)
    local cfg = config_ref()
    local cfg_list = cfg and cfg.get_level_bases and cfg.get_level_bases(level_name) or nil
    local merged = merge_unique_arrays(cfg_list, runtime_list)
    return self:_filter_level_smart_view(level_name, merged, opts_or_fn)
end

function BoardIndex:_get_respawn_base_smarts(level_name, opts_or_fn)
    local runtime_list = self:_materialize_level_bucket("respawn_base_smarts_by_level", "smart", self.RUNTIME.respawn_base_smarts_by_level, level_name, false)
    return self:_filter_level_smart_view(level_name, runtime_list, opts_or_fn)
end

function BoardIndex:_get_level_squads(level_name)
    return self:_materialize_level_bucket("squads_by_level", "squad", self.RUNTIME.squads_by_level, level_name, true)
end

function BoardIndex:_get_known_smart_levels()
    local out = {}
    for level_name in pairs(self.RUNTIME and self.RUNTIME.smarts_by_level or {}) do
        if type(level_name) == "string" and level_name ~= "" then
            out[#out + 1] = level_name
        end
    end
    if table_sort then
        table_sort(out)
    end
    return out
end

function BoardIndex:_get_smart_level(smart_name)
    return self.RUNTIME.smart_level_by_name[type(smart_name) == "string" and smart_name or ""] or nil
end

function BoardIndex:_get_smart_name_by_id(smart_id)
    return self.RUNTIME.smart_name_by_id[tonumber(smart_id) or -1] or nil
end

function BoardIndex:_get_level_neighbors(level_name, opts_or_fn)
    local list = self.RUNTIME.neighbors_by_level[type(level_name) == "string" and level_name or ""] or {}
    local opts = normalize_view_opts(opts_or_fn)
    if not opts then
        return list
    end

    local community = opts.community
    local section_name = opts.section_name
    local filter_fn = type(opts.filter_fn) == "function" and opts.filter_fn or nil
    local out = {}
    local out_n = 0
    for i = 1, #list do
        local neighbor = list[i]
        local ok = type(neighbor) == "string"
            and neighbor ~= ""
            and (not is_level_blacklisted_for_context(neighbor, community, section_name))
        if ok and filter_fn then
            local ok_call, res = pcall(filter_fn, neighbor, level_name)
            ok = ok_call and res == true or false
        end
        if ok then
            out_n = out_n + 1
            out[out_n] = neighbor
        end
    end
    return out
end

function BoardIndex:_get_topology_revision(level_name)
    return tonumber(self.RUNTIME.topology_revision_by_level[type(level_name) == "string" and level_name or ""]) or 0
end

function BoardIndex:_get_smart_revision(level_name)
    return tonumber(self.RUNTIME.smart_revision_by_level[type(level_name) == "string" and level_name or ""]) or 0
end

local inst = BoardIndex.new and BoardIndex.new() or setmetatable({}, BoardIndex)
if not inst.RUNTIME then
    BoardIndex.__init(inst)
end

inst.on_actor_first_update = function() return inst:_on_bootstrap() end
inst.on_load_state = function() return inst:_on_bootstrap() end
inst.on_server_entity_register = function(se_obj, type_name) return inst:_on_server_entity_register(se_obj, type_name) end
inst.on_server_entity_unregister = function(se_obj, type_name) return inst:_on_server_entity_unregister(se_obj, type_name) end
inst.on_smart_terrain_update = function(smart) return inst:_on_smart_terrain_update(smart) end
inst.on_squad_first_update = function(squad) return inst:_on_squad_first_update(squad) end
inst.on_squad_update = function(squad) return inst:_on_squad_update(squad) end
inst.on_squad_enter_smart = function(squad, smart) return inst:_on_squad_enter_smart(squad, smart) end
inst.on_squad_leave_smart = function(squad, smart) return inst:_on_squad_leave_smart(squad, smart) end
inst.on_squad_after_level_change = function(squad, old_level, new_level) return inst:_on_squad_after_level_change(squad, old_level, new_level) end
inst.get_level_smarts = function(level_name, opts_or_fn) return inst:_get_level_smarts(level_name, opts_or_fn) end
inst.get_base_smarts = function(level_name, opts_or_fn) return inst:_get_base_smarts(level_name, opts_or_fn) end
inst.get_respawn_base_smarts = function(level_name, opts_or_fn) return inst:_get_respawn_base_smarts(level_name, opts_or_fn) end
inst.get_known_smart_levels = function() return inst:_get_known_smart_levels() end
inst.get_level_squads = function(level_name) return inst:_get_level_squads(level_name) end
inst.get_smart_level = function(smart_name) return inst:_get_smart_level(smart_name) end
inst.get_smart_name_by_id = function(smart_id) return inst:_get_smart_name_by_id(smart_id) end
inst.get_level_neighbors = function(level_name, opts_or_fn) return inst:_get_level_neighbors(level_name, opts_or_fn) end
inst.get_topology_revision = function(level_name) return inst:_get_topology_revision(level_name) end
inst.get_smart_revision = function(level_name) return inst:_get_smart_revision(level_name) end

zhopa.board_index = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_board_index

-- BEGIN module zhopa_npc_faction_override
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local tostring = _G.tostring
local tonumber = _G.tonumber
local rawget = _G.rawget
local pairs = _G.pairs
local next = _G.next
local alife = _G.alife
local db = _G.db
local level = _G.level

local COMMUNITY_SET = {
    stalker = true,
    bandit = true,
    csky = true,
    army = true,
    dolg = true,
    freedom = true,
    ecolog = true,
    killer = true,
    monolith = true,
    trader = true,
    zombied = true,
    greh = true,
    isg = true,
    renegade = true,
}

local RUNTIME = {
    enabled_prev = false,
    first_update_done = false,
    applied_squads = {},
    applied_members = {},
    warned_invalid_factions = {},
}

local function reset_runtime(reason)
    RUNTIME.applied_squads = {}
    RUNTIME.applied_members = {}
    if zhopa and zhopa.log and zhopa.log.debug then
        zhopa.log.debug("NPC_FACTION", "RESET_RUNTIME reason=%s", tostring(reason or "-"))
    end
end

local function safe_call(tag, fn, ...)
    local safe = zhopa and zhopa.safe
    if safe and safe.safe_call then
        return safe.safe_call(tag, fn, ...)
    end
    return pcall(fn, ...)
end

local function log_info(fmt, ...)
    if zhopa and zhopa.log and zhopa.log.info then
        zhopa.log.info("NPC_FACTION", fmt, ...)
    end
end

local function log_warn(fmt, ...)
    if zhopa and zhopa.log and zhopa.log.warn then
        zhopa.log.warn("NPC_FACTION", fmt, ...)
    end
end

local function log_debug(fmt, ...)
    if zhopa and zhopa.log and zhopa.log.debug then
        zhopa.log.debug("NPC_FACTION", fmt, ...)
    end
end

local function get_board()
    return rawget(_G, "SIMBOARD")
end


local function is_valid_server_id(id)
    id = tonumber(id) or 0
    return id > 0 and id ~= 65535
end

local function feature_enabled()
    local sw = zhopa and zhopa.switches or nil
    if not (sw and sw.npc_faction_override == true) then
        return false
    end

    local cfg = zhopa and zhopa.config
    if not (cfg and cfg.get) then
        return false
    end

    if cfg.get("enabled", true) ~= true then
        return false
    end

    return cfg.get("npc_faction_override_enabled", false) == true
end

local function get_override_map()
    local cfg = zhopa and zhopa.config
    if not (cfg and cfg.get_section_kv_map) then
        return {}
    end
    return cfg.get_section_kv_map("npc_faction_override") or {}
end

local function get_online_object(npc_id)
    local storage = db and db.storage and db.storage[npc_id] or nil
    if storage and storage.object then
        return storage.object
    end
    if level and level.object_by_id then
        local ok_obj, obj = safe_call("level.object_by_id", level.object_by_id, npc_id)
        if ok_obj then
            return obj
        end
    end
    return nil
end

local function get_override_for_squad(se_squad, override_map)
    if not se_squad then
        return nil, nil
    end
    local ok_section, squad_section = safe_call("se_squad:section_name", function()
        return se_squad:section_name()
    end)
    if not (ok_section and type(squad_section) == "string" and squad_section ~= "") then
        return nil, nil
    end
    local target_faction = type(override_map) == "table" and override_map[squad_section] or nil
    return squad_section, target_faction
end

local function apply_member_faction(sim, npc_id, target_faction)
    local npc = get_online_object(npc_id)
    if not npc then
        log_debug("MEMBER_OFFLINE npc_id=%s faction=%s", tostring(npc_id), tostring(target_faction))
        return false
    end

    local ok_alive, alive = safe_call("npc:alive", function() return npc:alive() end)
    if not (ok_alive and alive == true) then
        return false
    end

    local ok_comm, current_comm = safe_call("npc:character_community", function() return npc:character_community() end)
    if ok_comm and current_comm == target_faction then
        RUNTIME.applied_members[npc_id] = target_faction
        return false
    end

    local se_member = nil
    local ok_se, res_se = false, nil
    if is_valid_server_id(npc_id) then
        ok_se, res_se = safe_call("alife:object(member)", function() return sim:object(npc_id) end)
    end
    if ok_se then
        se_member = res_se
    end

    local current_squad = se_member and tonumber(se_member.squad) or 0
    local current_group = se_member and tonumber(se_member.group) or 0

    local ok_apply = safe_call(
        "npc:set_character_community",
        function()
            npc:set_character_community(target_faction, current_squad or 0, current_group or 0)
        end
    )
    if not ok_apply then
        return false
    end

    RUNTIME.applied_members[npc_id] = target_faction
    return true
end

local function apply_squad_override(sim, se_squad, override_map, reason)
    if not (sim and se_squad and type(override_map) == "table") then
        return false, 0, nil
    end
    local squad_section, target_faction = get_override_for_squad(se_squad, override_map)
    if not (squad_section and target_faction) then
        return false, 0, squad_section
    end
    if not COMMUNITY_SET[target_faction] then
        if not RUNTIME.warned_invalid_factions[target_faction] then
            RUNTIME.warned_invalid_factions[target_faction] = true
            log_warn("INVALID_FACTION squad=%s faction=%s", tostring(squad_section), tostring(target_faction))
        end
        return false, 0, squad_section
    end

    local updated_squad = false
    if se_squad.player_id ~= target_faction then
        local ok_set = safe_call("se_squad.player_id", function()
            se_squad.player_id = target_faction
        end)
        if ok_set then
            updated_squad = true
        end
    end

    local updated_members = 0
    local ok_members = safe_call("se_squad:squad_members", function() return se_squad:squad_members() end)
    if ok_members then
        for member in se_squad:squad_members() do
            local npc_id = member and member.id or nil
            if npc_id and apply_member_faction(sim, npc_id, target_faction) then
                updated_members = updated_members + 1
            end
        end
    end

    local squad_id = tonumber(se_squad.id) or nil
    if squad_id then
        RUNTIME.applied_squads[squad_id] = target_faction
    end

    if updated_squad or updated_members > 0 then
        log_debug(
            "APPLY reason=%s squad=%s faction=%s squad_changed=%s members=%s",
            tostring(reason or "-"),
            tostring(squad_section),
            tostring(target_faction),
            tostring(updated_squad),
            tostring(updated_members)
        )
    end

    return updated_squad, updated_members, squad_section
end

local function apply_existing_squads(reason)
    local sim = alife and alife() or nil
    if not sim then
        return
    end

    local override_map = get_override_map()
    local configured = 0
    for _ in pairs(override_map) do
        configured = configured + 1
    end
    if configured == 0 then
        if reason == "first_update" or reason == "load_state" then
            log_info("HYDRATION_DONE reason=%s configured=0 squads=0 members=0", tostring(reason))
        end
        return
    end

    local matched_sections = {}
    local updated_squads = 0
    local updated_members = 0
    local seen_sids = {}
    local board_index = zhopa and zhopa.board_index or nil
    local levels = board_index and board_index.get_known_smart_levels and board_index.get_known_smart_levels() or {}
    local used_index = false

    for i = 1, #levels do
        local list = board_index and board_index.get_level_squads and board_index.get_level_squads(levels[i]) or {}
        if #list > 0 then
            used_index = true
        end
        for j = 1, #list do
                local sid = tonumber(list[j]) or nil
                if is_valid_server_id(sid) and seen_sids[sid] ~= true then
                    seen_sids[sid] = true
                    local ok_squad, se_squad = safe_call("alife:object(indexed_squad)", function()
                        return sim:object(sid)
                end)
                if ok_squad and se_squad then
                    local squad_changed, member_count, squad_section = apply_squad_override(sim, se_squad, override_map, reason)
                    if squad_section then
                        matched_sections[squad_section] = true
                    end
                    if squad_changed then
                        updated_squads = updated_squads + 1
                    end
                    updated_members = updated_members + (tonumber(member_count) or 0)
                end
            end
        end
    end

    if used_index ~= true and (reason == "first_update" or reason == "load_state") then
        local board = get_board()
        if board and board.squads then
            for sid_key in pairs(board.squads) do
                    local sid = tonumber(sid_key) or nil
                    if is_valid_server_id(sid) and seen_sids[sid] ~= true then
                        seen_sids[sid] = true
                        local ok_squad, res_squad = safe_call("alife:object(existing_squad)", function()
                            return sim:object(sid)
                    end)
                    local se_squad = ok_squad and res_squad or nil
                    if se_squad then
                        local squad_changed, member_count, squad_section = apply_squad_override(sim, se_squad, override_map, reason)
                        if squad_section then
                            matched_sections[squad_section] = true
                        end
                        if squad_changed then
                            updated_squads = updated_squads + 1
                        end
                        updated_members = updated_members + (tonumber(member_count) or 0)
                    end
                end
            end
        end
    end

    for squad_section in pairs(override_map) do
        if not matched_sections[squad_section] then
            log_debug("SQUAD_NOT_FOUND squad=%s", tostring(squad_section))
        end
    end

    if reason == "first_update" or reason == "load_state" or reason == "mcm_toggle" then
        log_info(
            "HYDRATION_DONE reason=%s configured=%s squads=%s members=%s",
            tostring(reason),
            tostring(configured),
            tostring(updated_squads),
            tostring(updated_members)
        )
    elseif updated_squads > 0 or updated_members > 0 then
        log_info("APPLY_EXISTING reason=%s squads=%s members=%s", tostring(reason), tostring(updated_squads), tostring(updated_members))
    end
end

local function on_actor_first_update()
    RUNTIME.first_update_done = true
    RUNTIME.enabled_prev = feature_enabled()
    if not RUNTIME.enabled_prev then
        reset_runtime("first_update_disabled")
        return
    end
    reset_runtime("first_update")
    apply_existing_squads("first_update")
end

local function on_option_change()
    local enabled = feature_enabled()
    if not enabled then
        RUNTIME.enabled_prev = false
        reset_runtime("option_disabled")
        return
    end
    if RUNTIME.enabled_prev == true then
        return
    end
    RUNTIME.enabled_prev = true
    reset_runtime("option_enabled")
    apply_existing_squads("mcm_toggle_enable")
end

local function on_load_state()
    if not feature_enabled() then
        RUNTIME.enabled_prev = false
        reset_runtime("load_disabled")
        return
    end
    RUNTIME.enabled_prev = true
    reset_runtime("load_state")
    apply_existing_squads("load_state")
end

local function on_server_entity_register(se_obj, type_name)
    if feature_enabled() ~= true then
        return
    end
    if type(type_name) ~= "string" or type_name ~= "sim_squad_scripted" or not se_obj then
        return
    end
    local sim = alife and alife() or nil
    if not sim then
        return
    end
    local override_map = get_override_map()
    if next(override_map) == nil then
        return
    end
    apply_squad_override(sim, se_obj, override_map, "register")
end

local function on_squad_npc_creation(squad, npc)
    if feature_enabled() ~= true then
        return
    end
    local sim = alife and alife() or nil
    if not (sim and squad and npc) then
        return
    end
    local override_map = get_override_map()
    local squad_section, target_faction = get_override_for_squad(squad, override_map)
    if not (squad_section and target_faction and COMMUNITY_SET[target_faction]) then
        return
    end
    local npc_id = tonumber(npc and npc.id) or tonumber(npc)
    if npc_id and apply_member_faction(sim, npc_id, target_faction) then
        log_debug("MEMBER_APPLIED reason=npc_creation squad=%s npc_id=%s faction=%s", tostring(squad_section), tostring(npc_id), tostring(target_faction))
    end
end

local function on_server_entity_unregister(se_obj, type_name)
    if type(type_name) ~= "string" or type_name ~= "sim_squad_scripted" or not se_obj then
        return
    end
    local squad_id = tonumber(se_obj.id) or nil
    if squad_id then
        RUNTIME.applied_squads[squad_id] = nil
    end
    local ok_members = safe_call("se_squad:squad_members(unregister)", function()
        return se_obj:squad_members()
    end)
    if ok_members then
        for member in se_obj:squad_members() do
            local npc_id = tonumber(member and member.id) or nil
            if npc_id then
                RUNTIME.applied_members[npc_id] = nil
            end
        end
    end
end

local function on_squad_npc_death(squad, npc)
    local npc_id = tonumber(npc and npc.id) or tonumber(npc)
    if npc_id then
        RUNTIME.applied_members[npc_id] = nil
    end
    if squad then
        local squad_id = tonumber(squad.id) or nil
        if squad_id and feature_enabled() ~= true then
            RUNTIME.applied_squads[squad_id] = nil
        end
    end
end

local function on_game_start()
end

zhopa.npc_faction_override = {
    on_game_start = on_game_start,
    on_actor_first_update = on_actor_first_update,
    on_option_change = on_option_change,
    on_load_state = on_load_state,
    on_server_entity_register = on_server_entity_register,
    on_server_entity_unregister = on_server_entity_unregister,
    on_squad_npc_creation = on_squad_npc_creation,
    on_squad_npc_death = on_squad_npc_death,
}
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_npc_faction_override

-- BEGIN module zhopa_xr_conditions_patch
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local rawget = _G.rawget
local tostring = _G.tostring
local tonumber = _G.tonumber
local string = _G.string
local alife = _G.alife

local SERVICE_TOKEN = "_sim_squad_service_"
local CAMPER_TOKEN = "_sim_squad_camper_"

local Patch = {
    RUNTIME = {
        originals = {},
        last_signature = nil,
    }
}

local function log_info(fmt, ...)
    if zhopa.log and zhopa.log.info then
        zhopa.log.info("XR_COND_PATCH", fmt, ...)
    end
end

local function safe_call_string_method(obj, method_name)
    if not obj then
        return nil
    end
    local fn = obj[method_name]
    if type(fn) ~= "function" then
        return nil
    end
    local ok, value = pcall(fn, obj)
    if not ok or type(value) ~= "string" or value == "" then
        return nil
    end
    return value
end

local function safe_call_number_method(obj, method_name)
    if not obj then
        return nil
    end
    local fn = obj[method_name]
    if type(fn) ~= "function" then
        return nil
    end
    local ok, value = pcall(fn, obj)
    if not ok or type(value) ~= "number" then
        return nil
    end
    return value
end

local function safe_read_number_field(obj, field_name)
    if not obj then
        return nil
    end
    local ok, value = pcall(function()
        return obj[field_name]
    end)
    if not ok or type(value) ~= "number" then
        return nil
    end
    return value
end

local function is_zhopa_squad_section(section)
    if type(section) ~= "string" or section == "" then
        return false
    end
    if string.find(section, SERVICE_TOKEN, 1, true) then
        return true
    end
    if string.find(section, CAMPER_TOKEN, 1, true) then
        return true
    end
    return false
end

local function normalize_alife_id(value)
    local id = tonumber(value)
    if type(id) ~= "number" then
        return nil
    end
    if id <= 0 or id == 65535 then
        return nil
    end
    return id
end

local function safe_alife_object(id)
    local valid_id = normalize_alife_id(id)
    if not valid_id then
        return nil
    end
    local sim = alife and alife()
    if not sim then
        return nil
    end
    local ok_obj, se_obj = pcall(function()
        return sim:object(valid_id)
    end)
    if not ok_obj then
        return nil
    end
    return se_obj
end

local function resolve_squad_section_by_group_id(group_id)
    local se_squad = safe_alife_object(group_id)
    if not se_squad then
        return nil
    end
    return safe_call_string_method(se_squad, "section_name")
end

local function resolve_npc_squad_section(npc)
    local get_object_squad = rawget(_G, "get_object_squad")
    if type(get_object_squad) == "function" then
        local ok_squad, se_squad = pcall(get_object_squad, npc, "zhopa_xr_conditions_patch")
        if ok_squad and se_squad then
            local section = safe_call_string_method(se_squad, "section_name")
            if section then
                return section
            end
        end
    end

    local group_id = normalize_alife_id(safe_read_number_field(npc, "group_id"))
        or normalize_alife_id(safe_call_number_method(npc, "group_id"))
    if not group_id then
        local npc_id = safe_call_number_method(npc, "id")
        if normalize_alife_id(npc_id) then
            local se_obj = safe_alife_object(npc_id)
            group_id = se_obj and normalize_alife_id(se_obj.group_id) or nil
        end
        if not group_id then
            return nil
        end
    end
    return resolve_squad_section_by_group_id(group_id)
end

local function is_zhopa_npc(npc)
    return is_zhopa_squad_section(resolve_npc_squad_section(npc))
end

local function disable_npc_invulnerability(npc)
    if not npc then
        return
    end
    local fn = npc.invulnerable
    if type(fn) ~= "function" then
        return
    end
    pcall(fn, npc, false)
end

local function matches_role_seed(obj, role)
    if type(role) ~= "string" or role == "" then
        return false
    end
    local pattern = "sim_default_%a+_" .. role
    local name = safe_call_string_method(obj, "name")
    if name and string.find(name, pattern) then
        return true
    end
    local profile = safe_call_string_method(obj, "profile_name")
    if profile and string.find(profile, pattern) then
        return true
    end
    return false
end

local function wrap_role_check(fn_name, role)
    local original = rawget(_G, fn_name)
    if type(original) ~= "function" then
        return false
    end
    if Patch.RUNTIME.originals[fn_name] then
        return true
    end

    Patch.RUNTIME.originals[fn_name] = original
    _G[fn_name] = function(actor, npc, p)
        local ok, result = pcall(original, actor, npc, p)
        if ok and result == true then
            return true
        end
        return matches_role_seed(npc, role)
    end
    return true
end

local function wrap_stalker_invulnerability()
    local original = rawget(_G, "is_need_invulnerability")
    if type(original) ~= "function" then
        return false
    end
    if Patch.RUNTIME.originals.is_need_invulnerability then
        return true
    end

    Patch.RUNTIME.originals.is_need_invulnerability = original
    _G.is_need_invulnerability = function(npc)
        if is_zhopa_npc(npc) then
            return false
        end
        return original(npc)
    end
    return true
end

local function wrap_stalker_generic_module()
    local mod = rawget(_G, "stalker_generic")
    if type(mod) ~= "table" then
        return false
    end

    local wrapped = false

    local original_is_need = rawget(mod, "is_need_invulnerability")
    if type(original_is_need) == "function" and not Patch.RUNTIME.originals.stalker_generic_is_need_invulnerability then
        Patch.RUNTIME.originals.stalker_generic_is_need_invulnerability = original_is_need
        mod.is_need_invulnerability = function(npc)
            if is_zhopa_npc(npc) then
                return false
            end
            return original_is_need(npc)
        end
        wrapped = true
    end

    local original_reset = rawget(mod, "reset_invulnerability")
    if type(original_reset) == "function" and not Patch.RUNTIME.originals.stalker_generic_reset_invulnerability then
        Patch.RUNTIME.originals.stalker_generic_reset_invulnerability = original_reset
        mod.reset_invulnerability = function(npc, ...)
            if is_zhopa_npc(npc) then
                disable_npc_invulnerability(npc)
                return
            end
            return original_reset(npc, ...)
        end
        wrapped = true
    end

    local original_update = rawget(mod, "update_invulnerability")
    if type(original_update) == "function" and not Patch.RUNTIME.originals.stalker_generic_update_invulnerability then
        Patch.RUNTIME.originals.stalker_generic_update_invulnerability = original_update
        mod.update_invulnerability = function(npc, ...)
            if is_zhopa_npc(npc) then
                disable_npc_invulnerability(npc)
                return
            end
            return original_update(npc, ...)
        end
        wrapped = true
    end

    return wrapped
end

local function wrap_sim_squad_invulnerability()
    local cls = rawget(_G, "sim_squad_scripted")
    if type(cls) ~= "table" then
        return false
    end
    local original = rawget(cls, "check_invulnerability")
    if type(original) ~= "function" then
        return false
    end
    if Patch.RUNTIME.originals.sim_squad_check_invulnerability then
        return true
    end

    Patch.RUNTIME.originals.sim_squad_check_invulnerability = original
    cls.check_invulnerability = function(self, ...)
        local section = safe_call_string_method(self, "section_name")
        if is_zhopa_squad_section(section) then
            if self and type(self.squad_members) == "function" then
                for k in self:squad_members() do
                    local npc_st = db and db.storage and db.storage[k.id]
                    local npc = npc_st and npc_st.object
                    disable_npc_invulnerability(npc)
                end
            end
            return
        end
        return original(self, ...)
    end
    return true
end

function Patch.apply()
    wrap_role_check("check_npc_trader", "trader")
    wrap_role_check("check_npc_mechanic", "mechanic")
    wrap_role_check("check_npc_medic", "medic")
    wrap_role_check("check_npc_barman", "barman")
    wrap_stalker_invulnerability()
    wrap_stalker_generic_module()
    wrap_sim_squad_invulnerability()

    local role_count = 0
    if Patch.RUNTIME.originals.check_npc_trader then
        role_count = role_count + 1
    end
    if Patch.RUNTIME.originals.check_npc_mechanic then
        role_count = role_count + 1
    end
    if Patch.RUNTIME.originals.check_npc_medic then
        role_count = role_count + 1
    end
    if Patch.RUNTIME.originals.check_npc_barman then
        role_count = role_count + 1
    end
    local stalker_guard = Patch.RUNTIME.originals.is_need_invulnerability and 1 or 0
    local stalker_module_guard = (
        Patch.RUNTIME.originals.stalker_generic_is_need_invulnerability
        or Patch.RUNTIME.originals.stalker_generic_reset_invulnerability
        or Patch.RUNTIME.originals.stalker_generic_update_invulnerability
    ) and 1 or 0
    local squad_guard = Patch.RUNTIME.originals.sim_squad_check_invulnerability and 1 or 0
    local signature = table.concat({
        tostring(role_count),
        tostring(stalker_guard),
        tostring(stalker_module_guard),
        tostring(squad_guard),
    }, ":")
    if Patch.RUNTIME.last_signature ~= signature then
        Patch.RUNTIME.last_signature = signature
        log_info(
            "applied role_checks=%s stalker_invul=%s stalker_mod=%s squad_invul=%s",
            tostring(role_count),
            tostring(stalker_guard),
            tostring(stalker_module_guard),
            tostring(squad_guard)
        )
    end
    return (stalker_guard == 1 or stalker_module_guard == 1) and squad_guard == 1
end

Patch.apply()
zhopa.xr_conditions_patch = Patch
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_xr_conditions_patch

-- BEGIN module zhopa_memory
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local setmetatable = _G.setmetatable
local tonumber = _G.tonumber
local tostring = _G.tostring
local time_global = _G.time_global
local alife = _G.alife
local game_graph = _G.game_graph
local game = _G.game
local get_object_story_id = _G.get_object_story_id
local IsMonster = _G.IsMonster
local math = _G.math
local next = _G.next
local pairs = _G.pairs
local rawget = _G.rawget

local math_max = math.max

local IDENTITY_FALLBACK_TTL_MS = 60000
local SNAPSHOT_IDENTITY_REFRESH_MS = 1000
local SNAPSHOT_IDENTITY_DIRTY_REFRESH_MS = 0
local INTEGRITY_SOFT_FAIL_THRESHOLD = 3
local INTEGRITY_SOFT_FAIL_WINDOW_MS = 30000

local STATE_VERSION = "1.0.1"


local Memory = zhopa.class("Memory")
Memory.__index = Memory

local function tg()
    return (time_global and time_global()) or 0
end

local function route_task_current_change(payload)
    local core = zhopa and zhopa.core or nil
    local fn = core and core.on_task_current_changed or nil
    if type(fn) == "function" then
        fn(payload)
    end
end

local MEMORY_GVID_LEVEL_CACHE_MS = 1000
local memory_gvid_level_cache = {}

local function now_level_name_by_gvid(gvid)
    gvid = tonumber(gvid) or nil
    if not (gvid and alife and game_graph) then return nil end
    local now = tg()
    local cached = memory_gvid_level_cache[gvid]
    if type(cached) == "table" and now <= (tonumber(cached.tg) or 0) + MEMORY_GVID_LEVEL_CACHE_MS then
        return cached.value
    end
    local ok, res = pcall(function()
        local gv = game_graph():vertex(gvid)
        if not gv then return nil end
        return alife():level_name(gv:level_id())
    end)
    if ok and type(res) == "string" and res ~= "" then
        memory_gvid_level_cache[gvid] = { value = res, tg = now }
        return res
    end
    memory_gvid_level_cache[gvid] = { value = nil, tg = now }
    return nil
end

local function get_board()
    return rawget(_G, "SIMBOARD")
end

local function resolve_smart_level_name(smart_name, fallback_level)
    if type(smart_name) ~= "string" or smart_name == "" then
        return fallback_level
    end
    if zhopa.board_index and zhopa.board_index.get_smart_level then
        local level_name = zhopa.board_index.get_smart_level(smart_name)
        if type(level_name) == "string" and level_name ~= "" then
            return level_name
        end
    end
    local board = get_board()
    local sm = board and board.smarts_by_names and board.smarts_by_names[smart_name] or nil
    if sm and sm.m_game_vertex_id then
        return now_level_name_by_gvid(tonumber(sm.m_game_vertex_id) or 0) or fallback_level
    end
    return fallback_level
end

local function normalize_community(community)
    if not community then return nil end
    if type(community) ~= "string" then
        community = tostring(community)
    end
    if zhopa.config and zhopa.config.get_faction_alias then
        local alias = zhopa.config.get_faction_alias(community)
        if alias then
            return alias
        end
    end
    return community
end

local function is_zombied_community_name(community)
    return normalize_community(community) == "zombied"
end

local function is_zombied_section_name(section)
    if type(section) ~= "string" or section == "" then
        return false
    end
    if not (zhopa.config and zhopa.config.get_section_set) then
        return false
    end
    local set = zhopa.config.get_section_set("spawner_allowed_sections_zombied")
    return set and set[section] == true or false
end

local function get_mutant_allowed_section_set(section, community)
    if not (zhopa.config and zhopa.config.get_section_set) then
        return nil
    end
    if is_zombied_community_name(community) or is_zombied_section_name(section) then
        return zhopa.config.get_section_set("spawner_allowed_sections_zombied")
    end
    return zhopa.config.get_section_set("spawner_allowed_sections_mutants")
end

local function read_live_squad_section(se_squad)
    if zhopa.safe and zhopa.safe.safe_section then
        return zhopa.safe.safe_section(se_squad)
    end
    return nil
end

local function read_live_squad_community(se_squad)
    if zhopa.safe and zhopa.safe.safe_squad_community then
        return normalize_community(zhopa.safe.safe_squad_community(se_squad))
    end
    return nil
end

local function is_level_globally_blacklisted(level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    local cfg = zhopa.config
    if cfg and cfg.is_level_globally_blacklisted then
        return cfg.is_level_globally_blacklisted(level_name) == true
    end
    return false
end

local safe_alife_object

local function resolve_live_squad_level_name(se_squad, entry)
    if not se_squad then
        return entry and entry.level or nil
    end

    local level_name = now_level_name_by_gvid(tonumber(se_squad.m_game_vertex_id) or 0)
    if type(level_name) == "string" and level_name ~= "" then
        return level_name
    end

    local smart_name = nil
    local ok_target, scripted_target = pcall(function() return se_squad.scripted_target end)
    if ok_target and type(scripted_target) == "string" and scripted_target ~= "" then
        smart_name = scripted_target
    end
    if not smart_name then
        local ok_smart, smart_id = pcall(function() return se_squad.smart_id end)
        smart_id = ok_smart and tonumber(smart_id) or nil
        if smart_id and smart_id > 0 then
            local ok_obj, smart = safe_alife_object(smart_id)
            smart_name = ok_obj and smart and smart.name or nil
        end
    end

    level_name = resolve_smart_level_name(smart_name, entry and entry.level or nil)
    if type(level_name) == "string" and level_name ~= "" then
        return level_name
    end

    return entry and entry.level or nil
end

local function normalize_alife_id(value)
    local id = tonumber(value)
    if type(id) ~= "number" then
        return nil
    end
    if id <= 0 or id == 65535 then
        return nil
    end
    return id
end

safe_alife_object = function(id)
    local valid_id = normalize_alife_id(id)
    if not valid_id or not alife then
        return false, nil
    end
    local sim = alife()
    if not sim then
        return false, nil
    end
    local ok, obj = pcall(function() return sim:object(valid_id) end)
    if not ok then
        return false, nil
    end
    return true, obj
end

local function read_commander_id(se_squad)
    if not se_squad then return nil end
    local ok, cid = pcall(function() return se_squad:commander_id() end)
    if not ok or cid == nil then
        ok, cid = pcall(function() return se_squad.commander_id end)
    end
    return ok and normalize_alife_id(cid) or nil
end

local function is_monster_squad_by_player_id(se_squad)
    if not se_squad then return false end
    local pid = se_squad.player_id
    if pid == nil then return false end
    local normalized = normalize_community(pid)
    if normalized == "zombied" then
        return true
    end
    if not is_squad_monster then return false end
    return is_squad_monster[pid] == true or (normalized and is_squad_monster[normalized] == true) or false
end

local function is_monster_squad_live(se_squad)
    if not se_squad then return false end
    if is_monster_squad_by_player_id(se_squad) then
        return true
    end

    local section = read_live_squad_section(se_squad)
    local community = read_live_squad_community(se_squad)
    if is_zombied_community_name(community) or is_zombied_section_name(section) then
        return true
    end

    if not (alife and IsMonster) then
        return false
    end

    local commander_id = read_commander_id(se_squad)
    if not commander_id then
        return false
    end

    local ok_obj, commander = safe_alife_object(commander_id)
    if not (ok_obj and commander) then
        return false
    end

    local ok_monster, is_monster = pcall(function() return IsMonster(commander) end)
    return ok_monster and is_monster == true
end

local function is_companion_squad_id(sid)
    if not sid then return false end
    local squads = axr_companions and axr_companions.companion_squads or nil
    if type(squads) ~= "table" then return false end
    return squads[sid] ~= nil or squads[tostring(sid)] ~= nil
end

local function has_story_binding(object_id)
    if not (get_object_story_id and object_id) then return false end
    local ok, story = pcall(function() return get_object_story_id(object_id) end)
    return ok and story ~= nil and story ~= false
end


local function extract_smart_name(smart_ref)
    if type(smart_ref) == "string" and smart_ref ~= "" then
        return smart_ref
    end
    if type(smart_ref) ~= "table" then
        return nil
    end
    local name = smart_ref.name
    if type(name) == "string" and name ~= "" then
        return name
    end
    local ok_name, resolved = pcall(function() return smart_ref:name() end)
    if ok_name and type(resolved) == "string" and resolved ~= "" then
        return resolved
    end
    return nil
end

local function reset_task_scheduler_fields(task)
    if type(task) ~= "table" then return end
    local params = type(task.params) == "table" and task.params or nil
    if not params then
        task.params = nil
        return
    end
    params._applied = nil
    if next(params) == nil then
        task.params = nil
    else
        task.params = params
    end
end

local function ensure_dirty_shape(e)
    if type(e) ~= "table" then return end
    local d = type(e.dirty) == "table" and e.dirty or {}
    e.dirty = {
        level = d.level == true,
        community = d.community == true,
        smart = d.smart == true,
        task = d.task == true,
        identity = d.identity == true,
    }
end

local function ctime_from_table(t)
    if not (game and game.get_game_time and game.CTime and type(t) == "table") then
        return nil
    end
    local ok_new, ct = pcall(function() return game.CTime() end)
    if not (ok_new and ct and ct.set) then
        return nil
    end
    local ok_set = pcall(function()
        ct:set(t.Y, t.M, t.D, t.h, t.m, t.s, t.ms)
    end)
    if not ok_set then
        return nil
    end
    return ct
end

local function game_time_diff_sec(start_ct)
    if not (game and game.get_game_time and start_ct and start_ct.diffSec) then
        return nil
    end
    local ok_now, now_ct = pcall(function() return game.get_game_time() end)
    if not (ok_now and now_ct and now_ct.diffSec) then
        return nil
    end
    local ok_diff, sec = pcall(function() return now_ct:diffSec(start_ct) end)
    return ok_diff and tonumber(sec) or nil
end

local function clone_serializable(value, depth, seen)
    local t = type(value)
    if t == "nil" or t == "boolean" or t == "number" or t == "string" then
        return value
    end
    if t ~= "table" then
        return nil
    end

    depth = tonumber(depth) or 0
    if depth > 12 then
        return nil
    end

    seen = seen or {}
    if seen[value] then
        return nil
    end
    seen[value] = true

    local out = {}
    for k, v in pairs(value) do
        local kt = type(k)
        if kt == "string" or kt == "number" then
            local sv = clone_serializable(v, depth + 1, seen)
            if sv ~= nil then
                out[k] = sv
            end
        end
    end

    seen[value] = nil
    return out
end

local function compact_task(task)
    if type(task) ~= "table" then return nil end
    local out = clone_serializable(task, 0, {})
    if type(out) ~= "table" then return nil end
    if type(out.params) == "table" then
        out.params._applied = nil
        if next(out.params) == nil then
            out.params = nil
        end
    end
    return out
end

local function compact_entry(entry)
    if type(entry) ~= "table" then return nil end
    if entry.allowed ~= true then
        return nil
    end
    local out = {}

    local function set_if(k, v, default)
        if v == nil then return end
        if default ~= nil and v == default then return end
        out[k] = v
    end

    set_if("squad_id", tonumber(entry.squad_id), nil)
    set_if("npc_kind", entry.npc_kind, nil)
    set_if("allowed", entry.allowed, nil)
    set_if("surge_lock", entry.surge_lock == true and true or nil, nil)

    if type(entry.tasks) == "table" then
        local tp = compact_task(entry.tasks.prev)
        local tc = compact_task(entry.tasks.current)
        if tp or tc then
            out.tasks = { prev = tp, current = tc }
        end
    end

    return out
end

function Memory:__init()
    self.STATE = { version = STATE_VERSION, squads = {}, patrol = {} }
    self.RUNTIME = {}
    self:_reset_runtime_tables()
end

function Memory:_get_state()
    return self.STATE
end

function Memory:_get_runtime()
    return self.RUNTIME
end

function Memory:_get_squad_entry(squad_id)
    if not squad_id then return nil end
    return self.STATE.squads[tonumber(squad_id)]
end

function Memory:_reset_runtime_tables()
    self.RUNTIME.log_next_tg = {}
    self.RUNTIME.integrity_reject_count = 0
    self.RUNTIME.integrity_purge_count = 0
    self.RUNTIME.integrity_soft_fail_count = 0
    self.RUNTIME.touch_create_blocked_count = 0
    self.RUNTIME.managed_squads_by_level = {}
    self.RUNTIME.anchors_by_community_level = {}
    self.RUNTIME.communities_by_smart_level = {}
    self.RUNTIME.trade_target_occupancy = {}
    self.RUNTIME.index_rev = 0
end

function Memory:_clear_runtime_indexes()
    self.RUNTIME.managed_squads_by_level = {}
    self.RUNTIME.anchors_by_community_level = {}
    self.RUNTIME.communities_by_smart_level = {}
    self.RUNTIME.trade_target_occupancy = {}
    self.RUNTIME.index_rev = (tonumber(self.RUNTIME.index_rev) or 0) + 1
end

function Memory:_get_index_rev()
    return tonumber(self.RUNTIME and self.RUNTIME.index_rev) or 0
end

function Memory:_bump_index_rev()
    self.RUNTIME.index_rev = (tonumber(self.RUNTIME.index_rev) or 0) + 1
end

function Memory:_resolve_entry_trade_target(e)
    if type(e) ~= "table" then
        return nil, nil
    end
    local current = e.tasks and e.tasks.current or nil
    local target = current and current.type == "TRADE" and current.target or nil
    if type(target) ~= "string" or target == "" then
        return nil, nil
    end
    return target, resolve_smart_level_name(target, e.level)
end

function Memory:_resolve_entry_anchor_smart(e)
    if type(e) ~= "table" then
        return nil, nil
    end

    local target = e.scripted_target
    if type(target) == "string" and target ~= "" then
        return target, resolve_smart_level_name(target, e.level)
    end

    local smart_id = tonumber(e.smart_id) or nil
    if smart_id then
        if zhopa.board_index and zhopa.board_index.get_smart_name_by_id then
            local smart_name = zhopa.board_index.get_smart_name_by_id(smart_id)
            if type(smart_name) == "string" and smart_name ~= "" then
                return smart_name, resolve_smart_level_name(smart_name, e.level)
            end
        end
    end

    local current = e.tasks and e.tasks.current or nil
    target = current and current.target or nil
    if type(target) == "string" and target ~= "" then
        return target, resolve_smart_level_name(target, e.level)
    end

    return nil, nil
end

function Memory:_unindex_entry(e)
    if type(e) ~= "table" then
        return
    end

    local sid = tonumber(e.squad_id) or nil
    local managed_level = type(e.index_managed_level) == "string" and e.index_managed_level or nil
    if sid and managed_level then
        local by_level = self.RUNTIME.managed_squads_by_level[managed_level]
        if type(by_level) == "table" then
            by_level[sid] = nil
            if next(by_level) == nil then
                self.RUNTIME.managed_squads_by_level[managed_level] = nil
            end
        end
    end
    e.index_managed_level = nil

    local anchor_comm = type(e.index_anchor_community) == "string" and e.index_anchor_community or nil
    local anchor_level = type(e.index_anchor_level) == "string" and e.index_anchor_level or nil
    local anchor_smart = type(e.index_anchor_smart) == "string" and e.index_anchor_smart or nil
    if anchor_comm and anchor_level and anchor_smart then
        local by_comm = self.RUNTIME.anchors_by_community_level[anchor_comm]
        local by_level = by_comm and by_comm[anchor_level] or nil
        if type(by_level) == "table" then
            by_level[anchor_smart] = nil
            if next(by_level) == nil then
                by_comm[anchor_level] = nil
            end
            if next(by_comm) == nil then
                self.RUNTIME.anchors_by_community_level[anchor_comm] = nil
            end
        end

        local by_smart = self.RUNTIME.communities_by_smart_level[anchor_smart]
        local by_smart_level = by_smart and by_smart[anchor_level] or nil
        if type(by_smart_level) == "table" then
            by_smart_level[anchor_comm] = nil
            if next(by_smart_level) == nil then
                by_smart[anchor_level] = nil
            end
            if next(by_smart) == nil then
                self.RUNTIME.communities_by_smart_level[anchor_smart] = nil
            end
        end
    end
    e.index_anchor_community = nil
    e.index_anchor_level = nil
    e.index_anchor_smart = nil

    local trade_level = type(e.index_trade_target_level) == "string" and e.index_trade_target_level or nil
    local trade_smart = type(e.index_trade_target_smart) == "string" and e.index_trade_target_smart or nil
    if trade_level and trade_smart then
        local by_level = self.RUNTIME.trade_target_occupancy[trade_level]
        if type(by_level) == "table" then
            local next_count = (tonumber(by_level[trade_smart]) or 0) - 1
            if next_count > 0 then
                by_level[trade_smart] = next_count
            else
                by_level[trade_smart] = nil
            end
            if next(by_level) == nil then
                self.RUNTIME.trade_target_occupancy[trade_level] = nil
            end
        end
    end
    e.index_trade_target_level = nil
    e.index_trade_target_smart = nil
end

function Memory:_index_entry(e)
    if type(e) ~= "table" or e.allowed ~= true then
        return
    end

    local sid = tonumber(e.squad_id) or nil
    local level_name = type(e.level) == "string" and e.level or nil
    if sid and level_name then
        local by_level = self.RUNTIME.managed_squads_by_level[level_name]
        if type(by_level) ~= "table" then
            by_level = {}
            self.RUNTIME.managed_squads_by_level[level_name] = by_level
        end
        by_level[sid] = true
        e.index_managed_level = level_name
    end

    local community = type(e.community) == "string" and e.community or nil
    local anchor_smart, anchor_level = self:_resolve_entry_anchor_smart(e)
    if community and anchor_level and anchor_smart then
        local by_comm = self.RUNTIME.anchors_by_community_level[community]
        if type(by_comm) ~= "table" then
            by_comm = {}
            self.RUNTIME.anchors_by_community_level[community] = by_comm
        end
        local by_level = by_comm[anchor_level]
        if type(by_level) ~= "table" then
            by_level = {}
            by_comm[anchor_level] = by_level
        end
        by_level[anchor_smart] = true

        local by_smart = self.RUNTIME.communities_by_smart_level[anchor_smart]
        if type(by_smart) ~= "table" then
            by_smart = {}
            self.RUNTIME.communities_by_smart_level[anchor_smart] = by_smart
        end
        local by_smart_level = by_smart[anchor_level]
        if type(by_smart_level) ~= "table" then
            by_smart_level = {}
            by_smart[anchor_level] = by_smart_level
        end
        by_smart_level[community] = true

        e.index_anchor_community = community
        e.index_anchor_level = anchor_level
        e.index_anchor_smart = anchor_smart
    end

    local trade_target, trade_level = self:_resolve_entry_trade_target(e)
    if trade_target and trade_level then
        local by_level = self.RUNTIME.trade_target_occupancy[trade_level]
        if type(by_level) ~= "table" then
            by_level = {}
            self.RUNTIME.trade_target_occupancy[trade_level] = by_level
        end
        by_level[trade_target] = (tonumber(by_level[trade_target]) or 0) + 1
        e.index_trade_target_level = trade_level
        e.index_trade_target_smart = trade_target
    end
end

function Memory:_reindex_entry(e)
    if type(e) ~= "table" then
        return
    end
    local old_managed = e.index_managed_level
    local old_anchor_comm = e.index_anchor_community
    local old_anchor_level = e.index_anchor_level
    local old_anchor_smart = e.index_anchor_smart
    local old_trade_level = e.index_trade_target_level
    local old_trade_smart = e.index_trade_target_smart
    self:_unindex_entry(e)
    self:_index_entry(e)
    if old_managed ~= e.index_managed_level
        or old_anchor_comm ~= e.index_anchor_community
        or old_anchor_level ~= e.index_anchor_level
        or old_anchor_smart ~= e.index_anchor_smart
        or old_trade_level ~= e.index_trade_target_level
        or old_trade_smart ~= e.index_trade_target_smart
    then
        self:_bump_index_rev()
    end
end

function Memory:_rebuild_runtime_indexes()
    self:_clear_runtime_indexes()
    for sid, e in pairs(self.STATE and self.STATE.squads or {}) do
        if type(e) == "table" then
            self:_ensure_entry_defaults(e, sid)
            self:_index_entry(e)
        end
    end
end

function Memory:_entry_last_seen_tg(e)
    if type(e) ~= "table" then return 0 end
    return tonumber(e.last_seen_tg) or tonumber(e.updated_at_tg) or 0
end

function Memory:_entry_age_ms(e, now)
    now = tonumber(now) or tg()
    return now - self:_entry_last_seen_tg(e)
end

function Memory:_log_throttled(key, interval_ms, level, fmt, ...)
    local log = zhopa.log
    if not log then return end

    local now = tg()
    self.RUNTIME.log_next_tg = self.RUNTIME.log_next_tg or {}
    local next_tg = tonumber(self.RUNTIME.log_next_tg[key]) or 0
    if now < next_tg then return end
    self.RUNTIME.log_next_tg[key] = now + (tonumber(interval_ms) or 5000)

    if level == "warn" and log.warn then
        log.warn("MEMORY", fmt, ...)
        return
    end
    if level == "trace" and log.trace then
        log.trace("MEMORY", fmt, ...)
        return
    end
    if level == "debug" and log.debug then
        log.debug("MEMORY", fmt, ...)
        return
    end
    if log.info then
        log.info("MEMORY", fmt, ...)
    end
end

local function count_squad_members(members)
    if members == nil then
        return nil, false
    end
    if type(members) == "table" then
        local n = 0
        for _ in pairs(members) do
            n = n + 1
            if n > 0 then break end
        end
        return n, true
    end

    local ok_size, sz = pcall(function()
        if members.size then
            return members:size()
        end
        return nil
    end)
    if ok_size and tonumber(sz) then
        return tonumber(sz), true
    end

    return nil, false
end

local function extract_member_candidate_id(k, v)
    if type(v) == "table" then
        local idv = tonumber(v.id) or tonumber(v.object_id) or tonumber(v.squad_id)
        if idv and idv > 0 then
            return idv
        end
    end
    local id = tonumber(v)
    if id and id > 0 then
        return id
    end
    id = tonumber(k)
    if id and id > 0 then
        return id
    end
    return nil
end

function Memory:_integrity_reject(sid, source, reason, severity)
    self.RUNTIME.integrity_reject_count = (tonumber(self.RUNTIME.integrity_reject_count) or 0) + 1
    severity = severity == "hard" and "hard" or "soft"
    if severity == "soft" then
        self.RUNTIME.integrity_soft_fail_count = (tonumber(self.RUNTIME.integrity_soft_fail_count) or 0) + 1
    end

    self:_log_throttled(
        "integrity_reject:" .. tostring(sid or 0) .. ":" .. tostring(reason or "-"),
        3000,
        "warn",
        "MEMORY_INTEGRITY_REJECT sid=%s source=%s reason=%s severity=%s",
        tostring(sid or "-"),
        tostring(source or "-"),
        tostring(reason or "-"),
        tostring(severity)
    )
    return false, sid, reason, severity
end

function Memory:_purge_squad_entry(sid, reason, source)
    local id = tonumber(sid)
    if not id then return false end
    local e = self.STATE.squads[id]
    if type(e) ~= "table" then return false end

    self:_unindex_entry(e)
    self.STATE.squads[id] = nil
    self.RUNTIME.integrity_purge_count = (tonumber(self.RUNTIME.integrity_purge_count) or 0) + 1
    self:_log_throttled(
        "purged_ghost:" .. tostring(id),
        2000,
        "warn",
        "MEMORY_PURGED_GHOST sid=%s source=%s reason=%s",
        tostring(id),
        tostring(source or "-"),
        tostring(reason or "-")
    )
    return true
end

function Memory:_note_integrity_soft_fail(sid, source, reason)
    local id = tonumber(sid)
    if not id then return false end
    local e = self:_get_squad_entry(id)
    if type(e) ~= "table" then return false end

    local now = tg()
    self:_ensure_entry_defaults(e, id)

    local window_tg = tonumber(e.integrity_soft_fail_window_tg) or 0
    local count = tonumber(e.integrity_soft_fail_count) or 0
    if window_tg <= 0 or now > (window_tg + INTEGRITY_SOFT_FAIL_WINDOW_MS) then
        window_tg = now
        count = 0
    end

    count = count + 1
    e.integrity_soft_fail_window_tg = window_tg
    e.integrity_soft_fail_count = count
    e.last_seen_source = tostring(source or "integrity") .. ":" .. tostring(reason or "soft_fail")

    if count >= INTEGRITY_SOFT_FAIL_THRESHOLD then
        return self:_purge_squad_entry(id, "soft_fail_threshold:" .. tostring(reason or "-"), source or "integrity")
    end
    return false
end

function Memory:_validate_live_squad(se_squad, source)
    local sid = tonumber(se_squad and se_squad.id)
    if not sid or sid <= 0 then
        return self:_integrity_reject(sid, source, "sid_invalid", "hard")
    end

    local sim = alife and alife() or nil
    if not sim then
        return self:_integrity_reject(sid, source, "alife_nil", "soft")
    end

    local ok_obj, live = safe_alife_object(sid)
    if not ok_obj then
        return self:_integrity_reject(sid, source, "object_read_fail", "soft")
    end
    if not live then
        return self:_integrity_reject(sid, source, "object_nil", "hard")
    end

    local commander_id = read_commander_id(se_squad)
    if commander_id then
        local ok_commander, commander = safe_alife_object(commander_id)
        if not ok_commander then
            return self:_integrity_reject(sid, source, "commander_read_fail", "soft")
        end
        if not commander then
            return self:_integrity_reject(sid, source, "commander_nil", "hard")
        end
    end

    local ok_has_npc_count, npc_count_member = pcall(function() return se_squad and se_squad.npc_count end)
    if ok_has_npc_count and npc_count_member then
        local ok_count, npc_count = pcall(function() return se_squad:npc_count() end)
        if not ok_count then
            return self:_integrity_reject(sid, source, "npc_count_read_fail", "soft")
        end
        npc_count = tonumber(npc_count)
        if npc_count and npc_count <= 0 then
            return self:_integrity_reject(sid, source, "npc_count_zero", "hard")
        end
    end

    local ok_has_members, members_member = pcall(function() return se_squad and se_squad.squad_members end)
    if ok_has_members and members_member then
        local ok_members, members = pcall(function() return se_squad:squad_members() end)
        if not ok_members then
            return self:_integrity_reject(sid, source, "members_read_fail", "soft")
        end
        local members_count, known = count_squad_members(members)
        if known and tonumber(members_count) and tonumber(members_count) <= 0 then
            return self:_integrity_reject(sid, source, "members_empty", "hard")
        end

        if type(members) == "table" then
            local has_any_candidate = false
            local has_live_member = false
            for k, v in pairs(members) do
                local mid = extract_member_candidate_id(k, v)
                mid = normalize_alife_id(mid)
                if mid then
                    has_any_candidate = true
                    local ok_member, member_obj = safe_alife_object(mid)
                    if not ok_member then
                        return self:_integrity_reject(sid, source, "member_read_fail", "soft")
                    end
                    if member_obj then
                        has_live_member = true
                        break
                    end
                end
            end

            if has_any_candidate and not has_live_member then
                return self:_integrity_reject(sid, source, "members_all_nil", "hard")
            end
        end
    end

    return true, sid, nil, nil
end

function Memory:_ensure_tasks_shape(e)
    if type(e) ~= "table" then return end
    local t = type(e.tasks) == "table" and e.tasks or {}
    e.tasks = {
        prev = t.prev,
        current = t.current,
    }
end

function Memory:_ensure_entry_defaults(e, id)
    if type(e) ~= "table" then return end
    e.squad_id = tonumber(e.squad_id) or tonumber(id) or e.squad_id
    self:_ensure_tasks_shape(e)
    if e.surge_lock ~= true then
        e.surge_lock = false
    end

    e.last_seen_tg = tonumber(e.last_seen_tg) or tonumber(e.updated_at_tg) or 0
    e.updated_at_tg = tonumber(e.updated_at_tg) or e.last_seen_tg
    e.last_seen_source = e.last_seen_source or "unknown"
    e.community_verified_tg = tonumber(e.community_verified_tg) or 0
    e.level_verified_tg = tonumber(e.level_verified_tg) or 0
    e.section_verified_tg = tonumber(e.section_verified_tg) or 0
    e.identity_refresh_next_tg = tonumber(e.identity_refresh_next_tg) or 0
    e.npc_kind = (e.npc_kind == "mutant" or e.npc_kind == "stalker") and e.npc_kind or nil
    e.identity_source = type(e.identity_source) == "string" and e.identity_source or nil
    e.integrity_soft_fail_count = tonumber(e.integrity_soft_fail_count) or 0
    e.integrity_soft_fail_window_tg = tonumber(e.integrity_soft_fail_window_tg) or 0
    ensure_dirty_shape(e)
end

function Memory:_mark_entry_seen(e, now, source)
    if type(e) ~= "table" then return end
    now = tonumber(now) or tg()
    e.updated_at_tg = now
    e.last_seen_tg = now
    e.last_seen_source = source or "snapshot"
    e.integrity_soft_fail_count = 0
    e.integrity_soft_fail_window_tg = 0
end

function Memory:_touch_squad(squad_id, mark_seen, source)
    local id = tonumber(squad_id)
    if not id then return nil end
    local e = self.STATE.squads[id]
    if not e then
        e = { squad_id = id, tasks = { prev = nil, current = nil }, surge_lock = false }
        self.STATE.squads[id] = e
    end

    self:_ensure_entry_defaults(e, id)
    if mark_seen == true then
        self:_mark_entry_seen(e, tg(), source or "touch")
    end

    return e
end

function Memory:_touch_squad_validated(se_squad, mark_seen, source)
    local src = tostring(source or "touch_validated")
    local ok, sid, reason, severity = self:_validate_live_squad(se_squad, src)
    if not ok then
        self.RUNTIME.touch_create_blocked_count = (tonumber(self.RUNTIME.touch_create_blocked_count) or 0) + 1
        if severity == "hard" then
            self:_purge_squad_entry(sid, reason, src)
        else
            self:_note_integrity_soft_fail(sid, src, reason)
        end
        self:_log_throttled(
            "touch_blocked:" .. tostring(sid or 0) .. ":" .. tostring(src),
            3000,
            "warn",
            "MEMORY_TOUCH_BLOCKED sid=%s source=%s reason=%s severity=%s",
            tostring(sid or "-"),
            tostring(src),
            tostring(reason or "-"),
            tostring(severity or "-")
        )
        return nil, reason
    end

    if self:_should_manage_squad(se_squad) ~= true then
        self:_purge_squad_entry(sid, "not_managed", src)
        return nil, "not_managed"
    end

    local e = self:_touch_squad(sid, mark_seen == true, src)
    if type(e) == "table" then
        e.integrity_soft_fail_count = 0
        e.integrity_soft_fail_window_tg = 0
    end
    return e, nil
end

function Memory:_get_entry_for_mutation(squad_id, source)
    local id = tonumber(squad_id)
    if not id then
        return nil
    end
    local e = self:_get_squad_entry(id)
    if type(e) ~= "table" then
        self.RUNTIME.touch_create_blocked_count = (tonumber(self.RUNTIME.touch_create_blocked_count) or 0) + 1
        self:_log_throttled(
            "touch_blocked:missing:" .. tostring(id) .. ":" .. tostring(source or "-"),
            3000,
            "warn",
            "MEMORY_TOUCH_BLOCKED sid=%s source=%s reason=missing_entry severity=hard",
            tostring(id),
            tostring(source or "-")
        )
        return nil
    end
    self:_ensure_entry_defaults(e, id)
    return e
end

function Memory:_apply_squad_snapshot(squad, id, source)
    if not squad then return end
    id = tonumber(id) or tonumber(squad.id)
    if not id then return end

    local now = tg()
    local e = self:_touch_squad(id, true, source or "snapshot")
    if not e then return end
    e.integrity_soft_fail_count = 0
    e.integrity_soft_fail_window_tg = 0
    local prev_dirty = e.dirty
    local meaningful_changed = type(prev_dirty) == "table"
        and (prev_dirty.task == true
            or prev_dirty.smart == true
            or prev_dirty.level == true
            or prev_dirty.community == true
            or prev_dirty.identity == true)
        or false

    local prev_level = e.level
    local prev_level_gvid = tonumber(e.level_gvid) or nil
    local prev_comm = e.community
    local prev_smart = tonumber(e.smart_id) or nil
    local prev_section = e.section
    local prev_allowed = e.allowed
    local prev_kind = e.npc_kind
    local prev_gvid = tonumber(e.m_game_vertex_id) or nil

    e.smart_id = squad.smart_id
    e.scripted_target = squad.scripted_target
    e.current_action = squad.current_action
    e.assigned_target_id = squad.assigned_target_id
    if tonumber(e.smart_id) ~= prev_smart then
        meaningful_changed = true
        e.dirty.smart = true
        e.dirty.task = true
    end
    local gvid = tonumber(squad.m_game_vertex_id) or nil
    e.m_game_vertex_id = gvid or squad.m_game_vertex_id

    local gvid_changed = gvid ~= prev_gvid
    if gvid_changed then
        meaningful_changed = true
        e.dirty.level = true
        e.dirty.identity = true
        e.dirty.task = true
    end

    local dirty_identity_refresh = e.dirty.identity == true
    local need_identity_refresh = false
    if dirty_identity_refresh then
        need_identity_refresh = true
    elseif e.level == nil or e.community == nil or e.section == nil or e.allowed == nil or e.npc_kind == nil then
        need_identity_refresh = true
    elseif now >= (tonumber(e.identity_refresh_next_tg) or 0) then
        need_identity_refresh = true
    elseif tonumber(e.smart_id) ~= prev_smart or gvid_changed then
        need_identity_refresh = true
    end

    if not need_identity_refresh then
        return e, meaningful_changed == true
    end

    local commander_id = read_commander_id(squad)
    if commander_id then
        e.commander_id = commander_id
    end

    local is_mutant = is_monster_squad_live(squad)
    e.npc_kind = is_mutant and "mutant" or "stalker"
    e.identity_source = is_mutant and "live_mutant" or "live_human"

    if gvid then
        local level_name = now_level_name_by_gvid(gvid)
        if level_name then
            e.level = level_name
            e.level_gvid = gvid
            e.level_verified_tg = now
        else
            e.dirty.level = true
        end
    end
    if e.level ~= prev_level or ((tonumber(e.level_gvid) or nil) ~= prev_level_gvid) then
        meaningful_changed = true
        e.dirty.level = true
        e.dirty.task = true
    end

    local live_section = read_live_squad_section(squad)
    if live_section then
        e.section = live_section
        e.section_verified_tg = now
    end

    local live_community = read_live_squad_community(squad)
    if not live_community and is_zombied_section_name(e.section) then
        live_community = "zombied"
    end
    if live_community then
        e.community = live_community
        e.community_verified_tg = now
    end
    if e.community ~= prev_comm then
        meaningful_changed = true
        e.dirty.community = true
        e.dirty.task = true
    end

    if zhopa.config and zhopa.config.get_section_set and e.section then
        if is_mutant then
            local set = get_mutant_allowed_section_set(e.section, e.community)
            if set then
                e.allowed = set[e.section] == true
            end
        elseif e.community then
            local set = zhopa.config.get_section_set("spawner_allowed_sections_" .. tostring(e.community))
            e.allowed = set and set[e.section] == true or false
        end
    end
    if e.npc_kind ~= prev_kind then
        meaningful_changed = true
        e.dirty.task = true
    end
    if e.section ~= prev_section then
        meaningful_changed = true
        e.dirty.task = true
    end
    if e.allowed ~= prev_allowed then
        meaningful_changed = true
        e.dirty.task = true
    end

    e.dirty.identity = false
    e.identity_refresh_next_tg = now + (dirty_identity_refresh and SNAPSHOT_IDENTITY_DIRTY_REFRESH_MS or SNAPSHOT_IDENTITY_REFRESH_MS)
    if e.level == prev_level
        and (e.community ~= prev_comm
            or tonumber(e.smart_id) ~= prev_smart
            or e.section ~= prev_section
            or e.allowed ~= prev_allowed
            or e.npc_kind ~= prev_kind
            or gvid_changed)
    then
        meaningful_changed = true
        e.dirty.task = true
    end
    self:_reindex_entry(e)
    return e, meaningful_changed == true
end

function Memory:_update_squad_snapshot(squad)
    if not squad then return end
    local ok_live, id, reason, severity = self:_validate_live_squad(squad, "snapshot")
    if not ok_live then
        if severity == "hard" then
            self:_purge_squad_entry(id, reason, "snapshot")
        else
            self:_note_integrity_soft_fail(id, "snapshot", reason)
        end
        return
    end

    if self:_should_manage_squad(squad) ~= true then
        self:_purge_squad_entry(id, "not_managed", "snapshot")
        return
    end

    self:_apply_squad_snapshot(squad, id, "snapshot")
end

function Memory:_update_squad_snapshot_verified(squad, squad_id)
    if not squad then return end
    local sid = tonumber(squad_id) or tonumber(squad.id)
    if not sid then return end
    if self:_should_manage_squad(squad) ~= true then
        self:_purge_squad_entry(sid, "not_managed", "snapshot_verified")
        return
    end
    self:_apply_squad_snapshot(squad, sid, "snapshot")
end

function Memory:_upsert_snapshot(squad, source)
    if not squad then return nil end
    local src = tostring(source or "upsert_snapshot")
    local ok_live, sid, reason, severity = self:_validate_live_squad(squad, src)
    if not ok_live then
        if severity == "hard" then
            self:_purge_squad_entry(sid, reason, src)
        else
            self:_note_integrity_soft_fail(sid, src, reason)
        end
        return nil
    end
    if self:_should_manage_squad(squad) ~= true then
        self:_purge_squad_entry(sid, "not_managed", src)
        return nil
    end
    local entry, changed = self:_apply_squad_snapshot(squad, sid, src)
    return entry or self:_get_squad_entry(sid), changed == true
end

function Memory:_set_task_current(squad_id, task)
    local e = self:_get_entry_for_mutation(squad_id, "set_task_current")
    if not e then return end
    local prev_task = e.tasks and e.tasks.current or nil
    self:_ensure_tasks_shape(e)
    e.tasks.prev = prev_task
    e.tasks.current = task
    ensure_dirty_shape(e)
    e.dirty.task = true
    self:_reindex_entry(e)
    route_task_current_change({
        squad_id = tonumber(e.squad_id) or tonumber(squad_id) or nil,
        prev_task = prev_task,
        current_task = e.tasks and e.tasks.current or nil,
    })
end

function Memory:_clear_tasks(squad_id)
    local e = self:_get_entry_for_mutation(squad_id, "clear_tasks")
    if not e then return end
    local prev_task = e.tasks and e.tasks.current or nil
    e.tasks = { prev = nil, current = nil }
    ensure_dirty_shape(e)
    e.dirty.task = true
    self:_reindex_entry(e)
    route_task_current_change({
        squad_id = tonumber(e.squad_id) or tonumber(squad_id) or nil,
        prev_task = prev_task,
        current_task = e.tasks and e.tasks.current or nil,
    })
end

function Memory:_is_entry_recent(entry, now, max_age_ms)
    if type(entry) ~= "table" or entry.allowed ~= true then
        return false
    end
    now = tonumber(now) or tg()
    local max_age = tonumber(max_age_ms) or IDENTITY_FALLBACK_TTL_MS
    if max_age < 1 then
        max_age = IDENTITY_FALLBACK_TTL_MS
    end
    return self:_entry_age_ms(entry, now) <= max_age
end

function Memory:_get_managed_squads_by_level()
    return self.RUNTIME.managed_squads_by_level or {}
end

function Memory:_get_anchor_index()
    return self.RUNTIME.anchors_by_community_level or {}
end

function Memory:_get_communities_by_smart_level()
    return self.RUNTIME.communities_by_smart_level or {}
end

function Memory:_get_trade_target_occupancy()
    return self.RUNTIME.trade_target_occupancy or {}
end

function Memory:_mark_dirty(squad_id, key)
    local e = self:_get_entry_for_mutation(squad_id, "mark_dirty")
    if not e then return false end
    ensure_dirty_shape(e)
    if type(key) == "string" and e.dirty[key] ~= nil then
        e.dirty[key] = true
        return true
    end
    e.dirty.task = true
    return true
end

function Memory:_mark_arrived_to_target(squad_id, smart_ref, source)
    local e = self:_get_entry_for_mutation(squad_id, "mark_arrived_to_target")
    if not e then return false end
    local current = e.tasks and e.tasks.current or nil
    if type(current) ~= "table" then
        return false
    end
    current.params = type(current.params) == "table" and current.params or {}
    local smart_name = extract_smart_name(smart_ref)
    current.params.entered_target_smart = smart_name
    current.params.arrived_at_tg = tg()
    current.params.in_transit = false
    current.params.last_semantic_source = tostring(source or "enter_smart")
    if current.type == "TRADE" and smart_name and current.target == smart_name then
        current.params.trade_arrived_at_tg = tonumber(current.params.trade_arrived_at_tg) or tg()
        current.params.arrived_phase = true
    end
    ensure_dirty_shape(e)
    e.dirty.task = true
    return true
end

function Memory:_mark_left_target(squad_id, smart_ref, source)
    local e = self:_get_entry_for_mutation(squad_id, "mark_left_target")
    if not e then return false end
    local current = e.tasks and e.tasks.current or nil
    if type(current) ~= "table" then
        return false
    end
    current.params = type(current.params) == "table" and current.params or {}
    current.params.left_target_smart = extract_smart_name(smart_ref)
    current.params.left_target_tg = tg()
    current.params.in_transit = true
    current.params.last_semantic_source = tostring(source or "leave_smart")
    if current.type == "TRADE" then
        current.params.arrived_phase = false
    end
    ensure_dirty_shape(e)
    e.dirty.task = true
    return true
end

function Memory:_mark_level_changed(squad_id, old_level, new_level, source)
    local e = self:_get_entry_for_mutation(squad_id, "mark_level_changed")
    if not e then return false end
    local old_name = type(old_level) == "string" and old_level or nil
    local new_name = type(new_level) == "string" and new_level or nil
    if new_name and new_name ~= "" then
        e.level = new_name
    end
    local current = e.tasks and e.tasks.current or nil
    if type(current) == "table" then
        current.params = type(current.params) == "table" and current.params or {}
        current.params.level_changed_from = old_name
        current.params.level_changed_to = new_name
        current.params.level_changed_tg = tg()
        current.params.last_semantic_source = tostring(source or "after_level_change")
    end
    ensure_dirty_shape(e)
    e.dirty.level = true
    e.dirty.task = true
    self:_reindex_entry(e)
    return true
end

function Memory:_prune_missing_squads_once(source)
    local sim = alife and alife() or nil
    if not sim then
        return 0
    end

    local removed = 0
    for sid, entry in pairs(self.STATE and self.STATE.squads or {}) do
        local id = tonumber(sid) or tonumber(type(entry) == "table" and entry.squad_id or nil)
        if id then
            local ok_obj, live = safe_alife_object(id)
            if ok_obj and not live then
                if self:_purge_squad_entry(id, "missing_on_prune", source or "prune_missing_squads_once") then
                    removed = removed + 1
                end
            end
        end
    end
    return removed
end

function Memory:_consume_dirty(entry, key)
    if type(entry) ~= "table" then return false end
    ensure_dirty_shape(entry)
    if type(key) ~= "string" or entry.dirty[key] == nil then
        return false
    end
    local v = entry.dirty[key] == true
    entry.dirty[key] = false
    return v
end

function Memory:_normalize_loaded_task(task)
    if type(task) ~= "table" then return task end
    reset_task_scheduler_fields(task)
    if task.type == "FACTION_TASK" then
        return nil
    end
    return task
end

function Memory:_normalize_loaded_entry(id, src, now)
    local e = type(src) == "table" and src or {}
    e.squad_id = tonumber(id) or tonumber(e.squad_id)
    self:_ensure_entry_defaults(e, e.squad_id)

    e.tasks.prev = self:_normalize_loaded_task(e.tasks.prev)
    e.tasks.current = self:_normalize_loaded_task(e.tasks.current)

    e.last_seen_source = "load_state"
    e.integrity_soft_fail_count = 0
    e.integrity_soft_fail_window_tg = 0

    e.community_verified_tg = 0
    e.level_verified_tg = 0
    e.section_verified_tg = 0
    e.identity_refresh_next_tg = 0
    e.updated_at_tg = tonumber(e.updated_at_tg) or now
    e.last_seen_tg = tonumber(e.last_seen_tg) or e.updated_at_tg
    e.commander_id = tonumber(e.commander_id) or nil
    e.npc_kind = (e.npc_kind == "mutant" or e.npc_kind == "stalker") and e.npc_kind or nil
    e.identity_source = type(e.identity_source) == "string" and e.identity_source or nil

    e.level = nil
    e.level_gvid = nil
    e.community = nil
    e.section = nil
    e.smart_id = nil
    e.scripted_target = nil
    e.current_action = nil
    e.assigned_target_id = nil
    e.commander_id = nil
    e.m_game_vertex_id = nil
    e.identity_source = nil

    if e.npc_kind == "mutant" then
        -- Mutant task/target state is cheap to rebuild and can preserve stuck paths across saves.
        e.tasks.prev = nil
        e.tasks.current = nil
        e.scripted_target = nil
        e.current_action = nil
        e.assigned_target_id = nil
        e.smart_id = nil
    end

    ensure_dirty_shape(e)
    e.dirty.level = true
    e.dirty.community = true
    e.dirty.smart = true
    e.dirty.task = true
    e.dirty.identity = true

    return e
end

function Memory:_is_protected_squad(se_squad)
    if not se_squad then return false end
    local sid = tonumber(se_squad.id)
    if not sid then return false end

    if is_companion_squad_id(sid) then
        return true
    end

    local commander_id = read_commander_id(se_squad)
    if commander_id and has_story_binding(commander_id) then
        return true
    end
    return false
end

function Memory:_should_manage_squad(se_squad)
    if not se_squad then return false end

    local sid = tonumber(se_squad.id)
    if not sid then return false end
    if self:_is_protected_squad(se_squad) then
        self:_log_throttled("protected_skip:" .. tostring(sid), 8000, "info", "MEMORY_PROTECTED_SKIP sid=%s", tostring(sid))
        return false
    end

    local now = tg()
    local entry = self:_get_squad_entry(sid)
    local level_name = resolve_live_squad_level_name(se_squad, entry)
    if is_level_globally_blacklisted(level_name) then
        if entry then
            self:_ensure_entry_defaults(entry, sid)
            entry.level = level_name or entry.level
            entry.allowed = false
            self:_reindex_entry(entry)
        end
        self:_log_throttled("global_level_blacklist_skip:" .. tostring(sid), 8000, "info",
            "MEMORY_GLOBAL_LEVEL_BLACKLIST_SKIP sid=%s level=%s", tostring(sid), tostring(level_name or "-"))
        return false
    end
    local commander_id = read_commander_id(se_squad)
    if entry then
        self:_ensure_entry_defaults(entry, sid)
        if commander_id and entry.commander_id and commander_id ~= entry.commander_id then
            entry.allowed = false
            self:_reindex_entry(entry)
            return false
        end
    end

    local is_mutant = is_monster_squad_live(se_squad)
    local mutant_sim_enabled = true
    if zhopa.runtime_cfg and zhopa.runtime_cfg.get then
        mutant_sim_enabled = zhopa.runtime_cfg.get("mutant_sim_enabled", true) ~= false
    elseif zhopa.config and zhopa.config.get then
        mutant_sim_enabled = zhopa.config.get("mutant_sim_enabled", true) ~= false
    end
    local section = nil
    section = read_live_squad_section(se_squad)

    local community = read_live_squad_community(se_squad)
    if not community and is_zombied_section_name(section) then
        community = "zombied"
    end

    if is_mutant then
        if mutant_sim_enabled == false then
            if entry then
                entry.npc_kind = "mutant"
                entry.identity_source = "mutant_disabled"
                if commander_id then
                    entry.commander_id = commander_id
                end
            end
            return false
        end

        local allowed_live = nil
        if section and zhopa.config and zhopa.config.get_section_set then
            local set = get_mutant_allowed_section_set(section, community)
            if set then
                allowed_live = set[section] == true
            end
        end

        if entry then
            entry.npc_kind = "mutant"
            entry.identity_source = "live_mutant"
            entry.section = section or entry.section
            if community then
                entry.community = community
                entry.community_verified_tg = now
            end
            if allowed_live ~= nil then
                entry.allowed = allowed_live
            end
            if commander_id then
                entry.commander_id = commander_id
            end
        end

        if allowed_live ~= nil then
            return allowed_live == true
        end

        if not entry then return false end
        if not self:_is_entry_recent(entry, now, IDENTITY_FALLBACK_TTL_MS) then
            return false
        end
        if entry.npc_kind ~= "mutant" then
            return false
        end
        if entry.allowed ~= true then
            return false
        end
        if section and entry.section and section ~= entry.section then
            return false
        end
        return entry.section ~= nil
    end

    local has_live_identity = community ~= nil and section ~= nil
    local allowed_live = nil
    if has_live_identity and zhopa.config and zhopa.config.get_section_set then
        local set = zhopa.config.get_section_set("spawner_allowed_sections_" .. tostring(community))
        allowed_live = set and set[section] == true or false

        if entry then
            entry.npc_kind = "stalker"
            entry.identity_source = "live_human"
            entry.community = community
            entry.section = section
            entry.allowed = allowed_live
            entry.community_verified_tg = now
            if commander_id then
                entry.commander_id = commander_id
            end
        end

        if allowed_live == true then
            return true
        end
        return false
    end

    if not entry then return false end

    if not self:_is_entry_recent(entry, now, IDENTITY_FALLBACK_TTL_MS) then
        return false
    end
    if entry.allowed ~= true then
        return false
    end
    if entry.npc_kind and entry.npc_kind ~= "stalker" then
        return false
    end
    if section and entry.section and section ~= entry.section then
        return false
    end
    if community and entry.community and community ~= entry.community then
        return false
    end

    return entry.community ~= nil and entry.section ~= nil
end

function Memory:_on_squad_npc_death(squad_or_id, npc, killer_npc, killer_squad)
    local sid = nil
    local dead_npc_id = nil
    if type(squad_or_id) == "number" then
        sid = tonumber(squad_or_id)
    elseif type(squad_or_id) == "table" then
        sid = tonumber(squad_or_id.id) or tonumber(squad_or_id.squad_id)
    end
    if type(npc) == "table" then
        dead_npc_id = tonumber(npc.id) or tonumber(type(npc.id) == "function" and npc:id() or nil)
    elseif type(npc) == "number" then
        dead_npc_id = tonumber(npc)
    end
    if not sid then return end

    local e = self:_get_squad_entry(sid)
    if not e then return end

    self:_ensure_entry_defaults(e, sid)
    ensure_dirty_shape(e)
    e.dirty.identity = true
    e.dirty.task = true
    e.identity_refresh_next_tg = 0

    if dead_npc_id and tonumber(e.commander_id) == dead_npc_id then
        e.commander_id = nil
        e.community_verified_tg = 0
        e.level_verified_tg = 0
        e.section_verified_tg = 0
        e.dirty.smart = true
    end
end

function Memory:_save_state(m_data)
    if not m_data then return end
    self.STATE.version = STATE_VERSION

    local out = {
        version = STATE_VERSION,
        squads = {},
        patrol = clone_serializable(self.STATE.patrol, 0, {}) or {},
    }
    for sid, e in pairs(self.STATE.squads or {}) do
        local key = tonumber(sid) or tonumber(type(e) == "table" and e.squad_id or nil)
        if key and type(e) == "table" and e.allowed == true then
            local compact = compact_entry(e)
            if compact then
                out.squads[key] = compact
            end
        end
    end
    m_data.zhopa_state = out
end

function Memory:_load_state(m_data)
    local loaded = m_data and m_data.zhopa_state or nil
    if loaded and type(loaded) == "table" then
        local now = tg()
        local out = {
            version = STATE_VERSION,
            squads = {},
            patrol = type(loaded.patrol) == "table" and loaded.patrol or {},
        }
        local loaded_ver = tostring(loaded.version or "0.0")

        local src_squads = type(loaded.squads) == "table" and loaded.squads or {}
        for key, e in pairs(src_squads) do
            local sid = tonumber(key) or tonumber(type(e) == "table" and e.squad_id or nil)
            if sid then
                local normalized = self:_normalize_loaded_entry(sid, e, now)
                if type(normalized) == "table" and normalized.allowed == true then
                    out.squads[sid] = normalized
                end
            end
        end

        self.STATE = out
        self:_reset_runtime_tables()
        self:_rebuild_runtime_indexes()

        if zhopa.log and zhopa.log.info then
            zhopa.log.info(
                "MEMORY",
                "Loaded ZHOPA state v=%s -> %s. Squads: %d",
                tostring(loaded_ver),
                tostring(STATE_VERSION),
                (table.size and table.size(self.STATE.squads)) or 0
            )
        end
    else
        self.STATE = { version = STATE_VERSION, squads = {}, patrol = {} }
        self:_reset_runtime_tables()
        self:_rebuild_runtime_indexes()
        if zhopa.log and zhopa.log.info then
            zhopa.log.info("MEMORY", "No save state found. Starting fresh.")
        end
    end
end

local inst = Memory.new and Memory.new() or setmetatable({}, Memory)
if not inst.STATE then
    Memory.__init(inst)
end

inst.get_state = function() return inst:_get_state() end
inst.get_runtime = function() return inst:_get_runtime() end
inst.get_squad_entry = function(squad_id) return inst:_get_squad_entry(squad_id) end
inst.validate_live_squad = function(se_squad, source) return inst:_validate_live_squad(se_squad, source) end
inst.touch_squad_validated = function(se_squad, mark_seen, source) return inst:_touch_squad_validated(se_squad, mark_seen, source) end
inst.purge_squad_entry = function(squad_id, reason, source) return inst:_purge_squad_entry(squad_id, reason, source) end
inst.touch_squad = function(squad_id, mark_seen, source) return inst:_touch_squad(squad_id, mark_seen, source) end
inst.update_squad_snapshot = function(squad) return inst:_update_squad_snapshot(squad) end
inst.update_squad_snapshot_verified = function(squad, squad_id) return inst:_update_squad_snapshot_verified(squad, squad_id) end
inst.upsert_snapshot = function(squad, source) return inst:_upsert_snapshot(squad, source) end
inst.set_task_current = function(squad_id, task) return inst:_set_task_current(squad_id, task) end
inst.clear_tasks = function(squad_id) return inst:_clear_tasks(squad_id) end
inst.get_managed_squads_by_level = function() return inst:_get_managed_squads_by_level() end
inst.get_anchor_index = function() return inst:_get_anchor_index() end
inst.get_communities_by_smart_level = function() return inst:_get_communities_by_smart_level() end
inst.get_trade_target_occupancy = function() return inst:_get_trade_target_occupancy() end
inst.get_index_rev = function() return inst:_get_index_rev() end
inst.mark_dirty = function(squad_id, key) return inst:_mark_dirty(squad_id, key) end
inst.mark_arrived_to_target = function(squad_id, smart_ref, source) return inst:_mark_arrived_to_target(squad_id, smart_ref, source) end
inst.mark_left_target = function(squad_id, smart_ref, source) return inst:_mark_left_target(squad_id, smart_ref, source) end
inst.mark_level_changed = function(squad_id, old_level, new_level, source) return inst:_mark_level_changed(squad_id, old_level, new_level, source) end
inst.prune_missing_squads_once = function(source) return inst:_prune_missing_squads_once(source) end
inst.consume_dirty = function(entry, key) return inst:_consume_dirty(entry, key) end
inst.is_protected_squad = function(se_squad) return inst:_is_protected_squad(se_squad) end
inst.should_manage_squad = function(se_squad) return inst:_should_manage_squad(se_squad) end
inst.on_squad_npc_death = function(squad_or_id, npc, killer_npc, killer_squad) return inst:_on_squad_npc_death(squad_or_id, npc, killer_npc, killer_squad) end
inst.save_state = function(m_data) return inst:_save_state(m_data) end
inst.load_state = function(m_data) return inst:_load_state(m_data) end
inst.on_actor_first_update = function()
    inst:_rebuild_runtime_indexes()
    inst:_prune_missing_squads_once("actor_on_first_update")
end
inst.on_server_entity_unregister = function(se_obj, type_name)
    if type(type_name) == "string" and type_name == "sim_squad_scripted" then
        inst:_purge_squad_entry(se_obj and se_obj.id or nil, "server_unregister", "server_entity_on_unregister")
    end
end

function Memory:_set_surge_lock(squad_id, locked)
    local e = self:_get_entry_for_mutation(squad_id, "set_surge_lock")
    if not e then return end
    e.surge_lock = locked == true
    ensure_dirty_shape(e)
    e.dirty.task = true
end

function Memory:_get_surge_lock(squad_id)
    local e = self:_get_squad_entry(squad_id)
    if not e then return false end
    return e.surge_lock == true
end

inst.set_surge_lock = function(squad_id, locked) return inst:_set_surge_lock(squad_id, locked) end
inst.get_surge_lock = function(squad_id) return inst:_get_surge_lock(squad_id) end

zhopa.memory = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_memory

-- BEGIN module zhopa_story_psy_watchdog
zhopa_bundle_module = function()
zhopa = zhopa or {}
zhopa.story_psy_watchdog = zhopa.story_psy_watchdog or {}

local watchdog = zhopa.story_psy_watchdog

local type = _G.type
local pcall = _G.pcall
local rawget = _G.rawget
local tonumber = _G.tonumber
local tostring = _G.tostring
local pairs = _G.pairs
local next = _G.next
local time_global = _G.time_global
local alife = _G.alife
local alife_create = _G.alife_create
local game_graph = _G.game_graph
local db = _G.db
local math_random = _G.math and _G.math.random or nil
local vector = _G.vector
local SendScriptCallback = _G.SendScriptCallback

local string_find = _G.string and _G.string.find or nil
local string_gsub = _G.string and _G.string.gsub or nil
local string_lower = _G.string and _G.string.lower or nil

local DEFAULT_PSI_LEVELS = "l10_limansk, l10_red_forest, l10_radar"
local DEFAULT_IMMUNE_FACTIONS = "monolith, isg, greh"

local SECTION_ZOMBIED_NOVICE = "zombied_sim_squad_novice"
local SECTION_ZOMBIED_ADVANCED = "zombied_sim_squad_advanced"
local SECTION_ZOMBIED_VETERAN = "zombied_sim_squad_veteran"

local PREVALIDATED_CTX = { prevalidated = true }
local PSI_RECONCILE_LEVEL_BUDGET = 1
local PSI_RECONCILE_CONTINUE_MS = 250

local MEMBER_POOL_BY_SECTION = {
    [SECTION_ZOMBIED_NOVICE] = {
        "sim_default_zombied_1",
        "sim_default_zombied_1",
        "sim_default_zombied_2",
    },
    [SECTION_ZOMBIED_ADVANCED] = {
        "sim_default_zombied_2",
        "sim_default_zombied_2",
        "sim_default_zombied_3",
    },
    [SECTION_ZOMBIED_VETERAN] = {
        "sim_default_zombied_3",
        "sim_default_zombied_3",
        "sim_default_zombied_4",
    },
}

local RUNTIME = {
    psi_levels = nil,
    immune_factions = nil,
    processing_by_sid = {},
    psi_reconcile_levels = nil,
    psi_reconcile_cursor = 1,
    psi_reconcile_source = nil,
}

local function tg()
    return (time_global and time_global()) or 0
end

local function log_info(fmt, ...)
    if zhopa.log and zhopa.log.info then
        zhopa.log.info("STORY_PSY", fmt, ...)
    end
end

local function log_warn(fmt, ...)
    if zhopa.log and zhopa.log.warn then
        zhopa.log.warn("STORY_PSY", fmt, ...)
    end
end

local function trim(value)
    if type(value) ~= "string" then
        return nil
    end
    if string_gsub then
        value = string_gsub(value, "^%s*(.-)%s*$", "%1")
    end
    if value == "" then
        return nil
    end
    return value
end

local function lower_trim(value)
    value = trim(value)
    if not value then
        return nil
    end
    if string_lower then
        return string_lower(value)
    end
    return value
end

local function normalize_community(value)
    if value == nil then
        return nil
    end
    if type(value) ~= "string" then
        value = tostring(value)
    end
    if zhopa.config and zhopa.config.get_faction_alias then
        local alias = zhopa.config.get_faction_alias(value)
        if alias then
            return alias
        end
    end
    return lower_trim(value)
end

local function parse_csv_set(value)
    local out = {}
    if type(value) ~= "string" or value == "" then
        return out
    end
    for token in value:gmatch("([^,]+)") do
        local normalized = normalize_community(token)
        if normalized then
            out[normalized] = true
        end
    end
    return out
end

local function invalidate_runtime_caches()
    RUNTIME.psi_levels = nil
    RUNTIME.immune_factions = nil
end

local function get_cfg_value(key, fallback)
    if zhopa.runtime_cfg and zhopa.runtime_cfg.get then
        return zhopa.runtime_cfg.get(key, fallback)
    elseif zhopa.config and zhopa.config.get then
        local value = zhopa.config.get(key, fallback)
        if value ~= nil then
            return value
        end
    end
    return fallback
end

local function get_psi_levels()
    if RUNTIME.psi_levels ~= nil then
        return RUNTIME.psi_levels
    end
    RUNTIME.psi_levels = parse_csv_set(get_cfg_value("story_psy_watchdog_levels", DEFAULT_PSI_LEVELS))
    return RUNTIME.psi_levels
end

local function get_immune_factions()
    if RUNTIME.immune_factions ~= nil then
        return RUNTIME.immune_factions
    end
    RUNTIME.immune_factions = parse_csv_set(get_cfg_value("story_psy_watchdog_immune_factions", DEFAULT_IMMUNE_FACTIONS))
    return RUNTIME.immune_factions
end

local function has_alife_info_safe(info)
    if type(info) ~= "string" or info == "" then
        return false
    end

    local fn = rawget(_G, "has_alife_info")
    if type(fn) == "function" then
        local ok, has = pcall(fn, info)
        if ok then
            return has == true
        end
    end

    local actor = db and db.actor or nil
    if actor and actor.has_info then
        local ok, has = pcall(function()
            return actor:has_info(info)
        end)
        if ok then
            return has == true
        end
    end

    return false
end

local function normalize_alife_id(value)
    local id = tonumber(value)
    if not id or id <= 0 or id == 65535 then
        return nil
    end
    return id
end

local function resolve_alife_object(id)
    id = normalize_alife_id(id)
    if not (id and alife) then
        return nil
    end
    local sim = alife()
    if not sim then
        return nil
    end
    local ok, obj = pcall(function()
        return sim:object(id)
    end)
    if ok then
        return obj
    end
    return nil
end

local function safe_object_name(obj)
    if not obj then
        return nil
    end
    local raw_name = obj.name
    if type(raw_name) == "string" and raw_name ~= "" then
        return raw_name
    end
    local ok, name = pcall(function()
        return obj:name()
    end)
    if ok and type(name) == "string" and name ~= "" then
        return name
    end
    return nil
end

local function clone_position(pos)
    if not pos then
        return nil
    end
    if type(vector) == "function" then
        local ok, cloned = pcall(function()
            return vector():set(pos.x, pos.y, pos.z)
        end)
        if ok and cloned then
            return cloned
        end
    end
    return pos
end

local function safe_position(obj)
    if zhopa.safe and zhopa.safe.safe_position then
        return zhopa.safe.safe_position(obj)
    end
    return nil
end

local function safe_section(obj)
    if zhopa.safe and zhopa.safe.safe_section then
        return zhopa.safe.safe_section(obj)
    end
    return nil
end

local function safe_squad_community(obj)
    if zhopa.safe and zhopa.safe.safe_squad_community then
        return normalize_community(zhopa.safe.safe_squad_community(obj))
    end
    return nil
end

local function get_board()
    if SIMBOARD then
        return SIMBOARD
    end
    if sim_board and sim_board.get_sim_board then
        local ok, board = pcall(function()
            return sim_board.get_sim_board()
        end)
        if ok then
            return board
        end
    end
    return nil
end

local function now_level_name_by_gvid(gvid)
    if not (gvid and alife and game_graph) then
        return nil
    end
    local ok, res = pcall(function()
        local gv = game_graph():vertex(gvid)
        if not gv then
            return nil
        end
        return alife():level_name(gv:level_id())
    end)
    if ok then
        return res
    end
    return nil
end

local function resolve_smart_name_by_id(smart_id)
    smart_id = normalize_alife_id(smart_id)
    if not smart_id then
        return nil
    end
    local board = get_board()
    local smart = board and board.smarts and board.smarts[smart_id] and board.smarts[smart_id].smrt or nil
    if smart then
        return safe_object_name(smart)
    end
    return safe_object_name(resolve_alife_object(smart_id))
end

local function resolve_smart_object_by_id(smart_id)
    smart_id = normalize_alife_id(smart_id)
    if not smart_id then
        return nil
    end
    local board = get_board()
    local smart = board and board.smarts and board.smarts[smart_id] and board.smarts[smart_id].smrt or nil
    if smart then
        return smart
    end
    return resolve_alife_object(smart_id)
end

local function read_commander_id(se_squad, entry)
    if se_squad and se_squad.commander_id then
        local ok, cid = pcall(function()
            return se_squad:commander_id()
        end)
        cid = ok and normalize_alife_id(cid) or nil
        if cid then
            return cid
        end
    end

    local raw_cid = normalize_alife_id(se_squad and se_squad.commander_id or nil)
    if raw_cid then
        return raw_cid
    end
    return normalize_alife_id(entry and entry.commander_id or nil)
end

local function extract_member_candidate_id(k, v)
    if type(v) == "table" then
        local idv = normalize_alife_id(v.id) or normalize_alife_id(v.object_id) or normalize_alife_id(v.squad_id)
        if idv then
            return idv
        end
    end

    local id = normalize_alife_id(v)
    if id then
        return id
    end
    return normalize_alife_id(k)
end

local function get_squad_member_ids(se_squad)
    local out = {}
    local seen = {}
    if not se_squad then
        return out
    end

    local function push(id)
        id = normalize_alife_id(id)
        if not id or seen[id] then
            return
        end
        seen[id] = true
        out[#out + 1] = id
    end

    local ok_members, a, b, c = pcall(function()
        return se_squad:squad_members()
    end)
    if ok_members and a ~= nil then
        local ok_iter = pcall(function()
            for member in a, b, c do
                push(extract_member_candidate_id(nil, member))
            end
        end)
        if (not ok_iter) and type(a) == "table" then
            for k, v in pairs(a) do
                push(extract_member_candidate_id(k, v))
            end
        end
    end

    return out
end

local function read_member_count(se_squad)
    if not se_squad then
        return nil
    end
    local ok_count, count = pcall(function()
        return se_squad:npc_count()
    end)
    count = ok_count and tonumber(count) or nil
    if count and count > 0 then
        return count
    end

    local ids = get_squad_member_ids(se_squad)
    if #ids > 0 then
        return #ids
    end
    return nil
end

local function pick_zombied_squad_section(source_section)
    local value = lower_trim(source_section)
    if type(value) ~= "string" then
        return SECTION_ZOMBIED_ADVANCED
    end
    if string_find and string_find(value, "master", 1, true) then
        return SECTION_ZOMBIED_VETERAN
    end
    if string_find and (string_find(value, "veteran", 1, true) or string_find(value, "expert", 1, true)) then
        return SECTION_ZOMBIED_ADVANCED
    end
    if string_find and (string_find(value, "novice", 1, true) or string_find(value, "advanced", 1, true)) then
        return SECTION_ZOMBIED_NOVICE
    end
    return SECTION_ZOMBIED_ADVANCED
end

local function pick_zombied_member_section(zombied_squad_section)
    local pool = MEMBER_POOL_BY_SECTION[zombied_squad_section] or MEMBER_POOL_BY_SECTION[SECTION_ZOMBIED_ADVANCED]
    if type(pool) ~= "table" or #pool == 0 then
        return "sim_default_zombied_2"
    end
    if math_random then
        return pool[math_random(#pool)] or pool[1]
    end
    return pool[1]
end

local function feature_enabled_now()
    if zhopa.switches and zhopa.switches.story_psy_watchdog == false then
        return false
    end
    if get_cfg_value("enabled", true) == false then
        return false
    end
    if get_cfg_value("story_psy_watchdog_enabled", true) == false then
        return false
    end
    if has_alife_info_safe("story_mode_disabled") == true then
        return false
    end
    if has_alife_info_safe("bar_deactivate_radar_done") == true then
        return false
    end
    return true
end

local function is_immune_faction(community)
    community = normalize_community(community)
    if not community then
        return false
    end
    return get_immune_factions()[community] == true
end

local function is_target_level(level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    return get_psi_levels()[level_name] == true
end

local function build_snapshot_context(se_squad, entry)
    if not se_squad then
        return nil
    end

    local sid = normalize_alife_id(se_squad.id)
    local section = safe_section(se_squad) or entry and entry.section or nil
    local community = safe_squad_community(se_squad) or normalize_community(entry and entry.community or nil)
    local commander = resolve_alife_object(read_commander_id(se_squad, entry))
    local position = clone_position(safe_position(se_squad) or safe_position(commander))
    local level_vertex_id = tonumber(se_squad.m_level_vertex_id) or tonumber(commander and commander.m_level_vertex_id) or nil
    local game_vertex_id = tonumber(se_squad.m_game_vertex_id) or tonumber(commander and commander.m_game_vertex_id) or tonumber(entry and entry.m_game_vertex_id) or nil
    local smart_id = normalize_alife_id(se_squad.smart_id) or normalize_alife_id(entry and entry.smart_id or nil)
    local smart_name = resolve_smart_name_by_id(smart_id) or entry and entry.scripted_target or nil
    local level_name = type(entry and entry.level) == "string" and entry.level or now_level_name_by_gvid(game_vertex_id)
    local member_count = read_member_count(se_squad)
    local zombied_section = pick_zombied_squad_section(section)

    if not (sid and section and community and position and level_vertex_id and game_vertex_id and level_name and member_count and member_count > 0) then
        return nil
    end

    return {
        sid = sid,
        source_section = section,
        source_community = community,
        position = position,
        level_vertex_id = level_vertex_id,
        game_vertex_id = game_vertex_id,
        level_name = level_name,
        member_count = member_count,
        smart_id = smart_id,
        smart_name = smart_name,
        zombied_squad_section = zombied_section,
    }
end

local function create_empty_squad(section, position, level_vertex_id, game_vertex_id)
    if type(section) ~= "string" or section == "" then
        return nil
    end
    if type(alife_create) == "function" then
        local ok, squad = pcall(function()
            return alife_create(section, position, level_vertex_id, game_vertex_id)
        end)
        if ok then
            return squad
        end
    end

    local sim = alife and alife() or nil
    if sim and sim.create then
        local ok, squad = pcall(function()
            return sim:create(section, position, level_vertex_id, game_vertex_id)
        end)
        if ok then
            return squad
        end
    end

    return nil
end

local function release_squad_safe(se_squad, reason)
    local sid = normalize_alife_id(se_squad and se_squad.id or nil)
    if not sid then
        return false
    end

    local released = false
    local rel = rawget(_G, "alife_release_id")
    if type(rel) == "function" then
        local ok, res = pcall(function()
            return rel(sid, reason)
        end)
        if ok and res ~= false then
            released = true
        end
    end

    if not released and se_squad and se_squad.remove_squad then
        local ok_remove, res_remove = pcall(function()
            return se_squad:remove_squad()
        end)
        if ok_remove and res_remove ~= false then
            released = true
        end
    end

    if not released then
        local sim = alife and alife() or nil
        if sim and sim.release then
            local ok_release, res_release = pcall(function()
                return sim:release(se_squad, true)
            end)
            if ok_release and res_release ~= false then
                released = true
            end
        end
    end

    if zhopa.memory and zhopa.memory.purge_squad_entry then
        zhopa.memory.purge_squad_entry(sid, tostring(reason or "story_psy_release"), "story_psy_watchdog")
    end

    return released
end

local function assign_squad_to_smart(se_squad, smart_id)
    smart_id = normalize_alife_id(smart_id)
    if not (se_squad and smart_id) then
        return false
    end
    local board = get_board()
    if not (board and board.assign_squad_to_smart and board.smarts and board.smarts[smart_id]) then
        return false
    end
    local ok = pcall(function()
        board:assign_squad_to_smart(se_squad, smart_id)
    end)
    return ok == true
end

local function finalize_spawned_squad(se_squad, context)
    if not (se_squad and context) then
        return false
    end

    local smart_obj = nil
    if context.smart_id then
        assign_squad_to_smart(se_squad, context.smart_id)
        smart_obj = resolve_smart_object_by_id(context.smart_id)
    end

    if se_squad.set_squad_relation then
        pcall(function()
            se_squad:set_squad_relation()
        end)
    end
    if se_squad.refresh then
        pcall(function()
            se_squad:refresh()
        end)
    end

    local board = get_board()
    local member_ids = get_squad_member_ids(se_squad)
    for i = 1, #member_ids do
        local member = resolve_alife_object(member_ids[i])
        if member and board and board.setup_squad_and_group then
            pcall(function()
                board:setup_squad_and_group(member)
            end)
        end
        if member and type(SendScriptCallback) == "function" then
            pcall(function()
                SendScriptCallback("squad_on_npc_creation", se_squad, member, smart_obj)
            end)
        end
    end

    if se_squad.update then
        pcall(function()
            se_squad:update()
        end)
    end

    local sid = normalize_alife_id(se_squad.id)
    if zhopa.memory and zhopa.memory.upsert_snapshot then
        zhopa.memory.upsert_snapshot(se_squad, "story_psy_watchdog_spawn")
    end
    if zhopa.memory and zhopa.memory.mark_dirty then
        zhopa.memory.mark_dirty(sid, "task")
    end

    if zhopa.mutants and zhopa.mutants.update_squad_tasks then
        pcall(function()
            zhopa.mutants.update_squad_tasks(se_squad, PREVALIDATED_CTX)
        end)
    end

    return true
end

local function populate_zombied_squad(se_squad, context)
    if not (se_squad and context and tonumber(context.member_count)) then
        return false
    end

    for _ = 1, tonumber(context.member_count) do
        local npc_section = pick_zombied_member_section(context.zombied_squad_section)
        local ok_add, member_id = pcall(function()
            return se_squad:add_squad_member(
                npc_section,
                context.position,
                context.level_vertex_id,
                context.game_vertex_id
            )
        end)
        if not (ok_add and normalize_alife_id(member_id)) then
            return false
        end
    end

    return true
end

local function candidate_should_convert(se_squad, entry)
    if not feature_enabled_now() then
        return false, nil
    end
    if not se_squad then
        return false, nil
    end

    local sid = normalize_alife_id(se_squad.id)
    if not sid or RUNTIME.processing_by_sid[sid] == true then
        return false, nil
    end

    if zhopa.memory and zhopa.memory.is_protected_squad and zhopa.memory.is_protected_squad(se_squad) == true then
        return false, nil
    end
    if zhopa.memory and zhopa.memory.upsert_snapshot then
        entry = zhopa.memory.upsert_snapshot(se_squad, "story_psy_watchdog_probe") or entry
    end
    if type(entry) ~= "table" then
        return false, nil
    end
    if entry.allowed ~= true then
        return false, nil
    end
    if entry.npc_kind ~= "stalker" then
        return false, nil
    end
    if is_immune_faction(entry.community) then
        return false, nil
    end
    if normalize_community(entry.community) == "zombied" then
        return false, nil
    end
    if is_target_level(entry.level) ~= true then
        return false, nil
    end

    return true, entry
end

local function convert_squad_to_zombied(se_squad, entry, source)
    local sid = normalize_alife_id(se_squad and se_squad.id or nil)
    if not sid or RUNTIME.processing_by_sid[sid] == true then
        return false
    end

    RUNTIME.processing_by_sid[sid] = true

    local context = build_snapshot_context(se_squad, entry)
    if not context then
        RUNTIME.processing_by_sid[sid] = nil
        log_warn("convert_skip sid=%s source=%s reason=invalid_snapshot", tostring(sid), tostring(source or "-"))
        return false
    end

    local new_squad = create_empty_squad(
        context.zombied_squad_section,
        context.position,
        context.level_vertex_id,
        context.game_vertex_id
    )
    local new_sid = normalize_alife_id(new_squad and new_squad.id or nil)
    if not (new_squad and new_sid) then
        RUNTIME.processing_by_sid[sid] = nil
        log_warn("convert_skip sid=%s source=%s reason=create_failed", tostring(sid), tostring(source or "-"))
        return false
    end

    RUNTIME.processing_by_sid[new_sid] = true

    if populate_zombied_squad(new_squad, context) ~= true then
        release_squad_safe(new_squad, "story_psy_watchdog_spawn_failed")
        RUNTIME.processing_by_sid[new_sid] = nil
        RUNTIME.processing_by_sid[sid] = nil
        log_warn("convert_skip sid=%s source=%s reason=member_spawn_failed", tostring(sid), tostring(source or "-"))
        return false
    end

    if zhopa.memory and zhopa.memory.clear_tasks then
        zhopa.memory.clear_tasks(sid)
    end

    if release_squad_safe(se_squad, "story_psy_watchdog_convert") ~= true then
        release_squad_safe(new_squad, "story_psy_watchdog_rollback")
        RUNTIME.processing_by_sid[new_sid] = nil
        RUNTIME.processing_by_sid[sid] = nil
        log_warn("convert_skip sid=%s source=%s reason=source_release_failed", tostring(sid), tostring(source or "-"))
        return false
    end

    finalize_spawned_squad(new_squad, context)

    RUNTIME.processing_by_sid[new_sid] = nil
    RUNTIME.processing_by_sid[sid] = nil

    log_info(
        "converted sid=%s new_sid=%s level=%s smart=%s members=%s tier=%s source=%s",
        tostring(sid),
        tostring(new_sid),
        tostring(context.level_name or "-"),
        tostring(context.smart_name or "-"),
        tostring(context.member_count or 0),
        tostring(context.zombied_squad_section or "-"),
        tostring(source or "-")
    )

    return true
end

local function try_process_squad(se_squad, source)
    local should_convert, entry = candidate_should_convert(se_squad, nil)
    if should_convert ~= true then
        return false
    end
    return convert_squad_to_zombied(se_squad, entry, source)
end

local function reconcile_level_once(level_name, source)
    if not is_target_level(level_name) then
        return 0
    end
    if not (zhopa.memory and zhopa.memory.get_managed_squads_by_level) then
        return 0
    end

    local by_level = zhopa.memory.get_managed_squads_by_level()
    local bucket = by_level and by_level[level_name] or nil
    if type(bucket) ~= "table" then
        return 0
    end

    local sids = {}
    for sid in pairs(bucket) do
        local normalized = normalize_alife_id(sid)
        if normalized then
            sids[#sids + 1] = normalized
        end
    end

    local converted = 0
    for i = 1, #sids do
        local squad = resolve_alife_object(sids[i])
        if squad and try_process_squad(squad, source or "reconcile_level") == true then
            converted = converted + 1
        end
    end
    return converted
end

local function build_psi_reconcile_levels()
    local levels = {}
    for level_name in pairs(get_psi_levels()) do
        levels[#levels + 1] = level_name
    end
    return levels
end

local function reconcile_all_levels(source, continuation)
    if not feature_enabled_now() then
        RUNTIME.psi_reconcile_levels = nil
        RUNTIME.psi_reconcile_cursor = 1
        return 0
    end
    if continuation ~= true or type(RUNTIME.psi_reconcile_levels) ~= "table" then
        RUNTIME.psi_reconcile_levels = build_psi_reconcile_levels()
        RUNTIME.psi_reconcile_cursor = 1
        RUNTIME.psi_reconcile_source = tostring(source or "reconcile_all")
    end

    local converted = 0
    local levels = RUNTIME.psi_reconcile_levels or {}
    local processed = 0
    while processed < PSI_RECONCILE_LEVEL_BUDGET and (tonumber(RUNTIME.psi_reconcile_cursor) or 1) <= #levels do
        local idx = tonumber(RUNTIME.psi_reconcile_cursor) or 1
        local level_name = levels[idx]
        RUNTIME.psi_reconcile_cursor = idx + 1
        converted = converted + reconcile_level_once(level_name, source or "reconcile_all")
        processed = processed + 1
    end

    if (tonumber(RUNTIME.psi_reconcile_cursor) or 1) <= #levels then
        if zhopa.timers and zhopa.timers.schedule then
            zhopa.timers.schedule("story_psy_watchdog", "psi_reconcile", PSI_RECONCILE_CONTINUE_MS, function()
                reconcile_all_levels(RUNTIME.psi_reconcile_source or source, true)
            end)
            return converted
        end
        while (tonumber(RUNTIME.psi_reconcile_cursor) or 1) <= #levels do
            local idx = tonumber(RUNTIME.psi_reconcile_cursor) or 1
            local level_name = levels[idx]
            RUNTIME.psi_reconcile_cursor = idx + 1
            converted = converted + reconcile_level_once(level_name, source or "reconcile_all")
        end
    end

    RUNTIME.psi_reconcile_levels = nil
    RUNTIME.psi_reconcile_cursor = 1
    RUNTIME.psi_reconcile_source = nil
    return converted
end

local function on_actor_first_update()
    invalidate_runtime_caches()
    reconcile_all_levels("actor_on_first_update")
end

local function on_load_state()
    invalidate_runtime_caches()
    reconcile_all_levels("load_state")
end

local function on_option_change()
    invalidate_runtime_caches()
    reconcile_all_levels("on_option_change")
end

local function on_squad_after_level_change(squad)
    if not (feature_enabled_now() and squad) then
        return
    end
    try_process_squad(squad, "squad_on_after_level_change")
end

watchdog.reconcile_all_levels = reconcile_all_levels
watchdog.on_actor_first_update = on_actor_first_update
watchdog.on_load_state = on_load_state
watchdog.on_option_change = on_option_change
watchdog.on_squad_after_level_change = on_squad_after_level_change
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_story_psy_watchdog

-- BEGIN module zhopa_story_events
zhopa_bundle_module = function()
zhopa = zhopa or {}
zhopa.story_events = zhopa.story_events or {}

local story_events = zhopa.story_events

local type = _G.type
local pcall = _G.pcall
local rawget = _G.rawget
local tonumber = _G.tonumber
local tostring = _G.tostring
local pairs = _G.pairs
local next = _G.next
local time_global = _G.time_global
local alife = _G.alife
local game_graph = _G.game_graph
local db = _G.db
local level = _G.level
local math_floor = _G.math and _G.math.floor or nil
local math_random = _G.math and _G.math.random or nil

local table_sort = table.sort
local string_gsub = string.gsub
local string_lower = string.lower

local STATE_KEY = "zhopa_story_events_state"
local EVENT_NORTH_MIGRATION = "north_migration"
local TASK_NORTH_MIGRATION = "STORY EVENT: NORTH MIGRATION"
local DISTANCE_FALLBACK = 1000000000
local ENEMIES_THRESHOLD = tonumber(_G.game_relations and _G.game_relations.ENEMIES) or -1000
local STORY_ARRIVAL_LIVE_GRACE_MS = 5000
local STORY_ARRIVAL_CONFIRM_MS = 3000

local NORTH_LEVELS = {
    "zaton",
    "jupiter",
    "pripyat",
}

local NORTH_LEVEL_SET = {
    zaton = true,
    jupiter = true,
    pripyat = true,
}

local EXCLUDED_COMMUNITIES = {
    monolith = true,
    greh = true,
    isg = true,
}

local RUNTIME = {
    surge_cache_active = false,
    surge_cache_next_tg = 0,
    rollout_running = false,
}

local function new_state()
    return {
        initialized = true,
        north_migration = {
            fired = false,
            legacy_skipped = false,
            selected_by_sid = {},
            status_by_sid = {},
        },
    }
end

local STATE = new_state()
local is_story_task

local function tg()
    return (time_global and time_global()) or 0
end

local function log_info(fmt, ...)
    if zhopa.log and zhopa.log.info then
        zhopa.log.info("STORY_EVENTS", fmt, ...)
    end
end

local function log_warn(fmt, ...)
    if zhopa.log and zhopa.log.warn then
        zhopa.log.warn("STORY_EVENTS", fmt, ...)
    end
end

local function trim(value)
    if type(value) ~= "string" then
        return nil
    end
    value = string_gsub(value, "^%s*(.-)%s*$", "%1")
    if value == "" then
        return nil
    end
    return value
end

local function lower_trim(value)
    value = trim(value)
    if not value then
        return nil
    end
    return string_lower(value)
end

local function normalize_community_key(value)
    if value == nil then
        return nil
    end
    if type(value) ~= "string" then
        value = tostring(value)
    end
    local key = lower_trim(value)
    if not key then
        return nil
    end
    if zhopa.config and zhopa.config.get_faction_alias then
        local alias = zhopa.config.get_faction_alias(key)
        alias = lower_trim(alias)
        if alias then
            key = alias
        end
    end
    return key
end

local function normalize_status(value)
    value = lower_trim(value)
    if value == "travel" or value == "done" or value == "dead_or_invalid" then
        return value
    end
    return "pending"
end

local function normalize_sid(value)
    local sid = tonumber(value)
    if not sid or sid <= 0 or sid == 65535 then
        return nil
    end
    return sid
end

local function resolve_alife_object(id)
    id = normalize_sid(id)
    if not (id and alife) then
        return nil
    end
    local sim = alife()
    if not sim then
        return nil
    end
    local ok, obj = pcall(function()
        return sim:object(id)
    end)
    if ok then
        return obj
    end
    return nil
end

local function now_level_name_by_gvid(gvid)
    gvid = tonumber(gvid)
    if not (gvid and alife and game_graph) then
        return nil
    end
    local ok, res = pcall(function()
        local gg = game_graph()
        if not gg then
            return nil
        end
        local gv = gg:vertex(gvid)
        if not gv then
            return nil
        end
        local sim = alife()
        if not sim then
            return nil
        end
        return sim:level_name(gv:level_id())
    end)
    if ok and type(res) == "string" and res ~= "" then
        return res
    end
    return nil
end

local function get_board()
    if rawget(_G, "SIMBOARD") then
        return rawget(_G, "SIMBOARD")
    end
    if _G.sim_board and _G.sim_board.get_sim_board then
        local ok, board = pcall(function()
            return _G.sim_board.get_sim_board()
        end)
        if ok then
            return board
        end
    end
    return nil
end

local function resolve_smart_by_name(smart_name)
    smart_name = trim(smart_name)
    if not smart_name then
        return nil
    end
    local board = get_board()
    if not (board and board.smarts_by_names) then
        return nil
    end
    return board.smarts_by_names[smart_name]
end

local function resolve_smart_id(smart_name)
    local smart = resolve_smart_by_name(smart_name)
    return tonumber(smart and smart.id) or nil, smart
end

local function resolve_smart_level_name(smart_name, fallback_level)
    smart_name = trim(smart_name)
    if not smart_name then
        return fallback_level
    end
    if zhopa.board_index and zhopa.board_index.get_smart_level then
        local indexed = zhopa.board_index.get_smart_level(smart_name)
        if type(indexed) == "string" and indexed ~= "" then
            return indexed
        end
    end
    local smart = resolve_smart_by_name(smart_name)
    local gvid = tonumber(smart and smart.m_game_vertex_id) or nil
    if gvid then
        return now_level_name_by_gvid(gvid) or fallback_level
    end
    return fallback_level
end

local function has_alife_info_safe(info)
    if type(info) ~= "string" or info == "" then
        return false
    end

    local fn = rawget(_G, "has_alife_info")
    if type(fn) == "function" then
        local ok, has = pcall(fn, info)
        if ok then
            return has == true
        end
    end

    local actor = db and db.actor or nil
    if actor and actor.has_info then
        local ok, has = pcall(function()
            return actor:has_info(info)
        end)
        if ok then
            return has == true
        end
    end

    return false
end

local function is_story_mode_active()
    return has_alife_info_safe("story_mode_disabled") ~= true
end

local function get_cfg_bool(key, fallback)
    if zhopa.runtime_cfg and zhopa.runtime_cfg.bool then
        return zhopa.runtime_cfg.bool(key, fallback)
    elseif zhopa.config and zhopa.config.get then
        local value = zhopa.config.get(key, fallback)
        if value ~= nil then
            return value == true
        end
    end
    return fallback == true
end

local function feature_enabled_now()
    if zhopa.switches and zhopa.switches.story_events == false then
        return false
    end
    if get_cfg_bool("enabled", true) ~= true then
        return false
    end
    if get_cfg_bool("story_events_enabled", true) ~= true then
        return false
    end
    if get_cfg_bool("story_events_north_migration_enabled", true) ~= true then
        return false
    end
    return true
end

local function migration_trigger_active()
    if is_story_mode_active() ~= true then
        return false
    end
    return has_alife_info_safe("bar_deactivate_radar_done") == true
end

local function get_north_migration_percent()
    local percent = tonumber(zhopa.config and zhopa.config.get and zhopa.config.get("story_events_north_migration_percent", 50) or 50) or 50
    if percent < 0 then
        percent = 0
    elseif percent > 100 then
        percent = 100
    end
    return percent
end

local function is_protected_squad(se_squad)
    if zhopa.memory and zhopa.memory.is_protected_squad then
        local ok, protected = pcall(zhopa.memory.is_protected_squad, se_squad)
        if ok then
            return protected == true
        end
    end
    return false
end

local function get_state_event()
    if type(STATE) ~= "table" then
        STATE = new_state()
    end
    if type(STATE.north_migration) ~= "table" then
        STATE.north_migration = {
            fired = false,
            legacy_skipped = false,
            selected_by_sid = {},
            status_by_sid = {},
        }
    end
    STATE.initialized = true
    STATE.north_migration.selected_by_sid = type(STATE.north_migration.selected_by_sid) == "table" and STATE.north_migration.selected_by_sid or {}
    STATE.north_migration.status_by_sid = type(STATE.north_migration.status_by_sid) == "table" and STATE.north_migration.status_by_sid or {}
    return STATE.north_migration
end

local function set_sid_status(sid, status)
    sid = normalize_sid(sid)
    if not sid then
        return
    end
    local event = get_state_event()
    event.status_by_sid[sid] = normalize_status(status)
end

local function recover_story_selection_from_entry(sid, entry, source)
    sid = normalize_sid(sid or (type(entry) == "table" and entry.squad_id))
    if not sid or type(entry) ~= "table" then
        return false
    end
    local current = entry.tasks and entry.tasks.current or nil
    if is_story_task(current) ~= true then
        return false
    end
    local event = get_state_event()
    event.selected_by_sid[sid] = true
    if normalize_status(event.status_by_sid[sid]) ~= "done" then
        event.status_by_sid[sid] = "travel"
    end
    if zhopa.log and zhopa.log.info and source then
        zhopa.log.info("STORY_EVENTS", "north_migration_recover sid=%s source=%s target=%s",
            tostring(sid),
            tostring(source),
            tostring(current.target or "-")
        )
    end
    return true
end

local function recover_story_selection_from_memory(source)
    local state = zhopa.memory and zhopa.memory.get_state and zhopa.memory.get_state() or nil
    local squads = type(state) == "table" and type(state.squads) == "table" and state.squads or nil
    if type(squads) ~= "table" then
        return 0
    end
    local recovered = 0
    for sid, entry in pairs(squads) do
        if recover_story_selection_from_entry(sid, entry, source) == true then
            recovered = recovered + 1
        end
    end
    return recovered
end

local function is_transient_reconcile_source(source)
    source = tostring(source or "")
    return source == "load_state" or source == "actor_on_first_update"
end

local function is_sid_selected(sid)
    sid = normalize_sid(sid)
    if not sid then
        return false
    end
    local event = get_state_event()
    return event.selected_by_sid[sid] == true
end

local function is_sid_locked(sid)
    sid = normalize_sid(sid)
    if not sid then
        return false
    end
    if feature_enabled_now() ~= true then
        return false
    end
    if is_sid_selected(sid) ~= true then
        return false
    end
    local event = get_state_event()
    local status = normalize_status(event.status_by_sid[sid])
    return status ~= "done" and status ~= "dead_or_invalid"
end

local function normalize_sid_set(src)
    local out = {}
    if type(src) ~= "table" then
        return out
    end
    for k, v in pairs(src) do
        local sid = normalize_sid(k)
        if sid and v ~= false and v ~= nil then
            out[sid] = true
        elseif sid == nil then
            sid = normalize_sid(v)
            if sid then
                out[sid] = true
            end
        end
    end
    return out
end

local function normalize_status_map(src)
    local out = {}
    if type(src) ~= "table" then
        return out
    end
    for k, v in pairs(src) do
        local sid = normalize_sid(k)
        if sid then
            out[sid] = normalize_status(v)
        end
    end
    return out
end

local function load_state_blob(m_data)
    local blob = type(m_data) == "table" and m_data[STATE_KEY] or nil
    if type(blob) == "table" then
        STATE = {
            initialized = blob.initialized == true,
            north_migration = {
                fired = type(blob.north_migration) == "table" and blob.north_migration.fired == true or false,
                legacy_skipped = type(blob.north_migration) == "table" and blob.north_migration.legacy_skipped == true or false,
                selected_by_sid = normalize_sid_set(type(blob.north_migration) == "table" and blob.north_migration.selected_by_sid or nil),
                status_by_sid = normalize_status_map(type(blob.north_migration) == "table" and blob.north_migration.status_by_sid or nil),
            },
        }
        STATE.initialized = true
        return
    end

    STATE = new_state()
    if migration_trigger_active() == true then
        local event = get_state_event()
        event.fired = true
        event.legacy_skipped = true
    end
end

local function save_state_blob(m_data)
    if type(m_data) ~= "table" then
        return
    end
    local event = get_state_event()
    m_data[STATE_KEY] = {
        initialized = true,
        north_migration = {
            fired = event.fired == true,
            legacy_skipped = event.legacy_skipped == true,
            selected_by_sid = normalize_sid_set(event.selected_by_sid),
            status_by_sid = normalize_status_map(event.status_by_sid),
        },
    }
end

local function get_memory_entry(sid)
    if not (zhopa.memory and zhopa.memory.get_squad_entry) then
        return nil
    end
    return zhopa.memory.get_squad_entry(sid)
end

local function touch_or_get_entry(se_squad, sid, source)
    sid = normalize_sid(sid or (se_squad and se_squad.id))
    if not sid then
        return nil
    end
    if se_squad and zhopa.memory and zhopa.memory.upsert_snapshot then
        local ok, entry = pcall(zhopa.memory.upsert_snapshot, se_squad, tostring(source or "story_events"))
        if ok and type(entry) == "table" then
            return entry
        end
    end
    return get_memory_entry(sid)
end

is_story_task = function(task)
    if type(task) ~= "table" then
        return false
    end
    if task.type ~= TASK_NORTH_MIGRATION then
        return false
    end
    local params = type(task.params) == "table" and task.params or nil
    if not params then
        return false
    end
    if params.story_event == true and params.story_event_name == EVENT_NORTH_MIGRATION then
        return true
    end
    return false
end

local function make_story_task(target, target_level)
    local now = tg()
    return {
        id = TASK_NORTH_MIGRATION .. "_" .. tostring(now),
        type = TASK_NORTH_MIGRATION,
        target = target,
        created_at_tg = now,
        priority = 100,
        params = {
            story_event = true,
            story_event_name = EVENT_NORTH_MIGRATION,
            target_level = target_level,
            started_at_tg = now,
            arrival_live_check_after_tg = now + STORY_ARRIVAL_LIVE_GRACE_MS,
            in_transit = true,
        },
    }
end

local function clear_task_apply_state(task)
    if type(task) ~= "table" then
        return
    end
    task.params = type(task.params) == "table" and task.params or {}
    task.params._applied = nil
    task.params.online_intent_next_tg = nil
    task.params.arrival_candidate_source = nil
    task.params.arrival_candidate_tg = nil
    task.params.arrival_candidate_smart = nil
end

local function set_squad_always_arrived(se_squad, should_hold)
    if not se_squad then
        return
    end
    pcall(function()
        se_squad.always_arrived = should_hold == true
    end)
end

local function is_target_sync_enabled()
    return get_cfg_bool("target_sync_enabled", true) == true
end

local function get_online_intent_enforce_enabled()
    return get_cfg_bool("online_intent_enforce_enabled", true) == true
end

local function set_scripted_target(se_squad, smart_name, params, opts)
    if not se_squad then
        return false
    end
    se_squad.scripted_target = smart_name
    if se_squad.task_target_id ~= nil then
        se_squad.task_target_id = nil
    end

    if not is_target_sync_enabled() then
        return true
    end
    if type(smart_name) ~= "string" or smart_name == "" then
        return true
    end

    params = type(params) == "table" and params or nil
    local now = tg()
    local smart_id = nil
    smart_id = resolve_smart_id(smart_name)
    local force_sync = opts and opts.force_sync == true

    local changed = false
    if params then
        changed = params.target_sync_name ~= smart_name
        params.target_sync_name = smart_name
        params.target_sync_smart_id = smart_id or nil
        if changed then
            params.target_sync_started_tg = now
            params.target_last_progress_tg = now
            params.target_last_gvid = tonumber(se_squad.m_game_vertex_id) or nil
            params.target_last_assigned_id = tonumber(se_squad.assigned_target_id) or nil
            params.target_last_current_id = tonumber(se_squad.current_target_id) or nil
            params.target_last_action = tonumber(se_squad.current_action) or nil
        end
    end

    if changed or force_sync then
        se_squad.current_action = 0
        se_squad.current_target_id = nil
        if smart_id then
            se_squad.assigned_target_id = smart_id
        end
        se_squad.stay_time = nil
        se_squad.arrive_time = nil
        if params then
            params.target_last_progress_tg = now
            params.target_last_gvid = tonumber(se_squad.m_game_vertex_id) or nil
            params.target_last_assigned_id = tonumber(se_squad.assigned_target_id) or nil
            params.target_last_current_id = tonumber(se_squad.current_target_id) or nil
            params.target_last_action = tonumber(se_squad.current_action) or nil
        end
    end

    return true
end

local function is_online_squad(se_squad)
    if not se_squad then
        return false
    end
    local ok, online = pcall(function()
        return se_squad.online
    end)
    return ok and online == true
end

local function should_enforce_online_intent(task, now, entry)
    if zhopa.tasks and type(zhopa.tasks._should_enforce_online_intent) == "function" then
        return zhopa.tasks._should_enforce_online_intent(task, now, entry) == true
    end
    task = type(task) == "table" and task or nil
    if not task then
        return false
    end
    local params = type(task.params) == "table" and task.params or nil
    if not params then
        return false
    end
    local next_tg = tonumber(params.online_intent_next_tg) or 0
    return tonumber(now) >= next_tg
end

local function enforce_online_task_intent(se_squad, entry, task)
    if get_online_intent_enforce_enabled() ~= true then
        return
    end
    if not (se_squad and entry and type(task) == "table") then
        return
    end
    if not is_online_squad(se_squad) then
        return
    end
    if type(task.target) ~= "string" or task.target == "" then
        return
    end

    local target_id = resolve_smart_id(task.target)
    local scripted_target = se_squad.scripted_target
    local assigned_target = tonumber(se_squad.assigned_target_id) or nil
    local current_action = tonumber(se_squad.current_action) or nil
    local mismatch = false

    if scripted_target ~= task.target then mismatch = true end
    if target_id and assigned_target and assigned_target ~= target_id then mismatch = true end
    if current_action == nil then mismatch = true end

    if mismatch then
        set_scripted_target(se_squad, task.target, task.params, { force_sync = true, reason = "online_intent_enforce" })
    end
end

local function clear_live_task_state(se_squad)
    if not se_squad then
        return
    end
    set_squad_always_arrived(se_squad, false)
    pcall(function() se_squad.scripted_target = nil end)
    pcall(function() se_squad.assigned_target_id = nil end)
    pcall(function() se_squad.current_target_id = nil end)
    pcall(function() se_squad.task_target_id = nil end)
    pcall(function() se_squad.current_action = 0 end)
    pcall(function() se_squad.stay_time = nil end)
    pcall(function() se_squad.arrive_time = nil end)
end

local function sync_story_task_live_state(se_squad, task)
    if not (se_squad and type(task) == "table") then
        return
    end
    task.params = type(task.params) == "table" and task.params or {}
    set_squad_always_arrived(se_squad, false)
    if set_scripted_target(se_squad, task.target, task.params, {
        force_sync = task.params._applied ~= true or se_squad.scripted_target ~= task.target,
        reason = "story_event_sync",
    }) then
        task.params._applied = true
    end
end

local function get_arrive_dist_cap_m()
    local value = 5
    if zhopa.runtime_cfg and zhopa.runtime_cfg.num then
        value = zhopa.runtime_cfg.num("task_arrive_dist_cap_m", value, 0)
    else
        value = tonumber(zhopa.config and zhopa.config.get and zhopa.config.get("task_arrive_dist_cap_m", value) or value) or value
    end
    if value < 0 then
        value = 0
    end
    return value
end

local function vanilla_am_i_reached(se_squad, smart)
    if not (se_squad and smart) then
        return false
    end

    local sgvid = tonumber(se_squad.m_game_vertex_id) or nil
    local tgvid = tonumber(smart.m_game_vertex_id) or nil
    if sgvid and tgvid and sgvid == tgvid then
        return true
    end

    if sgvid and tgvid and game_graph then
        local ok_lvl, same_level = pcall(function()
            local gg = game_graph()
            return gg and gg:vertex(sgvid):level_id() == gg:vertex(tgvid):level_id()
        end)
        if ok_lvl and same_level == false then
            return false
        end
    end

    local cap_m = get_arrive_dist_cap_m()
    if cap_m <= 0 then
        return false
    end

    local pos_s = zhopa.safe and zhopa.safe.safe_position and zhopa.safe.safe_position(se_squad) or nil
    local pos_t = smart.position
    if not (pos_s and pos_t and pos_s.distance_to_sqr) then
        return false
    end

    local arrive_dist = tonumber(smart.arrive_dist) or cap_m
    if arrive_dist > cap_m then
        arrive_dist = cap_m
    end

    local ok_alw, alw = pcall(function()
        return se_squad.always_arrived
    end)
    if ok_alw and alw == true then
        return true
    end

    local ok_d2, d2 = pcall(function()
        return pos_s:distance_to_sqr(pos_t)
    end)
    d2 = ok_d2 and tonumber(d2) or nil
    if not d2 then
        return false
    end

    return d2 <= (arrive_dist * arrive_dist)
end

local function get_story_live_arrival_signal(se_squad, smart_name)
    local smart = resolve_smart_by_name(smart_name)
    if not (se_squad and smart) then
        return nil
    end

    local current_action = tonumber(se_squad.current_action) or nil
    local current_target = tonumber(se_squad.current_target_id) or nil
    local smart_slot = tonumber(se_squad.smart_id) or nil
    local smart_id = tonumber(smart.id) or nil

    if current_action == 1 and smart_id and ((current_target and current_target == smart_id) or (smart_slot and smart_slot == smart_id)) then
        return "fast_current"
    end

    if smart.am_i_reached then
        local ok, reached = pcall(function()
            return smart:am_i_reached(se_squad)
        end)
        if ok and reached == true then
            return "smart_am_i_reached"
        end
    end

    if vanilla_am_i_reached(se_squad, smart) == true then
        return "vanilla_fallback"
    end
    return nil
end

local function entry_arrived_to_smart(entry, smart_name, smart_id)
    if type(entry) ~= "table" then
        return false
    end
    local params = entry.tasks and entry.tasks.current and entry.tasks.current.params or nil
    if params and params.entered_target_smart == smart_name then
        return true
    end
    local current_action = tonumber(entry.current_action) or tonumber(entry.tasks and entry.tasks.current and entry.tasks.current.params and entry.tasks.current.params.target_last_action) or nil
    local entry_smart_id = tonumber(entry.smart_id) or nil
    if current_action == 1 and smart_id and entry_smart_id and entry_smart_id == smart_id then
        return true
    end
    return false
end

local function live_arrival_check_allowed(task)
    local params = type(task) == "table" and type(task.params) == "table" and task.params or nil
    if not params then
        return true
    end
    local check_after = tonumber(params.arrival_live_check_after_tg) or 0
    return tg() >= check_after
end

local function clear_story_arrival_candidate(task)
    local params = type(task) == "table" and type(task.params) == "table" and task.params or nil
    if not params then
        return
    end
    params.arrival_candidate_source = nil
    params.arrival_candidate_tg = nil
    params.arrival_candidate_smart = nil
end

local function consume_story_live_arrival_signal(task, signal, smart_name)
    local params = type(task) == "table" and type(task.params) == "table" and task.params or nil
    if not params then
        return false
    end

    if not signal then
        clear_story_arrival_candidate(task)
        return false
    end

    if signal == "fast_current" then
        clear_story_arrival_candidate(task)
        return true
    end

    if signal == "smart_am_i_reached" then
        local now = tg()
        local same_source = params.arrival_candidate_source == signal
        local same_smart = params.arrival_candidate_smart == smart_name
        local candidate_tg = tonumber(params.arrival_candidate_tg) or 0
        if same_source and same_smart and now >= (candidate_tg + STORY_ARRIVAL_CONFIRM_MS) then
            clear_story_arrival_candidate(task)
            return true
        end
        params.arrival_candidate_source = signal
        params.arrival_candidate_tg = now
        params.arrival_candidate_smart = smart_name
        return false
    end

    params.arrival_candidate_source = signal
    params.arrival_candidate_tg = tg()
    params.arrival_candidate_smart = smart_name
    return false
end

local function is_story_arrived(entry, se_squad, smart_name, smart_id, task)
    if entry_arrived_to_smart(entry, smart_name, smart_id) then
        clear_story_arrival_candidate(task)
        return true
    end
    if se_squad and live_arrival_check_allowed(task) then
        local signal = get_story_live_arrival_signal(se_squad, smart_name)
        return consume_story_live_arrival_signal(task, signal, smart_name) == true
    end
    return false
end

local function try_game_graph_distance(sgvid, tgvid)
    sgvid = tonumber(sgvid)
    tgvid = tonumber(tgvid)
    if not (sgvid and tgvid and game_graph) then
        return nil
    end
    local ok, distance = pcall(function()
        local gg = game_graph()
        if not gg then
            return nil
        end
        return gg:distance(sgvid, tgvid)
    end)
    distance = ok and tonumber(distance) or nil
    return distance
end

local function surge_active_uncached()
    local xr = _G.xr_conditions
    local surge_started = xr and xr.surge_started or nil
    if type(surge_started) == "function" then
        local ok, active = pcall(surge_started)
        if ok and (active == true or active == false) then
            return active == true
        end
    end

    local fn = _G.surge_started
    if type(fn) == "function" then
        local ok, active = pcall(fn)
        if ok and (active == true or active == false) then
            return active == true
        end
    end

    local psm = _G.psi_storm_manager
    if psm and type(psm.is_loaded) == "function" and type(psm.is_started) == "function" then
        local ok_loaded, loaded = pcall(function() return psm.is_loaded() end)
        if ok_loaded and loaded == true then
            local ok_started, started = pcall(function() return psm.is_started() end)
            if ok_started and started == true then
                return true
            end
        end
    end

    local sm = _G.surge_manager
    if sm and type(sm.is_loaded) == "function" and type(sm.is_started) == "function" then
        local ok_loaded, loaded = pcall(function() return sm.is_loaded() end)
        if ok_loaded and loaded == true then
            local ok_started, started = pcall(function() return sm.is_started() end)
            if ok_started and started == true then
                return true
            end
        end
    end

    if level and type(level.is_surge) == "function" then
        local ok, active = pcall(function() return level.is_surge() end)
        if ok and active == true then
            return true
        end
    end

    return false
end

local function is_surge_active_now()
    local now = tg()
    if now < (tonumber(RUNTIME.surge_cache_next_tg) or 0) then
        return RUNTIME.surge_cache_active == true
    end
    local active = surge_active_uncached() == true
    local cache_ms = 250
    if zhopa.runtime_cfg and zhopa.runtime_cfg.num then
        cache_ms = zhopa.runtime_cfg.num("surge_check_cache_ms", cache_ms, 0)
    else
        cache_ms = tonumber(zhopa.config and zhopa.config.get and zhopa.config.get("surge_check_cache_ms", cache_ms) or cache_ms) or cache_ms
        if cache_ms < 0 then
            cache_ms = 0
        end
    end
    RUNTIME.surge_cache_active = active
    RUNTIME.surge_cache_next_tg = now + cache_ms
    return active
end

local function shuffle_in_place(arr)
    if type(arr) ~= "table" or not math_random then
        return arr
    end
    for i = #arr, 2, -1 do
        local j = math_random(i)
        if j ~= i then
            arr[i], arr[j] = arr[j], arr[i]
        end
    end
    return arr
end

local function pick_random(arr)
    if type(arr) ~= "table" or #arr <= 0 or not math_random then
        return nil
    end
    return arr[math_random(#arr)]
end

local function relation_allows_coexist(source_community, other_community)
    source_community = normalize_community_key(source_community)
    other_community = normalize_community_key(other_community)
    if not (source_community and other_community) then
        return false
    end
    if source_community == other_community then
        return true
    end
    if _G.game_relations and type(_G.game_relations.get_factions_community) == "function" then
        local ok, relation = pcall(function()
            return _G.game_relations.get_factions_community(source_community, other_community)
        end)
        relation = ok and tonumber(relation) or nil
        if relation ~= nil then
            return relation > ENEMIES_THRESHOLD
        end
    end
    return false
end

local function collect_smart_communities(level_name, smart_name)
    local out = {}
    local seen = {}
    if not (type(level_name) == "string" and level_name ~= "" and type(smart_name) == "string" and smart_name ~= "") then
        return out
    end
    local index = zhopa.memory and zhopa.memory.get_communities_by_smart_level and zhopa.memory.get_communities_by_smart_level() or nil
    if type(index) == "table" then
        local by_level = type(index[smart_name]) == "table" and index[smart_name][level_name] or nil
        if type(by_level) == "table" then
            for community in pairs(by_level) do
                local key = normalize_community_key(community)
                if key and seen[key] ~= true then
                    seen[key] = true
                    out[#out + 1] = key
                end
            end
        end
    end

    local event = get_state_event()
    for sid in pairs(event.selected_by_sid) do
        local status = normalize_status(event.status_by_sid[sid])
        if status ~= "done" and status ~= "dead_or_invalid" then
            local entry = get_memory_entry(sid)
            local current = entry and entry.tasks and entry.tasks.current or nil
            if is_story_task(current) == true and current.target == smart_name then
                local current_level = resolve_smart_level_name(current.target, current.params and current.params.target_level or entry and entry.level or nil)
                if current_level == level_name then
                    local key = normalize_community_key(entry and entry.community)
                    if key and seen[key] ~= true then
                        seen[key] = true
                        out[#out + 1] = key
                    end
                end
            end
        end
    end

    return out
end

local function is_story_target_safe(smart_name, level_name, community, section_name)
    if not (type(smart_name) == "string" and smart_name ~= "" and type(level_name) == "string" and level_name ~= "") then
        return false, "invalid_target"
    end
    if not (zhopa.tasks and zhopa.tasks.is_smart_spawn_allowed) then
        return false, "tasks_gate_missing"
    end
    local allowed, reason = zhopa.tasks.is_smart_spawn_allowed(smart_name, community, level_name, section_name)
    if allowed ~= true then
        return false, tostring(reason or "blocked")
    end
    local occupancy = collect_smart_communities(level_name, smart_name)
    for i = 1, #occupancy do
        if relation_allows_coexist(community, occupancy[i]) ~= true then
            return false, "relation:" .. tostring(occupancy[i])
        end
    end
    return true
end

local function distance_to_smart(se_squad, entry, smart_name)
    smart_name = trim(smart_name)
    if not smart_name then
        return DISTANCE_FALLBACK
    end
    local smart = resolve_smart_by_name(smart_name)
    if not smart then
        return DISTANCE_FALLBACK
    end
    local squad_gvid = tonumber(se_squad and se_squad.m_game_vertex_id) or tonumber(entry and entry.level_gvid) or nil
    local smart_gvid = tonumber(smart.m_game_vertex_id) or nil
    local distance = try_game_graph_distance(squad_gvid, smart_gvid)
    if distance ~= nil then
        return distance
    end
    local pos_s = zhopa.safe and zhopa.safe.safe_position and zhopa.safe.safe_position(se_squad) or nil
    local pos_t = smart.position
    if pos_s and pos_t and pos_s.distance_to then
        local ok, fallback = pcall(function()
            return pos_s:distance_to(pos_t)
        end)
        fallback = ok and tonumber(fallback) or nil
        if fallback ~= nil then
            return fallback
        end
    end
    return DISTANCE_FALLBACK
end

local function get_level_base_smarts(level_name)
    if zhopa.board_index and zhopa.board_index.get_base_smarts then
        return zhopa.board_index.get_base_smarts(level_name) or {}
    end
    return {}
end

local function get_level_smarts(level_name)
    if zhopa.board_index and zhopa.board_index.get_level_smarts then
        return zhopa.board_index.get_level_smarts(level_name) or {}
    end
    return {}
end

local function get_level_territory_smarts(level_name)
    if not (zhopa.board_index and zhopa.board_index.get_level_smarts) then
        return {}
    end
    return zhopa.board_index.get_level_smarts(level_name, function(smart_name)
        local smart = resolve_smart_by_name(smart_name)
        local props = smart and smart.props or nil
        return tonumber(props and props.territory) and tonumber(props and props.territory) > 0 or false
    end) or {}
end

local function get_level_neighbors(level_name, community, section_name)
    if type(level_name) ~= "string" or level_name == "" then
        return {}
    end
    if zhopa.board_index and zhopa.board_index.get_level_neighbors then
        local res = zhopa.board_index.get_level_neighbors(level_name, {
            community = community,
            section_name = section_name,
        })
        if type(res) == "table" then
            return res
        end
    end
    return {}
end

local function get_north_level_projected_load(level_name, exclude_sid)
    level_name = lower_trim(level_name)
    exclude_sid = normalize_sid(exclude_sid)
    if not level_name or NORTH_LEVEL_SET[level_name] ~= true then
        return 0
    end

    local event = get_state_event()
    local load = 0
    for sid in pairs(event.selected_by_sid) do
        sid = normalize_sid(sid)
        if sid and sid ~= exclude_sid then
            local status = normalize_status(event.status_by_sid[sid])
            if status ~= "dead_or_invalid" then
                local entry = get_memory_entry(sid)
                local current = entry and entry.tasks and entry.tasks.current or nil
                local current_level = nil
                if is_story_task(current) == true then
                    current_level = resolve_smart_level_name(current.target, current.params and current.params.target_level or entry and entry.level or nil)
                elseif status == "done" and type(entry) == "table" then
                    current_level = lower_trim(entry.level)
                end
                current_level = lower_trim(current_level)
                if current_level == level_name then
                    load = load + 1
                end
            end
        end
    end
    return load
end

local function level_order_for_squad(se_squad, entry)
    local scored = {}
    local source_sid = normalize_sid(entry and entry.squad_id)
    for i = 1, #NORTH_LEVELS do
        local level_name = NORTH_LEVELS[i]
        local bases = get_level_base_smarts(level_name)
        local best = DISTANCE_FALLBACK
        for j = 1, #bases do
            local d = distance_to_smart(se_squad, entry, bases[j])
            if d < best then
                best = d
            end
        end
        scored[#scored + 1] = {
            level = level_name,
            load = get_north_level_projected_load(level_name, source_sid),
            distance = best,
            order = i,
        }
    end

    table_sort(scored, function(a, b)
        local la = tonumber(a and a.load) or 0
        local lb = tonumber(b and b.load) or 0
        if la ~= lb then
            return la < lb
        end
        local da = tonumber(a and a.distance) or DISTANCE_FALLBACK
        local dbv = tonumber(b and b.distance) or DISTANCE_FALLBACK
        if da ~= dbv then
            return da < dbv
        end
        return (tonumber(a and a.order) or 0) < (tonumber(b and b.order) or 0)
    end)

    local out = {}
    for i = 1, #scored do
        out[i] = scored[i].level
    end
    return out
end

local function pick_nearest_safe_base_on_level(se_squad, entry, community, section_name, level_name)
    local bases = get_level_base_smarts(level_name)
    if #bases <= 0 then
        return nil
    end

    local best_name = nil
    local best_distance = nil
    local fallback = {}

    for i = 1, #bases do
        local smart_name = bases[i]
        local safe = is_story_target_safe(smart_name, level_name, community, section_name)
        if safe == true then
            local d = distance_to_smart(se_squad, entry, smart_name)
            if d < DISTANCE_FALLBACK then
                if best_distance == nil or d < best_distance then
                    best_distance = d
                    best_name = smart_name
                end
            else
                fallback[#fallback + 1] = smart_name
            end
        end
    end

    if best_name then
        return best_name
    end
    return pick_random(fallback)
end

local function pick_nearest_safe_territory_on_level(se_squad, entry, community, section_name, level_name)
    local territories = get_level_territory_smarts(level_name)
    if #territories <= 0 then
        return nil
    end

    local best_name = nil
    local best_distance = nil
    local fallback = {}

    for i = 1, #territories do
        local smart_name = territories[i]
        local safe = is_story_target_safe(smart_name, level_name, community, section_name)
        if safe == true then
            local d = distance_to_smart(se_squad, entry, smart_name)
            if d < DISTANCE_FALLBACK then
                if best_distance == nil or d < best_distance then
                    best_distance = d
                    best_name = smart_name
                end
            else
                fallback[#fallback + 1] = smart_name
            end
        end
    end

    if best_name then
        return best_name
    end
    return pick_random(fallback)
end

local function pick_random_safe_smart_on_level(community, section_name, level_name)
    local smarts = get_level_smarts(level_name)
    if #smarts <= 0 then
        return nil
    end
    local safe = {}
    for i = 1, #smarts do
        local smart_name = smarts[i]
        local ok_safe = is_story_target_safe(smart_name, level_name, community, section_name)
        if ok_safe == true then
            safe[#safe + 1] = smart_name
        end
    end
    return pick_random(safe)
end

local function pick_safe_target_on_level(se_squad, entry, community, section_name, level_name)
    local best_base = pick_nearest_safe_base_on_level(se_squad, entry, community, section_name, level_name)
    if best_base then
        return best_base, level_name
    end
    local best_territory = pick_nearest_safe_territory_on_level(se_squad, entry, community, section_name, level_name)
    if best_territory then
        return best_territory, level_name
    end
    local fallback = pick_random_safe_smart_on_level(community, section_name, level_name)
    if fallback then
        return fallback, level_name
    end
    return nil, nil
end

local function pick_north_migration_target(se_squad, entry)
    if type(entry) ~= "table" then
        return nil, nil
    end
    local community = normalize_community_key(entry.community)
    local section_name = entry.section
    if not (community and type(section_name) == "string" and section_name ~= "") then
        return nil, nil
    end

    local ordered_levels = level_order_for_squad(se_squad, entry)
    local searched_levels = {}
    for i = 1, #ordered_levels do
        local level_name = ordered_levels[i]
        if searched_levels[level_name] ~= true then
            searched_levels[level_name] = true
            local target, target_level = pick_safe_target_on_level(se_squad, entry, community, section_name, level_name)
            if target then
                return target, target_level
            end
        end

        local neighbors = get_level_neighbors(level_name, community, section_name)
        for j = 1, #neighbors do
            local neighbor_level = neighbors[j]
            if searched_levels[neighbor_level] ~= true then
                searched_levels[neighbor_level] = true
                local target, target_level = pick_safe_target_on_level(se_squad, entry, community, section_name, neighbor_level)
                if target then
                    return target, target_level
                end
            end
        end
    end

    return nil, nil
end

local function is_eligible_human_entry(entry, se_squad)
    if type(entry) ~= "table" then
        return false
    end
    if entry.allowed ~= true then
        return false
    end
    if entry.npc_kind ~= "stalker" then
        return false
    end
    local community = normalize_community_key(entry.community)
    if not community or EXCLUDED_COMMUNITIES[community] == true then
        return false
    end
    if not se_squad then
        return false
    end
    if is_protected_squad(se_squad) then
        return false
    end
    return true
end

local function maybe_finish_as_rest(se_squad, sid, source)
    sid = normalize_sid(sid)
    if not (sid and se_squad and zhopa.tasks and zhopa.tasks.force_rest_after_external_reclaim) then
        return false
    end
    return zhopa.tasks.force_rest_after_external_reclaim(se_squad, source or "story_event_done") == true
end

local function log_story_rest_transition(sid, target, level_name, reason, rest_ok)
    log_info(
        "north_migration_rest sid=%s target=%s level=%s reason=%s rest_ok=%s",
        tostring(sid or "-"),
        tostring(target or "-"),
        tostring(level_name or "-"),
        tostring(reason or "-"),
        tostring(rest_ok == true)
    )
end

local function clear_story_task_if_present(se_squad, sid, current, reason)
    sid = normalize_sid(sid)
    if not sid then
        return false
    end
    if is_story_task(current) ~= true then
        return false
    end
    clear_live_task_state(se_squad)
    if zhopa.memory and zhopa.memory.set_task_current then
        zhopa.memory.set_task_current(sid, nil)
    end
    log_info("north_migration_clear sid=%s reason=%s", tostring(sid), tostring(reason or "clear"))
    return true
end

local function assign_story_task(se_squad, sid, target, target_level, source)
    sid = normalize_sid(sid)
    target = trim(target)
    if not (sid and target and zhopa.memory and zhopa.memory.set_task_current) then
        return false
    end
    local task = make_story_task(target, target_level)
    clear_task_apply_state(task)
    zhopa.memory.set_task_current(sid, task)
    local current = get_memory_entry(sid)
    current = current and current.tasks and current.tasks.current or task
    set_sid_status(sid, "travel")
    if se_squad then
        sync_story_task_live_state(se_squad, current)
        local now = tg()
        if should_enforce_online_intent(current, now, get_memory_entry(sid)) then
            pcall(enforce_online_task_intent, se_squad, get_memory_entry(sid), current)
        end
    end
    log_info("north_migration_assign sid=%s target=%s level=%s source=%s", tostring(sid), tostring(target), tostring(target_level), tostring(source or "assign"))
    return true
end

local function retarget_story_task(se_squad, sid, entry, current_story, source)
    local target, target_level = pick_north_migration_target(se_squad, entry)
    if not target then
        clear_story_task_if_present(se_squad, sid, current_story, "unsafe_target_pending")
        set_sid_status(sid, "pending")
        return false
    end
    if assign_story_task(se_squad, sid, target, target_level, source or "retarget") ~= true then
        clear_story_task_if_present(se_squad, sid, current_story, "unsafe_target_pending")
        set_sid_status(sid, "pending")
        return false
    end
    log_info(
        "north_migration_retarget sid=%s from=%s to=%s level=%s source=%s",
        tostring(sid or "-"),
        tostring(current_story and current_story.target or "-"),
        tostring(target or "-"),
        tostring(target_level or "-"),
        tostring(source or "retarget")
    )
    return true
end

local function reconcile_selected_statuses(source)
    recover_story_selection_from_memory(source or "reconcile")
    local event = get_state_event()
    for sid in pairs(event.selected_by_sid) do
        local status = normalize_status(event.status_by_sid[sid])
        if status ~= "done" and status ~= "dead_or_invalid" then
            local entry = get_memory_entry(sid)
            if type(entry) ~= "table" then
                if is_transient_reconcile_source(source) == true then
                    event.status_by_sid[sid] = "pending"
                else
                    event.status_by_sid[sid] = "dead_or_invalid"
                end
            else
                local community = normalize_community_key(entry.community)
                if entry.allowed ~= true or entry.npc_kind ~= "stalker" or not community or EXCLUDED_COMMUNITIES[community] == true then
                    event.status_by_sid[sid] = "dead_or_invalid"
                elseif is_story_task(entry.tasks and entry.tasks.current or nil) == true then
                    event.status_by_sid[sid] = "travel"
                end
            end
        end
    end
    log_info("north_migration_reconcile source=%s selected=%s", tostring(source or "reconcile"), tostring(next(event.selected_by_sid) ~= nil))
end

local function collect_eligible_sids()
    local out = {}
    local seen = {}
    if not (zhopa.memory and zhopa.memory.get_managed_squads_by_level) then
        return out
    end
    local by_level = zhopa.memory.get_managed_squads_by_level()
    if type(by_level) ~= "table" then
        return out
    end
    for _, bucket in pairs(by_level) do
        if type(bucket) == "table" then
            for sid in pairs(bucket) do
                sid = normalize_sid(sid)
                if sid and seen[sid] ~= true then
                    seen[sid] = true
                    local se_squad = resolve_alife_object(sid)
                    local entry = touch_or_get_entry(se_squad, sid, "story_events_rollout_probe")
                    if is_eligible_human_entry(entry, se_squad) == true then
                        out[#out + 1] = sid
                    end
                end
            end
        end
    end
    return out
end

local function activate_selected_sid(sid, source, se_squad, ctx)
    sid = normalize_sid(sid)
    if not sid or is_sid_selected(sid) ~= true then
        return false
    end

    local event = get_state_event()
    local status = normalize_status(event.status_by_sid[sid])
    if status == "done" or status == "dead_or_invalid" then
        local entry_done = get_memory_entry(sid)
        local current_done = entry_done and entry_done.tasks and entry_done.tasks.current or nil
        clear_story_task_if_present(se_squad, sid, current_done, "terminal_status")
        return false
    end

    se_squad = se_squad or resolve_alife_object(sid)
    local entry = nil
    if se_squad and ctx and ctx.prevalidated == true and zhopa.memory and zhopa.memory.get_squad_entry then
        entry = zhopa.memory.get_squad_entry(sid)
    else
        entry = touch_or_get_entry(se_squad, sid, "story_events_activate:" .. tostring(source or "activate"))
    end
    local current = entry and entry.tasks and entry.tasks.current or nil

    if type(entry) ~= "table" then
        clear_story_task_if_present(se_squad, sid, current, "missing_entry")
        event.status_by_sid[sid] = "dead_or_invalid"
        return false
    end

    if not se_squad then
        if is_story_task(current) == true then
            event.status_by_sid[sid] = "travel"
        elseif status ~= "done" then
            event.status_by_sid[sid] = "pending"
        end
        return false
    end

    if is_eligible_human_entry(entry, se_squad) ~= true then
        clear_story_task_if_present(se_squad, sid, current, "no_longer_eligible")
        local community = normalize_community_key(entry.community)
        if entry.allowed ~= true or entry.npc_kind ~= "stalker" or not community or EXCLUDED_COMMUNITIES[community] == true then
            event.status_by_sid[sid] = "dead_or_invalid"
        end
        return false
    end

    if is_surge_active_now() == true then
        return false
    end

    local community = normalize_community_key(entry.community)
    local section_name = entry.section
    local current_story = is_story_task(current) == true and current or nil

    if current_story then
        local target_level = resolve_smart_level_name(current_story.target, current_story.params and current_story.params.target_level or entry.level)
        local safe = is_story_target_safe(current_story.target, target_level, community, section_name)
        if safe == true then
            local smart_id = resolve_smart_id(current_story.target)
            if is_story_arrived(entry, se_squad, current_story.target, smart_id, current_story) == true then
                event.status_by_sid[sid] = "done"
                local rest_ok = maybe_finish_as_rest(se_squad, sid, "story_events_arrived")
                log_story_rest_transition(sid, current_story.target, target_level, "story_events_arrived", rest_ok)
                return false
            end
            event.status_by_sid[sid] = "travel"
            sync_story_task_live_state(se_squad, current_story)
            if should_enforce_online_intent(current_story, tg(), entry) then
                pcall(enforce_online_task_intent, se_squad, entry, current_story)
            end
            return true
        end
        if retarget_story_task(se_squad, sid, entry, current_story, "unsafe_target") ~= true then
            return false
        end
        entry = get_memory_entry(sid) or entry
        local retargeted = entry and entry.tasks and entry.tasks.current or nil
        if is_story_task(retargeted) == true then
            local smart_id = resolve_smart_id(retargeted.target)
            if is_story_arrived(entry, se_squad, retargeted.target, smart_id, retargeted) == true then
                event.status_by_sid[sid] = "done"
                local rest_ok = maybe_finish_as_rest(se_squad, sid, "story_events_arrived_immediate")
                log_story_rest_transition(sid, retargeted.target, resolve_smart_level_name(retargeted.target, retargeted.params and retargeted.params.target_level or entry.level), "story_events_arrived_immediate", rest_ok)
                return false
            end
            return true
        end
        event.status_by_sid[sid] = "pending"
        return false
    end

    local target, target_level = pick_north_migration_target(se_squad, entry)
    if not target then
        event.status_by_sid[sid] = "pending"
        return false
    end

    if assign_story_task(se_squad, sid, target, target_level, source or "assign") ~= true then
        event.status_by_sid[sid] = "pending"
        return false
    end

    entry = get_memory_entry(sid) or entry
    local assigned = entry and entry.tasks and entry.tasks.current or nil
    if is_story_task(assigned) == true then
        local smart_id = resolve_smart_id(assigned.target)
        if is_story_arrived(entry, se_squad, assigned.target, smart_id, assigned) == true then
            event.status_by_sid[sid] = "done"
            local rest_ok = maybe_finish_as_rest(se_squad, sid, "story_events_arrived_immediate")
            log_story_rest_transition(sid, assigned.target, target_level, "story_events_arrived_immediate", rest_ok)
            return false
        end
        return true
    end

    event.status_by_sid[sid] = "pending"
    return false
end

local function maybe_fire_north_migration(source)
    local event = get_state_event()
    if event.fired == true then
        return false
    end
    if migration_trigger_active() ~= true then
        return false
    end
    if RUNTIME.rollout_running == true then
        return false
    end

    RUNTIME.rollout_running = true
    event.fired = true
    event.legacy_skipped = false

    local eligible = collect_eligible_sids()
    shuffle_in_place(eligible)

    local percent = get_north_migration_percent()
    local selected_count = math_floor and math_floor(#eligible * (percent / 100)) or 0
    if selected_count < 0 then
        selected_count = 0
    end

    for i = 1, selected_count do
        local sid = normalize_sid(eligible[i])
        if sid then
            event.selected_by_sid[sid] = true
            event.status_by_sid[sid] = "pending"
        end
    end

    log_info(
        "north_migration_fire source=%s eligible=%s selected=%s percent=%s",
        tostring(source or "fire"),
        tostring(#eligible),
        tostring(selected_count),
        tostring(percent)
    )

    if is_surge_active_now() ~= true then
        for i = 1, selected_count do
            activate_selected_sid(eligible[i], "north_migration_rollout")
        end
    end

    RUNTIME.rollout_running = false
    return true
end

local function clear_story_task_when_disabled(se_squad, sid, entry)
    sid = normalize_sid(sid)
    if not sid then
        return false
    end
    local current = entry and entry.tasks and entry.tasks.current or nil
    if is_story_task(current) ~= true then
        return false
    end
    clear_story_task_if_present(se_squad, sid, current, "feature_disabled")
    return true
end

function story_events.update_squad_tasks(se_squad, ctx)
    if not (zhopa.memory and (zhopa.memory.get_squad_entry or zhopa.memory.touch_squad_validated)) then
        return false
    end
    local sid = normalize_sid(se_squad and se_squad.id)
    if not sid then
        return false
    end

    local entry = nil
    if ctx and ctx.prevalidated == true and zhopa.memory.get_squad_entry then
        entry = zhopa.memory.get_squad_entry(sid)
    elseif zhopa.memory.touch_squad_validated then
        entry = zhopa.memory.touch_squad_validated(se_squad, false, "story_events")
    end
    if type(entry) ~= "table" then
        return false
    end

    if feature_enabled_now() ~= true then
        clear_story_task_when_disabled(se_squad, sid, entry)
        return false
    end

    if maybe_fire_north_migration("squad_update") == true then
        entry = get_memory_entry(sid) or entry
    end

    local current = entry.tasks and entry.tasks.current or nil
    if is_sid_selected(sid) ~= true and is_story_task(current) == true then
        recover_story_selection_from_entry(sid, entry, "update_current_task")
    end
    if is_sid_selected(sid) ~= true then
        clear_story_task_if_present(se_squad, sid, current, "not_selected")
        return false
    end

    local handled = activate_selected_sid(sid, "update", se_squad, ctx) == true
    if handled == true then
        return true
    end
    if is_surge_active_now() == true then
        return false
    end
    return is_sid_locked(sid)
end

local function on_actor_first_update()
    get_state_event()
    reconcile_selected_statuses("actor_on_first_update")
end

local function on_option_change()
    get_state_event()
    reconcile_selected_statuses("on_option_change")
end

local function on_server_entity_unregister(se_obj)
    local sid = normalize_sid(se_obj and se_obj.id)
    if sid and is_sid_selected(sid) == true then
        local event = get_state_event()
        if normalize_status(event.status_by_sid[sid]) ~= "done" then
            set_sid_status(sid, "pending")
        end
    end
end

story_events.save_state = save_state_blob
story_events.load_state = function(m_data)
    load_state_blob(m_data)
    reconcile_selected_statuses("load_state")
end
story_events.on_actor_first_update = on_actor_first_update
story_events.on_option_change = on_option_change
story_events.on_server_entity_unregister = on_server_entity_unregister
story_events.get_state = function()
    return get_state_event()
end
story_events.is_story_task = is_story_task
story_events.is_sid_selected = is_sid_selected
story_events.is_sid_locked = is_sid_locked
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_story_events

-- BEGIN module zhopa_smart_tasks
zhopa_bundle_module = function()
zhopa = zhopa or {}
zhopa.smart_tasks = zhopa.smart_tasks or {}

local smart_tasks = zhopa.smart_tasks

local type = _G.type
local pcall = _G.pcall
local tonumber = _G.tonumber
local tostring = _G.tostring
local pairs = _G.pairs
local next = _G.next
local time_global = _G.time_global
local game_graph = _G.game_graph
local alife = _G.alife
local db = _G.db
local level = _G.level
local setmetatable = _G.setmetatable

local table_sort = table.sort
local string_gsub = string.gsub
local string_lower = string.lower

local TASKTYPE_CONTROL = "control"
local TASK_GO_TO_CONTROL = "SMART TASK: GO TO CONTROL"
local TASK_CONTROL = "SMART TASK: CONTROL"
local CONTROL_MODE_AGGRESSIVE = "aggressive"
local CONTROL_MODE_PASSIVE = "passive"
local DIRTY_BATCH_PER_UPDATE = 1
local DISTANCE_FALLBACK = 1000000000
local PASSIVE_CONTROL_RADIUS_M = 100

local RUNTIME = {
    claims_by_smart = {},
    claims_by_smart_identity = {},
    claim_by_sid = {},
    dirty_smarts = {},
    dirty_queue = {},
    dirty_queue_head = 1,
    dirty_queue_tail = 0,
    reserved_squads = {},
    surge_cache_active = false,
    surge_cache_next_tg = 0,
    processing_dirty = false,
    bootstrapped = false,
}

local function tg()
    return (time_global and time_global()) or 0
end

local function cfg_bool(key, default)
    if zhopa.runtime_cfg and zhopa.runtime_cfg.bool then
        return zhopa.runtime_cfg.bool(key, default)
    end
    if zhopa.config and zhopa.config.get then
        return zhopa.config.get(key, default) ~= false
    end
    return default ~= false
end

local function cfg_num(key, default, min_v)
    local value = tonumber(default) or 0
    if zhopa.runtime_cfg and zhopa.runtime_cfg.num then
        return zhopa.runtime_cfg.num(key, value, min_v)
    end
    if zhopa.config and zhopa.config.get then
        value = tonumber(zhopa.config.get(key, value)) or value
    end
    if min_v ~= nil and value < min_v then
        value = min_v
    end
    return value
end

local function trim(value)
    if type(value) ~= "string" then
        return nil
    end
    value = string_gsub(value, "^%s*(.-)%s*$", "%1")
    if value == "" then
        return nil
    end
    return value
end

local function lower_trim(value)
    value = trim(value)
    if not value then
        return nil
    end
    return string_lower(value)
end

local function log_info(fmt, ...)
    if zhopa.log and zhopa.log.info then
        zhopa.log.info("SMART_TASKS", fmt, ...)
    end
end

local function log_warn(fmt, ...)
    if zhopa.log and zhopa.log.warn then
        zhopa.log.warn("SMART_TASKS", fmt, ...)
    end
end

local function get_board()
    if SIMBOARD then return SIMBOARD end
    if sim_board and sim_board.get_sim_board then
        local ok, board = pcall(function() return sim_board.get_sim_board() end)
        if ok then
            return board
        end
    end
    return nil
end

local function now_level_name_by_gvid(gvid)
    if not (gvid and alife and game_graph) then
        return nil
    end
    local ok, res = pcall(function()
        local gv = game_graph():vertex(gvid)
        if not gv then return nil end
        return alife():level_name(gv:level_id())
    end)
    if ok then
        return res
    end
    return nil
end

local function resolve_smart_by_name(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil
    end
    local board = get_board()
    if not (board and board.smarts_by_names) then
        return nil
    end
    return board.smarts_by_names[smart_name]
end

local function resolve_smart_level_name(smart_name, fallback_level)
    if type(smart_name) ~= "string" or smart_name == "" then
        return fallback_level
    end
    if zhopa.board_index and zhopa.board_index.get_smart_level then
        local indexed = zhopa.board_index.get_smart_level(smart_name)
        if type(indexed) == "string" and indexed ~= "" then
            return indexed
        end
    end
    local smart = resolve_smart_by_name(smart_name)
    local gvid = smart and tonumber(smart.m_game_vertex_id) or nil
    if gvid then
        return now_level_name_by_gvid(gvid) or fallback_level
    end
    return fallback_level
end

local function resolve_smart_id(smart_name)
    local smart = resolve_smart_by_name(smart_name)
    return tonumber(smart and smart.id) or nil, smart
end

local function resolve_squad_object(sid)
    sid = tonumber(sid)
    if not (sid and alife) then
        return nil
    end
    local sim = alife()
    if not sim then
        return nil
    end
    local ok, se_obj = pcall(function()
        return sim:object(sid)
    end)
    if ok then
        return se_obj
    end
    return nil
end

local function safe_obj_by_id(id)
    id = tonumber(id)
    if not id then
        return nil
    end
    if level and level.object_by_id then
        local ok, obj = pcall(function() return level.object_by_id(id) end)
        if ok and obj then
            return obj
        end
    end
    if db and db.storage and db.storage[id] then
        local obj = db.storage[id].object
        if obj then
            return obj
        end
    end
    return nil
end

local function safe_object_name(se_obj)
    if not se_obj then
        return nil
    end
    if type(se_obj.name) == "function" then
        local ok, name = pcall(function() return se_obj:name() end)
        if ok and type(name) == "string" and name ~= "" then
            return name
        end
    end
    if type(se_obj.name) == "string" and se_obj.name ~= "" then
        return se_obj.name
    end
    return nil
end

local function get_squad_commander_id(se_squad, entry)
    local cid = nil
    if se_squad and se_squad.commander_id then
        local ok, res = pcall(function() return se_squad:commander_id() end)
        cid = ok and tonumber(res) or nil
    end
    if not cid then
        cid = tonumber(se_squad and se_squad.commander_id) or nil
    end
    if not cid then
        cid = tonumber(entry and entry.commander_id) or nil
    end
    return cid
end

local function extract_member_candidate_id_local(k, v)
    if type(v) == "table" then
        local idv = tonumber(v.id) or tonumber(v.object_id) or tonumber(v.squad_id)
        if idv and idv > 0 then
            return idv
        end
    end

    local id = tonumber(v)
    if id and id > 0 then
        return id
    end

    id = tonumber(k)
    if id and id > 0 then
        return id
    end

    return nil
end

local function iter_online_squad_member_ids(se_squad, entry)
    local out = {}
    if not se_squad then
        return out
    end

    local seen = {}
    local function push(id)
        id = tonumber(id)
        if not id or id <= 0 or seen[id] then
            return
        end
        if not safe_obj_by_id(id) then
            return
        end
        seen[id] = true
        out[#out + 1] = id
    end

    local ok_members, a, b, c = pcall(function() return se_squad:squad_members() end)
    if ok_members and a ~= nil then
        local ok_iter = pcall(function()
            for member in a, b, c do
                push(extract_member_candidate_id_local(nil, member))
            end
        end)
        if (not ok_iter) and type(a) == "table" then
            for k, v in pairs(a) do
                push(extract_member_candidate_id_local(k, v))
            end
        end
    end

    if #out <= 0 then
        push(get_squad_commander_id(se_squad, entry))
    end

    return out
end

local function normalize_community_key(name)
    if type(name) ~= "string" then return nil end
    local key = lower_trim(name)
    if not key then return nil end
    if key == "mutant" or key == "mutants" or key == "monsters" then
        key = "monster"
    end
    local cfg = zhopa.config
    if cfg and cfg.get_faction_alias then
        local alias = cfg.get_faction_alias(key)
        alias = lower_trim(alias)
        if alias then
            key = alias
        end
    end
    if key == "mutant" or key == "mutants" or key == "monsters" then
        key = "monster"
    end
    return key
end

local function normalize_section_key(name)
    return lower_trim(name)
end

local function is_target_sync_enabled()
    return cfg_bool("target_sync_enabled", true)
end

local function get_online_intent_enforce_enabled()
    return cfg_bool("online_intent_enforce_enabled", true)
end

local function set_squad_always_arrived(se_squad, should_hold)
    if not se_squad then
        return
    end
    pcall(function()
        se_squad.always_arrived = should_hold == true
    end)
end

local function clear_task_apply_state(task)
    if type(task) ~= "table" then
        return
    end
    task.params = type(task.params) == "table" and task.params or {}
    task.params._applied = nil
    task.params.online_intent_next_tg = nil
end

local function should_enforce_online_intent(task, now, entry)
    if zhopa.tasks and type(zhopa.tasks._should_enforce_online_intent) == "function" then
        return zhopa.tasks._should_enforce_online_intent(task, now, entry) == true
    end
    return false
end

local function resolve_target_smart_id(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil, nil
    end
    return resolve_smart_id(smart_name)
end

local function set_scripted_target(se_squad, smart_name, params, opts)
    if not se_squad then return false end
    se_squad.scripted_target = smart_name
    if se_squad.task_target_id ~= nil then
        se_squad.task_target_id = nil
    end

    if not is_target_sync_enabled() then
        return true
    end
    if type(smart_name) ~= "string" or smart_name == "" then
        return true
    end

    params = type(params) == "table" and params or nil
    local now = tg()
    local sid = nil
    sid = resolve_target_smart_id(smart_name)
    local force_sync = opts and opts.force_sync == true

    local changed = false
    if params then
        changed = params.target_sync_name ~= smart_name
        params.target_sync_name = smart_name
        if sid then
            params.target_sync_smart_id = sid
        else
            params.target_sync_smart_id = nil
        end
        if changed then
            params.target_sync_started_tg = now
            params.target_last_progress_tg = now
            params.target_last_gvid = tonumber(se_squad.m_game_vertex_id) or nil
            params.target_last_assigned_id = tonumber(se_squad.assigned_target_id) or nil
            params.target_last_current_id = tonumber(se_squad.current_target_id) or nil
            params.target_last_action = tonumber(se_squad.current_action) or nil
        end
    end

    if changed or force_sync then
        se_squad.current_action = 0
        se_squad.current_target_id = nil
        if sid then
            se_squad.assigned_target_id = sid
        end
        se_squad.stay_time = nil
        se_squad.arrive_time = nil
        if params then
            params.target_last_progress_tg = now
            params.target_last_gvid = tonumber(se_squad.m_game_vertex_id) or nil
            params.target_last_assigned_id = tonumber(se_squad.assigned_target_id) or nil
            params.target_last_current_id = tonumber(se_squad.current_target_id) or nil
            params.target_last_action = tonumber(se_squad.current_action) or nil
        end
    end

    return true
end

local function is_online_squad(se_squad)
    if not se_squad then
        return false
    end
    local ok, online = pcall(function() return se_squad.online end)
    return ok and online == true
end

local function smart_supports_stalker_jobs(smart)
    local jobs = smart and smart.stalker_jobs or nil
    if type(jobs) ~= "table" or #jobs <= 0 then
        return false
    end
    if type(smart.npc_info) ~= "table" then
        return false
    end
    if type(smart.select_npc_job) ~= "function" then
        return false
    end
    return true
end

local function try_soft_register_squad_to_smart(se_squad, smart, board)
    if not (se_squad and smart and board and board.assign_squad_to_smart) then
        return false
    end
    local smart_id = tonumber(smart.id) or nil
    if not smart_id then
        return false
    end
    if tonumber(se_squad.smart_id) == smart_id then
        return true
    end
    local ok = pcall(function() board:assign_squad_to_smart(se_squad, smart_id) end)
    return ok == true
end

local function try_soft_assign_free_stalker_jobs_once(se_squad, smart, entry)
    if not smart_supports_stalker_jobs(smart) then
        return false
    end

    local member_ids = iter_online_squad_member_ids(se_squad, entry)
    for i = 1, #member_ids do
        local npc_id = member_ids[i]
        local npc_info = smart.npc_info[npc_id] or smart.npc_info[tostring(npc_id)]
        if npc_info and npc_info.job == nil then
            pcall(function() smart:select_npc_job(npc_info, true) end)
        end
    end

    return true
end

local function enforce_online_task_intent(se_squad, entry, task)
    if not get_online_intent_enforce_enabled() then return end
    if not (se_squad and entry and type(task) == "table") then return end
    if not is_online_squad(se_squad) then return end
    if type(task.target) ~= "string" or task.target == "" then return end

    local sid = resolve_target_smart_id(task.target)
    local stgt = se_squad.scripted_target
    local at = tonumber(se_squad.assigned_target_id) or nil
    local ca = tonumber(se_squad.current_action) or nil
    local mismatch = false

    if stgt ~= task.target then mismatch = true end
    if sid and at and at ~= sid then mismatch = true end
    if ca == nil then mismatch = true end

    if mismatch then
        set_scripted_target(se_squad, task.target, task.params, { force_sync = true, reason = "online_intent_enforce" })
        log_warn("ONLINE_WANDER_DETECTED sid=%s task=%s target=%s cur_level=%s gvid=%s",
            tostring(entry and entry.squad_id or "-"),
            tostring(task and task.type or "-"),
            tostring(task and task.target or "-"),
            tostring(entry and entry.level or "-"),
            tostring(se_squad and se_squad.m_game_vertex_id or "-")
        )
    end
end

local function clear_live_task_state(se_squad)
    if not se_squad then
        return
    end
    set_squad_always_arrived(se_squad, false)
    pcall(function() se_squad.scripted_target = nil end)
    pcall(function() se_squad.assigned_target_id = nil end)
    pcall(function() se_squad.current_target_id = nil end)
    pcall(function() se_squad.task_target_id = nil end)
    pcall(function() se_squad.current_action = 0 end)
    pcall(function() se_squad.stay_time = nil end)
    pcall(function() se_squad.arrive_time = nil end)
end

local function get_arrive_dist_cap_m()
    return cfg_num("task_arrive_dist_cap_m", 5, 0)
end

local function vanilla_am_i_reached(se_squad, smart)
    if not (se_squad and smart) then return false end

    local sgvid = tonumber(se_squad.m_game_vertex_id) or nil
    local tgvid = tonumber(smart.m_game_vertex_id) or nil
    if sgvid and tgvid and sgvid == tgvid then
        return true
    end

    if sgvid and tgvid and game_graph then
        local ok_lvl, same_level = pcall(function()
            return game_graph():vertex(sgvid):level_id() == game_graph():vertex(tgvid):level_id()
        end)
        if ok_lvl and same_level == false then
            return false
        end
    end

    local cap_m = get_arrive_dist_cap_m()
    if cap_m <= 0 then
        return false
    end

    local pos_s = zhopa.safe and zhopa.safe.safe_position and zhopa.safe.safe_position(se_squad) or nil
    local pos_t = smart.position
    if not (pos_s and pos_t and pos_s.distance_to_sqr) then
        return false
    end

    local arrive_dist = tonumber(smart.arrive_dist) or cap_m
    if arrive_dist > cap_m then
        arrive_dist = cap_m
    end

    local ok_alw, alw = pcall(function() return se_squad.always_arrived end)
    if ok_alw and alw == true then
        return true
    end

    local ok_d2, d2 = pcall(function() return pos_s:distance_to_sqr(pos_t) end)
    d2 = ok_d2 and tonumber(d2) or nil
    if not d2 then
        return false
    end
    return d2 <= (arrive_dist * arrive_dist)
end

local function is_squad_arrived_to_smart_live(se_squad, smart_name)
    local smart = resolve_smart_by_name(smart_name)
    if not (se_squad and smart) then
        return false
    end

    local ca = tonumber(se_squad.current_action) or nil
    local ct = tonumber(se_squad.current_target_id) or nil
    local ss = tonumber(se_squad.smart_id) or nil
    local smart_id = tonumber(smart.id) or nil

    if ca == 1 and smart_id and ((ct and ct == smart_id) or (ss and ss == smart_id)) then
        return true
    end

    if smart.am_i_reached then
        local ok, res = pcall(function() return smart:am_i_reached(se_squad) end)
        if ok and res == true then
            return true
        end
    end

    return vanilla_am_i_reached(se_squad, smart)
end

local function try_game_graph_distance(sgvid, tgvid)
    sgvid = tonumber(sgvid)
    tgvid = tonumber(tgvid)
    if not (sgvid and tgvid and game_graph) then
        return nil
    end
    local ok, distance = pcall(function()
        local gg = game_graph()
        if not gg then return nil end
        return gg:distance(sgvid, tgvid)
    end)
    distance = ok and tonumber(distance) or nil
    return distance
end

local function is_surge_active_now()
    local xc = _G.xr_conditions
    local xf = xc and xc.surge_started or nil
    if type(xf) == "function" then
        local ok, res = pcall(xf)
        if ok and res == true then return true, false end
        if ok and res == false then return false, false end
    end

    local fallback_used = false

    local f = _G.surge_started
    if type(f) == "function" then
        fallback_used = true
        local ok, res = pcall(f)
        if ok and res == true then return true, fallback_used end
        if ok and res == false then return false, fallback_used end
    end

    local psm = _G.psi_storm_manager
    if psm and type(psm.is_loaded) == "function" and type(psm.is_started) == "function" then
        fallback_used = true
        local okL, loaded = pcall(function() return psm.is_loaded() end)
        if okL and loaded == true then
            local okS, started = pcall(function() return psm.is_started() end)
            if okS and started == true then return true, fallback_used end
        end
    end

    local sm = _G.surge_manager
    if sm and type(sm.is_loaded) == "function" and type(sm.is_started) == "function" then
        fallback_used = true
        local okL, loaded = pcall(function() return sm.is_loaded() end)
        if okL and loaded == true then
            local okS, started = pcall(function() return sm.is_started() end)
            if okS and started == true then return true, fallback_used end
        end
    end

    if _G.level and type(_G.level.is_surge) == "function" then
        fallback_used = true
        local ok, res = pcall(function() return _G.level.is_surge() end)
        if ok and res == true then return true, fallback_used end
    end

    return false, fallback_used
end

local function is_surge_active()
    local now = tg()
    if now < (tonumber(RUNTIME.surge_cache_next_tg) or 0) then
        return RUNTIME.surge_cache_active == true
    end

    local active, fallback_used = is_surge_active_now()
    local cache_ms = cfg_num("surge_check_cache_ms", 250, 0)
    RUNTIME.surge_cache_active = active == true
    RUNTIME.surge_cache_next_tg = now + cache_ms

    if fallback_used then
        log_warn("SURGE_CHECK_FALLBACK source=smart_tasks")
    end

    return active == true
end

local function smart_tasks_enabled_now()
    local switches = zhopa.switches
    if not switches or switches.core ~= true or switches.smart_tasks ~= true then
        return false
    end
    if cfg_bool("enabled", true) == false then
        return false
    end
    return cfg_bool("smart_tasks_enabled", true)
end

local function is_tasktype_enabled(tasktype)
    if tasktype ~= TASKTYPE_CONTROL then
        return false
    end
    if not smart_tasks_enabled_now() then
        return false
    end
    return cfg_bool("smart_tasks_control_enabled", true)
end

local function get_control_cap()
    return cfg_num("smart_tasks_control_max_squads_per_faction", 1, 1)
end

local function is_level_globally_blacklisted(level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    local cfg = zhopa.config
    if cfg and cfg.is_level_globally_blacklisted then
        return cfg.is_level_globally_blacklisted(level_name) == true
    end
    return false
end

local function smart_blacklists_global_set()
    local cfg = zhopa.config
    if cfg and cfg.get_smart_blacklists_global_set then
        local res = cfg.get_smart_blacklists_global_set()
        if type(res) == "table" then
            return res
        end
    end
    return nil
end

local function smart_blacklists_rule(level_name)
    local cfg = zhopa.config
    if cfg and cfg.get_smart_blacklists_rule then
        local res = cfg.get_smart_blacklists_rule(level_name)
        if type(res) == "table" then
            return res
        end
    end
    return nil
end

local function faction_level_blacklists_rule(community)
    local cfg = zhopa.config
    if not (cfg and cfg.get_faction_level_blacklist_rule) then
        return nil
    end
    local key = normalize_community_key(community)
    if not key then return nil end
    local res = cfg.get_faction_level_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function faction_smart_blacklists_rule(community)
    local cfg = zhopa.config
    if not (cfg and cfg.get_faction_smart_blacklist_rule) then
        return nil
    end
    local key = normalize_community_key(community)
    if not key then return nil end
    local res = cfg.get_faction_smart_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function section_level_blacklists_rule(section_name)
    local cfg = zhopa.config
    if not (cfg and cfg.get_section_level_blacklist_rule) then
        return nil
    end
    local key = normalize_section_key(section_name)
    if not key then return nil end
    local res = cfg.get_section_level_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function section_smart_blacklists_rule(section_name)
    local cfg = zhopa.config
    if not (cfg and cfg.get_section_smart_blacklist_rule) then
        return nil
    end
    local key = normalize_section_key(section_name)
    if not key then return nil end
    local res = cfg.get_section_smart_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function is_level_blacklisted_for_faction(level_name, community, section_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    if is_level_globally_blacklisted(level_name) then
        return true
    end

    local rule = faction_level_blacklists_rule(community)
    if rule and rule.all == true then
        return true
    end
    local set = rule and rule.set or nil
    if set and set[level_name] then
        return true
    end

    local s_rule = section_level_blacklists_rule(section_name)
    if s_rule and s_rule.all == true then
        return true
    end
    local s_set = s_rule and s_rule.set or nil
    if s_set and s_set[level_name] then
        return true
    end
    return false
end

local function is_smart_blacklisted_for_faction(smart_name, community, level_name, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    if is_level_blacklisted_for_faction(level_name, community, section_name) then
        return true
    end

    local rule = faction_smart_blacklists_rule(community)
    if rule and rule.all == true then
        return true
    end
    local set = rule and rule.set or nil
    if set and set[smart_name] then
        return true
    end

    local s_rule = section_smart_blacklists_rule(section_name)
    if s_rule and s_rule.all == true then
        return true
    end
    local s_set = s_rule and s_rule.set or nil
    if s_set and s_set[smart_name] then
        return true
    end

    return false
end

local function smart_is_blacklisted_for_level(level_name, smart_name, community, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end

    local gset = smart_blacklists_global_set()
    if gset and gset[smart_name] then
        return true
    end

    local rule = level_name and smart_blacklists_rule(level_name) or nil
    if rule and rule.all == true then
        return true
    end
    local set = rule and rule.set or nil
    if set and set[smart_name] then
        return true
    end

    if is_smart_blacklisted_for_faction(smart_name, community, level_name, section_name) then
        return true
    end

    return false
end

local function get_tasktype_for_smart(smart_name)
    if not (zhopa.config and zhopa.config.get_smart_task_type) then
        return nil
    end
    return zhopa.config.get_smart_task_type(smart_name)
end

local function get_tasktype_allowed_tokens(tasktype)
    if not (zhopa.config and zhopa.config.get_smart_task_allowed_tokens) then
        return {}
    end
    local list = zhopa.config.get_smart_task_allowed_tokens(tasktype)
    if type(list) == "table" then
        return list
    end
    return {}
end

local function normalize_control_mode(mode)
    mode = lower_trim(mode)
    if mode == "agressive" then
        mode = CONTROL_MODE_AGGRESSIVE
    end
    if mode == nil then
        return CONTROL_MODE_PASSIVE
    end
    if mode == CONTROL_MODE_PASSIVE then
        return CONTROL_MODE_PASSIVE
    end
    return CONTROL_MODE_AGGRESSIVE
end

local function get_tasktype_mode(tasktype, smart_name)
    if not (zhopa.config and zhopa.config.get_smart_task_mode) then
        return CONTROL_MODE_PASSIVE
    end
    return normalize_control_mode(zhopa.config.get_smart_task_mode(tasktype, smart_name))
end

local function get_tasktype_blacklist_tokens(tasktype, smart_name)
    if not (zhopa.config and zhopa.config.get_smart_task_blacklist_tokens) then
        return {}
    end
    local list = zhopa.config.get_smart_task_blacklist_tokens(tasktype, smart_name)
    if type(list) == "table" then
        return list
    end
    return {}
end

local function get_tasktype_whitelist_tokens(tasktype, smart_name)
    if not (zhopa.config and zhopa.config.get_smart_task_whitelist_tokens) then
        return {}
    end
    local list = zhopa.config.get_smart_task_whitelist_tokens(tasktype, smart_name)
    if type(list) == "table" then
        return list
    end
    return {}
end

local function entry_npc_kind(entry)
    if type(entry) ~= "table" then
        return nil
    end
    if entry.npc_kind == "mutant" then
        return "mutant"
    end
    if entry.npc_kind == "stalker" then
        return "stalker"
    end
    return nil
end

local function entry_matches_token(entry, token)
    token = lower_trim(token)
    if not token or type(entry) ~= "table" then
        return false
    end

    local npc_kind = entry_npc_kind(entry)
    local community_key = normalize_community_key(entry.community)
    local section_key = normalize_section_key(entry.section)
    local token_community_key = normalize_community_key(token)
    local token_section_key = normalize_section_key(token)

    if token == "human" then
        return npc_kind == "stalker"
    end
    if token == "monster" then
        return npc_kind == "mutant"
    end
    if community_key and token_community_key and token_community_key == community_key then
        return true
    end
    if section_key and token_section_key and token_section_key == section_key then
        return true
    end
    return false
end

local function entry_allowed_for_smart_task(entry, smart_name, tasktype, smart_level)
    if type(entry) ~= "table" or entry.allowed ~= true then
        return false
    end
    if not is_tasktype_enabled(tasktype) then
        return false
    end
    local community = entry.community
    local section_name = entry.section
    if smart_is_blacklisted_for_level(smart_level, smart_name, community, section_name) then
        return false
    end

    local allowed_tokens = get_tasktype_allowed_tokens(tasktype)
    if #allowed_tokens == 0 then
        return false
    end
    local matched_allow = false
    for i = 1, #allowed_tokens do
        if entry_matches_token(entry, allowed_tokens[i]) then
            matched_allow = true
            break
        end
    end
    if not matched_allow then
        return false
    end

    local whitelist_tokens = get_tasktype_whitelist_tokens(tasktype, smart_name)
    if #whitelist_tokens > 0 then
        local matched_whitelist = false
        for i = 1, #whitelist_tokens do
            if entry_matches_token(entry, whitelist_tokens[i]) then
                matched_whitelist = true
                break
            end
        end
        if not matched_whitelist then
            return false
        end
    end

    local blacklist_tokens = get_tasktype_blacklist_tokens(tasktype, smart_name)
    for i = 1, #blacklist_tokens do
        if entry_matches_token(entry, blacklist_tokens[i]) then
            return false
        end
    end

    return true
end

local function build_identity_from_entry(entry)
    if type(entry) ~= "table" then
        return nil
    end
    local community_key = normalize_community_key(entry.community)
    local section_key = normalize_section_key(entry.section)
    local npc_kind = entry_npc_kind(entry)

    if npc_kind == "mutant" then
        return {
            key = "community:monster",
            kind = "community",
            community_key = "monster",
            section_key = section_key,
            npc_kind = npc_kind,
        }
    end

    if community_key then
        return {
            key = "community:" .. community_key,
            kind = "community",
            community_key = community_key,
            section_key = section_key,
            npc_kind = npc_kind,
        }
    end
    if section_key then
        return {
            key = "section:" .. section_key,
            kind = "section",
            community_key = nil,
            section_key = section_key,
            npc_kind = npc_kind,
        }
    end
    return nil
end

local function build_identity_from_task(task)
    local params = type(task) == "table" and type(task.params) == "table" and task.params or nil
    if not params then
        return nil
    end
    local key = trim(params.smart_task_identity_key)
    local kind = trim(params.smart_task_identity_kind)
    local community_key = normalize_community_key(params.smart_task_community)
    local section_key = normalize_section_key(params.smart_task_section)
    if key then
        return {
            key = key,
            kind = kind or "unknown",
            community_key = community_key,
            section_key = section_key,
            npc_kind = community_key == "monster" and "mutant" or nil,
        }
    end
    if community_key then
        return {
            key = "community:" .. community_key,
            kind = "community",
            community_key = community_key,
            section_key = section_key,
            npc_kind = community_key == "monster" and "mutant" or nil,
        }
    end
    if section_key then
        return {
            key = "section:" .. section_key,
            kind = "section",
            community_key = nil,
            section_key = section_key,
            npc_kind = nil,
        }
    end
    return nil
end

local function is_enemy_identity(a, b)
    if not (a and b and a.key and b.key) then
        return false
    end
    if a.key == b.key then
        return false
    end
    if a.community_key == "monster" or b.community_key == "monster" then
        return true
    end
    if a.npc_kind == "mutant" or b.npc_kind == "mutant" then
        return true
    end
    if game_relations and game_relations.is_factions_enemies and a.community_key and b.community_key then
        local ok, enemies = pcall(function()
            return game_relations.is_factions_enemies(a.community_key, b.community_key)
        end)
        if ok then
            return enemies == true
        end
    end
    return false
end

local function is_smart_task(task)
    if type(task) ~= "table" then
        return false
    end
    if task.type == TASK_GO_TO_CONTROL or task.type == TASK_CONTROL then
        return true
    end
    local params = type(task.params) == "table" and task.params or nil
    return params and params.smart_task == true or false
end

local function get_smart_task_meta(task)
    if type(task) ~= "table" then
        return nil
    end
    if not is_smart_task(task) then
        return nil
    end

    local params = type(task.params) == "table" and task.params or {}
    local tasktype = lower_trim(params.smart_task_type)
    local smart_name = trim(params.smart_task_smart) or trim(task.target)
    local phase = lower_trim(params.smart_task_phase)

    if not tasktype then
        if task.type == TASK_GO_TO_CONTROL or task.type == TASK_CONTROL then
            tasktype = TASKTYPE_CONTROL
        end
    end
    if not phase then
        if task.type == TASK_CONTROL then
            phase = "hold"
        elseif task.type == TASK_GO_TO_CONTROL then
            phase = "travel"
        end
    end

    if not (tasktype and smart_name and phase) then
        return nil
    end

    return {
        task = task,
        tasktype = tasktype,
        smart_name = smart_name,
        phase = phase,
    }
end

local function mark_smart_dirty(smart_name)
    smart_name = trim(smart_name)
    if not smart_name then
        return
    end
    if RUNTIME.dirty_smarts[smart_name] ~= true then
        local tail = (tonumber(RUNTIME.dirty_queue_tail) or 0) + 1
        RUNTIME.dirty_queue_tail = tail
        RUNTIME.dirty_queue[tail] = smart_name
    end
    RUNTIME.dirty_smarts[smart_name] = true
end

local function reset_dirty_queue()
    RUNTIME.dirty_smarts = {}
    RUNTIME.dirty_queue = {}
    RUNTIME.dirty_queue_head = 1
    RUNTIME.dirty_queue_tail = 0
end

local function remove_runtime_claim(sid)
    sid = tonumber(sid)
    if not sid then
        return
    end
    local claim = RUNTIME.claim_by_sid[sid]
    if not claim then
        return
    end

    local by_smart = RUNTIME.claims_by_smart[claim.smart_name]
    if type(by_smart) == "table" then
        by_smart[sid] = nil
        if next(by_smart) == nil then
            RUNTIME.claims_by_smart[claim.smart_name] = nil
        end
    end

    local by_identity = RUNTIME.claims_by_smart_identity[claim.smart_name]
    if type(by_identity) == "table" and type(claim.identity_key) == "string" then
        local next_count = (tonumber(by_identity[claim.identity_key]) or 0) - 1
        if next_count > 0 then
            by_identity[claim.identity_key] = next_count
        else
            by_identity[claim.identity_key] = nil
        end
        if next(by_identity) == nil then
            RUNTIME.claims_by_smart_identity[claim.smart_name] = nil
        end
    end

    RUNTIME.claim_by_sid[sid] = nil
end

local function add_runtime_claim(sid, smart_name, tasktype, phase, identity)
    sid = tonumber(sid)
    smart_name = trim(smart_name)
    if not (sid and smart_name) then
        return
    end
    remove_runtime_claim(sid)

    local record = {
        sid = sid,
        smart_name = smart_name,
        tasktype = tasktype,
        phase = phase,
        identity_key = identity and identity.key or nil,
        identity = identity,
    }

    local by_smart = RUNTIME.claims_by_smart[smart_name]
    if type(by_smart) ~= "table" then
        by_smart = {}
        RUNTIME.claims_by_smart[smart_name] = by_smart
    end
    by_smart[sid] = record

    if identity and identity.key then
        local by_identity = RUNTIME.claims_by_smart_identity[smart_name]
        if type(by_identity) ~= "table" then
            by_identity = {}
            RUNTIME.claims_by_smart_identity[smart_name] = by_identity
        end
        by_identity[identity.key] = (tonumber(by_identity[identity.key]) or 0) + 1
    end

    RUNTIME.claim_by_sid[sid] = record
end

local function current_identity_count(smart_name, identity_key)
    local bucket = RUNTIME.claims_by_smart_identity[smart_name]
    if type(bucket) ~= "table" or type(identity_key) ~= "string" then
        return 0
    end
    return tonumber(bucket[identity_key]) or 0
end

local function control_relation_allows(smart_name, identity)
    if not (type(smart_name) == "string" and identity and identity.key) then
        return false
    end

    local bucket = RUNTIME.claims_by_smart[smart_name]
    if type(bucket) ~= "table" or next(bucket) == nil then
        return true
    end

    local same_count = current_identity_count(smart_name, identity.key)
    if same_count > 0 then
        return same_count < get_control_cap()
    end

    for _, claim in pairs(bucket) do
        local other = claim and claim.identity or nil
        if other and other.key and other.key ~= identity.key then
            if not is_enemy_identity(other, identity) then
                return false
            end
        end
    end
    return true
end

local function build_control_task(sid, smart_name, phase, identity)
    local now = tg()
    local task_type = phase == "hold" and TASK_CONTROL or TASK_GO_TO_CONTROL
    local params = {
        smart_task = true,
        smart_task_type = TASKTYPE_CONTROL,
        smart_task_phase = phase,
        smart_task_smart = smart_name,
        smart_task_identity_key = identity and identity.key or nil,
        smart_task_identity_kind = identity and identity.kind or nil,
        smart_task_community = identity and identity.community_key or nil,
        smart_task_section = identity and identity.section_key or nil,
        in_transit = phase ~= "hold",
        created_by = "zhopa_smart_tasks",
    }
    if phase == "hold" then
        params.arrived_at_tg = now
        params.entered_target_smart = smart_name
        params.in_transit = false
    end
    return {
        id = "smart_task_control_" .. tostring(phase or "unknown") .. "_" .. tostring(sid or 0) .. "_" .. tostring(now),
        type = task_type,
        target = smart_name,
        params = params,
        created_at_tg = now,
        priority = 1000,
    }
end

local function get_entry_for_sid(sid)
    if not (zhopa.memory and zhopa.memory.get_squad_entry) then
        return nil
    end
    return zhopa.memory.get_squad_entry(sid)
end

local function entry_arrived_to_smart(entry, smart_name, smart_id)
    if type(entry) ~= "table" then
        return false
    end
    if smart_id and tonumber(entry.smart_id) == smart_id and tonumber(entry.current_action) == 1 then
        return true
    end
    local current = entry.tasks and entry.tasks.current or nil
    local params = type(current) == "table" and type(current.params) == "table" and current.params or nil
    if params and params.entered_target_smart == smart_name then
        return true
    end
    return false
end

local function is_claim_arrived(entry, se_squad, smart_name, smart_id)
    if entry_arrived_to_smart(entry, smart_name, smart_id) then
        return true
    end
    if se_squad and is_squad_arrived_to_smart_live(se_squad, smart_name) then
        return true
    end
    return false
end

local function sync_live_control_state(se_squad, task)
    local meta = get_smart_task_meta(task)
    if not (se_squad and meta) then
        return false
    end

    task.params = type(task.params) == "table" and task.params or {}
    set_squad_always_arrived(se_squad, meta.phase == "hold")

    local current_target = trim(se_squad.scripted_target)
    local smart_id = resolve_target_smart_id(meta.smart_name)
    local assigned_id = tonumber(se_squad.assigned_target_id) or nil
    local force_sync = task.params._applied ~= true
        or current_target ~= meta.smart_name
        or (smart_id and assigned_id ~= smart_id)

    if set_scripted_target(se_squad, meta.smart_name, task.params, {
        force_sync = force_sync,
        reason = meta.phase == "hold" and "smart_task_hold" or "smart_task_travel",
    }) then
        task.params._applied = true
        return true
    end
    return false
end

local function clear_claim_task(sid, smart_name, se_squad, reason)
    sid = tonumber(sid)
    if not sid then
        return false
    end
    if not (zhopa.memory and zhopa.memory.set_task_current) then
        return false
    end

    clear_live_task_state(se_squad)
    zhopa.memory.set_task_current(sid, nil)
    if smart_name then
        mark_smart_dirty(smart_name)
    end
    log_info("claim_cleared sid=%s smart=%s reason=%s", tostring(sid), tostring(smart_name or "-"), tostring(reason or "-"))
    return true
end

local function assign_control_task(sid, smart_name, phase, identity, reason)
    sid = tonumber(sid)
    smart_name = trim(smart_name)
    if not (sid and smart_name and zhopa.memory and zhopa.memory.set_task_current) then
        return false
    end

    RUNTIME.reserved_squads[sid] = smart_name
    local task = build_control_task(sid, smart_name, phase, identity)
    zhopa.memory.set_task_current(sid, task)
    RUNTIME.reserved_squads[sid] = nil

    local entry = get_entry_for_sid(sid)
    local current = entry and entry.tasks and entry.tasks.current or task
    clear_task_apply_state(current)
    local se_squad = resolve_squad_object(sid)
    if se_squad then
        sync_live_control_state(se_squad, current)
    end
    log_info("claim_assigned sid=%s smart=%s phase=%s reason=%s", tostring(sid), tostring(smart_name), tostring(phase or "-"), tostring(reason or "-"))
    return true
end

local function candidate_distance(entry, se_squad, smart)
    local sgvid = tonumber(entry and entry.m_game_vertex_id) or tonumber(se_squad and se_squad.m_game_vertex_id) or nil
    local tgvid = tonumber(smart and smart.m_game_vertex_id) or nil
    local distance = try_game_graph_distance(sgvid, tgvid)
    if distance ~= nil then
        return distance
    end

    local p1 = zhopa.safe and zhopa.safe.safe_position and zhopa.safe.safe_position(se_squad) or nil
    local p2 = smart and smart.position or nil
    if p1 and p2 and p1.distance_to then
        local ok, fallback = pcall(function() return p1:distance_to(p2) end)
        fallback = ok and tonumber(fallback) or nil
        if fallback ~= nil then
            return fallback
        end
    end

    return DISTANCE_FALLBACK
end

local function candidate_position_distance(se_squad, smart)
    local p1 = zhopa.safe and zhopa.safe.safe_position and zhopa.safe.safe_position(se_squad) or nil
    local p2 = smart and smart.position or nil
    if not (p1 and p2 and p1.distance_to) then
        return nil
    end
    local ok, distance = pcall(function() return p1:distance_to(p2) end)
    return ok and tonumber(distance) or nil
end

local function candidate_reject_reason(entry, sid, smart_name, tasktype, smart_level)
    sid = tonumber(sid)
    if not (sid and type(entry) == "table") then
        return "invalid"
    end
    if entry.allowed ~= true then
        return "not_allowed"
    end
    if RUNTIME.reserved_squads[sid] and RUNTIME.reserved_squads[sid] ~= smart_name then
        return "reserved"
    end

    local existing_claim = RUNTIME.claim_by_sid[sid]
    if existing_claim and existing_claim.smart_name ~= smart_name then
        return "claimed_elsewhere"
    end
    if existing_claim and existing_claim.smart_name == smart_name then
        return "already_claimed_here"
    end

    local current = entry.tasks and entry.tasks.current or nil
    if zhopa.story_events then
        if type(zhopa.story_events.is_story_task) == "function" and zhopa.story_events.is_story_task(current) == true then
            return "story_task"
        end
        if type(zhopa.story_events.is_sid_locked) == "function" and zhopa.story_events.is_sid_locked(sid) == true then
            return "story_locked"
        end
    end
    local current_meta = get_smart_task_meta(current)
    if current_meta and current_meta.smart_name ~= smart_name then
        return "smart_task_elsewhere"
    end

    local se_squad = resolve_squad_object(sid)
    if se_squad and zhopa.memory and zhopa.memory.is_protected_squad and zhopa.memory.is_protected_squad(se_squad) then
        return "protected"
    end

    if not entry_allowed_for_smart_task(entry, smart_name, tasktype, smart_level) then
        return "rule_reject"
    end

    local identity = build_identity_from_entry(entry)
    if not identity then
        return "identity_missing"
    end
    if not control_relation_allows(smart_name, identity) then
        return "relation_reject"
    end

    return nil, identity
end

local function pick_control_candidate(smart_name, smart, smart_id, smart_level)
    if not (zhopa.memory and zhopa.memory.get_managed_squads_by_level) then
        return nil
    end
    local by_level = zhopa.memory.get_managed_squads_by_level()
    local level_bucket = type(by_level) == "table" and by_level[smart_level] or nil
    if type(level_bucket) ~= "table" then
        return nil
    end

    local mode = get_tasktype_mode(TASKTYPE_CONTROL, smart_name)
    local best = nil
    for sid in pairs(level_bucket) do
        local entry = get_entry_for_sid(sid)
        local reject, identity = candidate_reject_reason(entry, sid, smart_name, TASKTYPE_CONTROL, smart_level)
        if not reject then
            local category = 3
            if type(entry.scripted_target) == "string" and entry.scripted_target == smart_name then
                category = 1
            elseif smart_id and tonumber(entry.smart_id) == smart_id then
                category = 2
            end
            local se_squad = resolve_squad_object(sid)
            local local_distance = candidate_position_distance(se_squad, smart)
            local passive_ok = true
            if mode == CONTROL_MODE_PASSIVE and category ~= 2 then
                passive_ok = local_distance ~= nil and local_distance <= PASSIVE_CONTROL_RADIUS_M
            end
            if passive_ok then
                local distance = candidate_distance(entry, se_squad, smart)
                if not best
                    or category < best.category
                    or (category == best.category and distance < best.distance)
                    or (category == best.category and distance == best.distance and sid < best.sid)
                then
                    best = {
                        sid = tonumber(sid) or 0,
                        phase = (smart_id and tonumber(entry.smart_id) == smart_id) and "hold" or "travel",
                        identity = identity,
                        category = category,
                        distance = distance,
                    }
                end
            end
        end
    end

    return best
end

local function validate_current_control_claim(sid, smart_name, smart, smart_id, smart_level)
    local entry = get_entry_for_sid(sid)
    local current = entry and entry.tasks and entry.tasks.current or nil
    local meta = get_smart_task_meta(current)
    if not (entry and current and meta and meta.smart_name == smart_name and meta.tasktype == TASKTYPE_CONTROL) then
        remove_runtime_claim(sid)
        return false
    end

    local se_squad = resolve_squad_object(sid)
    if se_squad and zhopa.memory and zhopa.memory.is_protected_squad and zhopa.memory.is_protected_squad(se_squad) then
        clear_claim_task(sid, smart_name, se_squad, "protected")
        return false
    end
    if not entry_allowed_for_smart_task(entry, smart_name, TASKTYPE_CONTROL, smart_level) then
        clear_claim_task(sid, smart_name, se_squad, "rule_reject")
        return false
    end

    local identity = build_identity_from_entry(entry) or build_identity_from_task(current)
    if meta.phase == "travel" and is_claim_arrived(entry, se_squad, smart_name, smart_id) then
        assign_control_task(sid, smart_name, "hold", identity, "arrived")
        return false
    end
    if meta.phase == "hold" and not is_claim_arrived(entry, se_squad, smart_name, smart_id) then
        assign_control_task(sid, smart_name, "travel", identity, "left_target")
        return false
    end

    local applied_task = entry.tasks and entry.tasks.current or current
    if se_squad then
        sync_live_control_state(se_squad, applied_task)
    end

    return true
end

local function sorted_numeric_keys(map)
    local out = {}
    if type(map) ~= "table" then
        return out
    end
    for key in pairs(map) do
        local id = tonumber(key)
        if id then
            out[#out + 1] = id
        end
    end
    table_sort(out)
    return out
end

local function build_control_claim_snapshot(sid, smart_name, smart, smart_id)
    sid = tonumber(sid)
    if not sid then
        return nil
    end

    local entry = get_entry_for_sid(sid)
    local current = entry and entry.tasks and entry.tasks.current or nil
    local meta = get_smart_task_meta(current)
    if not (entry and current and meta and meta.smart_name == smart_name and meta.tasktype == TASKTYPE_CONTROL) then
        return nil
    end

    local se_squad = resolve_squad_object(sid)
    local identity = build_identity_from_entry(entry) or build_identity_from_task(current)
    local category = 3
    if is_claim_arrived(entry, se_squad, smart_name, smart_id) then
        category = 1
    elseif type(entry.scripted_target) == "string" and entry.scripted_target == smart_name then
        category = 2
    end

    return {
        sid = sid,
        entry = entry,
        current = current,
        meta = meta,
        se_squad = se_squad,
        identity = identity,
        category = category,
        distance = candidate_distance(entry, se_squad, smart),
    }
end

local function sort_control_claim_snapshots(list)
    table_sort(list, function(a, b)
        if a.category ~= b.category then
            return a.category < b.category
        end

        local a_hold = a.meta and a.meta.phase == "hold"
        local b_hold = b.meta and b.meta.phase == "hold"
        if a_hold ~= b_hold then
            return a_hold == true
        end

        if a.distance ~= b.distance then
            return a.distance < b.distance
        end

        return (tonumber(a.sid) or 0) < (tonumber(b.sid) or 0)
    end)
end

local function resolve_control_conflicts(smart_name, smart, smart_id)
    local claims = RUNTIME.claims_by_smart[smart_name]
    local ids = sorted_numeric_keys(claims)
    if #ids <= 1 then
        return false
    end

    local snapshots = {}
    for i = 1, #ids do
        local snapshot = build_control_claim_snapshot(ids[i], smart_name, smart, smart_id)
        if snapshot then
            snapshots[#snapshots + 1] = snapshot
        end
    end
    if #snapshots <= 1 then
        return false
    end

    sort_control_claim_snapshots(snapshots)

    local kept_identities = {}
    local kept_counts = {}
    local cap = get_control_cap()
    local changed = false

    for i = 1, #snapshots do
        local snapshot = snapshots[i]
        local identity = snapshot.identity
        local reject_reason = nil

        if not (identity and identity.key) then
            reject_reason = "conflict_identity"
        else
            local same_count = tonumber(kept_counts[identity.key]) or 0
            if same_count > 0 then
                if same_count >= cap then
                    reject_reason = "conflict_cap"
                end
            else
                for other_key, other_identity in pairs(kept_identities) do
                    if other_key ~= identity.key and not is_enemy_identity(other_identity, identity) then
                        reject_reason = "conflict_relation"
                        break
                    end
                end
            end
        end

        if reject_reason then
            clear_claim_task(snapshot.sid, smart_name, snapshot.se_squad, reject_reason)
            changed = true
        else
            kept_identities[identity.key] = identity
            kept_counts[identity.key] = (tonumber(kept_counts[identity.key]) or 0) + 1
        end
    end

    return changed
end

local function reconcile_control_smart(smart_name)
    local tasktype = get_tasktype_for_smart(smart_name)
    local smart_id, smart = resolve_smart_id(smart_name)
    local smart_level = resolve_smart_level_name(smart_name, nil)

    if not smart_tasks_enabled_now() or tasktype ~= TASKTYPE_CONTROL or not is_tasktype_enabled(tasktype) then
        local claims = RUNTIME.claims_by_smart[smart_name]
        local ids = sorted_numeric_keys(claims)
        for i = 1, #ids do
            local sid = ids[i]
            clear_claim_task(sid, smart_name, resolve_squad_object(sid), "disabled_or_removed")
        end
        return
    end

    if not smart_level then
        local claims = RUNTIME.claims_by_smart[smart_name]
        local ids = sorted_numeric_keys(claims)
        for i = 1, #ids do
            local sid = ids[i]
            clear_claim_task(sid, smart_name, resolve_squad_object(sid), "smart_missing")
        end
        return
    end

    if is_surge_active() then
        mark_smart_dirty(smart_name)
        return
    end

    local claims = RUNTIME.claims_by_smart[smart_name]
    local ids = sorted_numeric_keys(claims)
    for i = 1, #ids do
        validate_current_control_claim(ids[i], smart_name, smart, smart_id, smart_level)
    end

    resolve_control_conflicts(smart_name, smart, smart_id)

    local by_level = zhopa.memory and zhopa.memory.get_managed_squads_by_level and zhopa.memory.get_managed_squads_by_level() or nil
    local level_bucket = type(by_level) == "table" and by_level[smart_level] or nil
    local candidate_guard = 0
    if type(level_bucket) == "table" then
        for _ in pairs(level_bucket) do
            candidate_guard = candidate_guard + 1
        end
    end
    if candidate_guard <= 0 then
        return
    end

    for _ = 1, candidate_guard do
        local candidate = pick_control_candidate(smart_name, smart, smart_id, smart_level)
        if not candidate then
            break
        end
        if not assign_control_task(candidate.sid, smart_name, candidate.phase, candidate.identity, "reconcile") then
            break
        end
    end
end

local function reconcile_smart(smart_name)
    smart_name = trim(smart_name)
    if not smart_name then
        return
    end
    local tasktype = get_tasktype_for_smart(smart_name)
    if tasktype == TASKTYPE_CONTROL or RUNTIME.claims_by_smart[smart_name] ~= nil then
        reconcile_control_smart(smart_name)
    end
end

local function try_fill_control_smart_jobs_once(smart_name, smart)
    smart_name = trim(smart_name)
    if not (smart_name and smart and smart_supports_stalker_jobs(smart)) then
        return false
    end

    local claims = RUNTIME.claims_by_smart[smart_name]
    if type(claims) ~= "table" then
        return false
    end

    local smart_id = tonumber(smart.id) or nil
    local board = get_board()
    local filled = false
    local ids = sorted_numeric_keys(claims)
    for i = 1, #ids do
        local sid = ids[i]
        local entry = get_entry_for_sid(sid)
        local current = entry and entry.tasks and entry.tasks.current or nil
        local meta = get_smart_task_meta(current)
        if meta and meta.tasktype == TASKTYPE_CONTROL and meta.smart_name == smart_name and meta.phase == "hold" then
            local se_squad = resolve_squad_object(sid)
            if se_squad and is_online_squad(se_squad) and is_claim_arrived(entry, se_squad, smart_name, smart_id) then
                try_soft_register_squad_to_smart(se_squad, smart, board)
                if try_soft_assign_free_stalker_jobs_once(se_squad, smart, entry) then
                    filled = true
                end
            end
        end
    end

    return filled
end

local function pop_dirty_smart()
    local queue = RUNTIME.dirty_queue
    local head = tonumber(RUNTIME.dirty_queue_head) or 1
    local tail = tonumber(RUNTIME.dirty_queue_tail) or 0
    while head <= tail do
        local smart_name = queue[head]
        queue[head] = nil
        head = head + 1
        if type(smart_name) == "string" and RUNTIME.dirty_smarts[smart_name] == true then
            RUNTIME.dirty_queue_head = head
            if head > 128 and head > (tail / 2) then
                local compacted = {}
                for i = head, tail do
                    compacted[#compacted + 1] = queue[i]
                end
                RUNTIME.dirty_queue = compacted
                RUNTIME.dirty_queue_head = 1
                RUNTIME.dirty_queue_tail = #compacted
            end
            return smart_name
        end
    end
    RUNTIME.dirty_queue = {}
    RUNTIME.dirty_queue_head = 1
    RUNTIME.dirty_queue_tail = 0
    return nil
end

local function process_dirty_smarts(limit, preferred_smarts)
    if RUNTIME.processing_dirty == true then
        return
    end
    RUNTIME.processing_dirty = true

    local processed = 0
    local visited = {}

    local function run_one(smart_name)
        smart_name = trim(smart_name)
        if not smart_name or visited[smart_name] == true or RUNTIME.dirty_smarts[smart_name] ~= true then
            return
        end
        visited[smart_name] = true
        RUNTIME.dirty_smarts[smart_name] = nil
        reconcile_smart(smart_name)
        processed = processed + 1
    end

    if type(preferred_smarts) == "table" then
        for i = 1, #preferred_smarts do
            if limit ~= nil and processed >= limit then
                break
            end
            run_one(preferred_smarts[i])
        end
    end

    while limit == nil or processed < limit do
        local smart_name = pop_dirty_smart()
        if not smart_name then
            break
        end
        run_one(smart_name)
    end

    RUNTIME.processing_dirty = false
end

local function rebuild_runtime_claims_from_memory()
    RUNTIME.claims_by_smart = {}
    RUNTIME.claims_by_smart_identity = {}
    RUNTIME.claim_by_sid = {}
    RUNTIME.reserved_squads = {}

    if not (zhopa.memory and zhopa.memory.get_state) then
        return
    end
    local state = zhopa.memory.get_state()
    local squads = state and state.squads or nil
    if type(squads) ~= "table" then
        return
    end

    for sid, entry in pairs(squads) do
        if type(entry) == "table" then
            local current = entry.tasks and entry.tasks.current or nil
            local meta = get_smart_task_meta(current)
            if meta then
                local identity = build_identity_from_entry(entry) or build_identity_from_task(current)
                add_runtime_claim(sid, meta.smart_name, meta.tasktype, meta.phase, identity)
            end
        end
    end
end

local function mark_all_known_smarts_dirty()
    if zhopa.config and zhopa.config.get_smart_task_map then
        local task_map = zhopa.config.get_smart_task_map()
        for smart_name in pairs(task_map or {}) do
            mark_smart_dirty(smart_name)
        end
    end
    for smart_name in pairs(RUNTIME.claims_by_smart) do
        mark_smart_dirty(smart_name)
    end
end

local function reactivate_runtime(reason)
    rebuild_runtime_claims_from_memory()
    reset_dirty_queue()
    mark_all_known_smarts_dirty()
    RUNTIME.bootstrapped = true
    process_dirty_smarts(nil)
    log_info("runtime_reactivated reason=%s dirty=%s", tostring(reason or "-"), tostring(next(RUNTIME.dirty_smarts) ~= nil))
end

local function on_task_current_changed(payload)
    local sid = tonumber(type(payload) == "table" and payload.squad_id or nil)
    if not sid then
        return
    end

    local prev = type(payload) == "table" and payload.prev_task or nil
    local current = type(payload) == "table" and payload.current_task or nil
    local prev_meta = get_smart_task_meta(prev)
    local current_meta = get_smart_task_meta(current)

    if prev_meta then
        remove_runtime_claim(sid)
        mark_smart_dirty(prev_meta.smart_name)
    else
        remove_runtime_claim(sid)
    end

    if current_meta then
        local entry = get_entry_for_sid(sid)
        local identity = build_identity_from_entry(entry) or build_identity_from_task(current)
        add_runtime_claim(sid, current_meta.smart_name, current_meta.tasktype, current_meta.phase, identity)
        mark_smart_dirty(current_meta.smart_name)
    end
end

local function on_server_entity_unregister(se_obj, type_name)
    local sid = tonumber(se_obj and se_obj.id) or nil
    if sid then
        local claim = RUNTIME.claim_by_sid[sid]
        if claim then
            local smart_name = claim.smart_name
            remove_runtime_claim(sid)
            mark_smart_dirty(smart_name)
        end
    end

    local smart_name = safe_object_name(se_obj)
    if type_name == "smart_terrain" or type_name == "smart_terrain_script" or type_name == "stalker_smart_terrain" then
        mark_smart_dirty(smart_name)
    elseif smart_name and (get_tasktype_for_smart(smart_name) or RUNTIME.claims_by_smart[smart_name]) then
        mark_smart_dirty(smart_name)
    end
end

local function build_preferred_dirty_list(entry, current)
    local out = {}
    local seen = {}

    local function add(smart_name)
        smart_name = trim(smart_name)
        if not smart_name or seen[smart_name] == true then
            return
        end
        seen[smart_name] = true
        out[#out + 1] = smart_name
    end

    local meta = get_smart_task_meta(current)
    if meta then
        add(meta.smart_name)
    end

    if type(entry) == "table" then
        add(entry.scripted_target)
        local smart_id = tonumber(entry.smart_id) or nil
        if smart_id and zhopa.board_index and zhopa.board_index.get_smart_name_by_id then
            add(zhopa.board_index.get_smart_name_by_id(smart_id))
        end
    end

    return out
end

local function validate_current_smart_task(se_squad, entry, meta)
    if not (entry and meta and meta.smart_name and meta.tasktype) then
        return false, "missing_meta"
    end
    if not smart_tasks_enabled_now() then
        return false, "disabled"
    end
    local configured = get_tasktype_for_smart(meta.smart_name)
    if configured ~= meta.tasktype then
        return false, "tasktype_changed"
    end
    local smart_level = resolve_smart_level_name(meta.smart_name, nil)
    if not smart_level then
        return false, "smart_missing"
    end
    if se_squad and zhopa.memory and zhopa.memory.is_protected_squad and zhopa.memory.is_protected_squad(se_squad) then
        return false, "protected"
    end
    if not entry_allowed_for_smart_task(entry, meta.smart_name, meta.tasktype, smart_level) then
        return false, "rule_reject"
    end
    return true, nil
end

local function handle_current_control_task(se_squad, entry, meta)
    local valid, reason = validate_current_smart_task(se_squad, entry, meta)
    if valid ~= true then
        clear_claim_task(entry.squad_id, meta.smart_name, se_squad, reason)
        process_dirty_smarts(1, { meta.smart_name })
        return false
    end

    if is_surge_active() then
        clear_claim_task(entry.squad_id, meta.smart_name, se_squad, "surge")
        return false
    end

    local smart_id = resolve_smart_id(meta.smart_name)
    local identity = build_identity_from_entry(entry) or build_identity_from_task(meta.task)

    if meta.phase == "travel" and is_claim_arrived(entry, se_squad, meta.smart_name, smart_id) then
        assign_control_task(entry.squad_id, meta.smart_name, "hold", identity, "arrived")
        entry = get_entry_for_sid(entry.squad_id) or entry
        meta = get_smart_task_meta(entry.tasks and entry.tasks.current or nil) or meta
    elseif meta.phase == "hold" and not is_claim_arrived(entry, se_squad, meta.smart_name, smart_id) then
        assign_control_task(entry.squad_id, meta.smart_name, "travel", identity, "repath")
        entry = get_entry_for_sid(entry.squad_id) or entry
        meta = get_smart_task_meta(entry.tasks and entry.tasks.current or nil) or meta
    end

    local current = entry.tasks and entry.tasks.current or nil
    if current then
        if meta.phase == "travel" and current.type == TASK_GO_TO_CONTROL and should_enforce_online_intent(current, tg(), entry) then
            local ok_enf, err_enf = pcall(enforce_online_task_intent, se_squad, entry, current)
            if not ok_enf then
                log_warn("intent_enforce_failed sid=%s smart=%s err=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(meta and meta.smart_name or "-"),
                    tostring(err_enf or "-")
                )
            end
        end
        sync_live_control_state(se_squad, current)
    end
    return true
end

local function update_squad_tasks_impl(se_squad, ctx)
    if not (zhopa.memory and (zhopa.memory.touch_squad_validated or zhopa.memory.get_squad_entry)) then
        return false
    end

    local entry = nil
    if ctx and ctx.prevalidated == true and se_squad and se_squad.id and zhopa.memory.get_squad_entry then
        entry = zhopa.memory.get_squad_entry(se_squad.id)
    elseif zhopa.memory.touch_squad_validated then
        entry = zhopa.memory.touch_squad_validated(se_squad, false, "smart_tasks")
    end
    if not entry then
        return false
    end

    local current = entry.tasks and entry.tasks.current or nil
    local preferred = build_preferred_dirty_list(entry, current)
    if next(RUNTIME.dirty_smarts) ~= nil then
        process_dirty_smarts(DIRTY_BATCH_PER_UPDATE, preferred)
        entry = get_entry_for_sid(entry.squad_id) or entry
        current = entry.tasks and entry.tasks.current or nil
    end

    local meta = get_smart_task_meta(current)
    if not meta then
        return false
    end

    if meta.tasktype == TASKTYPE_CONTROL then
        return handle_current_control_task(se_squad, entry, meta)
    end

    clear_claim_task(entry.squad_id, meta.smart_name, se_squad, "unsupported")
    return false
end

local function on_actor_first_update()
    reactivate_runtime("actor_on_first_update")
end

local function on_load_state()
    reactivate_runtime("load_state")
end

local function on_option_change()
    reactivate_runtime("option_change")
end

local function wants_smart_update(_, ctx)
    local smart_name = type(ctx) == "table" and ctx.name or nil
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    return get_tasktype_for_smart(smart_name) ~= nil or RUNTIME.claims_by_smart[smart_name] ~= nil
end

local function on_smart_terrain_update(smart, ctx)
    local smart_name = type(ctx) == "table" and ctx.name or safe_object_name(smart)
    if smart_name and (get_tasktype_for_smart(smart_name) or RUNTIME.claims_by_smart[smart_name]) then
        mark_smart_dirty(smart_name)
        process_dirty_smarts(1, { smart_name })
        try_fill_control_smart_jobs_once(smart_name, smart)
    end
end

local function on_squad_enter_smart(_, smart)
    local smart_name = safe_object_name(smart)
    if smart_name then
        mark_smart_dirty(smart_name)
    end
end

local function on_squad_leave_smart(_, smart)
    local smart_name = safe_object_name(smart)
    if smart_name then
        mark_smart_dirty(smart_name)
    end
end

smart_tasks.reactivate_runtime = reactivate_runtime
smart_tasks.update_squad_tasks = update_squad_tasks_impl
smart_tasks.on_actor_first_update = on_actor_first_update
smart_tasks.on_load_state = on_load_state
smart_tasks.on_option_change = on_option_change
smart_tasks.on_task_current_changed = on_task_current_changed
smart_tasks.wants_smart_update = wants_smart_update
smart_tasks.on_smart_terrain_update = on_smart_terrain_update
smart_tasks.on_server_entity_unregister = on_server_entity_unregister
smart_tasks.on_squad_enter_smart = on_squad_enter_smart
smart_tasks.on_squad_leave_smart = on_squad_leave_smart
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_smart_tasks

-- BEGIN module zhopa_trade
zhopa_bundle_module = function()
zhopa = zhopa or {}
zhopa.trade = zhopa.trade or {}

local trade = zhopa.trade

local _G = _G
local pcall = _G.pcall
local next = _G.next
local tonumber = _G.tonumber
local tostring = _G.tostring
local type = _G.type
local pairs = _G.pairs
local string = _G.string
local time_global = _G.time_global

local function tg()
    return (time_global and time_global()) or 0
end

local function cfg_num(key, default, min_v)
    local v = tonumber(default) or 0
    if zhopa.runtime_cfg and zhopa.runtime_cfg.num then
        return zhopa.runtime_cfg.num(key, v, min_v)
    end
    if zhopa.config and zhopa.config.get then
        local x = zhopa.config.get(key, default)
        if tonumber(x) then
            v = tonumber(x)
        end
    end
    if min_v ~= nil and v < min_v then
        v = min_v
    end
    return v
end

local function get_board()
    if _G.SIMBOARD then return _G.SIMBOARD end
    if _G.sim_board and _G.sim_board.get_sim_board then
        local ok, b = pcall(function() return _G.sim_board.get_sim_board() end)
        if ok then return b end
    end
    return nil
end

local function safe_obj_by_id(id)
    if not id then return nil end
    if _G.level and _G.level.object_by_id then
        local ok, obj = pcall(function() return _G.level.object_by_id(id) end)
        if ok and obj then return obj end
    end
    local st = _G.db and _G.db.storage and _G.db.storage[id]
    return st and st.object or nil
end

local no_trade_comm = {
    zombied = true,
    army = true,
    monolith = true,
    greh = true,
    isg = true,
}

local RUNTIME = {
    surge_cache_active = false,
    surge_cache_next_tg = 0,
    trade_started_by_squad = {},
    service_event_by_squad = {},
}

local function apply_service_event_to_memory(squad_id, evt)
    squad_id = tonumber(squad_id) or 0
    if squad_id <= 0 or type(evt) ~= "table" then
        return false
    end

    local memory = zhopa.memory
    local entry = memory and memory.get_squad_entry and memory.get_squad_entry(squad_id) or nil
    if type(entry) ~= "table" then
        return false
    end

    local task = entry.tasks and entry.tasks.current or nil
    if not (type(task) == "table" and task.type == "TRADE") then
        if memory and memory.mark_dirty then
            memory.mark_dirty(squad_id, "task")
        end
        return false
    end

    local p = type(task.params) == "table" and task.params or {}
    task.params = p

    p.trade_service_result_tg = tonumber(evt.tg) or tg()
    p.trade_service_result_source = evt.source
    p.trade_service_result_reason = evt.reason
    p.trade_service_result_phase = evt.phase
    p.trade_service_result_status = evt.status

    if evt.phase == "trade" or evt.phase == "tech" then
        p.trade_phase_kind = evt.phase
        p.trade_phase_started_tg = tonumber(evt.tg) or tg()
        p.trade_done_state = nil
        if evt.phase == "trade" and tonumber(p.trade_started_tg) == nil then
            p.trade_started_tg = tonumber(evt.tg) or tg()
        end
    end

    if memory and memory.mark_dirty then
        memory.mark_dirty(squad_id, "task")
    end
    return true
end

local function remember_service_event(squad_id, npc_id, smart_name, source, phase, status, reason)
    squad_id = tonumber(squad_id) or 0
    if squad_id <= 0 then
        return false
    end

    local now = tg()
    local evt = {
        npc_id = tonumber(npc_id) or nil,
        smart_name = type(smart_name) == "string" and smart_name or nil,
        source = tostring(source or "trade_manager"),
        phase = type(phase) == "string" and phase or nil,
        status = type(status) == "string" and status or nil,
        reason = type(reason) == "string" and reason or nil,
        tg = now,
    }

    RUNTIME.service_event_by_squad[squad_id] = evt
    if evt.phase == "trade" or evt.phase == "tech" then
        RUNTIME.trade_started_by_squad[squad_id] = evt
    end

    apply_service_event_to_memory(squad_id, evt)

    if zhopa.log and zhopa.log.debug then
        zhopa.log.debug(
            "TRADE",
            "service_event sid=%s npc=%s target=%s phase=%s status=%s source=%s reason=%s",
            tostring(squad_id),
            tostring(evt.npc_id or "-"),
            tostring(evt.smart_name or "-"),
            tostring(evt.phase or "-"),
            tostring(evt.status or "-"),
            tostring(evt.source or "-"),
            tostring(evt.reason or "-")
        )
    end
    return true
end

local function surge_started_uncached()
    local xc = _G.xr_conditions
    local xf = xc and xc.surge_started or nil
    if type(xf) == "function" then
        local ok, res = pcall(xf)
        if ok and res == true then return true, false end
        if ok and res == false then return false, false end
    end

    local fallback_used = false

    local f = _G.surge_started
    if type(f) == "function" then
        fallback_used = true
        local ok, res = pcall(f)
        if ok and res == true then return true, fallback_used end
        if ok and res == false then return false, fallback_used end
    end

    local psm = _G.psi_storm_manager
    if psm and type(psm.is_loaded) == "function" and type(psm.is_started) == "function" then
        fallback_used = true
        local okL, loaded = pcall(function() return psm.is_loaded() end)
        if okL and loaded == true then
            local okS, started = pcall(function() return psm.is_started() end)
            if okS and started == true then return true, fallback_used end
        end
    end

    local sm = _G.surge_manager
    if sm and type(sm.is_loaded) == "function" and type(sm.is_started) == "function" then
        fallback_used = true
        local okL, loaded = pcall(function() return sm.is_loaded() end)
        if okL and loaded == true then
            local okS, started = pcall(function() return sm.is_started() end)
            if okS and started == true then return true, fallback_used end
        end
    end

    if _G.level and type(_G.level.is_surge) == "function" then
        fallback_used = true
        local ok, res = pcall(function() return _G.level.is_surge() end)
        if ok and res == true then return true, fallback_used end
    end
    return false, fallback_used
end

local function is_surge_started(force_refresh)
    local now = tg()
    if force_refresh ~= true and now < (tonumber(RUNTIME.surge_cache_next_tg) or 0) then
        return RUNTIME.surge_cache_active == true
    end

    local active, fallback_used = surge_started_uncached()
    local cache_ms = cfg_num("surge_check_cache_ms", 250, 0)
    RUNTIME.surge_cache_active = active == true
    RUNTIME.surge_cache_next_tg = now + cache_ms

    if fallback_used then
        if zhopa.log and zhopa.log.warn then
            zhopa.log.warn("PERF", "PERF_SURGE_CHECK_FALLBACK source=trade")
        end
    end
    return active == true
end

local function infer_seller_id_from_smart(smart)
    if not smart then return nil end

    local by_job = smart.npc_by_job_section
    if type(by_job) == "table" then
        local best = nil
        for sec, nid in pairs(by_job) do
            if type(sec) == "string" then
                local s = string.lower(sec)
                if string.find(s, "barman", 1, true) ~= nil then
                    return tonumber(nid) or nil
                end
                if best == nil and (string.find(s, "trader", 1, true) ~= nil or string.find(s, "_trade_", 1, true) ~= nil) then
                    best = tonumber(nid) or best
                end
            end
        end
        if best then return best end
    end

    local npc_info = smart.npc_info
    if type(npc_info) == "table" then
        local best = nil
        for nid, info in pairs(npc_info) do
            local se = info and info.se_obj or nil
            if se and se.name then
                local ok_n, nm = pcall(function() return se:name() end)
                if ok_n and type(nm) == "string" then
                    local s = string.lower(nm)
                    if string.find(s, "_barman", 1, true) ~= nil then
                        return tonumber(nid) or nil
                    end
                    if best == nil and string.find(s, "_trader", 1, true) ~= nil then
                        best = tonumber(nid) or best
                    end
                end
            end
        end
        if best then return best end
    end

    return nil
end

local function ensure_storage(npc_id, npc_obj)
    if not (_G.db and _G.db.storage and npc_id) then return nil end
    local st = _G.db.storage[npc_id]
    if type(st) ~= "table" then
        st = {}
        _G.db.storage[npc_id] = st
    end
    if st.object == nil and npc_obj then
        st.object = npc_obj
    end
    return st
end

local function resolve_squad_id_from_npc_id(npc_id)
    npc_id = tonumber(npc_id) or 0
    if npc_id <= 0 or npc_id == 65535 then
        return nil
    end

    local af = _G.alife and _G.alife()
    if not af then
        return nil
    end

    local ok_obj, se_npc = pcall(function() return af:object(npc_id) end)
    if not (ok_obj and se_npc) then
        return nil
    end

    local ok_sid, squad_id = pcall(function() return se_npc.group_id end)
    squad_id = ok_sid and tonumber(squad_id) or nil
    if squad_id and squad_id > 0 and squad_id ~= 65535 then
        return squad_id
    end

    local ok_sid_fn, squad_id_fn = pcall(function() return se_npc:group_id() end)
    squad_id_fn = ok_sid_fn and tonumber(squad_id_fn) or nil
    if squad_id_fn and squad_id_fn > 0 and squad_id_fn ~= 65535 then
        return squad_id_fn
    end

    return nil
end

trade.resolve_squad_id_from_npc_id = resolve_squad_id_from_npc_id

function trade.notify_trade_started(npc_id, smart_name, source)
    local squad_id = resolve_squad_id_from_npc_id(npc_id)
    if not squad_id then
        return false
    end
    return remember_service_event(squad_id, npc_id, smart_name, source, "trade", "started", "trade_started")
end

function trade.consume_trade_started(squad_id, expected_target)
    squad_id = tonumber(squad_id) or 0
    if squad_id <= 0 then
        return false, nil
    end

    local evt = RUNTIME.trade_started_by_squad[squad_id]
    if type(evt) ~= "table" then
        return false, nil
    end

    local now = tg()
    if now > ((tonumber(evt.tg) or 0) + 60000) then
        RUNTIME.trade_started_by_squad[squad_id] = nil
        return false, nil
    end

    if type(expected_target) == "string" and expected_target ~= "" and type(evt.smart_name) == "string" and evt.smart_name ~= expected_target then
        return false, evt
    end

    RUNTIME.trade_started_by_squad[squad_id] = nil
    return true, evt
end

local function reset_trade_runtime()
    RUNTIME.trade_started_by_squad = {}
    RUNTIME.service_event_by_squad = {}
    RUNTIME.surge_cache_active = false
    RUNTIME.surge_cache_next_tg = 0
end

function trade.consume_service_event(squad_id, expected_target)
    squad_id = tonumber(squad_id) or 0
    if squad_id <= 0 then
        return false, nil
    end
    local evt = RUNTIME.service_event_by_squad[squad_id]
    if type(evt) ~= "table" then
        return false, nil
    end
    local now = tg()
    if now > ((tonumber(evt.tg) or 0) + 60000) then
        RUNTIME.service_event_by_squad[squad_id] = nil
        return false, nil
    end
    if type(expected_target) == "string" and expected_target ~= ""
        and type(evt.smart_name) == "string" and evt.smart_name ~= expected_target then
        return false, evt
    end
    RUNTIME.service_event_by_squad[squad_id] = nil
    return true, evt
end

local function prepare_trade_flags(leader_obj, params)
    if not (leader_obj and params) then return nil end
    local ok_id, leader_id = pcall(function() return leader_obj:id() end)
    leader_id = ok_id and tonumber(leader_id) or nil
    if not leader_id then return nil end

    local st = ensure_storage(leader_id, leader_obj)
    if not st then return nil end

    if type(st.trade_items) ~= "table" then
        st.trade_items = {}
    end
    st.has_items_to_sell = true

    params.trade_intent_applied_tg = params.trade_intent_applied_tg or tg()
    return true
end

local function is_tech_job(job)
    if not (job and job.section) then return false end
    local s = tostring(job.section)
    return string.find(s, "_beh_tech_job_", 1, true) ~= nil
end

local function is_trade_job(job)
    if not (job and job.section) then return false end
    local s = tostring(job.section)
    if string.find(s, "_beh_trade_job_", 1, true) ~= nil then return true end
    if string.find(s, "_beh_trade_", 1, true) ~= nil then return true end
    if string.find(s, "_beh_tech_job_", 1, true) ~= nil then return true end
    return false
end

local function is_trader_job(job)
    if not (job and job.section) then return false end
    local s = tostring(job.section)
    if string.find(s, "_beh_trade_job_", 1, true) ~= nil then return true end
    if string.find(s, "_beh_trade_", 1, true) ~= nil then return true end
    return false
end

local function has_service_items(tbl)
    return type(tbl) == "table" and next(tbl) ~= nil
end

local function get_service_state(st, now)
    now = tonumber(now) or tg()
    if type(st) ~= "table" then
        return false, false, false
    end
    local trade_pending = st.has_items_to_sell == true or has_service_items(st.trade_items)
    local tech_pending = st.has_tech_items == true or has_service_items(st.tech_items)
    local reset_active = now < (tonumber(st.zhopa_axr_service_reset_guard_tg) or 0)
    return trade_pending, tech_pending, reset_active
end

local function log_trade_done_gate_once(p, entry, target, phase_tag, leader_id, job, st, trade_pending, tech_pending, reset_active)
    if type(p) ~= "table" then
        return
    end

    local state_key = tostring(phase_tag or "done")
    if p.trade_done_state == state_key then
        return
    end
    p.trade_done_state = state_key

    local logger = zhopa and zhopa.log or nil
    local log_fn = reset_active == true and logger and logger.warn or logger and logger.info
    if type(log_fn) ~= "function" then
        return
    end

    local tag = reset_active == true and "trade_done_during_reset" or "trade_done_gate"
    log_fn(
        "TRADE",
        "%s sid=%s level=%s target=%s phase=%s leader=%s job=%s section=%s scheme=%s trade_pending=%s tech_pending=%s reset=%s event_status=%s event_phase=%s event_source=%s event_reason=%s",
        tostring(tag),
        tostring(entry and entry.squad_id or "-"),
        tostring(entry and entry.level or "-"),
        tostring(target or "-"),
        tostring(phase_tag or "-"),
        tostring(leader_id or "-"),
        tostring(job and job.section or nil),
        tostring(st and st.active_section or nil),
        tostring(st and st.active_scheme or nil),
        tostring(trade_pending == true),
        tostring(tech_pending == true),
        tostring(reset_active == true),
        tostring(p.trade_service_result_status or "-"),
        tostring(p.trade_service_result_phase or "-"),
        tostring(p.trade_service_result_source or "-"),
        tostring(p.trade_service_result_reason or "-")
    )
end

local function get_trade_phase(job)
    if is_tech_job(job) then
        return "tech"
    end
    if is_trade_job(job) then
        return "trade"
    end
    return nil
end

local function smart_has_trader_job_slot(smart)
    local jobs = smart and smart.stalker_jobs or nil
    if type(jobs) ~= "table" then
        return false
    end
    for i = 1, #jobs do
        if is_trader_job(jobs[i]) then
            return true
        end
    end
    return false
end

local function resolve_live_trader_for_trade_smart(smart, job)
    if not smart then
        return nil, nil
    end

    local seller_id = job and (tonumber(job.seller_id) or tonumber(job.seller)) or nil
    local seller = seller_id and safe_obj_by_id(seller_id) or nil
    if seller and zhopa.safe and zhopa.safe.is_alive and zhopa.safe.is_alive(seller) then
        if job then
            job.seller_id = seller_id
        end
        return seller, seller_id
    end

    seller_id = infer_seller_id_from_smart(smart)
    seller = seller_id and safe_obj_by_id(seller_id) or nil
    if seller and zhopa.safe and zhopa.safe.is_alive and zhopa.safe.is_alive(seller) then
        if job then
            job.seller_id = seller_id
        end
        return seller, seller_id
    end

    return nil, nil
end

local function evict_leader_from_trade_job(smart, leader_id)
    leader_id = tonumber(leader_id)
    if not (smart and leader_id) then
        return false, "invalid"
    end

    local npc_info = smart.npc_info and (smart.npc_info[leader_id] or smart.npc_info[tostring(leader_id)]) or nil
    if not npc_info then
        return false, "no_npc_info"
    end
    if not is_trader_job(npc_info.job) then
        return false, "not_trader_job"
    end

    local by_job = type(smart.npc_by_job_section) == "table" and smart.npc_by_job_section or nil
    if by_job then
        for sec, owner in pairs(by_job) do
            if tonumber(owner) == leader_id and is_trader_job({ section = sec }) then
                by_job[sec] = nil
            end
        end
    end

    npc_info.job = nil
    return true, "evicted"
end

function trade.can_trade_now(se_squad)
    if not se_squad then return false end
    local comm = nil
    if zhopa.safe and zhopa.safe.safe_squad_community then
        comm = zhopa.safe.safe_squad_community(se_squad)
    elseif _G.alife and se_squad.commander_id then
        local ok_cid, cid = pcall(function() return se_squad:commander_id() end)
        cid = ok_cid and tonumber(cid) or nil
        if cid and cid > 0 and cid ~= 65535 then
            local ok_obj, se_commander = pcall(function() return _G.alife():object(cid) end)
            if ok_obj and se_commander and se_commander.community then
                local ok_c, c = pcall(function() return se_commander:community() end)
                comm = ok_c and c or nil
            end
        end
    end
    if comm and no_trade_comm[tostring(comm)] then
        return false
    end
    local ok, cid = pcall(function() return se_squad:commander_id() end)
    return ok and tonumber(cid) ~= nil
end

function trade.tick(se_squad, entry, task)
    if not (se_squad and entry and task and task.target) then
        return "FAILED"
    end
    local p = task.params or {}
    task.params = p

    local target = task.target
    if p.trade_last_target ~= target then
        p.trade_last_target = target
        p.trade_intent_applied_tg = nil
        p.trade_entered_job_logged = nil
        p.trade_started_tg = nil
        p.trade_phase_kind = nil
        p.trade_phase_started_tg = nil
        p.trade_started_idle = nil
        p.trade_surge_was_active = nil
        p.trade_no_trader_hard = nil
        p.trade_no_trader_reason = nil
        p.trade_job_evicted = nil
        p.trade_done_state = nil
        p.trade_arrived_at_tg = nil
    end

    local board = get_board()
    local smart = board and board.smarts_by_names and board.smarts_by_names[target] or nil
    if not smart then return "NO_TRADER" end

    local ok_cid, leader_id = pcall(function() return se_squad:commander_id() end)
    leader_id = ok_cid and tonumber(leader_id) or nil
    if not leader_id then return "OFFLINE" end

    local leader = safe_obj_by_id(leader_id)
    if not (leader and zhopa.safe and zhopa.safe.is_alive and zhopa.safe.is_alive(leader)) then
        return "OFFLINE"
    end

    local info = smart.npc_info and (smart.npc_info[leader_id] or smart.npc_info[tostring(leader_id)]) or nil
    local job = info and info.job or nil
    local now = tg()

    local surge = is_surge_started()
    if surge then
        p.trade_surge_was_active = true
        return is_trade_job(job) and "TRADING" or "MEETING"
    end
    if p.trade_surge_was_active then
        p.trade_surge_was_active = nil
        p.trade_intent_applied_tg = now
    end

    local in_trade_job = is_trade_job(job)
    local in_trader_job = is_trader_job(job)
    local phase_kind = get_trade_phase(job)
    local seller, seller_id = resolve_live_trader_for_trade_smart(smart, job)
    local fast_trade_triggered = task and task.params and task.params.fast_trade_triggered == true
    local st = _G.db and _G.db.storage and _G.db.storage[leader_id] or nil
    local trade_pending, tech_pending, reset_active = get_service_state(st, now)

    if in_trader_job and not seller then
        local evicted, evict_reason = evict_leader_from_trade_job(smart, leader_id)
        p.trade_no_trader_hard = true
        p.trade_no_trader_reason = "no_live_trader"
        p.trade_job_evicted = evicted == true
        p.trade_started_tg = nil
        p.trade_phase_kind = nil
        p.trade_phase_started_tg = nil
        p.trade_started_idle = nil
        if evicted then
            if zhopa.log and zhopa.log.warn then
                zhopa.log.warn("TRADE", "TRADE_INVALID_JOB_EVICT sid=%s target=%s leader=%s reason=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(target or "-"),
                    tostring(leader_id or "-"),
                    tostring(evict_reason or "-"))
            end
        end
        if zhopa.log and zhopa.log.warn then
            zhopa.log.warn("TRADE", "TRADE_NO_LIVE_TRADER sid=%s target=%s leader=%s state=in_job seller_id=%s evicted=%s",
                tostring(entry and entry.squad_id or "-"),
                tostring(target or "-"),
                tostring(leader_id or "-"),
                tostring(seller_id or "-"),
                tostring(evicted == true))
        end
        return "NO_TRADER"
    end

    if (not in_trade_job) and smart_has_trader_job_slot(smart) and not seller then
        p.trade_no_trader_hard = true
        p.trade_no_trader_reason = "no_live_trader"
        p.trade_job_evicted = false
        p.trade_started_tg = nil
        p.trade_phase_kind = nil
        p.trade_phase_started_tg = nil
        p.trade_started_idle = nil
        if zhopa.log and zhopa.log.warn then
            zhopa.log.warn("TRADE", "TRADE_NO_LIVE_TRADER sid=%s target=%s leader=%s state=arrival seller_id=%s evicted=false",
                tostring(entry and entry.squad_id or "-"),
                tostring(target or "-"),
                tostring(leader_id or "-"),
                tostring(seller_id or "-"))
        end
        return "NO_TRADER"
    end

    if not in_trade_job then
        if tonumber(p.trade_started_tg) then
            local max_ms = tonumber(p.trade_max_duration_ms) or 60000
            if max_ms < 5000 then max_ms = 5000 end
            if now >= (tonumber(p.trade_started_tg) + max_ms) then
                if zhopa.log and zhopa.log.warn then
                    zhopa.log.warn(
                        "TRADE",
                        "service_transition_timeout sid=%s level=%s target=%s trade_pending=%s tech_pending=%s reset=%s",
                        tostring(entry and entry.squad_id or "-"),
                        tostring(entry and entry.level or "-"),
                        tostring(target or "-"),
                        tostring(trade_pending == true),
                        tostring(tech_pending == true),
                        tostring(reset_active == true)
                    )
                end
                return "NO_TRADER"
            end
            if trade_pending ~= true and tech_pending ~= true then
                log_trade_done_gate_once(p, entry, target, "post_job_clear", leader_id, job, st, trade_pending, tech_pending, reset_active)
                return "DONE"
            end
            return "MEETING"
        end
        if prepare_trade_flags(leader, p) == nil then
            return "MEETING"
        end

        local since = tonumber(p.trade_intent_applied_tg) or now
        local wait_ms = tonumber(p.trade_wait_job_ms) or 90000
        if wait_ms < 10000 then wait_ms = 10000 end
        if now >= (since + wait_ms) then
            if zhopa.log and zhopa.log.warn then
                zhopa.log.warn("TRADE", "no_trade_job_timeout sid=%s level=%s target=%s", tostring(entry and entry.squad_id or "-"), tostring(entry and entry.level or "-"), tostring(target))
            end
            return "NO_TRADER"
        end
        return "MEETING"
    end

    if job and job.seller_id == nil and seller_id then
        job.seller_id = seller_id
    end

    if zhopa.log and zhopa.log.info and not p.trade_entered_job_logged then
        p.trade_entered_job_logged = true
        zhopa.log.info("TRADE", "entered_trade_job sid=%s level=%s target=%s job=%s", tostring(entry and entry.squad_id or "-"), tostring(entry and entry.level or "-"), tostring(target), tostring(job and job.section or "-"))
    end

    -- Clear fast_trade_triggered flag when entering trade job
    if fast_trade_triggered and task and task.params then
        task.params.fast_trade_triggered = nil
    end

    -- Always mark trade start when entering trade job (idle is optional)
    if not p.trade_started_tg then
        p.trade_started_tg = now
        local idle = job and job.idle or nil
        if idle then
            p.trade_started_idle = tonumber(idle)
        end
    end
    if phase_kind and p.trade_phase_kind ~= phase_kind then
        p.trade_phase_kind = phase_kind
        p.trade_phase_started_tg = now
    end
    if not tonumber(p.trade_phase_started_tg) then
        p.trade_phase_started_tg = now
    end

    if p.trade_started_tg then
        local grace_ms = tonumber(p.trade_done_grace_ms) or 2000
        if grace_ms < 0 then grace_ms = 0 end
        local phase_started_tg = tonumber(p.trade_phase_started_tg) or tonumber(p.trade_started_tg) or now
        if phase_kind == "tech" then
            if tech_pending ~= true and now >= (phase_started_tg + grace_ms) then
                log_trade_done_gate_once(p, entry, target, "tech_phase_clear", leader_id, job, st, trade_pending, tech_pending, reset_active)
                return "DONE"
            end
        else
            if trade_pending ~= true and tech_pending ~= true and now >= (phase_started_tg + grace_ms) then
                log_trade_done_gate_once(p, entry, target, "trade_phase_clear", leader_id, job, st, trade_pending, tech_pending, reset_active)
                return "DONE"
            end
        end
        local max_ms = tonumber(p.trade_max_duration_ms) or 60000
        if max_ms < 5000 then max_ms = 5000 end
        if now >= (tonumber(p.trade_started_tg) + max_ms) then
            if zhopa.log and zhopa.log.warn then
                zhopa.log.warn("TRADE", "trade_duration_timeout sid=%s level=%s target=%s", tostring(entry and entry.squad_id or "-"), tostring(entry and entry.level or "-"), tostring(target))
            end
            return "NO_TRADER"
        end
    end

    return "TRADING"
end

function trade.on_load_state()
    reset_trade_runtime()
end

function trade.on_option_change()
    reset_trade_runtime()
end

function trade.on_trade_service_result(squad_id, npc_id, smart_name, source, phase, status, reason)
    return remember_service_event(squad_id, npc_id, smart_name, source, phase, status, reason)
end

function trade.on_server_entity_unregister(se_obj, type_name)
    if type(type_name) == "string" and type_name == "sim_squad_scripted" and se_obj and se_obj.id then
        local sid = tonumber(se_obj.id) or 0
        RUNTIME.trade_started_by_squad[sid] = nil
        RUNTIME.service_event_by_squad[sid] = nil
    end
end
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_trade

-- BEGIN module zhopa_tasks_registry
zhopa_bundle_module = function()
zhopa = zhopa or {}
zhopa.tasks = zhopa.tasks or {}

local tasks = zhopa.tasks

local tonumber  = _G.tonumber
local time_global = _G.time_global
local alife      = _G.alife
local game_graph = _G.game_graph
local rawget = _G.rawget

local RUNTIME = {
    beh_ini = nil,
    task_err_once = {},
    task_warn_once = {},
    smart_trade_slot_cache = {},
    smart_tech_slot_cache = {},
    smart_kamp_slot_cache = {},
    target_arrived_state_cache = {},
    surge_cache_active = false,
    surge_cache_next_tg = 0,
    smart_enemy_fallback_cache = {},
    trade_target_cache = {},
    cap_index_by_level = {},
    filtered_cap_bucket_cache = {},
    cap_bucket_bundle_cache = {},
    artefact_pool = false,
    stats = {},
    task_index_by_sid = {},
    task_index_dirty = true,
    build_prep = {
        last_prepare_tg = 0,
        sim_cycles_seen = 0,
        ctx_by_key = {},
        ctx_by_sid = {},
        level_search_cache = {},
        smart_bucket_cache = {},
        populate_anchor_cache = {},
        populate_candidate_cache = {},
        logic_index_cache = nil,
        logic_index_stats = {
            hits = 0,
            misses = 0,
        },
        stats = {
            ctx_hits = 0,
            ctx_misses = 0,
            populate_hits = 0,
            populate_misses = 0,
        },
    },
    hotpath_cfg = {
        online_intent = {
            interval_ms = 500,
            dirty_interval_ms = 100,
        },
        builders = {
            shared_cache_ttl_ms = 1000,
            populate_cache_ttl_ms = 1000,
            populate_candidate_ttl_ms = 1000,
            logic_index_ttl_ms = 1000,
            trade_taken_ttl_ms = 500,
            trade_arrived_timeout_ms = 300000,
            safe_bucket_ttl_ms = 500,
        },
    },
}

local COMMUNITY_REFRESH_TTL_MS = 15000
local COMMUNITY_RETRY_TTL_MS = 1000
local LOGIC_MAX_AGE_MS = 90000
local DIRTY_ENEMY_TTL_MS = 5000
local DIRTY_TRADE_PICK_TTL_MS = 3000
local ARTEFACT_CHECK_INTERVAL_MS = 5000
local ARTEFACT_SCAN_RADIUS = 50
local ARTEFACT_RELEASE_CONFIRM_MS = 3000
local ARTEFACT_OFFLINE_ROLL_PERCENT = 25
local ARRIVAL_ASSIST_SETTLE_MS = 10000
local function tg()
    return (time_global and time_global()) or 0
end

local function is_valid_server_id(id)
    id = tonumber(id) or 0
    return id > 0 and id ~= 65535
end

local function cfg_num(key, default, min_v)
    local v = tonumber(default) or 0
    if zhopa.runtime_cfg and zhopa.runtime_cfg.num then
        return zhopa.runtime_cfg.num(key, v, min_v)
    end
    if zhopa.config and zhopa.config.get then
        local x = zhopa.config.get(key, default)
        if tonumber(x) then
            v = tonumber(x)
        end
    end
    if min_v ~= nil and v < min_v then
        v = min_v
    end
    return v
end

local function cfg_bool(key, default)
    if zhopa.runtime_cfg and zhopa.runtime_cfg.bool then
        return zhopa.runtime_cfg.bool(key, default)
    end
    if zhopa.config and zhopa.config.get then
        return zhopa.config.get(key, default) ~= false
    end
    return default ~= false
end

function tasks._should_enforce_online_intent(task, now, entry)
    if type(task) ~= "table" then
        return false
    end
    task.params = type(task.params) == "table" and task.params or {}
    local cfg = RUNTIME.hotpath_cfg and RUNTIME.hotpath_cfg.online_intent or nil
    local interval_ms = tonumber(cfg and cfg.interval_ms) or 500
    local dirty_interval_ms = tonumber(cfg and cfg.dirty_interval_ms) or 100
    local dirty = type(entry) == "table" and entry.dirty or nil
    if task.params._applied == nil or task.params.online_force_rebuild == true then
        task.params.online_intent_next_tg = (tonumber(now) or tg()) + dirty_interval_ms
        return true
    end

    now = tonumber(now) or tg()
    local base_interval_ms = interval_ms
    if type(dirty) == "table" and (dirty.task == true or dirty.smart == true or dirty.identity == true) then
        base_interval_ms = dirty_interval_ms
    end
    local next_tg = tonumber(task.params.online_intent_next_tg) or 0
    if now < next_tg then
        return false
    end

    task.params.online_intent_next_tg = now + base_interval_ms
    return true
end

function tasks._can_assign_trade_task(entry, source)
    if type(entry) ~= "table" then
        return false
    end

    local current = entry.tasks and entry.tasks.current or nil
    if current and current.type == "TRADE" then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("TRADE", "assign_blocked sid=%s source=%s reason=current_trade",
                tostring(entry.squad_id or "-"),
                tostring(source or "-"))
        end
        return false
    end

    local prev = entry.tasks and entry.tasks.prev or nil
    if prev and prev.type == "TRADE" then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("TRADE", "assign_blocked sid=%s source=%s reason=prev_trade",
                tostring(entry.squad_id or "-"),
                tostring(source or "-"))
        end
        return false
    end

    return true
end

local function consume_entry_dirty(entry, key)
    if not (entry and zhopa.memory and zhopa.memory.consume_dirty) then
        return false
    end
    return zhopa.memory.consume_dirty(entry, key) == true
end

local is_squad_arrived_to_smart
local is_roam_smart_allowed
local get_smart_by_name
local ctx_get_smart_bucket_bundle
local ctx_get_smarts_by_level
local ctx_get_safe_buckets_by_level
local ctx_get_base_buckets_by_level
local ctx_get_kamp_buckets_by_level
local ctx_get_anomaly_buckets_by_level
local ctx_get_trade_candidate_smarts_by_level
local ctx_get_populate_anchor_by_level
local ctx_get_populate_anchor_priority_by_level
local ctx_get_populate_pass2_levels
local ctx_get_populate_candidate_bundle

local function has_game_time()
    return game and game.get_game_time and game.CTime
end

local function ctime_to_table(ct)
    if not (ct and ct.get) then return nil end
    local ok, Y, M, D, h, m, s, ms = pcall(function()
        return ct:get(0, 0, 0, 0, 0, 0, 0)
    end)
    if not ok then return nil end
    return { Y = Y, M = M, D = D, h = h, m = m, s = s, ms = ms }
end

local function ctime_from_table(t)
    if not (has_game_time() and t and type(t) == "table") then return nil end
    local ok_new, ct = pcall(function() return game.CTime() end)
    if not (ok_new and ct and ct.set) then return nil end
    local ok_set = pcall(function()
        ct:set(t.Y, t.M, t.D, t.h, t.m, t.s, t.ms)
    end)
    if not ok_set then return nil end
    return ct
end

local function game_time_now()
    if not has_game_time() then return nil end
    local ok, ct = pcall(function() return game.get_game_time() end)
    return ok and ct or nil
end

local function is_night_now()
    local ct = game_time_now()
    if not (ct and ct.get) then
        return false
    end
    local t = ctime_to_table(ct)
    local h = t and tonumber(t.h) or nil
    if h == nil then
        return false
    end
    return h >= 22 or h < 6
end

local function game_time_diff_sec(start_ct)
    local now = game_time_now()
    if not (now and now.diffSec and start_ct) then return nil end
    local ok, sec = pcall(function() return now:diffSec(start_ct) end)
    sec = ok and tonumber(sec) or nil
    return sec
end

local TASKS_GVID_LEVEL_CACHE_MS = 1000
local tasks_gvid_level_cache = {}

local function now_level_name_by_gvid(gvid)
    gvid = tonumber(gvid) or nil
    if not (gvid and alife and game_graph) then return nil end
    local now = tg()
    local cached = tasks_gvid_level_cache[gvid]
    if type(cached) == "table" and now <= (tonumber(cached.tg) or 0) + TASKS_GVID_LEVEL_CACHE_MS then
        return cached.value
    end
    local ok, res = pcall(function()
        local gv = game_graph():vertex(gvid)
        if not gv then return nil end
        return alife():level_name(gv:level_id())
    end)
    if ok and type(res) == "string" and res ~= "" then
        tasks_gvid_level_cache[gvid] = { value = res, tg = now }
        return res
    end
    tasks_gvid_level_cache[gvid] = { value = nil, tg = now }
    return nil
end

local function get_board()
    if SIMBOARD then return SIMBOARD end
    if sim_board and sim_board.get_sim_board then
        local ok, b = pcall(function() return sim_board.get_sim_board() end)
        if ok then return b end
    end
    return nil
end

local function safe_obj_by_id(id)
    id = tonumber(id)
    if not id then return nil end
    if level and level.object_by_id then
        local ok, obj = pcall(function() return level.object_by_id(id) end)
        if ok and obj then return obj end
    end
    if db and db.storage and db.storage[id] then
        local obj = db.storage[id].object
        if obj then return obj end
    end
    return nil
end

local function surge_active_uncached()
    local xc = _G.xr_conditions
    local xf = xc and xc.surge_started or nil
    if type(xf) == "function" then
        local ok, res = pcall(xf)
        if ok and res == true then return true, false end
        if ok and res == false then return false, false end
    end

    local fallback_used = false

    local f = _G.surge_started
    if type(f) == "function" then
        fallback_used = true
        local ok, res = pcall(f)
        if ok and res == true then return true, fallback_used end
        if ok and res == false then return false, fallback_used end
    end

    local psm = _G.psi_storm_manager
    if psm and type(psm.is_loaded) == "function" and type(psm.is_started) == "function" then
        fallback_used = true
        local okL, loaded = pcall(function() return psm.is_loaded() end)
        if okL and loaded == true then
            local okS, started = pcall(function() return psm.is_started() end)
            if okS and started == true then return true, fallback_used end
        end
    end

    local sm = _G.surge_manager
    if sm and type(sm.is_loaded) == "function" and type(sm.is_started) == "function" then
        fallback_used = true
        local okL, loaded = pcall(function() return sm.is_loaded() end)
        if okL and loaded == true then
            local okS, started = pcall(function() return sm.is_started() end)
            if okS and started == true then return true, fallback_used end
        end
    end

    if _G.level and type(_G.level.is_surge) == "function" then
        fallback_used = true
        local ok, res = pcall(function() return _G.level.is_surge() end)
        if ok and res == true then return true, fallback_used end
    end

    return false, fallback_used
end

local function is_surge_active(force_refresh)
    local now = tg()
    if force_refresh ~= true and now < (tonumber(RUNTIME.surge_cache_next_tg) or 0) then
        return RUNTIME.surge_cache_active == true
    end

    local active, fallback_used = surge_active_uncached()
    local cache_ms = cfg_num("surge_check_cache_ms", 250, 0)
    RUNTIME.surge_cache_active = active == true
    RUNTIME.surge_cache_next_tg = now + cache_ms

    if fallback_used then
        if zhopa.log and zhopa.log.warn then
            zhopa.log.warn("PERF", "PERF_SURGE_CHECK_FALLBACK source=tasks")
        end
    end
    return active == true
end

local function smart_blacklists_global_set()
    local cfg = zhopa.config
    if cfg and cfg.get_smart_blacklists_global_set then
        local res = cfg.get_smart_blacklists_global_set()
        if type(res) == "table" then
            return res
        end
    end
    return nil
end

local function smart_blacklists_rule(level_name)
    local cfg = zhopa.config
    if cfg and cfg.get_smart_blacklists_rule then
        local res = cfg.get_smart_blacklists_rule(level_name)
        if type(res) == "table" then
            return res
        end
    end
    return nil
end

local function normalize_community_key(name)
    if type(name) ~= "string" then return nil end
    local key = string.lower((string.gsub(name, "^%s*(.-)%s*$", "%1")))
    if key == "" then return nil end
    local cfg = zhopa.config
    if cfg and cfg.get_faction_alias then
        local alias = cfg.get_faction_alias(key)
        if type(alias) == "string" and alias ~= "" then
            alias = string.lower((string.gsub(alias, "^%s*(.-)%s*$", "%1")))
            if alias ~= "" then
                key = alias
            end
        end
    end
    return key
end

local function normalize_section_key(name)
    if type(name) ~= "string" then return nil end
    local key = string.lower((string.gsub(name, "^%s*(.-)%s*$", "%1")))
    if key == "" then return nil end
    return key
end

local function smart_task_control_populate_enabled()
    local switches = zhopa.switches
    if switches and (switches.core ~= true or switches.smart_tasks ~= true) then
        return false
    end
    if cfg_bool("enabled", true) == false then
        return false
    end
    if cfg_bool("smart_tasks_enabled", true) == false then
        return false
    end
    return cfg_bool("smart_tasks_control_enabled", true)
end

local function faction_level_blacklists_rule(community)
    local cfg = zhopa.config
    if not (cfg and cfg.get_faction_level_blacklist_rule) then
        return nil
    end
    local key = normalize_community_key(community)
    if not key then return nil end
    local res = cfg.get_faction_level_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function is_level_globally_blacklisted(level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    local cfg = zhopa.config
    if cfg and cfg.is_level_globally_blacklisted then
        return cfg.is_level_globally_blacklisted(level_name) == true
    end
    return false
end

local function faction_smart_blacklists_rule(community)
    local cfg = zhopa.config
    if not (cfg and cfg.get_faction_smart_blacklist_rule) then
        return nil
    end
    local key = normalize_community_key(community)
    if not key then return nil end
    local res = cfg.get_faction_smart_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function section_level_blacklists_rule(section_name)
    local cfg = zhopa.config
    if not (cfg and cfg.get_section_level_blacklist_rule) then
        return nil
    end
    local key = normalize_section_key(section_name)
    if not key then return nil end
    local res = cfg.get_section_level_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function section_smart_blacklists_rule(section_name)
    local cfg = zhopa.config
    if not (cfg and cfg.get_section_smart_blacklist_rule) then
        return nil
    end
    local key = normalize_section_key(section_name)
    if not key then return nil end
    local res = cfg.get_section_smart_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function is_level_blacklisted_for_faction(level_name, community, section_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    if is_level_globally_blacklisted(level_name) then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("TASKS", "GLOBAL_LEVEL_BLACKLIST_HIT level=%s", tostring(level_name))
        end
        return true
    end
    local rule = faction_level_blacklists_rule(community)
    if rule and rule.all == true then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("TASKS", "FACTION_LEVEL_BLACKLIST_HIT community=%s level=%s reason=all", tostring(community or "-"), tostring(level_name))
        end
        return true
    end
    local set = rule and rule.set or nil
    if set and set[level_name] then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("TASKS", "FACTION_LEVEL_BLACKLIST_HIT community=%s level=%s reason=list", tostring(community or "-"), tostring(level_name))
        end
        return true
    end

    local s_rule = section_level_blacklists_rule(section_name)
    if s_rule and s_rule.all == true then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("TASKS", "SECTION_LEVEL_BLACKLIST_HIT section=%s level=%s reason=all", tostring(section_name or "-"), tostring(level_name))
        end
        return true
    end
    local s_set = s_rule and s_rule.set or nil
    if s_set and s_set[level_name] then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("TASKS", "SECTION_LEVEL_BLACKLIST_HIT section=%s level=%s reason=list", tostring(section_name or "-"), tostring(level_name))
        end
        return true
    end
    return false
end

local function is_smart_blacklisted_for_faction(smart_name, community, level_name, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    if is_level_blacklisted_for_faction(level_name, community, section_name) then
        return true
    end
    local rule = faction_smart_blacklists_rule(community)
    if rule and rule.all == true then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("TASKS", "FACTION_SMART_BLACKLIST_HIT community=%s smart=%s reason=all", tostring(community or "-"), tostring(smart_name))
        end
        return true
    end
    local set = rule and rule.set or nil
    if set and set[smart_name] then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("TASKS", "FACTION_SMART_BLACKLIST_HIT community=%s smart=%s reason=list", tostring(community or "-"), tostring(smart_name))
        end
        return true
    end

    local s_rule = section_smart_blacklists_rule(section_name)
    if s_rule and s_rule.all == true then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("TASKS", "SECTION_SMART_BLACKLIST_HIT section=%s smart=%s reason=all", tostring(section_name or "-"), tostring(smart_name))
        end
        return true
    end
    local s_set = s_rule and s_rule.set or nil
    if s_set and s_set[smart_name] then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("TASKS", "SECTION_SMART_BLACKLIST_HIT section=%s smart=%s reason=list", tostring(section_name or "-"), tostring(smart_name))
        end
        return true
    end
    return false
end

local function smart_is_blacklisted_by_obj(sm, smart_name, community, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end

    local gset = smart_blacklists_global_set()
    if gset and gset[smart_name] then
        return true
    end

    local lvl = nil
    if sm and sm.m_game_vertex_id then
        lvl = now_level_name_by_gvid(sm.m_game_vertex_id)
        local rule = lvl and smart_blacklists_rule(lvl) or nil
        if rule and rule.all == true then
            return true
        end
        local set = rule and rule.set or nil
        if set and set[smart_name] then
            return true
        end
    end

    if is_smart_blacklisted_for_faction(smart_name, community, lvl, section_name) then
        return true
    end

    return false
end

local function smart_is_blacklisted_for_level(level_name, smart_name, community, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end

    local gset = smart_blacklists_global_set()
    if gset and gset[smart_name] then
        return true
    end

    local rule = level_name and smart_blacklists_rule(level_name) or nil
    if rule and rule.all == true then
        return true
    end

    local set = rule and rule.set or nil
    if set and set[smart_name] then
        return true
    end

    if is_smart_blacklisted_for_faction(smart_name, community, level_name, section_name) then
        return true
    end

    return false
end

local function get_smarts_for_level(level_name, community, section_name)
    if type(level_name) ~= "string" or level_name == "" then
        return {}
    end
    local board_index = zhopa.board_index
    if board_index and board_index.get_level_smarts then
        local filtered = board_index.get_level_smarts(level_name, {
            community = community,
            section_name = section_name,
        })
        if type(filtered) == "table" then
            return filtered
        end
    end
    return {}
end

local function pick_random(arr)
    local n = arr and #arr or 0
    if n <= 0 then return nil end
    return arr[math.random(n)]
end

local function pick_random_valid(arr, community, level_name, section_name)
    local n = arr and #arr or 0
    if n <= 0 then return nil end

    local board = get_board()
    if not (board and board.smarts_by_names) then
        for _ = 1, math.min(8, n) do
            local name = arr[math.random(n)]
            if name and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
                return name
            end
        end
        for i = 1, n do
            local name = arr[i]
            if name and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
                return name
            end
        end
        return nil
    end

    local by_name = board.smarts_by_names
    for _ = 1, math.min(8, n) do
        local name = arr[math.random(n)]
        local sm = name and by_name[name] or nil
        if sm and (not smart_is_blacklisted_by_obj(sm, name, community, section_name)) then
            return name
        end
    end

    for i = 1, n do
        local name = arr[i]
        local sm = name and by_name[name] or nil
        if sm and (not smart_is_blacklisted_by_obj(sm, name, community, section_name)) then
            return name
        end
    end

    return nil
end

local function diag_key(stage, squad_id, task)
    local tid = task and task.id or "-"
    return tostring(stage or "-") .. "|" .. tostring(squad_id or "-") .. "|" .. tostring(tid)
end

local function log_task_error(stage, entry, task, err)
    local tostring = tostring
    if not (zhopa.log and zhopa.log.error) then return end
    local key = diag_key(stage, entry and entry.squad_id, task)
    if RUNTIME.task_err_once[key] then return end
    RUNTIME.task_err_once[key] = true

    local t = task and task.type or "-"
    local tgt = task and task.target or "-"
    local e = tostring(err or "")
    local tb = (debug and debug.traceback) and debug.traceback("", 2) or ""
    zhopa.log.error("TASKS", "Task error stage=%s sid=%s type=%s target=%s err=%s %s",
        tostring(stage or "-"),
        tostring(entry and entry.squad_id or "-"),
        tostring(t),
        tostring(tgt),
        tostring(e),
        tostring(tb)
    )
end

local function task_warn_once(key, fmt, ...)
    if not (key and zhopa.log and zhopa.log.warn) then
        return
    end
    key = tostring(key)
    if RUNTIME.task_warn_once[key] then
        return
    end
    RUNTIME.task_warn_once[key] = true
    zhopa.log.warn("TASKS", fmt, ...)
end

local function get_squad_community(entry, se_squad)
    local now = tg()
    if entry and entry.community and now < (tonumber(entry.community_next_tg) or 0) then
        return entry.community
    end
    if not (zhopa.safe and zhopa.safe.safe_squad_community) then
        return entry and entry.community or nil
    end
    local community = zhopa.safe.safe_squad_community(se_squad)
    if community and zhopa.config and zhopa.config.get_faction_alias then
        local alias = zhopa.config.get_faction_alias(community)
        if alias then community = alias end
    end
    if entry then
        if community then
            entry.community = community
            entry.community_verified_tg = now
            entry.community_next_tg = now + COMMUNITY_REFRESH_TTL_MS
        else
            entry.community_next_tg = now + COMMUNITY_RETRY_TTL_MS
        end
        return entry.community
    end
    return community
end

local function get_squad_section(entry, se_squad)
    local section = entry and entry.section or nil
    section = normalize_section_key(section)
    if section then
        if entry then
            entry.section = section
        end
        return section
    end

    if not (zhopa.safe and zhopa.safe.safe_section) then
        return nil
    end
    local live = normalize_section_key(zhopa.safe.safe_section(se_squad))
    if live and entry then
        entry.section = live
    end
    return live
end

local function resolve_entry_level(entry, se_squad)
    if not entry then
        if not se_squad then return nil end
        local gvid = tonumber(se_squad.m_game_vertex_id) or nil
        return gvid and now_level_name_by_gvid(gvid) or nil
    end

    local cached = entry.level
    if not se_squad then
        return cached
    end

    local gvid = tonumber(se_squad.m_game_vertex_id) or nil
    if not gvid then
        return cached
    end

    local cached_gvid = tonumber(entry.level_gvid) or nil
    if cached and cached_gvid and cached_gvid == gvid then
        return cached
    end

    local resolved = now_level_name_by_gvid(gvid)
    if resolved then
        entry.level_gvid = gvid
        entry.level_verified_tg = tg()
        entry.level = resolved
        return resolved
    end
    return cached
end

local function clear_task_apply_state(task)
    if not task then return end
    task.params = task.params or {}
    task.params._applied = nil
    task.params.online_intent_next_tg = nil
end

local TASK_STATE_TIMER_NS = "zhopa_tasks"
local FAST_TRADE_RETRY_MS = 500
local TASK_NIGHT_RECHECK_MS = 60000

local function task_state_timer_name(squad_id)
    squad_id = tonumber(squad_id)
    if not squad_id or squad_id <= 0 then
        return nil
    end
    return "state:" .. tostring(squad_id)
end

local function cancel_task_state_timer(squad_id)
    local timer_name = task_state_timer_name(squad_id)
    if not (timer_name and zhopa.timers and zhopa.timers.cancel) then
        return false
    end
    return zhopa.timers.cancel(TASK_STATE_TIMER_NS, timer_name)
end

local function apply_task_timer_state(squad_id, reason)
    squad_id = tonumber(squad_id)
    if not squad_id or squad_id <= 0 then
        return false
    end
    local entry = zhopa.memory and zhopa.memory.get_squad_entry and zhopa.memory.get_squad_entry(squad_id) or nil
    local current = entry and entry.tasks and entry.tasks.current or nil
    if type(current) ~= "table" then
        return false
    end

    local p = type(current.params) == "table" and current.params or {}
    current.params = p
    local why = tostring(reason or "task_state")

    if why == "rest_due" and current.type == "REST_1H" then
        zhopa.memory.set_task_current(squad_id, nil)
        return true
    end

    if why == "trade_travel_timeout" and current.type == "TRADE" then
        p.trade_done_state = p.trade_done_state or "TRAVEL_TIMEOUT"
        return true
    end

    if why == "trade_arrived_timeout" and current.type == "TRADE" then
        p.trade_done_state = p.trade_done_state or "ARRIVED_TIMEOUT"
        return true
    end

    if why == "fast_trade_retry" then
        p.fast_trade_retry_next_tg = 0
    end

    if zhopa.memory and zhopa.memory.mark_dirty then
        zhopa.memory.mark_dirty(squad_id, "task")
    end
    return true
end

local function on_task_state_timer(squad_id, reason)
    apply_task_timer_state(squad_id, reason)
end

local function schedule_task_state_timer(squad_id, delay_ms, reason)
    local timer_name = task_state_timer_name(squad_id)
    local delay = tonumber(delay_ms)
    if not (timer_name and delay and zhopa.timers and zhopa.timers.schedule) then
        return false
    end
    if delay < 0 then
        delay = 0
    end
    return zhopa.timers.schedule(TASK_STATE_TIMER_NS, timer_name, delay, on_task_state_timer, squad_id, reason)
end

local function due_delay_ms(deadline_tg, now)
    deadline_tg = tonumber(deadline_tg) or 0
    now = tonumber(now) or tg()
    if deadline_tg <= 0 then
        return 0
    end
    local delay = deadline_tg - now
    if delay < 0 then
        delay = 0
    end
    return delay
end

local function due_delay_ms_from_game_time(started_at_gt, duration_game_sec)
    local started_gt = ctime_from_table(started_at_gt)
    local dur_gs = tonumber(duration_game_sec) or 0
    if not (started_gt and dur_gs > 0) then
        return nil
    end

    local elapsed = game_time_diff_sec(started_gt)
    if elapsed == nil then
        return nil
    end

    local remaining_sec = dur_gs - elapsed
    if remaining_sec <= 0 then
        return 0
    end

    local tf = (level and level.get_time_factor and level.get_time_factor()) or 10
    if tf <= 0 then tf = 10 end
    local delay_ms = math.floor((remaining_sec * 1000) / tf)
    if delay_ms < 1 then
        delay_ms = 1
    end
    return delay_ms
end

local function task_state_delay_ms(entry, task, now, se_squad)
    if type(task) ~= "table" or type(task.type) ~= "string" then
        return nil, nil, nil
    end

    now = tonumber(now) or tg()
    local p = type(task.params) == "table" and task.params or {}

    if p.fast_trade_trigger == true then
        local retry_next_tg = tonumber(p.fast_trade_retry_next_tg) or 0
        if retry_next_tg > 0 then
            return due_delay_ms(retry_next_tg, now), "fast_trade_retry"
        end
        return FAST_TRADE_RETRY_MS, "fast_trade_retry"
    end

    if task.type == "REST_1H" then
        local gt_delay_ms = due_delay_ms_from_game_time(p.started_at_gt, p.duration_game_sec)
        if gt_delay_ms ~= nil then
            return gt_delay_ms, "rest_due"
        end
        local next_tg = (tonumber(p.started_at_tg) or 0) + (tonumber(p.duration_ms) or 0)
        if next_tg > 0 then
            return due_delay_ms(next_tg, now), "rest_due"
        end
        return nil, nil, nil
    end

    if task.type == "TRADE" then
        local target = task.target
        if type(target) == "string" and target ~= "" and is_squad_arrived_to_smart(se_squad, target) then
            local arrived_timeout_ms = tonumber(RUNTIME.hotpath_cfg and RUNTIME.hotpath_cfg.builders and RUNTIME.hotpath_cfg.builders.trade_arrived_timeout_ms) or 300000
            if arrived_timeout_ms < 5000 then arrived_timeout_ms = 5000 end
            local arrived_at_tg = tonumber(p.trade_arrived_at_tg) or now
            return due_delay_ms(arrived_at_tg + arrived_timeout_ms, now), "trade_arrived_timeout"
        end

        local travel_ms = cfg_num("trade_travel_timeout_ms", 600000, 30000)
        local started_tg = tonumber(p.started_at_tg) or now
        if started_tg > now then
            started_tg = now
        end
        return due_delay_ms(started_tg + travel_ms, now), "trade_travel_timeout"
    end

    return nil, nil
end

local function sync_task_state_timer(entry, task, now, se_squad)
    local squad_id = entry and entry.squad_id or (se_squad and se_squad.id) or nil
    if not squad_id then
        return false
    end
    local delay_ms, reason = task_state_delay_ms(entry, task, now, se_squad)
    if delay_ms == nil then
        return cancel_task_state_timer(squad_id)
    end
    return schedule_task_state_timer(squad_id, delay_ms, reason)
end

function tasks._reset_build_prep_runtime()
    local bp = RUNTIME.build_prep
    bp.last_prepare_tg = 0
    bp.last_prepare_exec_tg = 0
    bp.sim_cycles_seen = 0
    bp.ctx_by_key = {}
    bp.ctx_by_sid = {}
    bp.level_search_cache = {}
    bp.smart_bucket_cache = {}
    bp.populate_anchor_cache = {}
    bp.populate_candidate_cache = {}
    bp.logic_index_cache = nil
    bp.logic_index_stats = {
        hits = 0,
        misses = 0,
    }
    bp.stats = {
        ctx_hits = 0,
        ctx_misses = 0,
        populate_hits = 0,
        populate_misses = 0,
    }
    RUNTIME.cap_index_by_level = {}
    RUNTIME.filtered_cap_bucket_cache = {}
    RUNTIME.cap_bucket_bundle_cache = {}
    RUNTIME.task_index_by_sid = {}
    RUNTIME.task_index_dirty = true
end

local function ensure_capability_index(level_name)
    local board = get_board()
    local by_name = board and board.smarts_by_names or nil
    local board_index = zhopa.board_index
    if type(level_name) ~= "string" or level_name == "" then
        return nil
    end

    local smart_revs = board_index and board_index.RUNTIME and board_index.RUNTIME.smart_revision_by_level or nil
    local smart_rev = tonumber(smart_revs and smart_revs[level_name]) or 0
    local cfg_rev = tonumber(zhopa.runtime_cfg and zhopa.runtime_cfg.version) or 0
    local cached = RUNTIME.cap_index_by_level[level_name]
    if type(cached) == "table" and tonumber(cached._smart_rev) == smart_rev and tonumber(cached._cfg_rev) == cfg_rev then
        return cached
    end

    local smarts = board_index and board_index.get_level_smarts and board_index.get_level_smarts(level_name) or {}
    if type(smarts) ~= "table" then
        smarts = {}
    end

    local idx = {
        trade_slot = {},
        trader = {},
        tech_slot = {},
        anomaly = {},
        kamp = {},
        base = {},
        safe = {},
        _smart_rev = smart_rev,
        _cfg_rev = cfg_rev,
    }
    local anomaly_set = {}
    local base_set = {}
    if zhopa.config and zhopa.config.get_anomaly_smarts then
        local anomaly = zhopa.config.get_anomaly_smarts(level_name) or {}
        for j = 1, #anomaly do anomaly_set[anomaly[j]] = true end
    end
    local bases = board_index and board_index.get_base_smarts and board_index.get_base_smarts(level_name) or {}
    for j = 1, #bases do
        base_set[bases[j]] = true
    end

    for j = 1, #smarts do
        local smart_name = smarts[j]
        local sm = by_name and smart_name and by_name[smart_name] or nil
        if sm then
            idx.safe[#idx.safe + 1] = smart_name
            if tasks._smart_has_trader_slot and tasks._smart_has_trader_slot(smart_name, sm) then
                idx.trade_slot[#idx.trade_slot + 1] = smart_name
            end
            if tasks._smart_has_real_trader and tasks._smart_has_real_trader(sm) then
                idx.trader[#idx.trader + 1] = smart_name
            end
            if tasks._smart_has_tech_slot and tasks._smart_has_tech_slot(smart_name, sm) then
                idx.tech_slot[#idx.tech_slot + 1] = smart_name
            end
            if tasks._smart_has_kamp_slot and tasks._smart_has_kamp_slot(smart_name, sm) then
                idx.kamp[#idx.kamp + 1] = smart_name
            end
            if anomaly_set[smart_name] == true then
                idx.anomaly[#idx.anomaly + 1] = smart_name
            end
            if base_set[smart_name] == true then
                idx.base[#idx.base + 1] = smart_name
            end
        end
    end

    RUNTIME.cap_index_by_level[level_name] = idx
    return idx
end

local function cap_cache_key_part(value)
    return value ~= nil and value or false
end

local function get_cap_context_cache(root, level_name, bucket, community, section_name, create)
    if type(root) ~= "table" then
        return nil, nil
    end

    local by_level = root[level_name]
    if type(by_level) ~= "table" then
        if create ~= true then
            return nil, nil
        end
        by_level = {}
        root[level_name] = by_level
    end

    local by_bucket = by_level[bucket]
    if type(by_bucket) ~= "table" then
        if create ~= true then
            return nil, nil
        end
        by_bucket = {}
        by_level[bucket] = by_bucket
    end

    local community_key = cap_cache_key_part(community)
    local by_community = by_bucket[community_key]
    if type(by_community) ~= "table" then
        if create ~= true then
            return nil, nil
        end
        by_community = {}
        by_bucket[community_key] = by_community
    end

    local section_key = cap_cache_key_part(section_name)
    return by_community, section_key
end

function tasks._ensure_build_prep(now)
    now = tonumber(now) or tg()
    local bp = RUNTIME.build_prep
    bp.last_prepare_tg = now
    bp.sim_cycles_seen = tonumber(bp.sim_cycles_seen) or 0
    if type(bp.ctx_by_sid) ~= "table" then bp.ctx_by_sid = {} end
    if type(bp.ctx_by_key) ~= "table" then bp.ctx_by_key = {} end
    return bp
end

function tasks._get_build_ctx_ttl_ms()
    return tonumber(RUNTIME.hotpath_cfg and RUNTIME.hotpath_cfg.builders and RUNTIME.hotpath_cfg.builders.shared_cache_ttl_ms) or 1000
end

function tasks._shared_build_key(level_name, community, section_name)
    return tostring(level_name or "-") .. "|" .. tostring(community or "-") .. "|" .. tostring(section_name or "-")
end

local effective_filter_opts = {}

local function get_effective_filter_opts(community, section_name)
    effective_filter_opts.community = community
    effective_filter_opts.section_name = section_name
    effective_filter_opts.filter_fn = nil
    return effective_filter_opts
end

function tasks._get_effective_neighbors(level_name, community, section_name)
    if type(level_name) ~= "string" or level_name == "" then
        return {}
    end
    if zhopa.board_index and zhopa.board_index.get_level_neighbors then
        local res = zhopa.board_index.get_level_neighbors(level_name, get_effective_filter_opts(community, section_name))
        if type(res) == "table" then
            return res
        end
    end
    return {}
end

function tasks._get_effective_level_bases(level_name, community, section_name)
    if type(level_name) ~= "string" or level_name == "" then
        return {}
    end
    if zhopa.board_index and zhopa.board_index.get_base_smarts then
        local runtime = zhopa.board_index.get_base_smarts(level_name, get_effective_filter_opts(community, section_name))
        if type(runtime) == "table" then
            return runtime
        end
    end
    return {}
end

function tasks._get_build_context_cache_key(entry, mode)
    local sid = tonumber(entry and entry.squad_id) or entry and entry.squad_id or "-"
    return tostring(sid) .. "|" .. tostring(mode or "normal")
end

function tasks._invalidate_build_context(entry, reason)
    local sid = tonumber(entry and entry.squad_id) or entry and entry.squad_id or nil
    local ctx_by_sid = RUNTIME.build_prep and RUNTIME.build_prep.ctx_by_sid or nil
    if not (sid and type(ctx_by_sid) == "table") then
        return
    end
    ctx_by_sid[tostring(sid)] = nil
end

function tasks._get_level_search_bundle(cur_level, community, section_name, now)
    local bp = tasks._ensure_build_prep(now)
    local ttl_ms = tasks._get_build_ctx_ttl_ms()
    local key = tasks._shared_build_key(cur_level, community, section_name)
    local cached = bp.level_search_cache[key]
    if type(cached) == "table" and now <= ((tonumber(cached.tg) or 0) + ttl_ms) then
        return cached
    end

    local neighbors_src = tasks._get_effective_neighbors(cur_level, community, section_name)

    local search_levels = {}
    local neighbors = {}
    local seen = {}

    local function add_level(into_neighbors, level_name)
        if type(level_name) ~= "string" or level_name == "" then return end
        if seen[level_name] then return end
        if is_level_blacklisted_for_faction(level_name, community, section_name) then return end
        seen[level_name] = true
        search_levels[#search_levels + 1] = level_name
        if into_neighbors == true then
            neighbors[#neighbors + 1] = level_name
        end
    end

    add_level(false, cur_level)
    for i = 1, #neighbors_src do
        add_level(true, neighbors_src[i])
    end

    cached = {
        tg = now,
        search_levels = search_levels,
        neighbors = neighbors,
        current_level_smarts = get_smarts_for_level(cur_level, community, section_name),
    }
    bp.level_search_cache[key] = cached
    return cached
end

function tasks._get_smart_bucket_bundle(cur_level, community, section_name, search_bundle, now)
    local bp = tasks._ensure_build_prep(now)
    local ttl_ms = tasks._get_build_ctx_ttl_ms()
    local key = tasks._shared_build_key(cur_level, community, section_name)
    local cached = bp.smart_bucket_cache[key]
    if type(cached) == "table" and now <= ((tonumber(cached.tg) or 0) + ttl_ms) then
        return cached
    end

    local levels = type(search_bundle) == "table" and search_bundle.search_levels or nil
    local current_level_smarts = type(search_bundle) == "table" and search_bundle.current_level_smarts or nil
    local smarts_by_level = {}
    local safe_by_level = {}
    local base_by_level = {}
    local kamp_by_level = {}
    local anomaly_by_level = {}
    local trade_by_level = {}

    for i = 1, (levels and #levels or 0) do
        local level_name = levels[i]
        local level_smarts = (level_name == cur_level) and current_level_smarts or get_smarts_for_level(level_name, community, section_name)
        local cap_bundle = tasks._get_cap_bucket_bundle and tasks._get_cap_bucket_bundle(level_name, community, section_name, now) or nil
        smarts_by_level[level_name] = level_smarts or {}
        safe_by_level[level_name] = (cap_bundle and cap_bundle.safe) or (tasks._get_cap_bucket and tasks._get_cap_bucket(level_name, "safe", community, section_name, now)) or level_smarts or {}
        base_by_level[level_name] = (cap_bundle and cap_bundle.base) or (tasks._get_cap_bucket and tasks._get_cap_bucket(level_name, "base", community, section_name, now)) or {}
        kamp_by_level[level_name] = (cap_bundle and cap_bundle.kamp) or (tasks._get_cap_bucket and tasks._get_cap_bucket(level_name, "kamp", community, section_name, now)) or {}
        anomaly_by_level[level_name] = (cap_bundle and cap_bundle.anomaly) or (tasks._get_cap_bucket and tasks._get_cap_bucket(level_name, "anomaly", community, section_name, now)) or {}
        trade_by_level[level_name] = RUNTIME.collect_trade_candidate_smarts(level_name, community, section_name, cap_bundle, now) or {}
    end

    cached = {
        tg = now,
        smarts_by_level = smarts_by_level,
        safe_by_level = safe_by_level,
        base_by_level = base_by_level,
        kamp_by_level = kamp_by_level,
        anomaly_by_level = anomaly_by_level,
        trade_by_level = trade_by_level,
    }
    bp.smart_bucket_cache[key] = cached
    return cached
end

function tasks._get_populate_anchor_bundle(community, now)
    local bp = tasks._ensure_build_prep(now)
    local ttl_ms = tonumber(RUNTIME.hotpath_cfg and RUNTIME.hotpath_cfg.builders and RUNTIME.hotpath_cfg.builders.populate_cache_ttl_ms) or 1000
    local key = tostring(community or "-")
    local cached = bp.populate_anchor_cache[key]
    if type(cached) == "table" and now <= ((tonumber(cached.tg) or 0) + ttl_ms) then
        bp.stats.populate_hits = (tonumber(bp.stats.populate_hits) or 0) + 1
        return cached
    end

    bp.stats.populate_misses = (tonumber(bp.stats.populate_misses) or 0) + 1
    local logic_index = tasks._get_logic_index(now)
    local by_level = logic_index and logic_index.anchors_by_community_level and logic_index.anchors_by_community_level[community] or nil
    local priority_by_level = logic_index and logic_index.anchor_priority_by_community_level and logic_index.anchor_priority_by_community_level[community] or nil
    cached = { tg = now, by_level = by_level or {}, priority_by_level = priority_by_level or {} }
    bp.populate_anchor_cache[key] = cached
    return cached
end

function tasks._get_populate_candidate_bundle(cur_level, community, section_name, ctx, now)
    now = tonumber(now) or tg()
    local bp = tasks._ensure_build_prep(now)
    local ttl_ms = tonumber(RUNTIME.hotpath_cfg and RUNTIME.hotpath_cfg.builders and RUNTIME.hotpath_cfg.builders.populate_candidate_ttl_ms) or 1000
    local key = tasks._shared_build_key(cur_level, community, section_name)
    local cached = bp.populate_candidate_cache[key]
    if type(cached) == "table" and now <= ((tonumber(cached.tg) or 0) + ttl_ms) then
        return cached
    end

    local anchor_bundle = nil
    local anchors_by_level = ctx_get_populate_anchor_by_level(ctx)
    local anchor_priority_by_level = ctx_get_populate_anchor_priority_by_level(ctx)
    if type(anchors_by_level) ~= "table" or type(anchor_priority_by_level) ~= "table" then
        anchor_bundle = tasks._get_populate_anchor_bundle(community, now)
        anchors_by_level = type(anchors_by_level) == "table" and anchors_by_level or (anchor_bundle and anchor_bundle.by_level or {})
        anchor_priority_by_level = type(anchor_priority_by_level) == "table" and anchor_priority_by_level or (anchor_bundle and anchor_bundle.priority_by_level or {})
    end
    local board = get_board()
    local by_name = board and board.smarts_by_names or nil
    local pass1 = {}
    local pass2 = {}
    local seen1 = {}
    local seen2 = {}
    local smart_level_by_name = {}
    local smart_gvid_by_name = {}
    local smart_anchor_priority_by_name = {}

    local function add_candidate(target, seen, smart_name, level_name)
        if type(smart_name) ~= "string" or smart_name == "" then return end
        if seen[smart_name] then return end
        local sm = (by_name and by_name[smart_name]) or get_smart_by_name(smart_name)
        if not sm then return end
        if smart_is_blacklisted_by_obj(sm, smart_name, community, section_name) then
            if ctx and ctx.allowed_by_name then
                ctx.allowed_by_name[smart_name] = false
            end
            return
        end
        local allowed = ctx and ctx.allowed_by_name and ctx.allowed_by_name[smart_name]
        if allowed == nil then
            allowed = tasks._is_roam_smart_allowed and tasks._is_roam_smart_allowed(smart_name, community) == true or false
            if ctx and ctx.allowed_by_name then
                ctx.allowed_by_name[smart_name] = allowed
            end
        end
        if allowed ~= true then
            return
        end
        seen[smart_name] = true
        target[#target + 1] = smart_name
        smart_level_by_name[smart_name] = level_name
        smart_gvid_by_name[smart_name] = tonumber(sm.m_game_vertex_id) or nil
        local priority_map = type(anchor_priority_by_level) == "table" and anchor_priority_by_level[level_name] or nil
        smart_anchor_priority_by_name[smart_name] = tonumber(type(priority_map) == "table" and priority_map[smart_name] or nil) or 0
    end

    local pass1_levels = ctx and ctx.neighbors or {}
    for i = 1, #pass1_levels do
        local level_name = pass1_levels[i]
        local arr = anchors_by_level and anchors_by_level[level_name] or nil
        for j = 1, (arr and #arr or 0) do
            add_candidate(pass1, seen1, arr[j], level_name)
        end
    end

    local pass2_levels = ctx_get_populate_pass2_levels(ctx)
    for i = 1, #pass2_levels do
        local level_name = pass2_levels[i]
        local arr = anchors_by_level and anchors_by_level[level_name] or nil
        for j = 1, (arr and #arr or 0) do
            add_candidate(pass2, seen2, arr[j], level_name)
        end
    end

    cached = {
        tg = now,
        pass1 = pass1,
        pass2 = pass2,
        smart_level_by_name = smart_level_by_name,
        smart_gvid_by_name = smart_gvid_by_name,
        smart_anchor_priority_by_name = smart_anchor_priority_by_name,
    }
    bp.populate_candidate_cache[key] = cached
    return cached
end

ctx_get_smart_bucket_bundle = function(ctx)
    if type(ctx) ~= "table" then
        return nil
    end
    local cached = rawget(ctx, "_lazy_smart_bucket_bundle")
    if type(cached) == "table" then
        return cached
    end
    cached = tasks._get_smart_bucket_bundle(ctx.cur_level, ctx.community, ctx.section_name, ctx._search_bundle, ctx.now)
    ctx._lazy_smart_bucket_bundle = cached
    return cached
end

ctx_get_smarts_by_level = function(ctx)
    local bundle = ctx_get_smart_bucket_bundle(ctx)
    return bundle and bundle.smarts_by_level or nil
end

ctx_get_safe_buckets_by_level = function(ctx)
    local bundle = ctx_get_smart_bucket_bundle(ctx)
    return bundle and bundle.safe_by_level or nil
end

ctx_get_base_buckets_by_level = function(ctx)
    local bundle = ctx_get_smart_bucket_bundle(ctx)
    return bundle and bundle.base_by_level or nil
end

ctx_get_kamp_buckets_by_level = function(ctx)
    local bundle = ctx_get_smart_bucket_bundle(ctx)
    return bundle and bundle.kamp_by_level or nil
end

ctx_get_anomaly_buckets_by_level = function(ctx)
    local bundle = ctx_get_smart_bucket_bundle(ctx)
    return bundle and bundle.anomaly_by_level or nil
end

ctx_get_trade_candidate_smarts_by_level = function(ctx)
    local bundle = ctx_get_smart_bucket_bundle(ctx)
    return bundle and bundle.trade_by_level or nil
end

ctx_get_populate_anchor_by_level = function(ctx)
    if type(ctx) ~= "table" then
        return nil
    end
    local cached = rawget(ctx, "_lazy_populate_anchor_by_level")
    if type(cached) == "table" then
        return cached
    end
    local bundle = tasks._get_populate_anchor_bundle(ctx.community, ctx.now)
    cached = bundle and bundle.by_level or {}
    ctx._lazy_populate_anchor_by_level = cached
    return cached
end

ctx_get_populate_anchor_priority_by_level = function(ctx)
    if type(ctx) ~= "table" then
        return nil
    end
    local cached = rawget(ctx, "_lazy_populate_anchor_priority_by_level")
    if type(cached) == "table" then
        return cached
    end
    local bundle = tasks._get_populate_anchor_bundle(ctx.community, ctx.now)
    cached = bundle and bundle.priority_by_level or {}
    ctx._lazy_populate_anchor_priority_by_level = cached
    return cached
end

ctx_get_populate_pass2_levels = function(ctx)
    if type(ctx) ~= "table" then
        return {}
    end
    local cached = rawget(ctx, "_lazy_populate_pass2_levels")
    if type(cached) == "table" then
        return cached
    end

    local cur_level = ctx.cur_level
    local community = ctx.community
    local section_name = ctx.section_name
    local pass2_levels = {}
    local pass2_seen = {}
    local neighbors = ctx.neighbors or {}
    for i = 1, #neighbors do
        local lvl = neighbors[i]
        local lvl_neighbors = tasks._get_effective_neighbors(lvl, community, section_name)
        for j = 1, #lvl_neighbors do
            local lv2 = lvl_neighbors[j]
            if type(lv2) == "string"
                and lv2 ~= ""
                and lv2 ~= cur_level
                and not pass2_seen[lv2]
                and not is_level_blacklisted_for_faction(lv2, community, section_name)
            then
                pass2_seen[lv2] = true
                pass2_levels[#pass2_levels + 1] = lv2
            end
        end
    end

    ctx._lazy_populate_pass2_levels = pass2_levels
    return pass2_levels
end

ctx_get_populate_candidate_bundle = function(ctx)
    if type(ctx) ~= "table" then
        return nil
    end
    local cached = rawget(ctx, "_lazy_populate_candidate_bundle")
    if type(cached) == "table" then
        return cached
    end
    cached = tasks._get_populate_candidate_bundle(ctx.cur_level, ctx.community, ctx.section_name, ctx, ctx.now)
    ctx._lazy_populate_candidate_bundle = cached
    return cached
end

function tasks._rebuild_task_index_from_memory()
    local memory = zhopa.memory
    local state = memory and memory.get_state and memory.get_state() or nil
    local squads = state and state.squads or nil
    local out = {}
    if type(squads) == "table" then
        for sid, entry in pairs(squads) do
            local id = tonumber(type(entry) == "table" and entry.squad_id or nil) or tonumber(sid) or nil
            local current = type(entry) == "table" and entry.tasks and entry.tasks.current or nil
            if id and type(current) == "table" then
                out[id] = entry
            end
        end
    end
    RUNTIME.task_index_by_sid = out
    RUNTIME.task_index_dirty = false
    return out
end

function tasks._get_task_index_entries()
    if RUNTIME.task_index_dirty == true or type(RUNTIME.task_index_by_sid) ~= "table" then
        return tasks._rebuild_task_index_from_memory()
    end
    return RUNTIME.task_index_by_sid
end

function tasks._get_logic_index(now, purpose)
    now = tonumber(now) or tg()
    local bp = tasks._ensure_build_prep(now)
    local memory = zhopa.memory
    local memory_rev = memory and memory.get_index_rev and memory.get_index_rev() or 0
    local cfg_rev = tonumber(zhopa.runtime_cfg and zhopa.runtime_cfg.version) or 0
    local cfg = RUNTIME.hotpath_cfg and RUNTIME.hotpath_cfg.builders or nil
    local ttl_ms = tonumber(cfg and cfg.logic_index_ttl_ms) or 1000
    local stable_ttl_ms = ttl_ms * 10
    if purpose == "trade" then
        local trade_ttl_ms = tonumber(cfg and cfg.trade_taken_ttl_ms) or ttl_ms
        if trade_ttl_ms > 0 and trade_ttl_ms < ttl_ms then
            ttl_ms = trade_ttl_ms
        end
    end

    local cached = bp.logic_index_cache
    if type(cached) == "table"
        and tonumber(cached._memory_rev) == tonumber(memory_rev)
        and tonumber(cached._cfg_rev) == cfg_rev
        and RUNTIME.task_index_dirty ~= true
        and now <= ((tonumber(cached.tg) or 0) + stable_ttl_ms)
    then
        bp.logic_index_stats.hits = (tonumber(bp.logic_index_stats.hits) or 0) + 1
        return cached
    end
    if type(cached) == "table" and RUNTIME.task_index_dirty ~= true and now <= ((tonumber(cached.tg) or 0) + ttl_ms) then
        bp.logic_index_stats.hits = (tonumber(bp.logic_index_stats.hits) or 0) + 1
        return cached
    end

    bp.logic_index_stats.misses = (tonumber(bp.logic_index_stats.misses) or 0) + 1
    local index = {
        tg = now,
        _memory_rev = memory_rev,
        _cfg_rev = cfg_rev,
        anchors_by_community_level = {},
        anchor_priority_by_community_level = {},
        communities_by_smart_level = {},
        trade_counts_by_level_smart = {},
    }
    local anchor_seen_by_community_level = {}

    local function add_populate_anchor(community, level_name, smart_name, priority)
        community = normalize_community_key(community)
        priority = tonumber(priority) or 0
        if type(level_name) ~= "string" or level_name == "" then
            return
        end
        if type(smart_name) ~= "string" or smart_name == "" then
            return
        end
        if not community then
            return
        end

        local seen_by_level = anchor_seen_by_community_level[community]
        if type(seen_by_level) ~= "table" then
            seen_by_level = {}
            anchor_seen_by_community_level[community] = seen_by_level
        end

        local priority_by_level = index.anchor_priority_by_community_level[community]
        if type(priority_by_level) ~= "table" then
            priority_by_level = {}
            index.anchor_priority_by_community_level[community] = priority_by_level
        end

        local seen = seen_by_level[level_name]
        if type(seen) ~= "table" then
            seen = {}
            seen_by_level[level_name] = seen
        end
        local priority_map = priority_by_level[level_name]
        if type(priority_map) ~= "table" then
            priority_map = {}
            priority_by_level[level_name] = priority_map
        end
        if seen[smart_name] == true then
            local prev_priority = tonumber(priority_map[smart_name]) or 0
            if priority > prev_priority then
                priority_map[smart_name] = priority
            end
            return
        end

        local out_by_level = index.anchors_by_community_level[community]
        if type(out_by_level) ~= "table" then
            out_by_level = {}
            index.anchors_by_community_level[community] = out_by_level
        end

        local arr = out_by_level[level_name]
        if type(arr) ~= "table" then
            arr = {}
            out_by_level[level_name] = arr
        end

        seen[smart_name] = true
        priority_map[smart_name] = priority
        arr[#arr + 1] = smart_name
    end

    local anchor_index = memory and memory.get_anchor_index and memory.get_anchor_index() or {}
    for community, by_level in pairs(anchor_index) do
        if type(by_level) == "table" then
            for level_name, smart_set in pairs(by_level) do
                if type(smart_set) == "table" then
                    for smart_name in pairs(smart_set) do
                        add_populate_anchor(community, level_name, smart_name, 0)
                    end
                end
            end
        end
    end

    if smart_task_control_populate_enabled() then
        local squads = tasks._get_task_index_entries()
        if type(squads) == "table" then
            for _, entry in pairs(squads) do
                if type(entry) == "table" and entry.npc_kind == "stalker" then
                    local current = entry.tasks and entry.tasks.current or nil
                    local params = type(current) == "table" and type(current.params) == "table" and current.params or nil
                    local tasktype = params and params.smart_task_type or nil
                    local phase = params and params.smart_task_phase or nil
                    if params and params.smart_task == true and tasktype == "control" and phase == "hold" then
                        local smart_name = type(params.smart_task_smart) == "string" and params.smart_task_smart or current.target
                        local community = entry.community or params.smart_task_community
                        local level_name = nil
                        if type(smart_name) == "string" and smart_name ~= "" then
                            if zhopa.board_index and zhopa.board_index.get_smart_level then
                                level_name = zhopa.board_index.get_smart_level(smart_name)
                            end
                            if (type(level_name) ~= "string" or level_name == "") then
                                level_name = entry.level
                            end
                            add_populate_anchor(community, level_name, smart_name, 10)
                        end
                    end
                end
            end
        end
    end

    local communities_index = memory and memory.get_communities_by_smart_level and memory.get_communities_by_smart_level() or {}
    for smart_name, by_level in pairs(communities_index) do
        if type(by_level) == "table" then
            local out_by_level = {}
            for level_name, comm_set in pairs(by_level) do
                if type(comm_set) == "table" then
                    local out_comm = {}
                    for community in pairs(comm_set) do
                        out_comm[community] = 1
                    end
                    out_by_level[level_name] = out_comm
                end
            end
            index.communities_by_smart_level[smart_name] = out_by_level
        end
    end

    local trade_index = memory and memory.get_trade_target_occupancy and memory.get_trade_target_occupancy() or {}
    for level_name, by_smart in pairs(trade_index) do
        if type(by_smart) == "table" then
            local out_by_smart = {}
            for smart_name, count in pairs(by_smart) do
                out_by_smart[smart_name] = tonumber(count) or 0
            end
            index.trade_counts_by_level_smart[level_name] = out_by_smart
        end
    end

    bp.logic_index_cache = index
    return index
end

function tasks._prepare_reactive_context(se_squad, entry, now, mode)
    if not (se_squad and entry) then
        return nil
    end
    now = tonumber(now) or tg()
    local bp = tasks._ensure_build_prep(now)
    local mode_name = type(mode) == "string" and mode or "normal"
    local sid_key = tostring(tonumber(entry and entry.squad_id) or entry and entry.squad_id or "-")
    local by_mode = bp.ctx_by_sid[sid_key]
    if type(by_mode) ~= "table" then
        by_mode = {}
        bp.ctx_by_sid[sid_key] = by_mode
    end
    local ttl_ms = tasks._get_build_ctx_ttl_ms()

    local cur_level = resolve_entry_level(entry, se_squad) or entry.level
    entry.level = cur_level
    local community = get_squad_community(entry, se_squad)
    local section_name = get_squad_section(entry, se_squad)
    local dirty = entry.dirty or nil
    local dirty_ctx = type(dirty) == "table" and (dirty.task == true or dirty.community == true or dirty.identity == true or dirty.smart == true)
    if dirty_ctx then
        tasks._invalidate_build_context(entry, "dirty")
        by_mode = {}
        bp.ctx_by_sid[sid_key] = by_mode
    end
    local cached = by_mode[mode_name]
    if type(cached) == "table"
        and now <= ((tonumber(cached._cache_tg) or 0) + ttl_ms)
        and cached.cur_level == cur_level
        and cached.community == community
        and cached.section_name == section_name
        and not dirty_ctx
    then
        bp.stats.ctx_hits = (tonumber(bp.stats.ctx_hits) or 0) + 1
        cached.now = now
        local sgvid = tonumber(se_squad and se_squad.m_game_vertex_id) or nil
        if cached.sgvid ~= sgvid then
            cached.distance_by_smart = {}
        end
        cached.sgvid = sgvid
        return cached
    end

    bp.stats.ctx_misses = (tonumber(bp.stats.ctx_misses) or 0) + 1

    local search_bundle = tasks._get_level_search_bundle(cur_level, community, section_name, now)

    local runtime_cfg = zhopa.runtime_cfg
    local runtime_get = runtime_cfg and runtime_cfg.get or nil
    local config_get = (not runtime_get) and zhopa.config and zhopa.config.get or nil
    local function cfg_bool_snapshot(key, default)
        if runtime_get then
            return runtime_get(key, default) ~= false
        end
        if config_get then
            return config_get(key, default) ~= false
        end
        return default ~= false
    end
    local trade_enabled = cfg_bool_snapshot("trade_enabled", true)
    local artefact_enabled = cfg_bool_snapshot("artefact_enabled", true)
    local explore_enabled = cfg_bool_snapshot("explore_enabled", true)
    local populate_enabled = cfg_bool_snapshot("populate_enabled", true)
    local base_camping_enabled = cfg_bool_snapshot("base_camping_enabled", true)
    local patrol_enabled = cfg_bool_snapshot("patrol_enabled", true)

    local ctx = {
        _cache_tg = now,
        _search_bundle = search_bundle,
        _lazy_smart_bucket_bundle = nil,
        _lazy_populate_anchor_by_level = nil,
        _lazy_populate_pass2_levels = nil,
        _lazy_populate_candidate_bundle = nil,
        now = now,
        cur_level = cur_level,
        community = community,
        section_name = section_name,
        search_levels = search_bundle.search_levels or {},
        current_level_smarts = search_bundle.current_level_smarts or {},
        neighbors = search_bundle.neighbors or {},
        allowed_by_name = {},
        sgvid = tonumber(se_squad and se_squad.m_game_vertex_id) or nil,
        trade_enabled = trade_enabled,
        artefact_enabled = artefact_enabled,
        explore_enabled = explore_enabled,
        populate_enabled = populate_enabled,
        base_camping_enabled = base_camping_enabled,
        patrol_enabled = patrol_enabled,
        logic_index = nil,
        distance_by_smart = {},
    }
    by_mode[mode_name] = ctx
    return ctx
end

local function make_task(task_type, target, params, priority)
    local now = tg()
    return {
        id = tostring(task_type) .. "_" .. tostring(now),
        type = task_type,
        target = target,
        params = params or {},
        created_at_tg = now,
        priority = priority or 0,
    }
end

get_smart_by_name = function(smart_name)
    if not smart_name then return nil end
    local board = get_board()
    if not (board and board.smarts_by_names) then return nil end
    return board.smarts_by_names[smart_name]
end

RUNTIME.resolve_smart_level_name = function(smart_name, fallback_level)
    if type(smart_name) ~= "string" or smart_name == "" then
        return fallback_level
    end
    if zhopa.board_index and zhopa.board_index.get_smart_level then
        local indexed_level = zhopa.board_index.get_smart_level(smart_name)
        if type(indexed_level) == "string" and indexed_level ~= "" then
            return indexed_level
        end
    end
    local sm = get_smart_by_name(smart_name)
    if sm and sm.m_game_vertex_id then
        return now_level_name_by_gvid(sm.m_game_vertex_id) or fallback_level
    end
    return fallback_level
end

RUNTIME.resolve_entry_anchor_smart = function(entry)
    if type(entry) ~= "table" then
        return nil, nil
    end

    local target = entry.scripted_target
    if type(target) == "string" and target ~= "" then
        local lvl = RUNTIME.resolve_smart_level_name(target, entry.level)
        return target, lvl
    end

    local smart_id = tonumber(entry.smart_id) or nil
    if smart_id then
        if zhopa.board_index and zhopa.board_index.get_smart_name_by_id then
            local smart_name = zhopa.board_index.get_smart_name_by_id(smart_id)
            if type(smart_name) == "string" and smart_name ~= "" then
                return smart_name, RUNTIME.resolve_smart_level_name(smart_name, entry.level)
            end
        end
    end

    local cur = entry.tasks and entry.tasks.current or nil
    target = cur and cur.target or nil
    if type(target) == "string" and target ~= "" then
        local lvl = RUNTIME.resolve_smart_level_name(target, entry.level)
        return target, lvl
    end

    return nil, nil
end

local function try_game_graph_distance(sgvid, tgvid)
    sgvid = tonumber(sgvid)
    tgvid = tonumber(tgvid)
    if not (sgvid and tgvid and game_graph) then return nil end
    local ok, d = pcall(function()
        local gg = game_graph()
        if not gg then return nil end
        local res = gg:distance(sgvid, tgvid)
        return res
    end)
    d = ok and tonumber(d) or nil
    if d ~= nil then
        return d
    end
    return nil
end

local function get_beh_ini()
    if RUNTIME.beh_ini ~= nil then
        return RUNTIME.beh_ini or nil
    end
    RUNTIME.beh_ini = false
    if ini_file then
        local paths = {
            "configs\\beh_gulag_jobs.ltx",
            "configs/beh_gulag_jobs.ltx",
            "configs\\misc\\beh_gulag_jobs.ltx",
            "configs/misc/beh_gulag_jobs.ltx",
        }
        for i = 1, #paths do
            local ok, ini = pcall(ini_file, paths[i])
            if ok and ini and ini.section_exist then
                RUNTIME.beh_ini = ini
                break
            end
        end
    end
    if RUNTIME.beh_ini == false and not RUNTIME.beh_ini_warned then
        RUNTIME.beh_ini_warned = true
        if zhopa.log and zhopa.log.warn then
            zhopa.log.warn("TRADE", "beh_gulag_jobs.ltx not found; trader-slot detection disabled")
        end
    end
    return RUNTIME.beh_ini or nil
end

local function smart_has_trader_slot_ltx(smart_name)
    local ini = get_beh_ini()
    if not (ini and ini.section_exist and smart_name) then
        return false
    end
    local ok, res = pcall(function()
        local base = tostring(smart_name)
        return ini:section_exist(base .. "_beh_trade_job_1")
            or ini:section_exist(base .. "_beh_trade_job_2")
            or ini:section_exist(base .. "_beh_trade_job_3")
            or ini:section_exist(base .. "_beh_trade_1")
            or ini:section_exist(base .. "_beh_trade_2")
            or ini:section_exist(base .. "_beh_trade_3")
    end)
    return ok and res == true
end

local function smart_has_trader_slot_runtime(sm)
    if not (sm and sm.stalker_jobs) then
        return false
    end
    local jobs = sm.stalker_jobs
    if type(jobs) ~= "table" then return false end
    for i = 1, #jobs do
        local job = jobs[i]
        local sec = job and job.section or nil
        if type(sec) == "string" then
            if string.find(sec, "_beh_trade_job_", 1, true) ~= nil
                or string.find(sec, "_beh_trade_", 1, true) ~= nil then
                return true
            end
        end
    end
    return false
end

local function smart_has_tech_slot_runtime(sm)
    if not (sm and sm.stalker_jobs) then
        return false
    end
    local jobs = sm.stalker_jobs
    if type(jobs) ~= "table" then return false end
    for i = 1, #jobs do
        local job = jobs[i]
        local sec = job and job.section or nil
        if type(sec) == "string" then
            if string.find(sec, "_beh_tech_job_", 1, true) ~= nil then
                return true
            end
        end
    end
    return false
end

local function smart_has_tech_slot(smart_name, sm)
    if sm and smart_name then
        local cache = RUNTIME.smart_tech_slot_cache
        local c = cache and cache[smart_name]
        local now = tg()
        if c and c.tg and c.ttl_ms and (now < (c.tg + c.ttl_ms)) and c.has ~= nil then
            return c.has == true
        end
        local has = smart_has_tech_slot_runtime(sm) == true
        if not cache then
            RUNTIME.smart_tech_slot_cache = {}
        end
        RUNTIME.smart_tech_slot_cache[smart_name] = { tg = now, ttl_ms = (has and 60000 or 5000), has = has == true }
        return has == true
    end
    return false
end

local function smart_has_trader_slot(smart_name, sm)
    if smart_name and smart_has_trader_slot_ltx(smart_name) then
        return true
    end

    if sm and smart_name then
        local cache = RUNTIME.smart_trade_slot_cache
        local c = cache[smart_name]
        local now = tg()
        if c and c.tg and c.ttl_ms and (now < (c.tg + c.ttl_ms)) and c.has ~= nil then
            return c.has == true
        end
        local has = smart_has_trader_slot_runtime(sm) == true
        cache[smart_name] = { tg = now, ttl_ms = (has and 60000 or 5000), has = has == true }
        return has == true
    end

    return false
end

local function smart_has_real_trader(sm)
    if not (sm and sm.npc_info and IsStalker) then
        return false
    end
    local by_job = type(sm.npc_by_job_section) == "table" and sm.npc_by_job_section or nil
    for _, info in pairs(sm.npc_info) do
        local se = info and info.se_obj or nil
        if se and se.clsid and IsStalker(nil, se:clsid()) then
            local ok_name, npc_name = pcall(function() return se:name() end)
            local lower_name = ok_name and type(npc_name) == "string" and string.lower(npc_name) or nil
            local sec = info and info.job and info.job.section or nil
            local lower_sec = type(sec) == "string" and string.lower(sec) or nil
            local blocked = false
            if lower_name then
                blocked = blocked
                    or string.find(lower_name, "leader", 1, true) ~= nil
                    or string.find(lower_name, "medic", 1, true) ~= nil
                    or string.find(lower_name, "mechanic", 1, true) ~= nil
                    or string.find(lower_name, "guide", 1, true) ~= nil
                    or string.find(lower_name, "_tech", 1, true) ~= nil
            end
            if lower_sec then
                blocked = blocked
                    or string.find(lower_sec, "leader", 1, true) ~= nil
                    or string.find(lower_sec, "medic", 1, true) ~= nil
                    or string.find(lower_sec, "mechanic", 1, true) ~= nil
                    or string.find(lower_sec, "guide", 1, true) ~= nil
                    or string.find(lower_sec, "_tech", 1, true) ~= nil
            end
            if lower_name and (string.find(lower_name, "_trader", 1, true) ~= nil
                or string.find(lower_name, "_barman", 1, true) ~= nil) then
                return true
            end
            if lower_sec and (string.find(lower_sec, "trader", 1, true) ~= nil
                or string.find(lower_sec, "barman", 1, true) ~= nil) then
                return true
            end
            local sid = info and info.se_obj and (tonumber(info.se_obj.id) or (type(info.se_obj.id) == "function" and tonumber(info.se_obj:id()) or nil)) or nil
            if by_job and sid then
                for job_sec, owner_id in pairs(by_job) do
                    if sid and tonumber(owner_id) == sid and type(job_sec) == "string" then
                        local lower_job_sec = string.lower(job_sec)
                        if string.find(lower_job_sec, "trader", 1, true) ~= nil
                            or string.find(lower_job_sec, "barman", 1, true) ~= nil then
                            return true
                        end
                        if string.find(lower_job_sec, "leader", 1, true) ~= nil
                            or string.find(lower_job_sec, "medic", 1, true) ~= nil
                            or string.find(lower_job_sec, "mechanic", 1, true) ~= nil
                            or string.find(lower_job_sec, "guide", 1, true) ~= nil
                            or string.find(lower_job_sec, "_tech", 1, true) ~= nil then
                            blocked = true
                        end
                    end
                end
            end
            local ok_c, c = pcall(function() return se:community() end)
            if ok_c and c == "trader" and not blocked then
                return true
            end
        end
    end
    return false
end

-- OPTIMIZED: Uses smart-local checks first, then a bounded logic-squad scan.
-- Checks: sm:check_alarm(), sm.faction_war_in_progress, sm.npc_info, anchored hostile logic squads.
-- Returns: bool (true = hostile enemy present, false = safe)
local function smart_has_enemy_for_faction(sm, community, smart_name)
    if not (sm and community) then
        return false
    end

    local pcall = _G.pcall
    local pairs = _G.pairs
    local tostring = _G.tostring
    local tonumber = _G.tonumber
    local math_min = (_G.math and _G.math.min) or math.min
    local time_global = _G.time_global
    local now = (time_global and time_global()) or 0
    local cache_ttl = 1000
    if zhopa.runtime_cfg and zhopa.runtime_cfg.num then
        cache_ttl = zhopa.runtime_cfg.num("smart_enemy_cache_ttl_ms", cache_ttl, 1, 120000)
    elseif zhopa.config and zhopa.config.get then
        local v = zhopa.config.get("smart_enemy_cache_ttl_ms", cache_ttl)
        local n = tonumber(v)
        if n and n > 0 then
            cache_ttl = n
        end
    end

    local cache_key = tostring(smart_name or tonumber(sm.id) or tonumber(sm.m_game_vertex_id) or tostring(sm)) .. "|" .. tostring(community)
    local board = zhopa.board_index
    local smart_level = board and board.get_smart_level and board.get_smart_level(smart_name or sm.name or sm.id) or nil
    if not smart_level and level and level.name then
        local ok_lvl, res_lvl = pcall(function() return level.name() end)
        if ok_lvl and type(res_lvl) == "string" then
            smart_level = res_lvl
        end
    end

    local cached = RUNTIME.smart_enemy_fallback_cache[cache_key]
    if type(cached) == "table" and cached.hostile ~= nil then
        local age = now - (tonumber(cached.tg) or 0)
        local ttl = cached.hostile == true and cache_ttl or math_min(cache_ttl, 1000)
        if age <= ttl then
            return cached.hostile == true
        end
    end

    if sm.check_alarm then
        local ok_alarm, alarm = pcall(function() return sm:check_alarm() end)
        if ok_alarm and alarm == true then
            RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = true }
            return true
        end
    end

    local ok_war, war = pcall(function() return sm.faction_war_in_progress end)
    if ok_war and war == true then
        RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = true }
        return true
    end

    local game_rel = _G.game_relations
    local is_stalker = _G.IsStalker
    if not (game_rel and game_rel.is_factions_enemies and is_stalker) then
        RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = false }
        return false
    end

    if sm.npc_info then
        for _, info in pairs(sm.npc_info) do
            local se = info and info.se_obj or nil
            if se and se.clsid and is_stalker(nil, se:clsid()) then
                local ok_c, c = pcall(function() return se:community() end)
                if ok_c and c and game_rel.is_factions_enemies(community, c) then
                    RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = true }
                    return true
                end
            end
        end
    end

    if type(smart_name) == "string" and smart_name ~= "" then
        local logic_index = zhopa.tasks and zhopa.tasks._get_logic_index and zhopa.tasks._get_logic_index(now) or nil
        local by_level = logic_index and logic_index.communities_by_smart_level and logic_index.communities_by_smart_level[smart_name] or nil
        if type(by_level) == "table" then
            if smart_level and type(by_level[smart_level]) == "table" then
                for other_comm in pairs(by_level[smart_level]) do
                    if type(other_comm) == "string" and other_comm ~= "" then
                        local ok_enemy, hostile = pcall(function()
                            return game_rel.is_factions_enemies(community, other_comm)
                        end)
                        if ok_enemy and hostile == true then
                            RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = true }
                            return true
                        end
                    end
                end
            else
                for _, level_map in pairs(by_level) do
                    if type(level_map) == "table" then
                        for other_comm in pairs(level_map) do
                            if type(other_comm) == "string" and other_comm ~= "" then
                                local ok_enemy, hostile = pcall(function()
                                    return game_rel.is_factions_enemies(community, other_comm)
                                end)
                                if ok_enemy and hostile == true then
                                    RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = true }
                                    return true
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = false }
    return false
end

-- OPTIMIZED: Uses sm.npc_info instead of level.iterate_nearest
-- Checks only NPCs registered on the smart, not all objects in radius
-- Returns: bool (true = hostile enemy present, false = safe)
local function has_enemy_stalker_near_smart(smart_name, community, radius_m, cur_level_name)
    if not (smart_name and community) then
        return false
    end

    local sm = get_smart_by_name(smart_name)
    if not sm then
        return false
    end

    -- Delegate to unified enemy check
    return smart_has_enemy_for_faction(sm, community, smart_name) == true
end

local function loaded_level_name()
    if not (level and level.name) then return nil end
    local ok, res = pcall(function() return level.name() end)
    return ok and res or nil
end

is_roam_smart_allowed = function(smart_name, community)
    if not (smart_name and community) then return true end
    return has_enemy_stalker_near_smart(smart_name, community, 50, loaded_level_name()) == false
end

local function pick_random_valid_safe(arr, community, allowed_by_name, level_name, section_name)
    local n = arr and #arr or 0
    if n <= 0 then return nil end

    local board = get_board()
    if not (board and board.smarts_by_names) then
        for _ = 1, math.min(8, n) do
            local name = arr[math.random(n)]
            if name and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
                return name
            end
        end
        for i = 1, n do
            local name = arr[i]
            if name and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
                return name
            end
        end
        return nil
    end

    local by_name = board.smarts_by_names
    local allowed_cache = allowed_by_name or {}
    local function is_allowed(name)
        if not name then return false end
        if allowed_cache[name] == nil then
            allowed_cache[name] = is_roam_smart_allowed(name, community) == true
        end
        return allowed_cache[name] == true
    end
    for _ = 1, math.min(8, n) do
        local name = arr[math.random(n)]
        local sm = name and by_name[name] or nil
        if sm and (not smart_is_blacklisted_by_obj(sm, name, community, section_name)) and is_allowed(name) then
            return name
        end
    end

    for i = 1, n do
        local name = arr[i]
        local sm = name and by_name[name] or nil
        if sm and (not smart_is_blacklisted_by_obj(sm, name, community, section_name)) and is_allowed(name) then
            return name
        end
    end

    return nil
end

local function shuffle_in_place(arr)
    if type(arr) ~= "table" then return end
    for i = #arr, 2, -1 do
        local j = math.random(i)
        arr[i], arr[j] = arr[j], arr[i]
    end
end

local function smart_has_campfires(smart_name)
    if not (smart_name and db and db.campfire_table_by_smart_names) then
        return false
    end
    local t = db.campfire_table_by_smart_names[smart_name]
    if type(t) ~= "table" then return false end
    for _ in pairs(t) do
        return true
    end
    return false
end

local function smart_has_kamp_slot_ltx(smart_name)
    local ini = get_beh_ini()
    if not (ini and ini.section_exist and smart_name) then
        return false
    end
    local ok, res = pcall(function()
        local base = tostring(smart_name)
        return ini:section_exist(base .. "_beh_kamp_1")
            or ini:section_exist(base .. "_beh_kamp_2")
            or ini:section_exist(base .. "_beh_kamp_3")
            or ini:section_exist(base .. "_beh_kamp_4")
    end)
    return ok and res == true
end

local function smart_has_kamp_slot_runtime(sm)
    if not (sm and sm.stalker_jobs) then
        return false
    end
    local jobs = sm.stalker_jobs
    if type(jobs) ~= "table" then return false end
    for i = 1, #jobs do
        local job = jobs[i]
        local sec = job and job.section or nil
        if type(sec) == "string" then
            if string.find(sec, "_beh_kamp_job_", 1, true) ~= nil then
                return true
            end
            if string.find(sec, "_beh_kamp_", 1, true) ~= nil then
                return true
            end
        end
    end
    return false
end
tasks._smart_has_tech_slot = smart_has_tech_slot
tasks._smart_has_trader_slot = smart_has_trader_slot
tasks._smart_has_real_trader = smart_has_real_trader

local function smart_has_kamp_slot(smart_name, sm)
    if smart_name and smart_has_kamp_slot_ltx(smart_name) then
        return true
    end
    if sm and smart_name then
        local cache = RUNTIME.smart_kamp_slot_cache
        if cache then
            local c = cache[smart_name]
            local now = tg()
            if c and c.tg and c.ttl_ms and (now < (c.tg + c.ttl_ms)) and c.has ~= nil then
                return c.has == true
            end
            local has = smart_has_kamp_slot_runtime(sm) == true
            cache[smart_name] = { tg = now, ttl_ms = (has and 60000 or 5000), has = has == true }
            return has == true
        end
    end
    if smart_name and smart_has_campfires(smart_name) then
        return true
    end
    return false
end
tasks._smart_has_kamp_slot = smart_has_kamp_slot

local function smart_is_safe_for_faction(smart_name, community, cur_level)
    if not (smart_name and community) then
        return true
    end
    if not (game_relations and game_relations.is_factions_enemies and IsStalker) then
        return true
    end
    local ok, hostile = pcall(has_enemy_stalker_near_smart, smart_name, community, 50, cur_level)
    if ok then
        return hostile ~= true
    end
    return true
end

tasks._is_roam_smart_allowed = is_roam_smart_allowed

local function filter_cap_bucket(level_name, bucket, arr, smart_rev, community, section_name, now)
    if type(arr) ~= "table" then
        return nil
    end
    if bucket ~= "safe" and not community and not section_name then
        return arr
    end

    local is_safe = bucket == "safe"
    local cache_by_section, section_key = get_cap_context_cache(
        RUNTIME.filtered_cap_bucket_cache,
        level_name,
        bucket,
        community,
        section_name,
        true
    )
    local cached = cache_by_section and cache_by_section[section_key] or nil
    local ttl_ms = is_safe and community and (tonumber(RUNTIME.hotpath_cfg and RUNTIME.hotpath_cfg.builders and RUNTIME.hotpath_cfg.builders.safe_bucket_ttl_ms) or 500) or nil
    local now_tg = nil
    if ttl_ms then
        now_tg = tonumber(now) or tg()
    end
    if type(cached) == "table"
        and tonumber(cached.smart_rev) == smart_rev
        and type(cached.items) == "table"
        and (not ttl_ms or now_tg <= ((tonumber(cached.tg) or 0) + ttl_ms))
    then
        return cached.items
    end

    local filtered = {}
    for i = 1, #arr do
        local name = arr[i]
        if name and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
            local allowed = true
            if is_safe and community then
                allowed = smart_is_safe_for_faction(name, community, level_name) == true
            end
            if allowed then
                filtered[#filtered + 1] = name
            end
        end
    end
    if cache_by_section then
        cache_by_section[section_key] = {
            smart_rev = smart_rev,
            tg = now_tg or tonumber(now) or 0,
            items = filtered,
        }
    end
    return filtered
end

local function get_cap_bucket(level_name, bucket, community, section_name, now)
    if type(level_name) ~= "string" or level_name == "" then
        return nil
    end
    local idx = ensure_capability_index(level_name)
    if type(idx) ~= "table" then
        return nil
    end
    local arr = idx[bucket]
    if type(arr) ~= "table" then
        return nil
    end
    return filter_cap_bucket(level_name, bucket, arr, tonumber(idx._smart_rev) or 0, community, section_name, now)
end

tasks._get_cap_bucket = get_cap_bucket

local function get_cap_bucket_bundle(level_name, community, section_name, now)
    if type(level_name) ~= "string" or level_name == "" then
        return nil
    end
    local idx = ensure_capability_index(level_name)
    if type(idx) ~= "table" then
        return nil
    end

    local smart_rev = tonumber(idx._smart_rev) or 0
    local ttl_ms = community and (tonumber(RUNTIME.hotpath_cfg and RUNTIME.hotpath_cfg.builders and RUNTIME.hotpath_cfg.builders.safe_bucket_ttl_ms) or 500) or nil
    local now_tg = ttl_ms and (tonumber(now) or tg()) or nil
    local cache_by_section, section_key = get_cap_context_cache(
        RUNTIME.cap_bucket_bundle_cache,
        level_name,
        "bundle",
        community,
        section_name,
        true
    )
    local cached = cache_by_section and cache_by_section[section_key] or nil
    if type(cached) == "table"
        and tonumber(cached.smart_rev) == smart_rev
        and type(cached.safe) == "table"
        and (not ttl_ms or now_tg <= ((tonumber(cached.tg) or 0) + ttl_ms))
    then
        return cached
    end

    local bundle = {
        smart_rev = smart_rev,
        tg = now_tg or tonumber(now) or 0,
        safe = filter_cap_bucket(level_name, "safe", idx.safe, smart_rev, community, section_name, now),
        base = filter_cap_bucket(level_name, "base", idx.base, smart_rev, community, section_name, now),
        kamp = filter_cap_bucket(level_name, "kamp", idx.kamp, smart_rev, community, section_name, now),
        anomaly = filter_cap_bucket(level_name, "anomaly", idx.anomaly, smart_rev, community, section_name, now),
        trade_slot = filter_cap_bucket(level_name, "trade_slot", idx.trade_slot, smart_rev, community, section_name, now),
        trader = filter_cap_bucket(level_name, "trader", idx.trader, smart_rev, community, section_name, now),
        tech_slot = filter_cap_bucket(level_name, "tech_slot", idx.tech_slot, smart_rev, community, section_name, now),
    }
    if cache_by_section then
        cache_by_section[section_key] = bundle
    end
    return bundle
end

tasks._get_cap_bucket_bundle = get_cap_bucket_bundle

local function pick_base_camping_target_smart(level_name, community, section_name, ctx)
    if not level_name then return nil end
    local smarts_by_level = ctx_get_smarts_by_level(ctx)
    local base_buckets_by_level = ctx_get_base_buckets_by_level(ctx)
    local kamp_buckets_by_level = ctx_get_kamp_buckets_by_level(ctx)
    local smarts = (smarts_by_level and smarts_by_level[level_name]) or get_smarts_for_level(level_name, community, section_name)
    local n = smarts and #smarts or 0
    if n <= 0 then return nil end

    local cap_base = (base_buckets_by_level and base_buckets_by_level[level_name]) or get_cap_bucket(level_name, "base", community, section_name)
    if cap_base and #cap_base > 0 then
        local picked = pick_random_valid_safe(cap_base, community, ctx and ctx.allowed_by_name or nil, level_name, section_name)
        if picked then
            return picked
        end
    end

    local cap_kamp = (kamp_buckets_by_level and kamp_buckets_by_level[level_name]) or get_cap_bucket(level_name, "kamp", community, section_name)
    if cap_kamp and #cap_kamp > 0 then
        local picked = pick_random_valid_safe(cap_kamp, community, ctx and ctx.allowed_by_name or nil, level_name, section_name)
        if picked then
            return picked
        end
    end

    local board = get_board()
    local by_name = board and board.smarts_by_names or nil

    local cfg = tasks._get_effective_level_bases(level_name, community, section_name)
    local cfg_n = cfg and #cfg or 0
    if cfg_n > 0 then
        local bases = {}
        local bn = 0
        for i = 1, cfg_n do
            local name = cfg[i]
            local sm = by_name and name and by_name[name] or nil
            if name and sm and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
                local safe = (ctx and ctx.allowed_by_name and ctx.allowed_by_name[name])
                if safe == nil then
                    safe = smart_is_safe_for_faction(name, community, level_name)
                    if ctx and ctx.allowed_by_name then
                        ctx.allowed_by_name[name] = safe == true
                    end
                end
                if safe then
                    bn = bn + 1
                    bases[bn] = name
                end
            end
        end
        local picked = pick_random_valid(bases, community, level_name, section_name)
        if picked then
            return picked
        end
    end

    local kamp = {}
    local kamp_n = 0
    local safe_any = {}
    local safe_n = 0

    for i = 1, n do
        local name = smarts[i]
        local sm = by_name and name and by_name[name] or nil
        if name and sm and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
            local safe = (ctx and ctx.allowed_by_name and ctx.allowed_by_name[name])
            if safe == nil then
                safe = smart_is_safe_for_faction(name, community, level_name)
                if ctx and ctx.allowed_by_name then
                    ctx.allowed_by_name[name] = safe == true
                end
            end
            if safe then
                safe_n = safe_n + 1
                safe_any[safe_n] = name

                if smart_has_kamp_slot(name, sm) then
                    kamp_n = kamp_n + 1
                    kamp[kamp_n] = name
                end
            end
        end
    end

    return pick_random_valid(kamp, community, level_name, section_name)
        or pick_random_valid(safe_any, community, level_name, section_name)
        or pick_random_valid(smarts, community, level_name, section_name)
end

local function ensure_patrol_order(task, level_name, community, section_name, ctx)
    if not (task and task.params and level_name) then return nil end
    local p = task.params
    local order = p.order
    if type(order) == "table" and #order > 0 then
        return order
    end

    local safe_buckets_by_level = ctx_get_safe_buckets_by_level(ctx)
    local smarts_by_level = ctx_get_smarts_by_level(ctx)
    local src = (safe_buckets_by_level and safe_buckets_by_level[level_name])
        or (smarts_by_level and smarts_by_level[level_name])
        or get_smarts_for_level(level_name, community, section_name)
    local list = {}
    local board = get_board()
    local by_name = board and board.smarts_by_names or nil
    local allowed_cache = p._ctx_allowed_by_name or (ctx and ctx.allowed_by_name) or {}
    for i = 1, (src and #src or 0) do
        local name = src[i]
        if name and ((not by_name) or by_name[name]) then
            local allowed = true
            if community then
                if allowed_cache[name] == nil then
                    allowed_cache[name] = is_roam_smart_allowed(name, community) == true
                end
                allowed = allowed_cache[name] == true
            end
            if allowed then
                list[#list + 1] = name
            end
        end
    end
    if #list > 0 then
        shuffle_in_place(list)
        p.order = list
        p.visited = {}
        p.visited_count = 0
        p.idx = 1
        return list
    end
    p.order = {}
    p.visited = {}
    p.visited_count = 0
    p.idx = 1
    return {}
end

local function pick_next_patrol_target(task, level_name, community, section_name, ctx)
    if not (task and task.params and level_name) then return nil end
    if ctx and not task.params._ctx_allowed_by_name then
        task.params._ctx_allowed_by_name = ctx.allowed_by_name
    end
    local p = task.params
    local order = ensure_patrol_order(task, level_name, community, section_name, ctx)
    local n = order and #order or 0
    if n <= 0 then return nil end

    p.visited = p.visited or {}
    p.visited_count = tonumber(p.visited_count) or 0
    p.idx = tonumber(p.idx) or 1

    if p.visited_count >= n then
        p.order = nil
        return pick_next_patrol_target(task, level_name, community, section_name, ctx)
    end

    local visited = p.visited
    local start = p.idx
    if start < 1 or start > n then start = 1 end

    for step = 0, n - 1 do
        local i = start + step
        if i > n then i = i - n end
        local name = order[i]
        if name and not visited[name] then
            p.idx = i + 1
            if p.idx > n then p.idx = 1 end
            return name
        end
    end

    p.order = nil
    return pick_next_patrol_target(task, level_name, community, section_name, ctx)
end

local function get_arrive_dist_cap_m()
    return cfg_num("task_arrive_dist_cap_m", 5, 0)
end

local function vanilla_am_i_reached(se_squad, sm)
    if not (se_squad and sm) then return false end

    local ok_sgvid, sgvid = pcall(function() return se_squad.m_game_vertex_id end)
    local ok_tgvid, tgvid = pcall(function() return sm.m_game_vertex_id end)
    sgvid = ok_sgvid and sgvid or nil
    tgvid = ok_tgvid and tgvid or nil
    if sgvid and tgvid and sgvid == tgvid then
        return true
    end

    if sgvid and tgvid and game_graph then
        local ok_lvl, same_level = pcall(function()
            return game_graph():vertex(sgvid):level_id() == game_graph():vertex(tgvid):level_id()
        end)
        if ok_lvl and same_level == false then
            return false
        end
    end

    local cap_m = get_arrive_dist_cap_m()
    if cap_m <= 0 then
        return false
    end

    local pos_s = zhopa.safe and zhopa.safe.safe_position and zhopa.safe.safe_position(se_squad) or nil
    local pos_t = sm.position
    if not (pos_s and pos_t and pos_s.distance_to_sqr) then
        return false
    end

    local ok_arr, arrive_dist = pcall(function() return sm.arrive_dist end)
    arrive_dist = ok_arr and tonumber(arrive_dist) or nil
    if not arrive_dist then
        arrive_dist = cap_m
    else
        arrive_dist = math.min(arrive_dist, cap_m)
    end

    local ok_alw, alw = pcall(function() return se_squad.always_arrived end)
    if ok_alw and alw == true then
        return true
    end

    local ok_d2, d2 = pcall(function() return pos_s:distance_to_sqr(pos_t) end)
    d2 = ok_d2 and tonumber(d2) or nil
    if not d2 then return false end
    return d2 <= (arrive_dist * arrive_dist)
end

is_squad_arrived_to_smart = function(se_squad, smart_name)
    local sm = get_smart_by_name(smart_name)
    if not (se_squad and sm) then return false end

    local ok_ca, ca = pcall(function() return se_squad.current_action end)
    local ok_at, at = pcall(function() return se_squad.assigned_target_id end)
    local ok_ct, ct = pcall(function() return se_squad.current_target_id end)
    local ok_ss, ss = pcall(function() return se_squad.smart_id end)
    local ok_id, sid = pcall(function() return sm.id end)
    ca = ok_ca and tonumber(ca) or nil
    at = ok_at and tonumber(at) or nil
    ct = ok_ct and tonumber(ct) or nil
    ss = ok_ss and tonumber(ss) or nil
    sid = ok_id and tonumber(sid) or nil

    local function log_state(arrived, source)
        if not (zhopa.log and zhopa.log.debug) then return end
        local sqid = tonumber(se_squad.id)
        if not sqid then return end
        local now = tg()
        local c = RUNTIME.target_arrived_state_cache[sqid]
        if c and c.arrived == arrived and now < (tonumber(c.next_tg) or 0) then
            return
        end
        RUNTIME.target_arrived_state_cache[sqid] = { arrived = arrived, next_tg = now + 5000 }
        zhopa.log.debug("TASKS", "target_arrived_state sid=%s target=%s arrived=%s source=%s ca=%s at=%s ct=%s smart_id=%s",
            tostring(sqid),
            tostring(smart_name or "-"),
            tostring(arrived == true),
            tostring(source or "-"),
            tostring(ca or "-"),
            tostring(at or "-"),
            tostring(ct or "-"),
            tostring(ss or "-")
        )
    end

    if ca == 1 and sid and ((ct and ct == sid) or (ss and ss == sid)) then
        log_state(true, "fast_current")
        return true
    end

    if sm.am_i_reached then
        local ok, res = pcall(function() return sm:am_i_reached(se_squad) end)
        if ok and res then
            log_state(true, "smart_am_i_reached")
            return true
        end
    end

    local arrived = vanilla_am_i_reached(se_squad, sm)
    log_state(arrived, "vanilla_fallback")
    return arrived
end

local TARGET_TASK_TYPES = {
    EXPLORE = true,
    ARTEFACT = true,
    BASE_CAMPING = true,
    PATROL = true,
    POPULATE = true,
    TRADE = true,
    NIGHT_REST = true,
}

local ROAM_LIKE_TYPES = {
    REST_1H = true,
    EXPLORE = true,
    ARTEFACT = true,
    BASE_CAMPING = true,
    PATROL = true,
    POPULATE = true,
    NIGHT_REST = true,
}

local function is_target_task(task)
    if not (task and TARGET_TASK_TYPES[task.type]) then return false end
    return type(task.target) == "string" and task.target ~= ""
end

local function get_target_sync_enabled()
    return cfg_bool("target_sync_enabled", true)
end

local function get_online_intent_enforce_enabled()
    return cfg_bool("online_intent_enforce_enabled", true)
end

local function resolve_target_smart_id(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil, nil
    end
    local board = get_board()
    local sm = board and board.smarts_by_names and board.smarts_by_names[smart_name] or nil
    local sid = sm and tonumber(sm.id) or nil
    return sid, sm
end

local function set_scripted_target(se_squad, smart_name, params, opts)
    if not se_squad then return false end
    se_squad.scripted_target = smart_name
    if se_squad.task_target_id ~= nil then
        se_squad.task_target_id = nil
    end

    if not get_target_sync_enabled() then
        return true
    end
    if type(smart_name) ~= "string" or smart_name == "" then
        return true
    end

    params = type(params) == "table" and params or nil
    local now = tg()
    local sid = nil
    sid = resolve_target_smart_id(smart_name)
    local force_sync = opts and opts.force_sync == true

    local changed = false
    if params then
        changed = params.target_sync_name ~= smart_name
        params.target_sync_name = smart_name
        if sid then
            params.target_sync_smart_id = sid
        else
            params.target_sync_smart_id = nil
        end
        if changed then
            params.target_sync_started_tg = now
            params.target_last_progress_tg = now
            params.target_last_gvid = tonumber(se_squad.m_game_vertex_id) or nil
            params.target_last_assigned_id = tonumber(se_squad.assigned_target_id) or nil
            params.target_last_current_id = tonumber(se_squad.current_target_id) or nil
            params.target_last_action = tonumber(se_squad.current_action) or nil
        end
    end

    if changed or force_sync then
        se_squad.current_action = 0
        se_squad.current_target_id = nil
        if sid then
            se_squad.assigned_target_id = sid
        end
        se_squad.stay_time = nil
        se_squad.arrive_time = nil

        if params then
            params.target_last_progress_tg = now
            params.target_last_gvid = tonumber(se_squad.m_game_vertex_id) or nil
            params.target_last_assigned_id = tonumber(se_squad.assigned_target_id) or nil
            params.target_last_current_id = tonumber(se_squad.current_target_id) or nil
            params.target_last_action = tonumber(se_squad.current_action) or nil
        end

        if zhopa.log and zhopa.log.info then
            zhopa.log.info("TASKS", "target_sync sid=%s target=%s smart_id=%s reason=%s changed=%s",
                tostring(se_squad.id or "-"),
                tostring(smart_name),
                tostring(sid or "-"),
                tostring(opts and opts.reason or "set"),
                tostring(changed)
            )
        end
    end

    return true
end

local function resolve_rest_hold_smart_name(entry, se_squad)
    local smart_id = tonumber(se_squad and se_squad.smart_id) or tonumber(entry and entry.smart_id) or nil
    if smart_id and zhopa.board_index and zhopa.board_index.get_smart_name_by_id then
        local smart_name = zhopa.board_index.get_smart_name_by_id(smart_id)
        if type(smart_name) == "string" and smart_name ~= "" then
            return smart_name
        end
    end

    local scripted = type(se_squad and se_squad.scripted_target) == "string" and se_squad.scripted_target or nil
    if scripted and get_smart_by_name(scripted) then
        return scripted
    end

    local entry_scripted = type(entry and entry.scripted_target) == "string" and entry.scripted_target or nil
    if entry_scripted and get_smart_by_name(entry_scripted) then
        return entry_scripted
    end

    return nil
end

local function is_online_squad(se_squad)
    if not se_squad then return false end
    local ok, online = pcall(function() return se_squad.online end)
    return ok and online == true
end

local function sync_rest_always_arrived(se_squad, task_or_flag)
    if not se_squad then return end

    local should_hold = false
    if type(task_or_flag) == "table" then
        should_hold = task_or_flag.type == "REST_1H"
    else
        should_hold = task_or_flag == true
    end
    if should_hold == true and is_squad_monster and is_squad_monster[se_squad.player_id] == true then
        should_hold = false
    end

    local ok_cur, current = pcall(function() return se_squad.always_arrived end)
    if ok_cur and current == should_hold then
        return
    end

    pcall(function()
        se_squad.always_arrived = should_hold
    end)
end

local function enforce_online_task_intent(se_squad, entry, task)
    if not get_online_intent_enforce_enabled() then return end
    if not (se_squad and entry and is_target_task(task)) then return end
    if not is_online_squad(se_squad) then return end

    local sid = resolve_target_smart_id(task.target)
    local stgt = se_squad.scripted_target
    local at = tonumber(se_squad.assigned_target_id) or nil
    local ca = tonumber(se_squad.current_action) or nil
    local mismatch = false

    if stgt ~= task.target then mismatch = true end
    if sid and at and at ~= sid then mismatch = true end
    if ca == nil then mismatch = true end

    if mismatch then
        set_scripted_target(se_squad, task.target, task.params, { force_sync = true, reason = "online_intent_enforce" })
        if zhopa.log and zhopa.log.warn then
            zhopa.log.warn("TASKS", "ONLINE_WANDER_DETECTED sid=%s task=%s target=%s cur_level=%s gvid=%s",
                tostring(entry and entry.squad_id or "-"),
                tostring(task and task.type or "-"),
                tostring(task and task.target or "-"),
                tostring(entry and entry.level or "-"),
                tostring(se_squad and se_squad.m_game_vertex_id or "-")
            )
        end
    end
end

local function should_revalidate_target(task, force, entry)
    if not task then return false end
    task.params = task.params or {}
    local dirty = false
    if entry then
        dirty = consume_entry_dirty(entry, "task") or consume_entry_dirty(entry, "level") or consume_entry_dirty(entry, "community") or consume_entry_dirty(entry, "identity")
    end
    if force == true then
        return true
    end
    if dirty then
        return true
    end
    return false
end

local function is_task_target_valid(task, community, section_name)
    if not (task and task.target and type(task.target) == "string") then
        return true
    end
    local sm = get_smart_by_name(task.target)
    if sm and smart_is_blacklisted_by_obj(sm, task.target, community, section_name) then
        return false
    end
    local target_level = task.params and task.params.target_level or nil
    if (not sm) and smart_is_blacklisted_for_level(target_level, task.target, community, section_name) then
        return false
    end
    return sm ~= nil
end

local function build_rest_task(se_squad)
    local tonumber = tonumber
    local rest_hours = cfg_num("rest_duration_game_hours", 1, nil)
    if rest_hours <= 0 then rest_hours = 1 end
    local duration_game_sec = math.floor(rest_hours * 3600)
    if duration_game_sec < 1 then duration_game_sec = 1 end
    do
        local min_s = cfg_num("rest_fallback_stay_min_sec", 900, 0)
        local max_s = cfg_num("rest_fallback_stay_max_sec", 1800, 0)
        if min_s < 0 then min_s = 0 end
        if max_s < 0 then max_s = 0 end
        if max_s > 0 and min_s > 0 and max_s < min_s then
            max_s = min_s
        end
        if min_s > 0 and duration_game_sec < min_s then
            duration_game_sec = max_s > 0 and math.random(min_s, max_s) or min_s
        elseif max_s > 0 and duration_game_sec > max_s then
            duration_game_sec = max_s
        end
        if duration_game_sec < 1 then duration_game_sec = 1 end
    end

    local started_gt = nil
    local now_gt = game_time_now()
    if now_gt then
        started_gt = ctime_to_table(now_gt)
    end

    local tf = (level and level.get_time_factor and level.get_time_factor()) or 10
    if tf <= 0 then tf = 10 end
    local duration_ms = math.floor((duration_game_sec * 1000) / tf)
    if duration_ms < 1000 then duration_ms = 1000 end

    return make_task("REST_1H", nil, {
        started_at_gt = started_gt,
        duration_game_sec = duration_game_sec,
        started_at_tg = tg(),
        duration_ms = duration_ms
    }, 0)
end

local function build_explore_task(se_squad, cur_level, community, section_name, ctx)
    local neighbors = (ctx and ctx.neighbors) or {}
    if #neighbors <= 0 then
        neighbors = tasks._get_effective_neighbors(cur_level, community, section_name)
    end
    local target_level = pick_random(neighbors)
    if not target_level then return nil end

    local safe_buckets_by_level = ctx_get_safe_buckets_by_level(ctx)
    local smarts_by_level = ctx_get_smarts_by_level(ctx)
    local smarts = (safe_buckets_by_level and safe_buckets_by_level[target_level])
        or (smarts_by_level and smarts_by_level[target_level])
        or get_smarts_for_level(target_level, community, section_name)
    local smart_name = nil
    if community then
        smart_name = pick_random_valid_safe(smarts, community, ctx and ctx.allowed_by_name or nil, target_level, section_name)
    else
        smart_name = pick_random_valid(smarts, community, target_level, section_name)
    end
    if not smart_name then return nil end
    return make_task("EXPLORE", smart_name, { started_at_tg = tg(), target_level = target_level }, 0)
end

local function build_force_exit_task(se_squad, entry, cur_level, community, section_name, ctx)
    if not (cur_level and community) then return nil end

    local neighbors = (ctx and ctx.neighbors) or {}
    local candidate_levels = {}
    local seen = {}
    for i = 1, (neighbors and #neighbors or 0) do
        local lvl = neighbors[i]
        if type(lvl) == "string" and lvl ~= "" and lvl ~= cur_level and (not seen[lvl]) then
            seen[lvl] = true
            if not is_level_blacklisted_for_faction(lvl, community, section_name) then
                candidate_levels[#candidate_levels + 1] = lvl
            end
        end
    end

    local sid = (entry and entry.squad_id) or (se_squad and se_squad.id) or "-"

    if #candidate_levels <= 0 then
        if zhopa.log and zhopa.log.info then
            zhopa.log.info("TASKS", "FORCE_EXIT_NO_ROUTE sid=%s community=%s from_level=%s reason=no_allowed_neighbor_levels",
                tostring(sid), tostring(community), tostring(cur_level))
        end
        return nil
    end

    shuffle_in_place(candidate_levels)
    for i = 1, #candidate_levels do
        local target_level = candidate_levels[i]
        local safe_buckets_by_level = ctx_get_safe_buckets_by_level(ctx)
        local smarts_by_level = ctx_get_smarts_by_level(ctx)
        local smarts = (safe_buckets_by_level and safe_buckets_by_level[target_level])
            or (smarts_by_level and smarts_by_level[target_level])
            or get_smarts_for_level(target_level, community, section_name)
        local target = pick_random_valid_safe(smarts, community, ctx and ctx.allowed_by_name or nil, target_level, section_name)
        if target then
            if zhopa.log and zhopa.log.info then
                zhopa.log.info("TASKS", "FORCE_EXIT_ASSIGNED sid=%s community=%s from_level=%s to_level=%s target=%s",
                    tostring(sid), tostring(community), tostring(cur_level), tostring(target_level), tostring(target))
            end
            return make_task("EXPLORE", target, {
                started_at_tg = tg(),
                target_level = target_level,
                from_level = cur_level,
                force_exit = true,
            }, 0)
        end
    end

    if zhopa.log and zhopa.log.info then
        zhopa.log.info("TASKS", "FORCE_EXIT_NO_ROUTE sid=%s community=%s from_level=%s reason=no_allowed_smarts",
            tostring(sid), tostring(community), tostring(cur_level))
    end
    return nil
end

local function pick_populate_target_smart(se_squad, cur_level, community, section_name, ctx)
    if not (se_squad and cur_level and community) then
        return nil
    end
    if not (zhopa.memory and zhopa.memory.get_state) then
        return nil
    end

    local bundle = ctx_get_populate_candidate_bundle(ctx)
        or tasks._get_populate_candidate_bundle(cur_level, community, section_name, ctx, ctx and ctx.now or nil)
    local sgvid = ctx and ctx.sgvid or tonumber(se_squad and se_squad.m_game_vertex_id) or nil

    local function scan_candidates(arr)
        if type(arr) ~= "table" or #arr <= 0 then
            return nil
        end

        local best_name = nil
        local best_dist = nil
        local best_priority = nil
        local fallback = {}
        local fallback_n = 0
        local fallback_seen = {}
        local fallback_best_priority = nil
        local distance_by_smart = ctx and ctx.distance_by_smart or nil
        local gvid_by_name = bundle and bundle.smart_gvid_by_name or nil
        local priority_by_name = bundle and bundle.smart_anchor_priority_by_name or nil

        for i = 1, #arr do
            local smart_name = arr[i]
            if type(smart_name) == "string" and smart_name ~= "" then
                local priority = tonumber(priority_by_name and priority_by_name[smart_name]) or 0
                local d = distance_by_smart and distance_by_smart[smart_name] or nil
                if d == nil then
                    local tgvid = gvid_by_name and gvid_by_name[smart_name] or nil
                    d = (not sgvid or not tgvid) and false or try_game_graph_distance(sgvid, tgvid)
                    if distance_by_smart then
                        distance_by_smart[smart_name] = d
                    end
                end
                if d ~= false and d ~= nil then
                    if best_priority == nil
                        or priority > best_priority
                        or (priority == best_priority and ((not best_dist) or d < best_dist))
                    then
                        best_priority = priority
                        best_dist = d
                        best_name = smart_name
                    end
                elseif not fallback_seen[smart_name] then
                    if fallback_best_priority == nil or priority > fallback_best_priority then
                        fallback = {}
                        fallback_n = 0
                        fallback_seen = {}
                        fallback_best_priority = priority
                    end
                    if fallback_best_priority == nil or priority >= fallback_best_priority then
                        fallback_seen[smart_name] = true
                        fallback_n = fallback_n + 1
                        fallback[fallback_n] = smart_name
                    end
                end
            end
        end

        if best_name then
            return best_name
        end
        if fallback_n > 0 then
            return pick_random_valid_safe(fallback, community, nil, nil, section_name)
        end
        return nil
    end

    local target = scan_candidates(bundle and bundle.pass1 or nil)
    if target then
        return target
    end
    return scan_candidates(bundle and bundle.pass2 or nil)
end

local function build_populate_task(se_squad, entry, cur_level, community, section_name, ctx)
    if not (cur_level and community) then return nil end
    local smart_name = pick_populate_target_smart(se_squad, cur_level, community, section_name, ctx)
    if not smart_name then return nil end
    return make_task("POPULATE", smart_name, { started_at_tg = tg(), from_level = cur_level }, 0)
end

local function ensure_task_params(task)
    if not task then return nil end
    task.params = task.params or {}
    return task.params
end

local function get_alife_sim()
    if not alife then return nil end
    local ok, sim = pcall(function() return alife() end)
    return ok and sim or nil
end

local function safe_se_obj_by_id(id)
    id = tonumber(id)
    if not is_valid_server_id(id) then return nil end
    local sim = get_alife_sim()
    if not sim then return nil end
    local ok, se_obj = pcall(function() return sim:object(id) end)
    return ok and se_obj or nil
end

local function is_loose_world_object_by_id(id)
    id = tonumber(id)
    if not id then return false end

    local se_obj = safe_se_obj_by_id(id)
    if se_obj then
        local parent_id = tonumber(se_obj.parent_id)
        if parent_id and parent_id ~= 65535 then
            return false
        end
        return true
    end

    return safe_obj_by_id(id) ~= nil
end

local function request_release_object_by_id(id)
    id = tonumber(id)
    if not id then
        return false, "still_exists_unknown"
    end

    local accepted = false
    local rel = _G.alife_release_id
    if type(rel) == "function" then
        local ok, res = pcall(function() return rel(id) end)
        if ok and res ~= false then
            accepted = true
        end
    end

    if not accepted then
        local sim = get_alife_sim()
        local se_obj = safe_se_obj_by_id(id)
        if sim and se_obj and sim.release then
            local ok, res = pcall(function() return sim:release(se_obj, true) end)
            if ok and res ~= false then
                accepted = true
            end
        end
    end

    if not safe_se_obj_by_id(id) and not safe_obj_by_id(id) then
        return accepted, "gone"
    end
    if is_loose_world_object_by_id(id) then
        return accepted, "still_loose"
    end
    return accepted, "still_exists_unknown"
end

local function create_alife_item(section, pos, lvid, gvid, parent_id)
    if not (section and pos) then return nil end
    lvid = tonumber(lvid)
    gvid = tonumber(gvid)
    parent_id = tonumber(parent_id)
    if not (lvid and gvid) then return nil end

    local sim = get_alife_sim()
    if sim and sim.create then
        if parent_id then
            local ok, created = pcall(function() return sim:create(section, pos, lvid, gvid, parent_id) end)
            if ok and created then
                return created
            end
        else
            local ok, created = pcall(function() return sim:create(section, pos, lvid, gvid) end)
            if ok and created then
                return created
            end
        end
    end

    if not parent_id then
        local alife_create = _G.alife_create
        if type(alife_create) == "function" then
            local ok, created = pcall(function() return alife_create(section, pos, lvid, gvid) end)
            if ok and created then
                return created
            end
        end
    end

    return nil
end

local function mark_artefact_pickup_done(task)
    local params = ensure_task_params(task)
    if not params then return true end
    params.pickup_stage = "done"
    params.pickup_release_requested_tg = nil
    params.pickup_release_deadline_tg = nil
    params.pickup_copy_id = nil
    params.pickup_wait_until_tg = nil
    return true
end

local function get_squad_commander_id(se_squad, entry)
    local cid = nil
    if se_squad and se_squad.commander_id then
        local ok, res = pcall(function() return se_squad:commander_id() end)
        cid = ok and tonumber(res) or nil
    end
    if not cid then
        cid = tonumber(se_squad and se_squad.commander_id) or nil
    end
    if not cid then
        cid = tonumber(entry and entry.commander_id) or nil
    end
    return cid
end

local function get_online_commander_obj(se_squad, entry)
    local cid = get_squad_commander_id(se_squad, entry)
    if not cid then return nil end
    return safe_obj_by_id(cid)
end

local function resolve_artefact_scan_anchor(se_squad, entry, target_smart_name)
    local sm = target_smart_name and get_smart_by_name(target_smart_name) or nil
    if sm and sm.position then
        return sm.position
    end

    local leader_obj = get_online_commander_obj(se_squad, entry)
    if leader_obj and zhopa.safe and zhopa.safe.safe_position then
        local pos = zhopa.safe.safe_position(leader_obj)
        if pos then
            return pos
        end
    end

    if zhopa.safe and zhopa.safe.safe_position then
        local pos = zhopa.safe.safe_position(se_squad)
        if pos then
            return pos
        end
    end

    return nil
end

local function resolve_artefact_parent_anchor(se_squad, entry, target_smart_name)
    local sm = target_smart_name and get_smart_by_name(target_smart_name) or nil
    local sm_lvid = tonumber(sm and sm.m_level_vertex_id) or nil
    local sm_gvid = tonumber(sm and sm.m_game_vertex_id) or nil
    if sm and sm.position and sm_lvid and sm_gvid then
        return {
            pos = sm.position,
            lvid = sm_lvid,
            gvid = sm_gvid,
        }
    end

    do
        local leader_obj = get_online_commander_obj(se_squad, entry)
        if leader_obj then
            local safe = zhopa.safe
            local pos = safe and safe.safe_position and safe.safe_position(leader_obj) or nil
            local lvid = safe and safe.safe_level_vertex_id and tonumber(safe.safe_level_vertex_id(leader_obj)) or nil
            local gvid = safe and safe.safe_game_vertex_id and tonumber(safe.safe_game_vertex_id(leader_obj)) or nil
            if pos and lvid and gvid then
                return {
                    pos = pos,
                    lvid = lvid,
                    gvid = gvid,
                }
            end
        end
    end

    local safe = zhopa.safe
    local pos = safe and safe.safe_position and safe.safe_position(se_squad) or nil
    local lvid = tonumber(se_squad and se_squad.m_level_vertex_id) or nil
    local gvid = tonumber(se_squad and se_squad.m_game_vertex_id) or nil
    if pos and lvid and gvid then
        return {
            pos = pos,
            lvid = lvid,
            gvid = gvid,
        }
    end

    return nil
end

local function extract_member_candidate_id_local(k, v)
    if type(v) == "table" then
        local idv = tonumber(v.id) or tonumber(v.object_id) or tonumber(v.squad_id)
        if idv and idv > 0 then
            return idv
        end
    end

    local id = tonumber(v)
    if id and id > 0 then
        return id
    end

    id = tonumber(k)
    if id and id > 0 then
        return id
    end

    return nil
end

local function iter_online_squad_member_ids(se_squad)
    local out = {}
    if not se_squad then
        return out
    end

    local seen = {}
    local function push(id)
        id = tonumber(id)
        if not id or id <= 0 or seen[id] then
            return
        end
        if not safe_obj_by_id(id) then
            return
        end
        seen[id] = true
        out[#out + 1] = id
    end

    local ok_members, a, b, c = pcall(function() return se_squad:squad_members() end)
    if ok_members and a ~= nil then
        local ok_iter = pcall(function()
            for member in a, b, c do
                push(extract_member_candidate_id_local(nil, member))
            end
        end)
        if (not ok_iter) and type(a) == "table" then
            for k, v in pairs(a) do
                push(extract_member_candidate_id_local(k, v))
            end
        end
    end

    if #out <= 0 then
        push(get_squad_commander_id(se_squad, nil))
    end

    return out
end

local function is_squad_online_for_tasks(se_squad, entry)
    return get_online_commander_obj(se_squad, entry) ~= nil
end

local function smart_supports_stalker_jobs(smart)
    local jobs = smart and smart.stalker_jobs or nil
    if type(jobs) ~= "table" or #jobs <= 0 then
        return false
    end
    if type(smart.npc_info) ~= "table" then
        return false
    end
    if type(smart.select_npc_job) ~= "function" then
        return false
    end
    return true
end

local function is_smart_on_actor_level_for_tasks(smart)
    if not smart then
        return false
    end

    local ok_actor, actor_level = pcall(function() return smart.is_on_actor_level end)
    if ok_actor and actor_level ~= nil then
        return actor_level == true
    end

    local active_level = loaded_level_name()
    local gvid = tonumber(smart.m_game_vertex_id) or nil
    local smart_level = gvid and now_level_name_by_gvid(gvid) or nil
    return smart_level ~= nil and smart_level == active_level
end

local function try_soft_register_squad_to_smart(se_squad, smart_name, smart, board)
    if not (se_squad and smart and board and board.assign_squad_to_smart) then
        return false
    end
    local smart_id = tonumber(smart.id) or nil
    if not smart_id then
        return false
    end
    if tonumber(se_squad.smart_id) == smart_id then
        return true
    end
    local ok = pcall(function() board:assign_squad_to_smart(se_squad, smart_id) end)
    return ok == true
end

local function try_soft_assign_free_stalker_jobs_once(se_squad, smart, smart_name)
    if not smart_supports_stalker_jobs(smart) then
        return false
    end

    local member_ids = iter_online_squad_member_ids(se_squad)
    for i = 1, #member_ids do
        local npc_id = member_ids[i]
        local npc_info = smart.npc_info[npc_id] or smart.npc_info[tostring(npc_id)]
        if npc_info and npc_info.job == nil then
            pcall(function() smart:select_npc_job(npc_info, true) end)
        end
    end

    return true
end

local function resolve_post_arrival_assist(se_squad, entry, task, target_smart_name)
    local params = ensure_task_params(task)
    if not params then
        return true
    end

    local task_type = task and task.type or nil
    if task_type ~= "EXPLORE" and task_type ~= "POPULATE" and task_type ~= "ARTEFACT" then
        return true
    end

    if params.arrival_assist_done == true then
        return true
    end

    local board = get_board()
    local smart = nil
    if type(target_smart_name) == "string" and target_smart_name ~= "" and board and board.smarts_by_names then
        smart = board.smarts_by_names[target_smart_name]
    end
    if not smart then
        params.arrival_assist_done = true
        return true
    end

    if params.arrival_register_attempted ~= true then
        try_soft_register_squad_to_smart(se_squad, target_smart_name, smart, board)
        params.arrival_register_attempted = true
    end

    local jobs_supported = smart_supports_stalker_jobs(smart)
    params.arrival_jobs_supported = jobs_supported == true
    if jobs_supported ~= true then
        params.arrival_assist_done = true
        return true
    end

    if not is_squad_online_for_tasks(se_squad, entry) then
        params.arrival_assist_done = true
        return true
    end

    if not is_smart_on_actor_level_for_tasks(smart) then
        params.arrival_assist_done = true
        return true
    end

    if params.arrival_jobs_attempted ~= true then
        try_soft_assign_free_stalker_jobs_once(se_squad, smart, target_smart_name)
        params.arrival_jobs_attempted = true
    end

    local now = tg()
    if not tonumber(params.arrival_settle_started_tg) then
        params.arrival_settle_started_tg = now
        params.arrival_settle_until_tg = now + ARRIVAL_ASSIST_SETTLE_MS
    end

    if now < (tonumber(params.arrival_settle_until_tg) or 0) then
        return false
    end

    params.arrival_assist_done = true
    return true
end

local function find_nearby_artifact_hit(anchor_pos, radius_m)
    if not (level and level.iterate_nearest and anchor_pos and radius_m) then return nil end
    local found = nil
    level.iterate_nearest(anchor_pos, radius_m, function(obj)
        if not obj then return false end
        local sec = zhopa.safe and zhopa.safe.safe_section and zhopa.safe.safe_section(obj) or nil
        if sec and string.sub(sec, 1, 3) == "af_" then
            local oid = zhopa.safe and zhopa.safe.safe_id and zhopa.safe.safe_id(obj) or nil
            found = {
                section = sec,
                object_id = tonumber(oid) or nil,
                object = obj,
            }
            return true
        end
        return false
    end)
    return found
end

local function get_offline_artefact_pool()
    if RUNTIME.artefact_pool ~= false then
        return RUNTIME.artefact_pool
    end

    local out = {}
    if type(_G.ini_file) == "function" then
        local ok_ini, ini = pcall(function() return _G.ini_file("items\\trade\\gulag_job_trade_buy_sell.ltx") end)
        if ok_ini and ini and ini.section_exist and ini.line_count and ini.r_line then
            local ok_sec, has_sec = pcall(function() return ini:section_exist("buy_sell") end)
            if ok_sec and has_sec then
                local ok_cnt, cnt = pcall(function() return ini:line_count("buy_sell") end)
                cnt = ok_cnt and tonumber(cnt) or 0
                if cnt > 0 then
                    for idx = 0, cnt - 1 do
                        local ok_line, key = pcall(function() return ini:r_line("buy_sell", idx) end)
                        if ok_line and type(key) == "string" and key ~= "" and string.sub(key, 1, 1) ~= ";" and string.sub(key, 1, 3) == "af_" then
                            out[#out + 1] = key
                        end
                    end
                end
            end
        end
    end

    RUNTIME.artefact_pool = out
    return out
end

local function resolve_artefact_completion_after_pickup(se_squad, entry, task)
    local params = ensure_task_params(task)
    local done = true
    if type(params.pickup_section) == "string" then
        done = resolve_post_arrival_assist(se_squad, entry, task, task and task.target or nil)
    end
    if done then
        params.fast_trade_block = nil
    end
    return done
end

local function complete_online_artefact_inventory_delivery(se_squad, entry, task)
    local leader_obj = get_online_commander_obj(se_squad, entry)
    local params = ensure_task_params(task)
    local sid = tostring(entry and entry.squad_id or "-")
    local target = tostring(task and task.target or "-")
    local section = type(params.pickup_section) == "string" and params.pickup_section or nil
    local source_id = tonumber(params.pickup_source_id) or nil

    local created = nil
    local alife_create_item = _G.alife_create_item
    if leader_obj and type(alife_create_item) == "function" and section then
        local ok, res = pcall(function() return alife_create_item(section, leader_obj) end)
        if ok and res then
            created = res
        end
    end

    if not created then
        task_warn_once("ARTEFACT_INV_CREATE_FAIL", "ARTEFACT_INV_CREATE_FAIL sid=%s target=%s src_id=%s sec=%s",
            sid, target, tostring(source_id or "-"), tostring(section or "-"))
        return mark_artefact_pickup_done(task)
    end

    local commander_id = get_squad_commander_id(se_squad, entry)
    if commander_id and zhopa.fast_trading and zhopa.fast_trading.enqueue_check_for_npc then
        pcall(function()
            zhopa.fast_trading.enqueue_check_for_npc(commander_id, section, "artefact_task_direct_inventory")
        end)
    end

    return mark_artefact_pickup_done(task)
end

local function resolve_artefact_release_pending(se_squad, entry, task)
    local params = ensure_task_params(task)
    local source_id = tonumber(params.pickup_source_id) or nil
    if not source_id then
        return mark_artefact_pickup_done(task)
    end

    if not is_loose_world_object_by_id(source_id) then
        return complete_online_artefact_inventory_delivery(se_squad, entry, task)
    end

    local now = tg()
    local deadline = tonumber(params.pickup_release_deadline_tg) or 0
    if now < deadline then
        return false
    end

    task_warn_once("ARTEFACT_SOURCE_RELEASE_TIMEOUT", "ARTEFACT_SOURCE_RELEASE_TIMEOUT sid=%s target=%s src_id=%s sec=%s",
        tostring(entry and entry.squad_id or "-"),
        tostring(task and task.target or "-"),
        tostring(source_id),
        tostring(params.pickup_section or "-"))
    return mark_artefact_pickup_done(task)
end

local function begin_online_artefact_pickup(se_squad, entry, task, hit)
    local params = ensure_task_params(task)
    local sid = tostring(entry and entry.squad_id or "-")
    local target = tostring(task and task.target or "-")
    local section = hit and hit.section or nil
    local source_id = tonumber(hit and hit.object_id) or nil

    if not (section and source_id) then
        task_warn_once("ARTEFACT_SOURCE_RELEASE_FAIL", "ARTEFACT_SOURCE_RELEASE_FAIL sid=%s target=%s src_id=%s sec=%s",
            sid, target, tostring(source_id or "-"), tostring(section or "-"))
        return mark_artefact_pickup_done(task)
    end

    params.pickup_section = section
    params.pickup_source_id = source_id

    local accepted, source_state = request_release_object_by_id(source_id)
    if accepted ~= true then
        task_warn_once("ARTEFACT_SOURCE_RELEASE_FAIL", "ARTEFACT_SOURCE_RELEASE_FAIL sid=%s target=%s src_id=%s sec=%s",
            sid, target, tostring(source_id), tostring(section))
        return mark_artefact_pickup_done(task)
    end

    if source_state == "still_loose" then
        params.pickup_stage = "release_pending"
        params.pickup_release_requested_tg = tg()
        params.pickup_release_deadline_tg = tg() + ARTEFACT_RELEASE_CONFIRM_MS
        return false
    end

    return complete_online_artefact_inventory_delivery(se_squad, entry, task)
end

local function grant_offline_artefact_to_squad(se_squad, entry, task, target_smart_name)
    local params = ensure_task_params(task)
    if params.offline_roll_done == true then
        if params.pickup_stage == "done" then
            return true
        end
        return true
    end

    params.offline_roll_done = true
    params.offline_roll_success = false

    if math.random(100) > ARTEFACT_OFFLINE_ROLL_PERCENT then
        return true
    end

    local pool = get_offline_artefact_pool()
    if not pool or #pool == 0 then
        task_warn_once("ARTEFACT_OFFLINE_POOL_EMPTY", "ARTEFACT_OFFLINE_POOL_EMPTY sid=%s target=%s",
            tostring(entry and entry.squad_id or "-"), tostring(task and task.target or "-"))
        return true
    end

    local section = pick_random(pool)
    local commander_id = get_squad_commander_id(se_squad, entry)
    local anchor = resolve_artefact_parent_anchor(se_squad, entry, target_smart_name)
    if not (section and commander_id and anchor) then
        task_warn_once("ARTEFACT_OFFLINE_CREATE_FAIL", "ARTEFACT_OFFLINE_CREATE_FAIL sid=%s target=%s sec=%s commander=%s",
            tostring(entry and entry.squad_id or "-"), tostring(task and task.target or "-"),
            tostring(section or "-"), tostring(commander_id or "-"))
        return true
    end

    local created = create_alife_item(section, anchor.pos, anchor.lvid, anchor.gvid, commander_id)
    if not created then
        task_warn_once("ARTEFACT_OFFLINE_CREATE_FAIL", "ARTEFACT_OFFLINE_CREATE_FAIL sid=%s target=%s sec=%s commander=%s",
            tostring(entry and entry.squad_id or "-"), tostring(task and task.target or "-"),
            tostring(section or "-"), tostring(commander_id or "-"))
        return true
    end

    params.offline_roll_success = true
    params.pickup_section = section
    return mark_artefact_pickup_done(task)
end

local function resolve_artefact_task_completion(se_squad, entry, task)
    local params = ensure_task_params(task)
    if params.pickup_stage == "done" then
        return resolve_artefact_completion_after_pickup(se_squad, entry, task)
    end

    local target = task and task.target or nil
    if not target then
        return false
    end
    if not is_squad_arrived_to_smart(se_squad, target) then
        return false
    end

    params.fast_trade_block = true

    local now = tg()
    local cd = tonumber(params.check_cd_tg) or 0
    if now < cd then
        return false
    end
    params.check_cd_tg = now + ARTEFACT_CHECK_INTERVAL_MS

    if params.pickup_stage == "ground_pending" then
        params.pickup_copy_id = nil
        params.pickup_wait_until_tg = nil
        params.pickup_stage = "done"
        return resolve_artefact_completion_after_pickup(se_squad, entry, task)
    end

    if params.pickup_stage == "release_pending" then
        local resolved_pending = resolve_artefact_release_pending(se_squad, entry, task)
        if params.pickup_stage == "done" then
            return resolve_artefact_completion_after_pickup(se_squad, entry, task)
        end
        return resolved_pending
    end

    local leader_obj = get_online_commander_obj(se_squad, entry)
    if leader_obj then
        if params.pickup_scan_done == true then
            params.pickup_stage = "done"
            return resolve_artefact_completion_after_pickup(se_squad, entry, task)
        end

        params.pickup_scan_done = true
        local anchor_pos = resolve_artefact_scan_anchor(se_squad, entry, target)
        local hit = anchor_pos and find_nearby_artifact_hit(anchor_pos, ARTEFACT_SCAN_RADIUS) or nil
        if not hit then
            params.pickup_stage = "done"
            return resolve_artefact_completion_after_pickup(se_squad, entry, task)
        end
        local resolved_online = begin_online_artefact_pickup(se_squad, entry, task, hit)
        if params.pickup_stage == "done" then
            return resolve_artefact_completion_after_pickup(se_squad, entry, task)
        end
        return resolved_online
    end

    local resolved_offline = grant_offline_artefact_to_squad(se_squad, entry, task, target)
    if params.pickup_stage == "done" then
        return resolve_artefact_completion_after_pickup(se_squad, entry, task)
    end
    return resolved_offline
end

local function build_artefact_task(se_squad, cur_level, community, section_name, ctx)
    local anomaly_buckets_by_level = ctx_get_anomaly_buckets_by_level(ctx)
    local smarts_by_level = ctx_get_smarts_by_level(ctx)
    local list = (anomaly_buckets_by_level and anomaly_buckets_by_level[cur_level]) or get_cap_bucket(cur_level, "anomaly", community, section_name)
    if not list or #list == 0 then
        list = (smarts_by_level and smarts_by_level[cur_level])
            or get_smarts_for_level(cur_level, community, section_name)
    end
    local smart_name = community and pick_random_valid_safe(list, community, ctx and ctx.allowed_by_name or nil, cur_level, section_name) or pick_random_valid(list, community, cur_level, section_name)
    if not smart_name then return nil end
    return make_task("ARTEFACT", smart_name, { started_at_tg = tg(), check_cd_tg = 0, hops = 0 }, 0)
end

local build_base_camping_task
local build_patrol_task
local build_night_rest_task
local build_trade_task

local function build_roam_task(se_squad, entry, cur_level, community, section_name, trade_enabled, artefact_enabled, explore_enabled, populate_enabled, base_camping_enabled, patrol_enabled, ctx)
    ctx = ctx or tasks._prepare_reactive_context(se_squad, entry, tg(), "normal")
    if ctx then
        trade_enabled = trade_enabled == nil and ctx.trade_enabled or trade_enabled
        artefact_enabled = artefact_enabled == nil and ctx.artefact_enabled or artefact_enabled
        explore_enabled = explore_enabled == nil and ctx.explore_enabled or explore_enabled
        populate_enabled = populate_enabled == nil and ctx.populate_enabled or populate_enabled
        base_camping_enabled = base_camping_enabled == nil and ctx.base_camping_enabled or base_camping_enabled
        patrol_enabled = patrol_enabled == nil and ctx.patrol_enabled or patrol_enabled
    end
    if is_level_blacklisted_for_faction(cur_level, community, section_name) then
        local forced = build_force_exit_task(se_squad, entry, cur_level, community, section_name, ctx)
        if forced then
            return forced
        end
    end

    local candidates = {}
    local n = 0

    if artefact_enabled then
        local t = build_artefact_task(se_squad, cur_level, community, section_name, ctx)
        if t then
            n = n + 1
            candidates[n] = t
        end
    end

    if trade_enabled and zhopa.trade and zhopa.trade.can_trade_now and tasks._can_assign_trade_task(entry, "roam") == true then
        local ok_can, can_trade = pcall(zhopa.trade.can_trade_now, se_squad)
        if ok_can and can_trade == true and build_trade_task then
            local t = build_trade_task(se_squad, entry, cur_level, community, section_name, ctx)
            if t then
                n = n + 1
                candidates[n] = t
            end
        end
    end

    if populate_enabled and community then
        local t = build_populate_task(se_squad, entry, cur_level, community, section_name, ctx)
        if t then
            n = n + 1
            candidates[n] = t
        end
    end

    if explore_enabled then
        local t = build_explore_task(se_squad, cur_level, community, section_name, ctx)
        if t then
            n = n + 1
            candidates[n] = t
        end
    end

    if base_camping_enabled then
        local t = build_base_camping_task(se_squad, entry, cur_level, community, section_name, ctx)
        if t then
            n = n + 1
            candidates[n] = t
        end
    end

    if patrol_enabled then
        local t = build_patrol_task(se_squad, entry, cur_level, community, section_name, ctx)
        if t then
            n = n + 1
            candidates[n] = t
        end
    end

    return pick_random(candidates)
end

build_base_camping_task = function(se_squad, entry, cur_level, community, section_name, ctx)
    if not cur_level then return nil end
    local smart_name = pick_base_camping_target_smart(cur_level, community, section_name, ctx)
    if not smart_name then return nil end

    local camp_hours = cfg_num("base_camping_duration_game_hours", 2, nil)
    if camp_hours <= 0 then camp_hours = 1 end

    local duration_game_sec = math.floor(camp_hours * 3600)
    if duration_game_sec < 1 then duration_game_sec = 1 end

    local tf = (level and level.get_time_factor and level.get_time_factor()) or 10
    if tf <= 0 then tf = 10 end
    local duration_ms = math.floor((camp_hours * 3600 * 1000) / tf)
    if duration_ms < 1000 then duration_ms = 1000 end

    return make_task("BASE_CAMPING", smart_name, {
        duration_game_sec = duration_game_sec,
        duration_ms = duration_ms,
        arrived_at_gt = nil,
        arrived_at_tg = nil,
    }, 0)
end

build_patrol_task = function(se_squad, entry, cur_level, community, section_name, ctx)
    if not cur_level then return nil end
    local task = make_task("PATROL", nil, {}, 0)
    task.params.started_at_tg = tg()
    do
        local now_gt = game_time_now()
        if now_gt then
            task.params.started_at_gt = ctime_to_table(now_gt)
        end
    end
    task.params.duration_game_sec = 7200
    do
        local tf = (level and level.get_time_factor and level.get_time_factor()) or 10
        if tf <= 0 then tf = 10 end
        task.params.duration_ms = math.floor((task.params.duration_game_sec * 1000) / tf)
        if task.params.duration_ms < 1000 then task.params.duration_ms = 1000 end
    end
    local target = pick_next_patrol_target(task, cur_level, community, section_name, ctx)
    if not target then return nil end
    task.target = target
    clear_task_apply_state(task)
    return task
end

build_night_rest_task = function(se_squad, entry, cur_level, community, section_name, ctx)
    if not cur_level then return nil end
    local smart_name = pick_base_camping_target_smart(cur_level, community, section_name, ctx)
    if not smart_name then return nil end
    local p = { started_at_tg = tg(), arrived_at_gt = nil, arrived_at_tg = nil }
    local now_gt = game_time_now()
    if now_gt then
        p.started_at_gt = ctime_to_table(now_gt)
    end
    return make_task("NIGHT_REST", smart_name, p, 0)
end

local function trade_target_cache_key(se_squad, cur_level, community, section_name)
    local sid = nil
    if se_squad and se_squad.id then
        sid = tonumber(se_squad.id)
    end
    return tostring(sid or "-") .. "|" .. tostring(cur_level or "-") .. "|" .. tostring(community or "-") .. "|" .. tostring(section_name or "-")
end

local function get_cached_trade_target(se_squad, cur_level, community, section_name, max_age_ms)
    local key = trade_target_cache_key(se_squad, cur_level, community, section_name)
    local c = RUNTIME.trade_target_cache[key]
    if type(c) ~= "table" then
        return nil
    end

    local now = tg()
    local age = now - (tonumber(c.tg) or 0)
    local ttl = tonumber(max_age_ms) or 30000
    if age > ttl then
        return nil
    end

    local target = c.target
    if not (target and type(target) == "string") then
        return nil
    end

    local sm = get_smart_by_name(target)
    if sm and smart_is_blacklisted_by_obj(sm, target, community, section_name) then
        return nil
    end
    if (not sm) and smart_is_blacklisted_for_level(cur_level, target, community, section_name) then
        return nil
    end
    if community and is_roam_smart_allowed(target, community) ~= true then
        return nil
    end
    return target
end

local function set_cached_trade_target(se_squad, cur_level, community, section_name, target)
    if not (target and type(target) == "string") then return end
    local key = trade_target_cache_key(se_squad, cur_level, community, section_name)
    RUNTIME.trade_target_cache[key] = {
        tg = tg(),
        target = target,
    }
end

RUNTIME.collect_trade_candidate_smarts = function(level_name, community, section_name, cap_bundle, now)
    if not level_name then
        return {}
    end

    if zhopa.config and zhopa.config.get_trade_smarts then
        local static_list = zhopa.config.get_trade_smarts(level_name) or {}
        if #static_list > 0 then
            local seen = {}
            local smarts = {}
            for i = 1, #static_list do
                local name = static_list[i]
                if name and not seen[name] then
                    seen[name] = true
                    smarts[#smarts + 1] = name
                end
            end
            return smarts
        end
    end

    local smarts = nil
    do
        local cap_slots = (cap_bundle and cap_bundle.trade_slot) or get_cap_bucket(level_name, "trade_slot", community, section_name, now) or {}
        if #cap_slots > 0 then
            local seen = {}
            smarts = {}
            for i = 1, #cap_slots do
                local name = cap_slots[i]
                if name and not seen[name] then
                    seen[name] = true
                    smarts[#smarts + 1] = name
                end
            end
        end
    end
    if not smarts or #smarts == 0 then
        local list = get_smarts_for_level(level_name, community, section_name)
        local board = get_board()
        local by_name = board and board.smarts_by_names or nil
        local seen = {}
        smarts = {}
        for i = 1, (list and #list or 0) do
            local name = list[i]
            local sm = name and by_name and by_name[name] or nil
            local has_trade_slot = name and smart_has_trader_slot(name, sm) or false
            if name and not seen[name] and has_trade_slot then
                seen[name] = true
                smarts[#smarts + 1] = name
            end
        end
    end
    return smarts or {}
end

RUNTIME.build_trade_search_levels = function(cur_level, community, section_name)
    local levels = {}
    local seen = {}

    local function add_level(level_name)
        if type(level_name) ~= "string" or level_name == "" then return end
        if seen[level_name] then return end
        if is_level_blacklisted_for_faction(level_name, community, section_name) then return end
        seen[level_name] = true
        levels[#levels + 1] = level_name
    end

    add_level(cur_level)

    local neighbors = tasks._get_effective_neighbors(cur_level, community, section_name)
    for i = 1, #neighbors do
        add_level(neighbors[i])
    end

    return levels
end

RUNTIME.pick_trade_target_on_level = function(se_squad, level_name, community, section_name, allowed_cache, smarts_override, entry, ctx, ignore_cap)
    local smarts = smarts_override or RUNTIME.collect_trade_candidate_smarts(level_name, community, section_name)
    local n = smarts and #smarts or 0
    local active_level = loaded_level_name()
    local require_live_provider = type(active_level) == "string" and active_level ~= "" and active_level == level_name
    ignore_cap = ignore_cap == true
    if n <= 0 then
        return nil, nil, {
            level = level_name,
            slot_n = 0,
            slot_any = 0,
            trader_only_n = 0,
            trader_any = 0,
            excluded_unsafe = 0,
            excluded_cap = 0,
            best_name = nil,
            best_dist = nil,
        }
    end

    local board = get_board()
    local by_name = board and board.smarts_by_names or nil

    local ok_sgvid, sgvid = pcall(function() return se_squad.m_game_vertex_id end)
    sgvid = ok_sgvid and sgvid or nil

    local ok_sid, sid = pcall(function() return se_squad.id end)
    sid = ok_sid and tonumber(sid) or nil

    local max_per_smart = cfg_num("trade_max_squads_per_smart", 1, 0)

    local taken = nil
    if max_per_smart > 0 and ignore_cap ~= true then
        local now = tg()
        local trade_ttl = tonumber(RUNTIME.hotpath_cfg and RUNTIME.hotpath_cfg.builders and RUNTIME.hotpath_cfg.builders.trade_taken_ttl_ms) or 500
        local logic_index = ctx and ctx.logic_index or nil
        if type(logic_index) ~= "table" or now > ((tonumber(logic_index.tg) or 0) + trade_ttl) then
            logic_index = tasks._get_logic_index(now, "trade")
            if ctx then
                ctx.logic_index = logic_index
            end
        end
        taken = logic_index and logic_index.trade_counts_by_level_smart and logic_index.trade_counts_by_level_smart[level_name] or nil
    end

    local best_slot = nil
    local best_slot_dist = nil
    local fallback_slot = {}
    local fb_slot_n = 0
    local slot_n = 0
    local trader_only_n = 0
    local excluded_cap = 0
    local excluded_unsafe = 0
    local slot_any = 0
    local trader_any = 0
    local function is_allowed(name)
        if not name then return false end
        allowed_cache = allowed_cache or {}
        if allowed_cache[name] == nil then
            allowed_cache[name] = is_roam_smart_allowed(name, community) == true
        end
        return allowed_cache[name] == true
    end

    for i = 1, n do
        local name = smarts[i]
        local used = taken and name and (tonumber(taken[name]) or 0) or 0
        local current = entry and entry.tasks and entry.tasks.current or nil
        if used > 0 and current and current.type == "TRADE" and current.target == name then
            local current_level = RUNTIME.resolve_smart_level_name(current.target, entry and entry.level or nil)
            if current_level == level_name then
                used = used - 1
            end
        end
        if used < 0 then used = 0 end
        if ignore_cap ~= true and max_per_smart > 0 and used >= max_per_smart then
            excluded_cap = excluded_cap + 1
        else
            local sm = by_name and name and by_name[name] or nil
            local has_slot = name and smart_has_trader_slot(name, sm) or false
            local has_trader = (sm and smart_has_real_trader(sm)) or false
            local trade_ready = has_slot and ((require_live_provider and has_trader) or (not require_live_provider))
            local ok_allowed = name and is_allowed(name)
            if has_slot then slot_any = slot_any + 1 end
            if has_trader then trader_any = trader_any + 1 end
            if ok_allowed ~= true then
                excluded_unsafe = excluded_unsafe + 1
            end
            if ok_allowed and trade_ready then
                slot_n = slot_n + 1
                local ok_gvid, tgvid = pcall(function() return sm and sm.m_game_vertex_id end)
                tgvid = ok_gvid and tgvid or nil
                local d = try_game_graph_distance(sgvid, tgvid)
                if d then
                    if not best_slot_dist or d < best_slot_dist then
                        best_slot_dist = d
                        best_slot = name
                    end
                else
                    fb_slot_n = fb_slot_n + 1
                    fallback_slot[fb_slot_n] = name
                end
            elseif ok_allowed and has_trader and not has_slot then
                trader_only_n = trader_only_n + 1
            end
        end
    end

    local picked = nil
    local reason = nil
    if slot_n > 0 then
        picked = best_slot or pick_random_valid_safe(fallback_slot, community, allowed_cache, level_name, section_name)
        reason = "slot"
    end

    return picked, reason, {
        level = level_name,
        slot_n = slot_n,
        slot_any = slot_any,
        trader_only_n = trader_only_n,
        trader_any = trader_any,
        excluded_unsafe = excluded_unsafe,
        excluded_cap = excluded_cap,
        best_name = best_slot or nil,
        best_dist = best_slot_dist or nil,
    }
end

RUNTIME.summarize_trade_pick_failure = function(se_squad, cur_level, community, section_name)
    local levels = RUNTIME.build_trade_search_levels(cur_level, community, section_name)
    if not levels or #levels <= 0 then
        return "-"
    end

    local parts = {}
    for i = 1, #levels do
        local level_name = levels[i]
        local _, _, stats = RUNTIME.pick_trade_target_on_level(se_squad, level_name, community, section_name, nil, nil, nil, nil)
        parts[#parts + 1] = string.format(
            "%s slot=%s/%s trader_only=%s/%s unsafe=%s cap=%s",
            tostring(level_name or "-"),
            tostring(stats and stats.slot_n or 0),
            tostring(stats and stats.slot_any or 0),
            tostring(stats and stats.trader_only_n or 0),
            tostring(stats and stats.trader_any or 0),
            tostring(stats and stats.excluded_unsafe or 0),
            tostring(stats and stats.excluded_cap or 0)
        )
    end

    return table.concat(parts, "; ")
end

local function pick_trade_target_smart(se_squad, cur_level, community, section_name, lane_granted, entry, ctx, opts)
    local tostring = tostring
    if not (se_squad and cur_level and community) then return nil end
    opts = type(opts) == "table" and opts or nil
    local ignore_cap = opts and opts.ignore_cap == true

    local trade_candidate_smarts_by_level = ctx_get_trade_candidate_smarts_by_level(ctx)
    local search_levels = (ctx and ctx.search_levels) or RUNTIME.build_trade_search_levels(cur_level, community, section_name)
    if #search_levels <= 0 then
        return nil
    end

    local now = tg()
    local dirty = false
    if entry then
        dirty = consume_entry_dirty(entry, "task") or consume_entry_dirty(entry, "community") or consume_entry_dirty(entry, "identity")
    end
    if lane_granted ~= true and (not dirty) then
        local cached_target = get_cached_trade_target(se_squad, cur_level, community, section_name, DIRTY_TRADE_PICK_TTL_MS)
        if cached_target then
            return cached_target
        end
    end

    local picked = nil
    local reason = nil
    local picked_level = nil
    local stats = nil
    local allowed_cache = ctx and ctx.allowed_by_name or nil
    for li = 1, #search_levels do
        local level_name = search_levels[li]
        local candidate, pick_reason, pick_stats = RUNTIME.pick_trade_target_on_level(se_squad, level_name, community, section_name, allowed_cache, (trade_candidate_smarts_by_level and trade_candidate_smarts_by_level[level_name]) or nil, entry, ctx, ignore_cap)
        if candidate then
            picked = candidate
            reason = (li == 1) and pick_reason or ("neighbor_" .. tostring(pick_reason or "pick"))
            picked_level = level_name
            stats = pick_stats
            break
        end
        if li == 1 then
            stats = pick_stats
        end
    end
    if zhopa.log and zhopa.log.debug then
        zhopa.log.debug("TRADE", "pick_trade_target level=%s picked_level=%s community=%s slot_smarts=%s/%s trader_only_smarts=%s/%s excluded_unsafe=%s excluded_cap=%s best=%s best_dist=%s picked=%s reason=%s",
            tostring(cur_level or "-"),
            tostring(picked_level or "-"),
            tostring(community or "-"),
            tostring(stats and stats.slot_n or 0),
            tostring(stats and stats.slot_any or 0),
            tostring(stats and stats.trader_only_n or 0),
            tostring(stats and stats.trader_any or 0),
            tostring(stats and stats.excluded_unsafe or 0),
            tostring(stats and stats.excluded_cap or 0),
            tostring(stats and stats.best_name or "-"),
            tostring(stats and stats.best_dist or "-"),
            tostring(picked or "-"),
            tostring(reason or "-")
        )
    end
    if picked then
        set_cached_trade_target(se_squad, cur_level, community, section_name, picked)
    end
    return picked
end

build_trade_task = function(se_squad, entry, cur_level, community, section_name, ctx, opts)
    local tostring = tostring
    if not (cur_level and community) then return nil end
    local smart_name = pick_trade_target_smart(se_squad, cur_level, community, section_name, false, entry, ctx, opts)
    if not smart_name then return nil end
    local task = make_task("TRADE", smart_name, { started_at_tg = tg() }, 0)
    if zhopa.log and zhopa.log.info then
        zhopa.log.info("TRADE", "build_trade_task sid=%s level=%s community=%s target=%s",
            tostring(entry and entry.squad_id or "-"),
            tostring(cur_level or "-"),
            tostring(community or "-"),
            tostring(smart_name or "-")
        )
    end
    return task
end

local function ensure_current_task(se_squad, entry)
    if entry.tasks and entry.tasks.current then return entry.tasks.current end
    local now = tg()

    local cur_level = now_level_name_by_gvid(se_squad.m_game_vertex_id) or entry.level
    entry.level = cur_level
    local community = get_squad_community(entry, se_squad)
    local section_name = get_squad_section(entry, se_squad)
    local ctx = tasks._prepare_reactive_context and tasks._prepare_reactive_context(se_squad, entry, now, "normal") or nil

    local task = nil
    if is_level_blacklisted_for_faction(cur_level, community, section_name) then
        task = build_force_exit_task(se_squad, entry, cur_level, community, section_name, ctx)
        if task then
            return task
        end
    end

    local night_rest_enabled = cfg_bool("night_rest_enabled", false)
    if night_rest_enabled and is_night_now() then
        task = build_night_rest_task(se_squad, entry, cur_level, community, section_name, ctx)
    end

    if not task then
        task = build_roam_task(se_squad, entry, cur_level, community, section_name,
            ctx and ctx.trade_enabled or nil,
            ctx and ctx.artefact_enabled or nil,
            ctx and ctx.explore_enabled or nil,
            ctx and ctx.populate_enabled or nil,
            ctx and ctx.base_camping_enabled or nil,
            ctx and ctx.patrol_enabled or nil,
            ctx)
    end
    if not task then
        task = build_rest_task(se_squad)
    end
    return task
end

local function should_preempt_for_night_rest(current)
    if type(current) ~= "table" then
        return true
    end
    if current.type == "NIGHT_REST" then
        return false
    end
    if current.type == "TRADE" then
        return false
    end
    if current.type == "EXPLORE" and current.params and current.params.force_exit == true then
        return false
    end
    return true
end

local function rotate_task_on_complete(se_squad, entry, surge_active)
    local current = entry and entry.tasks and entry.tasks.current or nil
    if current and current.type == "NIGHT_REST" then
        zhopa.memory.set_task_current(entry.squad_id, nil)
        return
    end
    zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
end

local function is_task_completed(se_squad, entry, task)
    local tonumber = tonumber
    local tostring = tostring
    if not task or not task.type then return true end

    if task.type == "REST_1H" then
        local p = task.params or {}
        local started_gt = ctime_from_table(p.started_at_gt)
        local dur_gs = tonumber(p.duration_game_sec)
        if started_gt and dur_gs and dur_gs > 0 then
            local elapsed = game_time_diff_sec(started_gt) or 0
            local done = elapsed >= dur_gs
            if done and not p.rest_dbg_done and zhopa.log and zhopa.log.info then
                p.rest_dbg_done = true
                zhopa.log.info("TASKS", "rest_done sid=%s", tostring(entry and entry.squad_id or "-"))
            end
            return done
        end
        local started = tonumber(p.started_at_tg) or 0
        local dur = tonumber(p.duration_ms) or 0
        local done = tg() >= (started + dur)
        if done and not p.rest_dbg_done and zhopa.log and zhopa.log.info then
            p.rest_dbg_done = true
            zhopa.log.info("TASKS", "rest_done sid=%s", tostring(entry and entry.squad_id or "-"))
        end
        return done
    end

    if task.type == "NIGHT_REST" then
        return is_night_now() == false
    end

    if task.type == "TRADE" then
        local target = task.target
        if not target then
            local p = task.params or {}
            task.params = p
            p.trade_done_state = "FAILED_NO_TARGET"
            return true
        end
        if not is_squad_arrived_to_smart(se_squad, target) then
            local p = task.params or {}
            task.params = p
            local now = tg()
            local cd = tonumber(p.trade_dbg_cd_ms) or 8000
            if zhopa.log and zhopa.log.debug and now >= (tonumber(p.trade_dbg_next_tg) or 0) then
                p.trade_dbg_next_tg = now + cd
                zhopa.log.debug("TRADE", "tick sid=%s level=%s state=TRAVEL target=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(entry and entry.level or "-"),
                    tostring(target or "-")
                )
            end
            local travel_ms = cfg_num("trade_travel_timeout_ms", 600000, 30000)
            local started = tonumber(p.started_at_tg) or now
            if started > now then started = now end
            if now >= (started + travel_ms) then
                local rerolls = tonumber(p.trade_travel_reroll_count) or 0
                if rerolls < 2 then
                    local cur_level = resolve_entry_level(entry, se_squad)
                    local community = get_squad_community(entry, se_squad)
                    local section_name = get_squad_section(entry, se_squad)
                    local build_ctx = tasks._prepare_reactive_context and tasks._prepare_reactive_context(se_squad, entry, now, "normal") or nil
                    local next_target = pick_trade_target_smart(se_squad, cur_level, community, section_name, true, entry, build_ctx)
                    if next_target and next_target ~= target then
                        p.trade_travel_reroll_count = rerolls + 1
                        task.target = next_target
                        clear_task_apply_state(task)
                        p.started_at_tg = now
                        p.trade_last_target = nil
                        p.trade_entered_job_logged = nil
                        p.trade_started_tg = nil
                        p.trade_started_idle = nil
                        p.trade_surge_was_active = nil
                        p.trade_no_trader_hard = nil
                        p.trade_no_trader_reason = nil
                        p.trade_job_evicted = nil
                        p.trade_done_state = nil
                        p.trade_arrived_at_tg = nil
                        p.trade_dbg_last_state = nil
                        if zhopa.log and zhopa.log.warn then
                            zhopa.log.warn("TRADE", "travel_timeout_reroll sid=%s old_target=%s new_target=%s",
                                tostring(entry and entry.squad_id or "-"),
                                tostring(target or "-"),
                                tostring(next_target or "-")
                            )
                        end
                        return false
                    end
                end
                if zhopa.log and zhopa.log.warn then
                    zhopa.log.warn("TRADE", "travel_timeout_giveup sid=%s target=%s",
                        tostring(entry and entry.squad_id or "-"),
                        tostring(target or "-")
                    )
                end
                p.trade_done_state = "TRAVEL_TIMEOUT"
                return true
            end
            return false
        end

        local p = task.params or {}
        task.params = p
        local now = tg()
        if not tonumber(p.trade_arrived_at_tg) then
            p.trade_arrived_at_tg = now
            p.trade_dbg_last_state = nil
            if zhopa.log and zhopa.log.info then
                zhopa.log.info("TRADE", "arrived sid=%s target=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(target or "-")
                )
            end
        end

        if zhopa.trade and (zhopa.trade.consume_service_event or zhopa.trade.consume_trade_started) then
            local consume_evt = zhopa.trade.consume_service_event or zhopa.trade.consume_trade_started
            local ok_evt, consumed, evt = pcall(consume_evt, entry and entry.squad_id, target)
            if ok_evt and consumed == true then
                if zhopa.log and zhopa.log.info then
                    zhopa.log.info("TRADE", "session_signal sid=%s target=%s source=%s phase=%s status=%s reason=%s",
                        tostring(entry and entry.squad_id or "-"),
                        tostring(target or "-"),
                        tostring(evt and evt.source or "-"),
                        tostring(evt and evt.phase or "-"),
                        tostring(evt and evt.status or "-"),
                        tostring(evt and evt.reason or "-")
                    )
                end
            end
        end

        if zhopa.trade and zhopa.trade.tick then
            local ok_tick, tick_state = pcall(zhopa.trade.tick, se_squad, entry, task)
            if not ok_tick then
                log_task_error("trade_tick", entry, task, tick_state)
                p.trade_done_state = "FAILED"
            elseif tick_state == "DONE" or tick_state == "FAILED" or tick_state == "NO_TRADER" or tick_state == "OFFLINE" then
                p.trade_done_state = tick_state
            else
                p.trade_done_state = nil
            end
        end

        local st = task.params and task.params.trade_done_state or nil

        do
            local now = tg()
            local cd = tonumber(p.trade_dbg_cd_ms) or 8000
            local last = p.trade_dbg_last_state
            local changed = st and st ~= last
            if (changed or (now >= (tonumber(p.trade_dbg_next_tg) or 0))) and zhopa.log and zhopa.log.debug then
                p.trade_dbg_next_tg = now + cd
                if st ~= nil then
                    p.trade_dbg_last_state = st
                end
                zhopa.log.debug("TRADE", "tick sid=%s level=%s state=%s target=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(entry and entry.level or "-"),
                    tostring(st or "nil"),
                    tostring(target or "-")
                )
            end
        end

        if st == "NO_TRADER" then
            if p.trade_no_trader_hard == true then
                p.trade_done_state = "NO_TRADER_HARD"
                task_warn_once(
                    "TRADE_HARD_NO_TRADER_COMPLETE:" .. tostring(entry and entry.squad_id or "-") .. ":" .. tostring(target or "-"),
                    "TRADE_HARD_NO_TRADER_COMPLETE sid=%s target=%s reason=%s evicted=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(target or "-"),
                    tostring(p.trade_no_trader_reason or "-"),
                    tostring(p.trade_job_evicted == true)
                )
                return true
            end
            p.trade_done_state = "NO_TRADER"
            if zhopa.log and zhopa.log.warn then
                zhopa.log.warn("TRADE", "no_trader sid=%s target=%s reason=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(target or "-"),
                    tostring(p.trade_no_trader_reason or "timeout"))
            end
            return true
        end
        if st == "FAILED" then
            p.trade_failed = true
            p.trade_done_state = "FAILED"
            if zhopa.log and zhopa.log.warn then
                zhopa.log.warn("TRADE", "failed sid=%s target=%s", tostring(entry and entry.squad_id or "-"), tostring(target or "-"))
            end
            return true
        end
        if st == "DONE" then
            p.trade_done_state = "DONE"
            if zhopa.log and zhopa.log.info then
                zhopa.log.info("TRADE", "done sid=%s target=%s state=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(target or "-"),
                    tostring(st))
            end
            return true
        end
        if st == "OFFLINE" then
            p.trade_done_state = "OFFLINE"
            if zhopa.log and zhopa.log.warn then
                zhopa.log.warn("TRADE", "offline sid=%s target=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(target or "-"))
            end
            return true
        end

        local arrived_timeout_ms = tonumber(RUNTIME.hotpath_cfg and RUNTIME.hotpath_cfg.builders and RUNTIME.hotpath_cfg.builders.trade_arrived_timeout_ms) or 30000
        if arrived_timeout_ms < 5000 then arrived_timeout_ms = 5000 end
        if now >= ((tonumber(p.trade_arrived_at_tg) or now) + arrived_timeout_ms) then
            p.trade_done_state = "ARRIVED_TIMEOUT"
            if zhopa.log and zhopa.log.warn then
                zhopa.log.warn("TRADE", "arrived_timeout_complete sid=%s target=%s elapsed_ms=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(target or "-"),
                    tostring(now - (tonumber(p.trade_arrived_at_tg) or now))
                )
            end
            return true
        end

        return false
    end

    if task.type == "BASE_CAMPING" then
        local target = task.target
        if not target then
            return true
        end
        if not is_squad_arrived_to_smart(se_squad, target) then
            return false
        end

        local p = task.params or {}
        if not p.arrived_at_tg then
            p.arrived_at_tg = tg()
            local now_gt = game_time_now()
            if now_gt then
                p.arrived_at_gt = ctime_to_table(now_gt)
            end
            return false
        end

        local started_gt = ctime_from_table(p.arrived_at_gt)
        local dur_gs = tonumber(p.duration_game_sec)
        if started_gt and dur_gs and dur_gs > 0 then
            local elapsed = game_time_diff_sec(started_gt) or 0
            return elapsed >= dur_gs
        end

        local started = tonumber(p.arrived_at_tg) or 0
        local dur = tonumber(p.duration_ms) or 0
        return tg() >= (started + dur)
    end

    if task.type == "PATROL" then
        local p = task.params or {}
        task.params = p

        if not p.started_at_tg then
            p.started_at_tg = tg()
            local now_gt = game_time_now()
            if now_gt then
                p.started_at_gt = ctime_to_table(now_gt)
            end
        end
        if not tonumber(p.duration_game_sec) then
            p.duration_game_sec = 7200
        end
        if not tonumber(p.duration_ms) then
            local tf = (level and level.get_time_factor and level.get_time_factor()) or 10
            if tf <= 0 then tf = 10 end
            p.duration_ms = math.floor((tonumber(p.duration_game_sec) * 1000) / tf)
            if p.duration_ms < 1000 then p.duration_ms = 1000 end
        end

        do
            local started_gt = ctime_from_table(p.started_at_gt)
            local dur_gs = tonumber(p.duration_game_sec)
            if started_gt and dur_gs and dur_gs > 0 then
                local elapsed = game_time_diff_sec(started_gt) or 0
                if elapsed >= dur_gs then
                    return true
                end
            else
                local started = tonumber(p.started_at_tg) or 0
                local dur = tonumber(p.duration_ms) or 0
                if tg() >= (started + dur) then
                    return true
                end
            end
        end

        local target = task.target
        local cur_level = entry and entry.level or nil
        local community = get_squad_community(entry, se_squad)
        local section_name = get_squad_section(entry, se_squad)
        local build_ctx = nil
        if not cur_level then
            cur_level = resolve_entry_level(entry, se_squad) or loaded_level_name()
            if entry and cur_level then entry.level = cur_level end
        end
        build_ctx = tasks._prepare_reactive_context and tasks._prepare_reactive_context(se_squad, entry, tg(), "normal") or nil

        if not target then
            local next_target = cur_level and pick_next_patrol_target(task, cur_level, community, section_name, build_ctx) or nil
            if not next_target then
                return true
            end
            task.target = next_target
            clear_task_apply_state(task)
            p._applied = nil
            return false
        end

        if is_squad_arrived_to_smart(se_squad, target) then
            p.visited = p.visited or {}
            if not p.visited[target] then
                p.visited[target] = true
                p.visited_count = (tonumber(p.visited_count) or 0) + 1
            end

            local next_target = cur_level and pick_next_patrol_target(task, cur_level, community, section_name, build_ctx) or nil
            if next_target and next_target ~= target then
                task.target = next_target
                clear_task_apply_state(task)
                p._applied = nil
            end
            return false
        end

        return false
    end

    if task.type == "POPULATE" then
        local target = task.target
        if not target then return true end
        if is_squad_arrived_to_smart(se_squad, target) ~= true then
            return false
        end
        return resolve_post_arrival_assist(se_squad, entry, task, target)
    end

    if task.type == "EXPLORE" then
        local target = task.target
        if target and is_squad_arrived_to_smart(se_squad, target) then
            return resolve_post_arrival_assist(se_squad, entry, task, target)
        end
        return false
    end

    if task.type == "ARTEFACT" then
        return resolve_artefact_task_completion(se_squad, entry, task)
    end

    return false
end

function apply_task(se_squad, task, surge_active, community, section_name)
    if not task then
        sync_rest_always_arrived(se_squad, false)
        return
    end
    sync_rest_always_arrived(se_squad, task)
    task.params = task.params or {}

    if task.type == "REST_1H" then
        local hold_target = resolve_rest_hold_smart_name(nil, se_squad)
        set_scripted_target(se_squad, hold_target, task.params, { force_sync = hold_target ~= nil, reason = "rest_hold" })
        return
    end

    if task.params._applied then
        return
    end

    if surge_active == nil then
        surge_active = is_surge_active()
    end
    if surge_active then
        return
    end

    if task.target and type(task.target) == "string" then
        local board = get_board()
        local sm = board and board.smarts_by_names and board.smarts_by_names[task.target] or nil
        if smart_is_blacklisted_by_obj(sm, task.target, community, section_name) then
            set_scripted_target(se_squad, nil)
            return
        end
        if set_scripted_target(se_squad, task.target, task.params, { force_sync = true, reason = "apply" }) then
            task.params._applied = true
        end
    end
end

function tasks.update_squad_tasks(se_squad, ctx)
    if not (zhopa.memory and (zhopa.memory.touch_squad_validated or zhopa.memory.get_squad_entry)) then return end
    if zhopa.memory.is_protected_squad and zhopa.memory.is_protected_squad(se_squad) then
        cancel_task_state_timer(se_squad and se_squad.id)
        return
    end
    local entry = nil
    if ctx and ctx.prevalidated == true and se_squad and se_squad.id and zhopa.memory.get_squad_entry then
        entry = zhopa.memory.get_squad_entry(se_squad.id)
    elseif zhopa.memory.touch_squad_validated then
        entry = zhopa.memory.touch_squad_validated(se_squad, false, "tasks")
    end
    if not entry then
        cancel_task_state_timer(se_squad and se_squad.id)
        return
    end
    local now = tg()
    local function sync_current_task_timer(task_override)
        return sync_task_state_timer(entry, task_override or (entry.tasks and entry.tasks.current) or nil, now, se_squad)
    end

    local surge_active = is_surge_active()
    local surge_locked = zhopa.memory.get_surge_lock(se_squad.id)
    if surge_active then
        local surge_hold_target = resolve_rest_hold_smart_name(entry, se_squad)
        if not surge_locked then
            local rest = build_rest_task(se_squad)
            zhopa.memory.set_task_current(entry.squad_id, rest)
            sync_rest_always_arrived(se_squad, rest)
            set_scripted_target(se_squad, surge_hold_target, rest.params, { force_sync = surge_hold_target ~= nil, reason = "surge_rest_hold" })
            zhopa.memory.set_surge_lock(se_squad.id, true)
        else
            sync_rest_always_arrived(se_squad, true)
            set_scripted_target(se_squad, surge_hold_target, nil, { force_sync = surge_hold_target ~= nil, reason = "surge_rest_hold" })
        end
        return
    end

    if surge_locked then
        zhopa.memory.set_surge_lock(se_squad.id, false)
    end

    local cur_level = resolve_entry_level(entry, se_squad) or entry.level
    local community = get_squad_community(entry, se_squad)
    local section_name = get_squad_section(entry, se_squad)
    local build_ctx = tasks._prepare_reactive_context and tasks._prepare_reactive_context(se_squad, entry, now, "normal") or nil
    entry.smart_id = se_squad.smart_id
    entry.scripted_target = se_squad.scripted_target

    entry.tasks = entry.tasks or { prev = nil, current = nil }
    local current = entry.tasks.current
    sync_rest_always_arrived(se_squad, current)
    local pending_fast_trade = nil
    local function bind_pending_fast_trade(task_ref)
        if type(task_ref) ~= "table" then
            return
        end
        if pending_fast_trade == nil then
            if zhopa.fast_trading and type(zhopa.fast_trading.consume_pending_trigger) == "function" then
                pending_fast_trade = zhopa.fast_trading.consume_pending_trigger(entry.squad_id)
            else
                pending_fast_trade = false
            end
        end
        if type(pending_fast_trade) ~= "table" then
            return
        end
        if task_ref.type == "TRADE" then
            pending_fast_trade = false
            return
        end
        task_ref.params = task_ref.params or {}
        task_ref.params.fast_trade_trigger = true
        task_ref.params.fast_trade_retry_next_tg = now
        pending_fast_trade = false
    end
    bind_pending_fast_trade(current)

    if is_level_blacklisted_for_faction(cur_level, community, section_name) then
        local force_exit_active = current
            and current.type == "EXPLORE"
            and current.params
            and current.params.force_exit == true
        if not force_exit_active then
            local forced = build_force_exit_task(se_squad, entry, cur_level, community, section_name, build_ctx)
            if forced then
                zhopa.memory.set_task_current(entry.squad_id, forced)
                current = entry.tasks and entry.tasks.current or forced
            else
                zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                current = entry.tasks and entry.tasks.current or nil
            end
        end
    end
    bind_pending_fast_trade(current)

    -- Fast trading: check trigger and swap to TRADE directly
    if current and current.params and current.params.fast_trade_trigger == true then
        local retry_ms = 2000
        local now_fast = tg()
        local retry_next_tg = tonumber(current.params.fast_trade_retry_next_tg) or 0
        if retry_next_tg <= now_fast then
            if tasks._can_assign_trade_task(entry, "fast_trade_trigger") ~= true then
                current.params.fast_trade_trigger = nil
                current.params.fast_trade_retry_next_tg = nil
                current.params.fast_trade_retry_count = nil
                current.params.online_force_rebuild = nil
            else
                local cur_level_fast = now_level_name_by_gvid(se_squad.m_game_vertex_id) or entry.level
                local community_fast = get_squad_community(entry, se_squad)
                local section_fast = get_squad_section(entry, se_squad)
                local trade_ctx = build_ctx or (tasks._prepare_reactive_context and tasks._prepare_reactive_context(se_squad, entry, now_fast, "normal")) or nil
                local trade_task = build_trade_task(se_squad, entry, cur_level_fast, community_fast, section_fast, trade_ctx, { ignore_cap = true })
                if trade_task and trade_task.params then
                    current.params.fast_trade_trigger = nil
                    current.params.fast_trade_retry_next_tg = nil
                    current.params.fast_trade_retry_count = nil
                    trade_task.params.fast_trade_triggered = true
                    trade_task.params.online_force_rebuild = true
                    trade_task.params.fast_trade_prev_type = current.type
                    if zhopa.log and zhopa.log.info then
                        zhopa.log.info("FAST_TRADE", "rebuild_to_trade sid=%s prev_type=%s target=%s",
                            tostring(entry.squad_id or "-"),
                            tostring(current.type or "-"),
                            tostring(trade_task.target or "-")
                        )
                    end
                    zhopa.memory.set_task_current(entry.squad_id, trade_task)
                    current = entry.tasks and entry.tasks.current or trade_task
                    clear_task_apply_state(current)
                    local ok_apply_trade, err_apply_trade = pcall(apply_task, se_squad, current, surge_active, community_fast, section_fast)
                    if not ok_apply_trade then
                        log_task_error("apply_fast_trade_preempt", entry, current, err_apply_trade)
                        zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                    end
                    sync_current_task_timer()
                    return
                else
                    current.params.online_force_rebuild = nil
                    current.params.fast_trade_retry_count = (tonumber(current.params.fast_trade_retry_count) or 0) + 1
                    current.params.fast_trade_retry_next_tg = now_fast + retry_ms
                    if zhopa.log and zhopa.log.warn then
                        local retry_count = tonumber(current.params.fast_trade_retry_count) or 0
                        if retry_count == 1 or (retry_count % 5) == 0 then
                            zhopa.log.warn(
                                "FAST_TRADE",
                                "build_failed sid=%s prev_type=%s level=%s community=%s retry=%s next_retry_ms=%s levels=%s",
                                tostring(entry.squad_id or "-"),
                                tostring(current.type or "-"),
                                tostring(cur_level_fast or "-"),
                                tostring(community_fast or "-"),
                                tostring(retry_count),
                                tostring(retry_ms),
                                tostring(RUNTIME.summarize_trade_pick_failure(se_squad, cur_level_fast, community_fast, section_fast))
                            )
                        end
                    end
                end
            end
        end
    end

    local night_rest_enabled = cfg_bool("night_rest_enabled", false)
    if current and night_rest_enabled and is_night_now() and should_preempt_for_night_rest(current) then
        local night_task = build_night_rest_task(se_squad, entry, cur_level, community, section_name, build_ctx)
        if night_task then
            zhopa.memory.set_task_current(entry.squad_id, night_task)
            current = entry.tasks and entry.tasks.current or night_task
            clear_task_apply_state(current)
            local ok_apply_night, err_apply_night = pcall(apply_task, se_squad, current, surge_active, community, section_name)
            if not ok_apply_night then
                log_task_error("apply_night_preempt", entry, current, err_apply_night)
                zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
            end
            sync_current_task_timer()
            return
        end
    end

    if not current then
        local ok_new, new_task = pcall(ensure_current_task, se_squad, entry)
        if not ok_new then
            log_task_error("ensure", entry, nil, new_task)
            new_task = build_rest_task(se_squad)
        end
        if not new_task then
            log_task_error("ensure_nil", entry, nil, "ensure_current_task returned nil")
            new_task = build_rest_task(se_squad)
        end
        zhopa.memory.set_task_current(entry.squad_id, new_task)
        current = entry.tasks.current
        if not current then
            zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
            current = entry.tasks.current
        end
        clear_task_apply_state(current)
        bind_pending_fast_trade(current)
        local valid_or_err = true
        local ok_valid = true
        local err_or_valid = true
        if should_revalidate_target(current, true, entry) then
            ok_valid, err_or_valid = pcall(is_task_target_valid, current, community, section_name)
            if not ok_valid then
                log_task_error("target_valid", entry, current, err_or_valid)
                zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                sync_current_task_timer()
                return
            end
            valid_or_err = err_or_valid
        end
        if valid_or_err == false then
            local rebuilt = ensure_current_task(se_squad, entry)
            if rebuilt then
                zhopa.memory.set_task_current(entry.squad_id, rebuilt)
                current = entry.tasks.current
            end
            if not current then
                zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                current = entry.tasks.current
            end
            clear_task_apply_state(current)
        end
        local ok_apply, err_apply = pcall(apply_task, se_squad, current, surge_active, community, section_name)
        if not ok_apply then
            log_task_error("apply", entry, current, err_apply)
            zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
        end
        sync_current_task_timer()
        return
    end

    if current.type ~= "REST_1H" then
        local should_enforce_intent = tasks._should_enforce_online_intent and tasks._should_enforce_online_intent(current, now, entry) == true
        if should_enforce_intent then
            local ok_enf, err_enf = pcall(enforce_online_task_intent, se_squad, entry, current)
            if not ok_enf then
                log_task_error("intent_enforce", entry, current, err_enf)
            end
        end

        local stgt = nil
        local ok_stgt, res_stgt = pcall(function() return se_squad.scripted_target end)
        if ok_stgt then
            stgt = res_stgt
        end

        if current.target and type(current.target) == "string" and stgt ~= current.target then
            current.params = current.params or {}
            current.params._applied = nil
            local ok_apply, err_apply = pcall(apply_task, se_squad, current, surge_active, community, section_name)
            if not ok_apply then
                log_task_error("apply_reassert", entry, current, err_apply)
                zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                sync_current_task_timer()
                return
            end
        end

        local valid_or_err = true
        if should_revalidate_target(current, false, entry) then
            local ok_valid, err_or_valid = pcall(is_task_target_valid, current, community, section_name)
            if not ok_valid then
                log_task_error("target_valid", entry, current, err_or_valid)
                zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                sync_current_task_timer()
                return
            end
            valid_or_err = err_or_valid
        end

        if valid_or_err == false then
            local rebuilt = ensure_current_task(se_squad, entry)
            if rebuilt then
                zhopa.memory.set_task_current(entry.squad_id, rebuilt)
                if not entry.tasks.current then
                    zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                end
                clear_task_apply_state(entry.tasks.current)
                local ok_apply, err_apply = pcall(apply_task, se_squad, entry.tasks.current, surge_active, community, section_name)
                if not ok_apply then
                    log_task_error("apply_rebuild", entry, entry.tasks.current, err_apply)
                    zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                end
                sync_current_task_timer()
                return
            end
        end
    end

    local ok_done, done_or_err = pcall(is_task_completed, se_squad, entry, current)
    if not ok_done then
        log_task_error("completed", entry, current, done_or_err)
        zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
        sync_current_task_timer()
        return
    end

    if done_or_err == true then
        if current and current.type == "TRADE" and zhopa.fast_trading and zhopa.fast_trading.on_trade_completed then
            local trade_result = current.params and current.params.trade_done_state or "DONE"
            local ok_fast, err_fast = pcall(zhopa.fast_trading.on_trade_completed, entry.squad_id, trade_result)
            if not ok_fast then
                log_task_error("fast_trade_complete", entry, current, err_fast)
            end
        end

        if current and current.type == "REST_1H" then
            zhopa.memory.set_task_current(entry.squad_id, nil)
        else
            local ok_rot, err_rot = pcall(rotate_task_on_complete, se_squad, entry, surge_active)
            if not ok_rot then
                log_task_error("rotate", entry, current, err_rot)
                zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
            end
        end
        if not (entry.tasks and entry.tasks.current) then
            sync_current_task_timer(nil)
            return
        end
        clear_task_apply_state(entry.tasks and entry.tasks.current or nil)
        local ok_apply, err_apply = pcall(apply_task, se_squad, entry.tasks.current, surge_active, community, section_name)
        if not ok_apply then
            log_task_error("apply_next", entry, entry.tasks.current, err_apply)
            zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
        end
        sync_current_task_timer()
        return
    end

    if current.type ~= "REST_1H" then
        local ok_apply, err_apply = pcall(apply_task, se_squad, current, surge_active, community, section_name)
        if not ok_apply then
            log_task_error("apply", entry, current, err_apply)
            zhopa.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
        end
    end
    sync_current_task_timer()
end

function tasks.on_first_update()
    tasks._reset_build_prep_runtime()
    RUNTIME.task_warn_once = {}
    if zhopa.timers and zhopa.timers.clear then
        zhopa.timers.clear(TASK_STATE_TIMER_NS)
    end
end

function tasks.on_option_change()
    tasks._reset_build_prep_runtime()
    if zhopa.timers and zhopa.timers.clear then
        zhopa.timers.clear(TASK_STATE_TIMER_NS)
    end
end

function tasks.force_rest_after_external_reclaim(se_squad, source)
    if not se_squad then
        return false
    end
    local sid = tonumber(se_squad.id) or nil
    if not sid then
        return false
    end
    local src = tostring(source or "external_reclaim")
    if zhopa.memory and zhopa.memory.upsert_snapshot then
        pcall(zhopa.memory.upsert_snapshot, se_squad, "tasks.force_rest_after_external_reclaim:" .. src)
    end
    if not (zhopa.memory and zhopa.memory.set_task_current) then
        return false
    end
    local rest = build_rest_task(se_squad)
    rest.params = type(rest.params) == "table" and rest.params or {}
    rest.params.external_reclaim_source = src
    clear_task_apply_state(rest)
    zhopa.memory.set_task_current(sid, rest)
    return true
end

-- Public gate for external modules (e.g. base_filler) to reuse task safety policy.
-- Returns: allowed:boolean, reason:string
function tasks.is_smart_spawn_allowed(smart_name, community, level_name, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false, "invalid_smart"
    end

    local board = get_board()
    local sm = board and board.smarts_by_names and board.smarts_by_names[smart_name] or nil
    local lvl = level_name
    if (type(lvl) ~= "string" or lvl == "") and sm and sm.m_game_vertex_id then
        lvl = now_level_name_by_gvid(sm.m_game_vertex_id)
    end

    if sm then
        if smart_is_blacklisted_by_obj(sm, smart_name, community, section_name) then
            return false, "blacklist"
        end
    elseif smart_is_blacklisted_for_level(lvl, smart_name, community, section_name) then
        return false, "blacklist"
    end

    if type(community) == "string" and community ~= "" then
        local ok_enemy, hostile = pcall(has_enemy_stalker_near_smart, smart_name, community, 50, lvl)
        if ok_enemy and hostile == true then
            return false, "enemy"
        end
        if smart_is_safe_for_faction(smart_name, community, lvl) ~= true then
            return false, "unsafe"
        end
    end

    return true, "ok"
end

function tasks.on_load_state()
    tasks._reset_build_prep_runtime()
    if zhopa.timers and zhopa.timers.clear then
        zhopa.timers.clear(TASK_STATE_TIMER_NS)
    end
    RUNTIME.task_warn_once = {}
end

function tasks.on_task_current_changed(payload)
    local sid = tonumber(type(payload) == "table" and payload.squad_id or nil) or nil
    if not sid then
        RUNTIME.task_index_dirty = true
        return
    end
    if RUNTIME.task_index_dirty == true then
        tasks._rebuild_task_index_from_memory()
    end
    RUNTIME.task_index_by_sid = type(RUNTIME.task_index_by_sid) == "table" and RUNTIME.task_index_by_sid or {}
    local entry = zhopa.memory and zhopa.memory.get_squad_entry and zhopa.memory.get_squad_entry(sid) or nil
    local current = type(payload) == "table" and payload.current_task or nil
    if type(current) ~= "table" and type(entry) == "table" then
        current = entry.tasks and entry.tasks.current or nil
    end
    if type(current) == "table" and type(entry) == "table" then
        RUNTIME.task_index_by_sid[sid] = entry
    else
        RUNTIME.task_index_by_sid[sid] = nil
    end
    RUNTIME.task_index_dirty = false
    local bp = tasks._ensure_build_prep(tg())
    bp.logic_index_cache = nil
    if type(entry) == "table" then
        tasks._invalidate_build_context(entry, "task_current_changed")
    end
end

function tasks.on_server_entity_unregister(se_obj, type_name)
    if type(type_name) == "string" and type_name == "sim_squad_scripted" and se_obj and se_obj.id then
        local sid = tonumber(se_obj.id) or nil
        if sid and type(RUNTIME.task_index_by_sid) == "table" then
            RUNTIME.task_index_by_sid[sid] = nil
        end
        cancel_task_state_timer(se_obj.id)
    end
end
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_tasks_registry

-- BEGIN module zhopa_mutants
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local setmetatable = _G.setmetatable
local tonumber = _G.tonumber
local tostring = _G.tostring
local pairs = _G.pairs
local next = _G.next
local time_global = _G.time_global
local alife = _G.alife
local game_graph = _G.game_graph
local game = _G.game
local level = _G.level
local math = _G.math
local string = _G.string

local math_floor = math.floor
local math_random = math.random
local math_max = math.max
local string_gsub = string.gsub
local string_lower = string.lower
local string_find = string.find

local LOGIC_MAX_AGE_MS = 90000
local NIGHT_START_HOUR = 22
local NIGHT_END_HOUR = 6
local HUNT_NEAR_RADIUS_M = 50
local HUNT_NEAR_RADIUS_SQR = HUNT_NEAR_RADIUS_M * HUNT_NEAR_RADIUS_M
local HUNT_R5_SQR = 5 * 5
local HUNT_R10_SQR = 10 * 10
local HUNT_R30_SQR = 30 * 30
local FILTERED_SMARTS_CACHE_TTL_MS = 3000
local FILTERED_SMARTS_CACHE_MAX = 256
local HUNT_BUCKET_IN_SMART = "in_smart"
local HUNT_BUCKET_R5 = "r5"
local HUNT_BUCKET_R10 = "r10"
local HUNT_BUCKET_R30 = "r30"
local HUNT_BUCKET_R50 = "r50"
local HUNT_BUCKET_CHAIN = {
    HUNT_BUCKET_IN_SMART,
    HUNT_BUCKET_R5,
    HUNT_BUCKET_R10,
    HUNT_BUCKET_R30,
    HUNT_BUCKET_R50,
}
local HUNT_BUCKET_PRIORITY = {
    [HUNT_BUCKET_IN_SMART] = 1,
    [HUNT_BUCKET_R5] = 2,
    [HUNT_BUCKET_R10] = 3,
    [HUNT_BUCKET_R30] = 4,
    [HUNT_BUCKET_R50] = 5,
}
local MUTANT_TARGET_SYNC_INTERVAL_MS = 5000
local MUTANT_LOG_THROTTLE_MS = 5000
local PREDATOR_PHASE_DAY = "day"
local PREDATOR_PHASE_NIGHT = "night"
local PREDATOR_PHASE_PROBE_INTERVAL_MS = 10000
local PREDATOR_PHASE_ACTIVE_PROBE_INTERVAL_MS = 1000
local PREDATOR_PHASE_ALIASES = {
    ["day"] = PREDATOR_PHASE_DAY,
    ["night"] = PREDATOR_PHASE_NIGHT,
    ["predator_day"] = PREDATOR_PHASE_DAY,
    ["day_predator"] = PREDATOR_PHASE_DAY,
    ["predator_night"] = PREDATOR_PHASE_NIGHT,
    ["night_predator"] = PREDATOR_PHASE_NIGHT,
    ["predatory_day"] = PREDATOR_PHASE_DAY,
    ["day_predatory"] = PREDATOR_PHASE_DAY,
    ["predatory_night"] = PREDATOR_PHASE_NIGHT,
    ["night_predatory"] = PREDATOR_PHASE_NIGHT,
    ["monster_predatory_day"] = PREDATOR_PHASE_DAY,
    ["monster_predatory_night"] = PREDATOR_PHASE_NIGHT,
    ["zombied_day"] = PREDATOR_PHASE_DAY,
    ["day_zombied"] = PREDATOR_PHASE_DAY,
    ["zombied_night"] = PREDATOR_PHASE_NIGHT,
    ["night_zombied"] = PREDATOR_PHASE_NIGHT,
    ["zombie_day"] = PREDATOR_PHASE_DAY,
    ["day_zombie"] = PREDATOR_PHASE_DAY,
    ["zombie_night"] = PREDATOR_PHASE_NIGHT,
    ["night_zombie"] = PREDATOR_PHASE_NIGHT,
    ["monster_zombied_day"] = PREDATOR_PHASE_DAY,
    ["monster_zombied_night"] = PREDATOR_PHASE_NIGHT,
}

local function is_valid_server_id(id)
    id = tonumber(id) or nil
    return id ~= nil and id > 0 and id ~= 65535
end


local Mutants = zhopa.class("Mutants")
Mutants.__index = Mutants

local function tg()
    return (time_global and time_global()) or 0
end

local function cfg_bool(key, default)
    if zhopa.runtime_cfg and zhopa.runtime_cfg.bool then
        return zhopa.runtime_cfg.bool(key, default)
    end
    if zhopa.config and zhopa.config.get then
        return zhopa.config.get(key, default) ~= false
    end
    return default ~= false
end

local function cfg_num(key, default, min_v)
    local value = tonumber(default) or 0
    if zhopa.runtime_cfg and zhopa.runtime_cfg.num then
        return zhopa.runtime_cfg.num(key, value, min_v)
    end
    if zhopa.config and zhopa.config.get then
        value = tonumber(zhopa.config.get(key, value)) or value
    end
    if min_v ~= nil and value < min_v then
        value = min_v
    end
    return value
end

local function has_game_time()
    return game and game.get_game_time and game.CTime
end

local function ctime_to_table(ct)
    if not (ct and ct.get) then return nil end
    local ok, Y, M, D, h, m, s, ms = pcall(function()
        return ct:get(0, 0, 0, 0, 0, 0, 0)
    end)
    if not ok then return nil end
    return { Y = Y, M = M, D = D, h = h, m = m, s = s, ms = ms }
end

local function ctime_from_table(t)
    if not (has_game_time() and type(t) == "table") then
        return nil
    end
    local ok_new, ct = pcall(function() return game.CTime() end)
    if not (ok_new and ct and ct.set) then
        return nil
    end
    local ok_set = pcall(function()
        ct:set(t.Y, t.M, t.D, t.h, t.m, t.s, t.ms)
    end)
    if not ok_set then
        return nil
    end
    return ct
end

local function game_time_now()
    if not has_game_time() then
        return nil
    end
    local ok, ct = pcall(function() return game.get_game_time() end)
    return ok and ct or nil
end

local function game_time_diff_sec(start_ct)
    local now = game_time_now()
    if not (now and now.diffSec and start_ct) then
        return nil
    end
    local ok, sec = pcall(function() return now:diffSec(start_ct) end)
    return ok and tonumber(sec) or nil
end

local function is_night_now()
    local ct = game_time_now()
    if not (ct and ct.get) then
        return false
    end
    local t = ctime_to_table(ct)
    local h = t and tonumber(t.h) or nil
    if h == nil then
        return false
    end
    return h >= NIGHT_START_HOUR or h < NIGHT_END_HOUR
end

local function read_commander_id(se_squad)
    if not se_squad then
        return nil
    end
    local ok, cid = pcall(function() return se_squad:commander_id() end)
    if not ok then
        ok, cid = pcall(function() return se_squad.commander_id end)
    end
    cid = ok and tonumber(cid) or nil
    if cid and cid > 0 and cid ~= 65535 then
        return cid
    end
    return nil
end

local function read_squad_player_id(se_squad)
    if not se_squad then
        return nil
    end
    local ok, pid = pcall(function() return se_squad.player_id end)
    if not ok or pid == nil then
        ok, pid = pcall(function() return se_squad:player_id() end)
    end
    if not ok or type(pid) ~= "string" then
        return nil
    end
    pid = string_lower(string_gsub(pid, "^%s*(.-)%s*$", "%1"))
    if pid == "" then
        return nil
    end
    return pid
end

local function normalize_predator_phase_alias_key(text)
    if type(text) ~= "string" then
        return nil
    end
    local s = string_lower(string_gsub(text, "^%s*(.-)%s*$", "%1"))
    if s == "" then
        return nil
    end
    s = string_gsub(s, "[%s%-]+", "_")
    s = string_gsub(s, "_+", "_")
    s = string_gsub(s, "^%[", "")
    s = string_gsub(s, "%]$", "")
    return s
end

local function detect_predator_phase_from_text(text)
    local s = normalize_predator_phase_alias_key(text)
    if not s then
        return nil
    end

    local alias = PREDATOR_PHASE_ALIASES[s]
    if alias == PREDATOR_PHASE_DAY or alias == PREDATOR_PHASE_NIGHT then
        return alias
    end

    if string_find(s, "predator_night", 1, true)
        or string_find(s, "night_predator", 1, true)
        or string_find(s, "predatory_night", 1, true)
        or string_find(s, "night_predatory", 1, true)
        or string_find(s, "zombied_night", 1, true)
        or string_find(s, "night_zombied", 1, true)
        or string_find(s, "zombie_night", 1, true)
        or string_find(s, "night_zombie", 1, true)
    then
        return PREDATOR_PHASE_NIGHT
    end
    if string_find(s, "predator_day", 1, true)
        or string_find(s, "day_predator", 1, true)
        or string_find(s, "predatory_day", 1, true)
        or string_find(s, "day_predatory", 1, true)
        or string_find(s, "zombied_day", 1, true)
        or string_find(s, "day_zombied", 1, true)
        or string_find(s, "zombie_day", 1, true)
        or string_find(s, "day_zombie", 1, true)
    then
        return PREDATOR_PHASE_DAY
    end

    local has_predator = string_find(s, "predator", 1, true) ~= nil or string_find(s, "predatory", 1, true) ~= nil
    local has_zombied = string_find(s, "zombied", 1, true) ~= nil or string_find(s, "zombie", 1, true) ~= nil
    if not (has_predator or has_zombied) then
        return nil
    end

    local has_night = string_find(s, "night", 1, true) ~= nil
    local has_day = string_find(s, "day", 1, true) ~= nil
    if has_night and (not has_day) then
        return PREDATOR_PHASE_NIGHT
    end
    if has_day and (not has_night) then
        return PREDATOR_PHASE_DAY
    end
    return nil
end

local function is_predator_phase_inactive(predator_phase, night_now)
    if predator_phase == PREDATOR_PHASE_DAY then
        return night_now == true
    end
    if predator_phase == PREDATOR_PHASE_NIGHT then
        return night_now ~= true
    end
    return false
end

local function is_hunt_enabled()
    if zhopa.runtime_cfg and zhopa.runtime_cfg.get then
        return zhopa.runtime_cfg.get("mutant_hunt_enabled", true) ~= false
    end
    if zhopa.config and zhopa.config.get then
        return zhopa.config.get("mutant_hunt_enabled", true) ~= false
    end
    return true
end

local MUTANT_GVID_LEVEL_CACHE_MS = 1000
local mutant_gvid_level_cache = {}

local function now_level_name_by_gvid(gvid)
    gvid = tonumber(gvid) or nil
    if not (gvid and alife and game_graph) then
        return nil
    end
    local now = tg()
    local cached = mutant_gvid_level_cache[gvid]
    if type(cached) == "table" and now <= (tonumber(cached.tg) or 0) + MUTANT_GVID_LEVEL_CACHE_MS then
        return cached.value
    end
    local ok, res = pcall(function()
        local gv = game_graph():vertex(gvid)
        if not gv then return nil end
        return alife():level_name(gv:level_id())
    end)
    if ok and type(res) == "string" and res ~= "" then
        mutant_gvid_level_cache[gvid] = { value = res, tg = now }
        return res
    end
    mutant_gvid_level_cache[gvid] = { value = nil, tg = now }
    return nil
end

local function get_board()
    if SIMBOARD then return SIMBOARD end
    if sim_board and sim_board.get_sim_board then
        local ok, board = pcall(function() return sim_board.get_sim_board() end)
        if ok then return board end
    end
    return nil
end

local function is_surge_active()
    if surge_manager and surge_manager.get_surge_manager then
        local ok_mgr, mgr = pcall(function() return surge_manager.get_surge_manager() end)
        if ok_mgr and mgr and mgr.is_started then
            local ok_state, state = pcall(function() return mgr:is_started() end)
            if ok_state then
                return state == true
            end
        end
    end
    return false
end

local function resolve_entry_level(entry, se_squad)
    if se_squad then
        local gvid = tonumber(se_squad.m_game_vertex_id)
        if gvid then
            local lvl = now_level_name_by_gvid(gvid)
            if lvl then
                if entry then
                    entry.level = lvl
                    entry.level_gvid = gvid
                end
                return lvl
            end
        end
    end
    if entry and type(entry.level) == "string" and entry.level ~= "" then
        return entry.level
    end
    if level and level.name then
        local ok_lvl, lvl = pcall(function() return level.name() end)
        if ok_lvl and lvl then
            return lvl
        end
    end
    return nil
end

local function normalize_community_key(name)
    if type(name) ~= "string" then return nil end
    local key = string_lower(string_gsub(name, "^%s*(.-)%s*$", "%1"))
    if key == "" then return nil end
    if key == "mutant" or key == "mutants" or key == "monsters" then
        key = "monster"
    end
    local cfg = zhopa.config
    if cfg and cfg.get_faction_alias then
        local alias = cfg.get_faction_alias(key)
        if type(alias) == "string" and alias ~= "" then
            alias = string_lower(string_gsub(alias, "^%s*(.-)%s*$", "%1"))
            if alias ~= "" then
                key = alias
            end
        end
    end
    if key == "mutant" or key == "mutants" or key == "monsters" then
        key = "monster"
    end
    return key
end

local function normalize_section_key(name)
    if type(name) ~= "string" then return nil end
    local key = string_lower(string_gsub(name, "^%s*(.-)%s*$", "%1"))
    if key == "" then return nil end
    return key
end

local function smart_blacklists_global_set()
    local cfg = zhopa.config
    if cfg and cfg.get_smart_blacklists_global_set then
        local res = cfg.get_smart_blacklists_global_set()
        if type(res) == "table" then
            return res
        end
    end
    return nil
end

local function smart_blacklists_rule(level_name)
    local cfg = zhopa.config
    if cfg and cfg.get_smart_blacklists_rule then
        local res = cfg.get_smart_blacklists_rule(level_name)
        if type(res) == "table" then
            return res
        end
    end
    return nil
end

local function faction_level_blacklists_rule(community)
    local cfg = zhopa.config
    if not (cfg and cfg.get_faction_level_blacklist_rule) then
        return nil
    end
    local key = normalize_community_key(community)
    if not key then return nil end
    local res = cfg.get_faction_level_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function is_level_globally_blacklisted(level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    local cfg = zhopa.config
    if cfg and cfg.is_level_globally_blacklisted then
        return cfg.is_level_globally_blacklisted(level_name) == true
    end
    return false
end

local function faction_smart_blacklists_rule(community)
    local cfg = zhopa.config
    if not (cfg and cfg.get_faction_smart_blacklist_rule) then
        return nil
    end
    local key = normalize_community_key(community)
    if not key then return nil end
    local res = cfg.get_faction_smart_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function section_level_blacklists_rule(section_name)
    local cfg = zhopa.config
    if not (cfg and cfg.get_section_level_blacklist_rule) then
        return nil
    end
    local key = normalize_section_key(section_name)
    if not key then return nil end
    local res = cfg.get_section_level_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function section_smart_blacklists_rule(section_name)
    local cfg = zhopa.config
    if not (cfg and cfg.get_section_smart_blacklist_rule) then
        return nil
    end
    local key = normalize_section_key(section_name)
    if not key then return nil end
    local res = cfg.get_section_smart_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function is_level_blacklisted_for_faction(level_name, community, section_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    if is_level_globally_blacklisted(level_name) then
        return true
    end
    local rule = faction_level_blacklists_rule(community)
    if rule and rule.all == true then
        return true
    end
    local set = rule and rule.set or nil
    if set and set[level_name] == true then
        return true
    end

    local s_rule = section_level_blacklists_rule(section_name)
    if s_rule and s_rule.all == true then
        return true
    end
    local s_set = s_rule and s_rule.set or nil
    return s_set and s_set[level_name] == true or false
end

local function is_smart_blacklisted_for_faction(smart_name, community, level_name, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    if is_level_blacklisted_for_faction(level_name, community, section_name) then
        return true
    end
    local rule = faction_smart_blacklists_rule(community)
    if rule and rule.all == true then
        return true
    end
    local set = rule and rule.set or nil
    if set and set[smart_name] == true then
        return true
    end

    local s_rule = section_smart_blacklists_rule(section_name)
    if s_rule and s_rule.all == true then
        return true
    end
    local s_set = s_rule and s_rule.set or nil
    return s_set and s_set[smart_name] == true or false
end

local function smart_is_blacklisted_for_level(level_name, smart_name, community, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end

    local gset = smart_blacklists_global_set()
    if gset and gset[smart_name] then
        return true
    end

    local rule = level_name and smart_blacklists_rule(level_name) or nil
    if rule and rule.all == true then
        return true
    end
    local set = rule and rule.set or nil
    if set and set[smart_name] then
        return true
    end

    if is_smart_blacklisted_for_faction(smart_name, community, level_name, section_name) then
        return true
    end
    return false
end

local function shuffle_in_place(arr)
    if type(arr) ~= "table" then return end
    for i = #arr, 2, -1 do
        local j = math_random(i)
        arr[i], arr[j] = arr[j], arr[i]
    end
end

local function pick_random(arr)
    if type(arr) ~= "table" then return nil end
    local n = #arr
    if n <= 0 then return nil end
    return arr[math_random(n)]
end

local function pick_weighted(arr)
    if type(arr) ~= "table" then return nil end
    local n = #arr
    if n <= 0 then return nil end

    local total = 0
    for i = 1, n do
        local w = tonumber(arr[i] and arr[i].weight) or 0
        if w < 1 then w = 1 end
        w = math_floor(w)
        if w < 1 then w = 1 end
        total = total + w
    end
    if total <= 0 then
        return arr[math_random(n)]
    end

    local roll = math_random(total)
    local acc = 0
    for i = 1, n do
        local item = arr[i]
        local w = tonumber(item and item.weight) or 0
        if w < 1 then w = 1 end
        w = math_floor(w)
        if w < 1 then w = 1 end
        acc = acc + w
        if roll <= acc then
            return item
        end
    end
    return arr[n]
end

local function hunt_range_bucket_by_d2(d2)
    d2 = tonumber(d2)
    if not d2 then return nil end
    if d2 <= HUNT_R5_SQR then return HUNT_BUCKET_R5 end
    if d2 <= HUNT_R10_SQR then return HUNT_BUCKET_R10 end
    if d2 <= HUNT_R30_SQR then return HUNT_BUCKET_R30 end
    if d2 <= HUNT_NEAR_RADIUS_SQR then return HUNT_BUCKET_R50 end
    return nil
end

local function get_neighbors(level_name, community, section_name)
    if type(level_name) ~= "string" or level_name == "" then
        return {}
    end
    if zhopa.board_index and zhopa.board_index.get_level_neighbors then
        local res = zhopa.board_index.get_level_neighbors(level_name, {
            community = community,
            section_name = section_name,
        })
        if type(res) == "table" then
            return res
        end
    end
    return {}
end

local function resolve_smart_level_by_name(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil
    end
    local board = get_board()
    local sm = board and board.smarts_by_names and board.smarts_by_names[smart_name] or nil
    local gvid = sm and tonumber(sm.m_game_vertex_id) or nil
    if not gvid then
        return nil
    end
    return now_level_name_by_gvid(gvid)
end

local function resolve_smart_level_from_obj(smart)
    local gvid = tonumber(smart and smart.m_game_vertex_id) or nil
    if not gvid then
        return nil
    end
    return now_level_name_by_gvid(gvid)
end

local function get_smart_obj_by_name(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil
    end
    local board = get_board()
    return board and board.smarts_by_names and board.smarts_by_names[smart_name] or nil
end

local function smart_exists(smart_name)
    return get_smart_obj_by_name(smart_name) ~= nil
end

local function resolve_target_smart_id(smart_name)
    local sm = get_smart_obj_by_name(smart_name)
    local sid = sm and tonumber(sm.id) or nil
    return sid, sm
end

local function set_scripted_target(se_squad, smart_name)
    if not se_squad then return false end
    se_squad.scripted_target = smart_name
    if se_squad.task_target_id ~= nil then
        se_squad.task_target_id = nil
    end

    if type(smart_name) ~= "string" or smart_name == "" then
        se_squad.current_action = 0
        se_squad.current_target_id = nil
        se_squad.assigned_target_id = nil
        se_squad.stay_time = nil
        se_squad.arrive_time = nil
        return true
    end

    local sid = resolve_target_smart_id(smart_name)
    if not sid then
        return false
    end

    se_squad.current_action = 0
    se_squad.current_target_id = nil
    se_squad.assigned_target_id = sid
    se_squad.stay_time = nil
    se_squad.arrive_time = nil
    return true
end

local function is_online_squad(se_squad)
    if not se_squad then return false end
    local ok, online = pcall(function() return se_squad.online end)
    return ok and online == true or false
end

local function clear_always_arrived(se_squad)
    if not se_squad then return end
    local ok_cur, current = pcall(function() return se_squad.always_arrived end)
    if not (ok_cur and current == true) then
        return
    end
    pcall(function()
        se_squad.always_arrived = false
    end)
end

local function is_squad_arrived_to_smart(se_squad, smart_name)
    if not se_squad then return false end
    local sid, sm = resolve_target_smart_id(smart_name)
    if not (sid and sm) then return false end

    local ca = tonumber(se_squad.current_action) or nil
    local ct = tonumber(se_squad.current_target_id) or nil
    local ss = tonumber(se_squad.smart_id) or nil
    if ca == 1 and (ct == sid or ss == sid) then
        return true
    end

    if sm.am_i_reached then
        local ok, reached = pcall(function() return sm:am_i_reached(se_squad) end)
        if ok and reached then
            return true
        end
    end

    local sgvid = tonumber(se_squad.m_game_vertex_id) or nil
    local tgvid = tonumber(sm.m_game_vertex_id) or nil
    if sgvid and tgvid and sgvid == tgvid then
        return true
    end

    local pos_s = zhopa.safe and zhopa.safe.safe_position and zhopa.safe.safe_position(se_squad) or nil
    local pos_t = sm.position
    if not (pos_s and pos_t and pos_s.distance_to_sqr) then
        return false
    end

    local arrive_dist = tonumber(sm.arrive_dist) or 5
    if arrive_dist > 5 then arrive_dist = 5 end
    if arrive_dist < 1 then arrive_dist = 1 end
    local ok_d2, d2 = pcall(function() return pos_s:distance_to_sqr(pos_t) end)
    return ok_d2 and tonumber(d2) and d2 <= (arrive_dist * arrive_dist) or false
end

local function make_task(task_type, target, params, priority)
    local now = tg()
    local token = math_random(1000, 999999)
    return {
        id = string.format("mutant_%s_%d_%d", tostring(task_type), now, token),
        type = task_type,
        target = target,
        params = params or {},
        priority = tonumber(priority) or 0,
        created_at = now,
    }
end

local function build_rest_task()
    local rest_hours = cfg_num("mutant_rest_duration_game_hours", cfg_num("rest_duration_game_hours", 1, nil), nil)
    if rest_hours <= 0 then rest_hours = 1 end

    local duration_game_sec = math_floor(rest_hours * 3600)
    if duration_game_sec < 1 then duration_game_sec = 1 end

    local started_gt = nil
    local now_gt = game_time_now()
    if now_gt then
        started_gt = ctime_to_table(now_gt)
    end

    local tf = (level and level.get_time_factor and level.get_time_factor()) or 10
    if tf <= 0 then tf = 10 end
    local duration_ms = math_floor((duration_game_sec * 1000) / tf)
    if duration_ms < 1000 then duration_ms = 1000 end

    return make_task("REST_1H", nil, {
        started_at_gt = started_gt,
        duration_game_sec = duration_game_sec,
        started_at_tg = tg(),
        duration_ms = duration_ms,
    }, 0)
end

local function is_rest_done(task)
    local p = task.params or {}
    local started_gt = ctime_from_table(p.started_at_gt)
    local dur_gs = tonumber(p.duration_game_sec)
    if started_gt and dur_gs and dur_gs > 0 then
        local elapsed = game_time_diff_sec(started_gt) or 0
        return elapsed >= dur_gs
    end

    local started = tonumber(p.started_at_tg) or 0
    local dur = tonumber(p.duration_ms) or 0
    if dur <= 0 then return true end
    return tg() >= (started + dur)
end

local function pick_next_patrol_target(task, avoid_smart_name)
    local p = task.params or {}
    local order = type(p.order) == "table" and p.order or nil
    if not order or #order <= 0 then
        return nil
    end
    local idx = tonumber(p.idx) or 1
    if idx < 1 then idx = 1 end
    if idx > #order then idx = 1 end
    for _ = 1, #order do
        local target = order[idx]
        idx = idx + 1
        if idx > #order then idx = 1 end
        if type(target) == "string" and target ~= "" and target ~= avoid_smart_name then
            p.idx = idx
            task.params = p
            return target
        end
    end

    p.idx = idx
    task.params = p
    return nil
end

function Mutants:__init()
    self.RUNTIME = {
        updates = 0,
        completions = 0,
        last_update_tg = 0,
        hunt_presence_by_level = {},
        hunt_presence_by_sid = {},
        presence_signature_by_sid = {},
        hunt_cache_tg = 0,
        hunt_level_smarts_cache = {},
        hunt_level_smarts_rev = {},
        hunt_smart_id_to_name = {},
        hunt_pass_obj_cache = {},
        hunt_pass_level_cache = {},
        hunt_pass_smart_cache = {},
        hunt_pass_exists_cache = {},
        hunt_cache_hits = 0,
        hunt_cache_miss = 0,
        hunt_targets_picked = 0,
        hunt_pick_same_level = 0,
        hunt_pick_neighbor_level = 0,
        hunt_pick_bucket_in_smart = 0,
        hunt_pick_bucket_r5 = 0,
        hunt_pick_bucket_r10 = 0,
        hunt_pick_bucket_r30 = 0,
        hunt_pick_bucket_r50 = 0,
        predator_phase_resolved_count = 0,
        predator_phase_day_count = 0,
        predator_phase_night_count = 0,
        phase_rest_forced_count = 0,
        phase_rest_forced_day_count = 0,
        phase_rest_forced_night_count = 0,
        night_forced_count = 0,
        night_fallback_rest_count = 0,
        day_hunt_released_count = 0,
        target_resync_count = 0,
        filtered_smarts_cache = {},
        log_throttle_next_tg = {},
    }
end

function Mutants:_log_throttled(key, interval_ms, level_name, fmt, ...)
    if type(key) ~= "string" or key == "" then return end
    if type(fmt) ~= "string" or fmt == "" then return end
    local log = zhopa.log
    if type(log) ~= "table" then return end
    local fn = log[level_name or "debug"]
    if type(fn) ~= "function" then return end

    local now = tg()
    local map = self.RUNTIME.log_throttle_next_tg
    if type(map) ~= "table" then
        map = {}
        self.RUNTIME.log_throttle_next_tg = map
    end
    local next_tg = tonumber(map[key]) or 0
    if now < next_tg then
        return
    end
    map[key] = now + (tonumber(interval_ms) or MUTANT_LOG_THROTTLE_MS)
    fn("MUTANTS", fmt, ...)
end

function Mutants:_sync_task_target(se_squad, task, reason)
    if not (se_squad and task and type(task.target) == "string" and task.target ~= "") then
        return false
    end
    local p = type(task.params) == "table" and task.params or {}
    task.params = p

    local now = tg()
    local sid = resolve_target_smart_id(task.target)
    if not set_scripted_target(se_squad, task.target) then
        p.target_sync_next_tg = now + 1000
        return false
    end

    p.target_sync_name = task.target
    p.target_sync_smart_id = sid
    p.target_sync_started_tg = tonumber(p.target_sync_started_tg) or now
    p.target_sync_next_tg = now + MUTANT_TARGET_SYNC_INTERVAL_MS
    p.online_last_progress_tg = now
    p.online_last_gvid = tonumber(se_squad.m_game_vertex_id) or nil
    p.online_nudge_stage = 0
    p.online_nudge_next_tg = nil

    self.RUNTIME.target_resync_count = (tonumber(self.RUNTIME.target_resync_count) or 0) + 1
    self:_log_throttled(
        "target_resync:" .. tostring(tonumber(se_squad.id) or 0),
        MUTANT_LOG_THROTTLE_MS,
        "info",
        "MUTANT_TARGET_RESYNC sid=%s task=%s target=%s reason=%s",
        tostring(se_squad.id or "-"),
        tostring(task.type or "-"),
        tostring(task.target or "-"),
        tostring(reason or "sync")
    )
    return true
end

function Mutants:_resolve_predator_phase(se_squad, entry, force_probe)
    if type(entry) ~= "table" then
        return nil
    end

    local cached = entry.predator_phase
    if cached == PREDATOR_PHASE_DAY or cached == PREDATOR_PHASE_NIGHT then
        return cached
    end

    local now = tg()
    local next_probe = nil
    if force_probe == true then
        next_probe = tonumber(entry.predator_phase_active_probe_next_tg) or 0
    else
        next_probe = tonumber(entry.predator_phase_probe_next_tg) or 0
    end
    if now < next_probe then
        return nil
    end
    if force_probe == true then
        entry.predator_phase_active_probe_next_tg = now + PREDATOR_PHASE_ACTIVE_PROBE_INTERVAL_MS
    else
        entry.predator_phase_probe_next_tg = now + PREDATOR_PHASE_PROBE_INTERVAL_MS
    end

    local function resolve_from(raw, source)
        local phase = detect_predator_phase_from_text(raw)
        if not phase then
            return nil
        end
        entry.predator_phase = phase
        entry.predator_phase_source = source
        entry.predator_phase_resolved_tg = now
        entry.predator_phase_probe_next_tg = nil
        entry.predator_phase_active_probe_next_tg = nil

        self.RUNTIME.predator_phase_resolved_count = (tonumber(self.RUNTIME.predator_phase_resolved_count) or 0) + 1
        if phase == PREDATOR_PHASE_DAY then
            self.RUNTIME.predator_phase_day_count = (tonumber(self.RUNTIME.predator_phase_day_count) or 0) + 1
        elseif phase == PREDATOR_PHASE_NIGHT then
            self.RUNTIME.predator_phase_night_count = (tonumber(self.RUNTIME.predator_phase_night_count) or 0) + 1
        end

        self:_log_throttled(
            "predator_phase:" .. tostring(tonumber(entry.squad_id) or 0),
            15000,
            "info",
            "MUTANT_PREDATOR_PHASE sid=%s phase=%s source=%s raw=%s",
            tostring(entry.squad_id or "-"),
            tostring(phase),
            tostring(source or "-"),
            tostring(raw or "-")
        )
        return phase
    end

    local safe_mod = zhopa.safe
    if resolve_from(read_squad_player_id(se_squad), "squad.player_id") then
        return entry.predator_phase
    end
    if resolve_from(entry.player_id, "entry.player_id") then
        return entry.predator_phase
    end
    if resolve_from(entry.section, "entry.section") then
        return entry.predator_phase
    end

    if safe_mod and safe_mod.safe_section and resolve_from(safe_mod.safe_section(se_squad), "squad.section") then
        return entry.predator_phase
    end
    if safe_mod and safe_mod.safe_name and resolve_from(safe_mod.safe_name(se_squad), "squad.name") then
        return entry.predator_phase
    end

    local commander_id = read_commander_id(se_squad) or tonumber(entry.commander_id) or nil
    if is_valid_server_id(commander_id) and alife then
        local sim = alife()
        if sim then
            local ok_obj, commander = pcall(function() return sim:object(commander_id) end)
            if ok_obj and commander then
                if safe_mod and safe_mod.safe_section and resolve_from(safe_mod.safe_section(commander), "commander.section") then
                    return entry.predator_phase
                end
                if safe_mod and safe_mod.safe_name and resolve_from(safe_mod.safe_name(commander), "commander.name") then
                    return entry.predator_phase
                end
            end
        end
    end

    return nil
end

function Mutants:_get_entry_community(entry)
    if type(entry) ~= "table" then return "monster" end
    local key = normalize_community_key(entry.community)
    if type(key) == "string" and key ~= "" then
        return key
    end
    return "monster"
end

function Mutants:_get_entry_section(entry, se_squad)
    if type(entry) == "table" then
        local key = normalize_section_key(entry.section)
        if key then
            entry.section = key
            return key
        end
    end
    if zhopa.safe and zhopa.safe.safe_section and se_squad then
        local live = normalize_section_key(zhopa.safe.safe_section(se_squad))
        if live and type(entry) == "table" then
            entry.section = live
        end
        return live
    end
    return nil
end

function Mutants:_filtered_smarts_cache_key(level_name, community, section_name)
    if type(level_name) ~= "string" or level_name == "" then
        return nil
    end
    local ckey = normalize_community_key(community) or "-"
    local skey = normalize_section_key(section_name) or "-"
    return tostring(level_name) .. "|" .. tostring(ckey) .. "|" .. tostring(skey)
end

function Mutants:_trim_filtered_smarts_cache()
    local cache = self.RUNTIME.filtered_smarts_cache or {}
    local size = 0
    local oldest_key = nil
    local oldest_tg = nil
    for key, rec in pairs(cache) do
        size = size + 1
        local ts = type(rec) == "table" and tonumber(rec.tg) or 0
        if oldest_tg == nil or ts < oldest_tg then
            oldest_tg = ts
            oldest_key = key
        end
    end
    if size > FILTERED_SMARTS_CACHE_MAX and oldest_key ~= nil then
        cache[oldest_key] = nil
    end
    self.RUNTIME.filtered_smarts_cache = cache
end

function Mutants:_get_filtered_smarts_for_level(level_name, community, section_name)
    if type(level_name) ~= "string" or level_name == "" then
        return {}
    end

    local cache_key = self:_filtered_smarts_cache_key(level_name, community, section_name)
    local now = tg()
    local cache = self.RUNTIME.filtered_smarts_cache or {}
    if cache_key then
        local cached = cache[cache_key]
        if type(cached) == "table" and now < ((tonumber(cached.tg) or 0) + FILTERED_SMARTS_CACHE_TTL_MS) and type(cached.list) == "table" then
            return cached.list
        end
    end

    local out = {}
    if zhopa.board_index and zhopa.board_index.get_level_smarts then
        local list = zhopa.board_index.get_level_smarts(level_name, {
            community = community,
            section_name = section_name,
            filter_fn = function(name)
                return smart_exists(name)
            end,
        })
        if type(list) == "table" then
            out = list
        end
    end

    if cache_key then
        cache[cache_key] = { tg = now, list = out }
        self.RUNTIME.filtered_smarts_cache = cache
        self:_trim_filtered_smarts_cache()
    end

    return out
end

function Mutants:_get_smart_name_by_id(smart_id)
    local sid = tonumber(smart_id)
    if not sid then return nil end

    local cache = self.RUNTIME.hunt_smart_id_to_name or {}
    local cached = cache[sid]
    if type(cached) == "string" and cached ~= "" then
        return cached
    end

    local board = get_board()
    local node = board and board.smarts and board.smarts[sid] or nil
    local sm = node and node.smrt or nil
    local nm = sm and sm.name or nil
    if type(nm) == "string" and nm ~= "" then
        cache[sid] = nm
        self.RUNTIME.hunt_smart_id_to_name = cache
        return nm
    end
    return nil
end

function Mutants:_get_current_smart_name(entry, se_squad)
    local smart_id = tonumber(se_squad and se_squad.smart_id) or tonumber(entry and entry.smart_id) or nil
    if smart_id then
        local smart_name = self:_get_smart_name_by_id(smart_id)
        if type(smart_name) == "string" and smart_name ~= "" then
            return smart_name
        end
    end
    return nil
end

function Mutants:_get_level_smart_positions(level_name)
    local cache = self.RUNTIME.hunt_level_smarts_cache or {}
    local rev_cache = self.RUNTIME.hunt_level_smarts_rev or {}
    local current_rev = zhopa.board_index and zhopa.board_index.get_smart_revision and zhopa.board_index.get_smart_revision(level_name) or 0
    local cached = cache[level_name]
    if type(cached) == "table" and (tonumber(rev_cache[level_name]) or 0) == (tonumber(current_rev) or 0) then
        return cached
    end

    local out = {}
    if zhopa.board_index and zhopa.board_index.get_level_smarts then
        local names = zhopa.board_index.get_level_smarts(level_name)
        local board = get_board()
        local by_name = board and board.smarts_by_names or nil
        for i = 1, (names and #names or 0) do
            local name = names[i]
            local sm = by_name and by_name[name] or nil
            if sm and sm.position then
                out[#out + 1] = { name = name, pos = sm.position }
            end
        end
    end
    cache[level_name] = out
    self.RUNTIME.hunt_level_smarts_cache = cache
    rev_cache[level_name] = tonumber(current_rev) or 0
    self.RUNTIME.hunt_level_smarts_rev = rev_cache
    return out
end

function Mutants:_invalidate_hunt_level_smarts_cache(level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    local cache = self.RUNTIME.hunt_level_smarts_cache or {}
    local rev_cache = self.RUNTIME.hunt_level_smarts_rev or {}
    local changed = cache[level_name] ~= nil or rev_cache[level_name] ~= nil
    cache[level_name] = nil
    rev_cache[level_name] = nil
    self.RUNTIME.hunt_level_smarts_cache = cache
    self.RUNTIME.hunt_level_smarts_rev = rev_cache
    return changed
end

function Mutants:_ensure_hunt_presence_slot(level_name, smart_name)
    if type(level_name) ~= "string" or level_name == "" then return nil end
    if type(smart_name) ~= "string" or smart_name == "" then return nil end
    local by_level = self.RUNTIME.hunt_presence_by_level
    if type(by_level) ~= "table" then
        by_level = {}
        self.RUNTIME.hunt_presence_by_level = by_level
    end

    local lvl = by_level[level_name]
    if type(lvl) ~= "table" then
        lvl = {}
        by_level[level_name] = lvl
    end

    local slot = lvl[smart_name]
    if type(slot) ~= "table" then
        slot = {
            [HUNT_BUCKET_IN_SMART] = 0,
            [HUNT_BUCKET_R5] = 0,
            [HUNT_BUCKET_R10] = 0,
            [HUNT_BUCKET_R30] = 0,
            [HUNT_BUCKET_R50] = 0,
        }
        lvl[smart_name] = slot
    end
    return slot
end

function Mutants:_add_hunt_presence(level_name, smart_name, bucket, delta)
    local slot = self:_ensure_hunt_presence_slot(level_name, smart_name)
    if type(slot) ~= "table" then return end
    if HUNT_BUCKET_PRIORITY[bucket] == nil then return end

    local inc = tonumber(delta) or 1
    inc = math_floor(inc)
    if inc == 0 then return end
    local next_count = (tonumber(slot[bucket]) or 0) + inc
    if next_count < 0 then next_count = 0 end
    slot[bucket] = next_count
end

function Mutants:_apply_hunt_presence_marks(sid, marks)
    sid = tonumber(sid) or nil
    if not sid then return end

    local by_sid = self.RUNTIME.hunt_presence_by_sid
    if type(by_sid) ~= "table" then
        by_sid = {}
        self.RUNTIME.hunt_presence_by_sid = by_sid
    end

    local old = by_sid[sid]
    local function apply(snapshot, delta)
        if type(snapshot) ~= "table" then return end
        for smart_name, rec in pairs(snapshot) do
            if type(rec) == "table" and type(smart_name) == "string" and smart_name ~= "" then
                local bucket = rec.bucket
                local level_name = rec.level
                if type(level_name) == "string" and level_name ~= "" and HUNT_BUCKET_PRIORITY[bucket] ~= nil then
                    self:_add_hunt_presence(level_name, smart_name, bucket, delta)
                end
            end
        end
    end

    if old then
        apply(old, -1)
    end
    if marks then
        apply(marks, 1)
        by_sid[sid] = marks
    else
        by_sid[sid] = nil
    end
end

function Mutants:_clear_hunt_presence_for_sid(sid)
    sid = tonumber(sid) or nil
    if sid and self.RUNTIME and self.RUNTIME.presence_signature_by_sid then
        self.RUNTIME.presence_signature_by_sid[sid] = nil
    end
    self:_apply_hunt_presence_marks(sid, nil)
end

function Mutants:_hunt_presence_signature(entry, se_squad)
    if type(entry) ~= "table" then
        return nil
    end

    local pos_sig = "-"
    local pos = zhopa.safe and zhopa.safe.safe_position and se_squad and zhopa.safe.safe_position(se_squad) or nil
    if pos then
        local x = tonumber(pos.x) or 0
        local z = tonumber(pos.z) or 0
        pos_sig = tostring(math_floor(x / 25)) .. ":" .. tostring(math_floor(z / 25))
    end

    return tostring(entry.npc_kind or "-")
        .. "|" .. tostring(entry.level or "-")
        .. "|" .. tostring(entry.level_gvid or "-")
        .. "|" .. tostring(entry.m_game_vertex_id or "-")
        .. "|" .. tostring(entry.smart_id or "-")
        .. "|" .. tostring(entry.scripted_target or "-")
        .. "|" .. tostring(entry.current_action or "-")
        .. "|" .. tostring(entry.assigned_target_id or "-")
        .. "|" .. pos_sig
end

function Mutants:_is_stalker_presence_entry(entry)
    if type(entry) ~= "table" then return false end
    if entry.npc_kind == "mutant" then return false end
    if entry.npc_kind == "stalker" then return true end
    -- If identity is temporarily degraded, treat non-mutant entries as stalker candidates.
    return true
end

function Mutants:_process_stalker_presence(sid, entry)
    if type(entry) ~= "table" then return end
    local level_name = nil
    local level_cache = self.RUNTIME.hunt_pass_level_cache or {}
    local smart_cache = self.RUNTIME.hunt_pass_smart_cache or {}
    local obj_cache = self.RUNTIME.hunt_pass_obj_cache or {}
    local exists_cache = self.RUNTIME.hunt_pass_exists_cache or {}

    local function cached_level_name(gvid)
        gvid = tonumber(gvid) or nil
        if not gvid then return nil end
        local cached = level_cache[gvid]
        if cached == nil then
            cached = now_level_name_by_gvid(gvid) or false
            level_cache[gvid] = cached
        end
        return cached ~= false and cached or nil
    end

    local se_squad = nil
    local need_live_obj = false
    level_name = type(entry.level) == "string" and entry.level or nil
    if (type(level_name) ~= "string" or level_name == "") then
        level_name = cached_level_name(entry.level_gvid) or cached_level_name(entry.m_game_vertex_id)
    end
    if type(level_name) ~= "string" or level_name == "" then
        need_live_obj = true
    end

    local smart_name = nil
    local smart_id = tonumber(entry.smart_id) or nil
    if smart_id then
        local cached = smart_cache[smart_id]
        if cached == nil then
            cached = self:_get_smart_name_by_id(smart_id) or false
            smart_cache[smart_id] = cached
        end
        smart_name = cached ~= false and cached or nil
    end
    if (not smart_name) and type(entry.scripted_target) == "string" then
        local action = tonumber(entry.current_action) or nil
        if action == 1 then
            smart_name = entry.scripted_target
        end
    end
    if not smart_name then
        need_live_obj = true
    end

    if need_live_obj then
        local sid_num = tonumber(sid) or nil
        local cached_obj = sid_num and obj_cache[sid_num] or nil
        if cached_obj == nil and is_valid_server_id(sid_num) then
            local sim = alife and alife() or nil
            if sim then
                local ok_obj, obj = pcall(function() return sim:object(sid_num) end)
                cached_obj = (ok_obj and obj) or false
            else
                cached_obj = false
            end
            obj_cache[sid_num] = cached_obj
        end
        se_squad = cached_obj ~= false and cached_obj or nil
    end

    if (type(level_name) ~= "string" or level_name == "") and se_squad then
        level_name = cached_level_name(se_squad.m_game_vertex_id)
    end
    if type(level_name) ~= "string" or level_name == "" then return end

    local marked = {}
    local function smart_exists_cached(name)
        if type(name) ~= "string" or name == "" then return false end
        local cached = exists_cache[name]
        if cached == nil then
            cached = smart_exists(name) == true
            exists_cache[name] = cached
        end
        return cached == true
    end
    local function mark_best_bucket(smart_name, bucket, mark_level)
        if type(smart_name) ~= "string" or smart_name == "" then return end
        local pr = HUNT_BUCKET_PRIORITY[bucket]
        if not pr then return end
        if not smart_exists_cached(smart_name) then return end
        if type(mark_level) ~= "string" or mark_level == "" then
            mark_level = level_name
        end
        local cur = marked[smart_name]
        if (not cur) or pr < (tonumber(cur.priority) or 999) then
            marked[smart_name] = { bucket = bucket, priority = pr, level = mark_level }
        end
    end

    if (not smart_name) and se_squad then
        smart_id = tonumber(se_squad.smart_id) or nil
        if smart_id then
            local cached = smart_cache[smart_id]
            if cached == nil then
                cached = self:_get_smart_name_by_id(smart_id) or false
                smart_cache[smart_id] = cached
            end
            smart_name = cached ~= false and cached or nil
        end
    end
    if (not smart_name) and type(entry.scripted_target) == "string" then
        -- Do not treat pure travel intent as on-smart presence.
        local action = tonumber(se_squad and se_squad.current_action) or tonumber(entry.current_action) or nil
        if action == 1 then
            smart_name = entry.scripted_target
        end
    end
    if smart_name then
        local smart_level = resolve_smart_level_by_name(smart_name) or level_name
        mark_best_bucket(smart_name, HUNT_BUCKET_IN_SMART, smart_level)
    end

    if se_squad then
        local pos = zhopa.safe and zhopa.safe.safe_position and zhopa.safe.safe_position(se_squad) or nil
        if pos and pos.distance_to_sqr then
            local candidates = self:_get_level_smart_positions(level_name)
            for i = 1, #candidates do
                local c = candidates[i]
                if c and c.pos and c.name then
                    local ok_d2, d2 = pcall(function() return pos:distance_to_sqr(c.pos) end)
                    d2 = ok_d2 and tonumber(d2) or nil
                    local bucket = hunt_range_bucket_by_d2(d2)
                    if bucket then
                        mark_best_bucket(c.name, bucket, level_name)
                    end
                end
            end
        end
    end

    for name, rec in pairs(marked) do
        if type(rec) == "table" and HUNT_BUCKET_PRIORITY[rec.bucket] ~= nil then
            local mark_level = type(rec.level) == "string" and rec.level or level_name
            rec.level = mark_level
        end
    end

    self:_apply_hunt_presence_marks(sid, marked)
end

function Mutants:_build_hunt_task(se_squad, entry, source, night_forced)
    if not is_hunt_enabled() then
        return nil
    end

    local cur_level = resolve_entry_level(entry, se_squad)
    if not cur_level then
        return nil
    end
    local community = self:_get_entry_community(entry)
    local section_name = self:_get_entry_section(entry, se_squad)
    local current_smart_name = self:_get_current_smart_name(entry, se_squad)

    local function pick_from_levels(levels)
        local buckets = {}
        for i = 1, #HUNT_BUCKET_CHAIN do
            buckets[HUNT_BUCKET_CHAIN[i]] = {}
        end

        for i = 1, #levels do
            local lvl = levels[i]
            if not is_level_blacklisted_for_faction(lvl, community, section_name) then
                local present = self.RUNTIME.hunt_presence_by_level and self.RUNTIME.hunt_presence_by_level[lvl] or nil
                if type(present) == "table" then
                    for smart_name, p_data in pairs(present) do
                        if type(smart_name) == "string"
                            and smart_name ~= ""
                            and smart_name ~= current_smart_name
                            and (not smart_is_blacklisted_for_level(lvl, smart_name, community, section_name))
                            and smart_exists(smart_name)
                        then
                            local slot = type(p_data) == "table" and p_data or nil
                            if not slot then
                                slot = {
                                    [HUNT_BUCKET_R50] = 1,
                                }
                            end
                            for j = 1, #HUNT_BUCKET_CHAIN do
                                local bucket = HUNT_BUCKET_CHAIN[j]
                                local cnt = tonumber(slot[bucket]) or 0
                                if cnt > 0 then
                                    local w = math_floor(cnt)
                                    if w < 1 then w = 1 end
                                    local list = buckets[bucket]
                                    list[#list + 1] = {
                                        level = lvl,
                                        smart = smart_name,
                                        bucket = bucket,
                                        weight = w,
                                    }
                                end
                            end
                        end
                    end
                end
            end
        end

        for i = 1, #HUNT_BUCKET_CHAIN do
            local bucket = HUNT_BUCKET_CHAIN[i]
            local chosen = pick_weighted(buckets[bucket])
            if chosen then
                return chosen
            end
        end
        return nil
    end

    local chosen = pick_from_levels({ cur_level })
    local pick_scope = "same_level"
    if not chosen then
        local neighbors = get_neighbors(cur_level, community, section_name)
        local levels = {}
        local seen = { [cur_level] = true }
        for i = 1, #neighbors do
            local lvl = neighbors[i]
            if type(lvl) == "string" and lvl ~= "" and not seen[lvl] then
                seen[lvl] = true
                levels[#levels + 1] = lvl
            end
        end
        chosen = pick_from_levels(levels)
        pick_scope = "neighbor_level"
    end

    if not chosen then
        self.RUNTIME.hunt_cache_miss = (tonumber(self.RUNTIME.hunt_cache_miss) or 0) + 1
        return nil
    end

    self.RUNTIME.hunt_cache_hits = (tonumber(self.RUNTIME.hunt_cache_hits) or 0) + 1
    if pick_scope == "same_level" then
        self.RUNTIME.hunt_pick_same_level = (tonumber(self.RUNTIME.hunt_pick_same_level) or 0) + 1
    else
        self.RUNTIME.hunt_pick_neighbor_level = (tonumber(self.RUNTIME.hunt_pick_neighbor_level) or 0) + 1
    end

    local bucket = chosen.bucket
    if bucket == HUNT_BUCKET_IN_SMART then
        self.RUNTIME.hunt_pick_bucket_in_smart = (tonumber(self.RUNTIME.hunt_pick_bucket_in_smart) or 0) + 1
    elseif bucket == HUNT_BUCKET_R5 then
        self.RUNTIME.hunt_pick_bucket_r5 = (tonumber(self.RUNTIME.hunt_pick_bucket_r5) or 0) + 1
    elseif bucket == HUNT_BUCKET_R10 then
        self.RUNTIME.hunt_pick_bucket_r10 = (tonumber(self.RUNTIME.hunt_pick_bucket_r10) or 0) + 1
    elseif bucket == HUNT_BUCKET_R30 then
        self.RUNTIME.hunt_pick_bucket_r30 = (tonumber(self.RUNTIME.hunt_pick_bucket_r30) or 0) + 1
    elseif bucket == HUNT_BUCKET_R50 then
        self.RUNTIME.hunt_pick_bucket_r50 = (tonumber(self.RUNTIME.hunt_pick_bucket_r50) or 0) + 1
    end

    self.RUNTIME.hunt_targets_picked = (tonumber(self.RUNTIME.hunt_targets_picked) or 0) + 1
    self:_log_throttled(
        "hunt_pick:" .. tostring(tonumber(se_squad and se_squad.id) or 0),
        MUTANT_LOG_THROTTLE_MS,
        "info",
        "MUTANT_HUNT_PICK sid=%s scope=%s smart=%s level=%s bucket=%s weight=%s",
        tostring(se_squad and se_squad.id or "-"),
        tostring(pick_scope),
        tostring(chosen.smart or "-"),
        tostring(chosen.level or "-"),
        tostring(bucket or "-"),
        tostring(chosen.weight or "-")
    )

    return make_task("HUNT", chosen.smart, {
        started_at_tg = tg(),
        target_level = chosen.level,
        source = source or "hunt",
        night_forced = night_forced == true,
        presence_bucket = bucket,
        presence_weight = tonumber(chosen.weight) or 1,
        pick_scope = pick_scope,
    }, 0)
end

function Mutants:_build_explore_task(se_squad, entry)
    local cur_level = resolve_entry_level(entry, se_squad)
    if not cur_level then
        return nil
    end
    local community = self:_get_entry_community(entry)
    local section_name = self:_get_entry_section(entry, se_squad)
    local current_smart_name = self:_get_current_smart_name(entry, se_squad)

    local levels = {}
    local seen = {}
    local function add_level(name)
        if type(name) ~= "string" or name == "" then return end
        if seen[name] then return end
        seen[name] = true
        levels[#levels + 1] = name
    end
    local neighbors = get_neighbors(cur_level, community, section_name)
    for i = 1, #neighbors do
        add_level(neighbors[i])
    end
    if #levels <= 0 then
        return nil
    end
    shuffle_in_place(levels)

    for i = 1, #levels do
        local target_level = levels[i]
        local smarts = self:_get_filtered_smarts_for_level(target_level, community, section_name)
        local candidates = {}
        for j = 1, #smarts do
            local smart_name = smarts[j]
            if smart_name ~= current_smart_name then
                candidates[#candidates + 1] = smart_name
            end
        end
        local target = pick_random(candidates)
        if target then
            return make_task("EXPLORE", target, {
                started_at_tg = tg(),
                target_level = target_level,
                source = "explore",
            }, 0)
        end
    end
    return nil
end

function Mutants:_build_patrol_task(se_squad, entry)
    local cur_level = resolve_entry_level(entry, se_squad)
    if not cur_level then
        return nil
    end
    local community = self:_get_entry_community(entry)
    local section_name = self:_get_entry_section(entry, se_squad)
    local current_smart_name = self:_get_current_smart_name(entry, se_squad)

    local cached_order = self:_get_filtered_smarts_for_level(cur_level, community, section_name)
    if #cached_order <= 0 then
        return nil
    end
    local order = {}
    for i = 1, #cached_order do
        local smart_name = cached_order[i]
        if smart_name ~= current_smart_name then
            order[#order + 1] = smart_name
        end
    end
    if #order <= 0 then
        return nil
    end
    shuffle_in_place(order)

    local patrol_hours = cfg_num("mutant_patrol_duration_game_hours", 1.0, nil)
    if patrol_hours <= 0 then patrol_hours = 1.0 end
    local duration_game_sec = math_floor(patrol_hours * 3600)
    if duration_game_sec < 1 then duration_game_sec = 1 end

    local tf = (level and level.get_time_factor and level.get_time_factor()) or 10
    if tf <= 0 then tf = 10 end
    local duration_ms = math_floor((duration_game_sec * 1000) / tf)
    if duration_ms < 1000 then duration_ms = 1000 end

    local started_gt = nil
    local now_gt = game_time_now()
    if now_gt then
        started_gt = ctime_to_table(now_gt)
    end

    local params = {
        started_at_tg = tg(),
        started_at_gt = started_gt,
        duration_game_sec = duration_game_sec,
        duration_ms = duration_ms,
        order = order,
        idx = 1,
        hops = 0,
        max_hops = math_max(3, #order),
        target_level = cur_level,
        source = "patrol",
    }
    return make_task("PATROL", order[1], params, 0)
end

function Mutants:_pick_day_roam_task(se_squad, entry, exclude_type)
    local hunt_enabled = is_hunt_enabled()
    local explore_enabled = cfg_bool("mutant_explore_enabled", true)
    local patrol_enabled = cfg_bool("mutant_patrol_enabled", true)

    local builders = {}
    if hunt_enabled then
        builders[#builders + 1] = { type = "HUNT", fn = function() return self:_build_hunt_task(se_squad, entry, "day_roam", false) end }
    end
    if explore_enabled then
        builders[#builders + 1] = { type = "EXPLORE", fn = function() return self:_build_explore_task(se_squad, entry) end }
    end
    if patrol_enabled then
        builders[#builders + 1] = { type = "PATROL", fn = function() return self:_build_patrol_task(se_squad, entry) end }
    end
    shuffle_in_place(builders)

    for pass = 1, 2 do
        for i = 1, #builders do
            local b = builders[i]
            if pass == 2 or b.type ~= exclude_type then
                local task = b.fn()
                if task then
                    return task
                end
            end
        end
    end
    return nil
end

function Mutants:_pick_first_task(se_squad, entry, night_now)
    if night_now == true then
        local hunt = self:_build_hunt_task(se_squad, entry, "night_force", true)
        if hunt then
            self.RUNTIME.night_forced_count = (tonumber(self.RUNTIME.night_forced_count) or 0) + 1
            return hunt
        end
        self.RUNTIME.night_fallback_rest_count = (tonumber(self.RUNTIME.night_fallback_rest_count) or 0) + 1
        return build_rest_task()
    end

    local task = self:_pick_day_roam_task(se_squad, entry, nil)
    if task then
        return task
    end
    return build_rest_task()
end

function Mutants:_rotate_task(se_squad, entry, prev, night_now)
    if night_now == true then
        local hunt = self:_build_hunt_task(se_squad, entry, "night_force", true)
        if hunt then
            self.RUNTIME.night_forced_count = (tonumber(self.RUNTIME.night_forced_count) or 0) + 1
            return hunt
        end
        self.RUNTIME.night_fallback_rest_count = (tonumber(self.RUNTIME.night_fallback_rest_count) or 0) + 1
        return build_rest_task()
    end

    local exclude = prev and prev.type or nil
    local next_task = self:_pick_day_roam_task(se_squad, entry, exclude)
    if next_task then
        return next_task
    end
    return build_rest_task()
end

function Mutants:_is_task_target_valid(task, entry, se_squad)
    if not task then return false end
    if task.type == "REST_1H" then return true end
    if type(task.target) ~= "string" or task.target == "" then
        return false
    end
    if not smart_exists(task.target) then
        return false
    end

    local community = self:_get_entry_community(entry)
    local section_name = self:_get_entry_section(entry, se_squad)
    local target_level = task.params and task.params.target_level or nil
    if type(target_level) ~= "string" or target_level == "" then
        target_level = resolve_smart_level_by_name(task.target) or resolve_entry_level(entry, se_squad)
    end
    if target_level and smart_is_blacklisted_for_level(target_level, task.target, community, section_name) then
        return false
    end
    return true
end

function Mutants:_is_task_completed(se_squad, task, night_now)
    if not task then return true end

    if task.type == "REST_1H" then
        return is_rest_done(task)
    end
    if task.type == "EXPLORE" then
        return is_squad_arrived_to_smart(se_squad, task.target) == true
    end
    if task.type == "HUNT" then
        return is_squad_arrived_to_smart(se_squad, task.target) == true
    end

    if task.type == "PATROL" then
        local p = type(task.params) == "table" and task.params or {}
        task.params = p

        if p.duration_elapsed == true then
            return true
        end

        local started_gt = ctime_from_table(p.started_at_gt)
        local dur_gs = tonumber(p.duration_game_sec)
        if started_gt and dur_gs and dur_gs > 0 then
            local elapsed = game_time_diff_sec(started_gt) or 0
            if elapsed >= dur_gs then
                return true
            end
        else
            local started = tonumber(p.started_at_tg) or 0
            local dur = tonumber(p.duration_ms) or 0
            if dur > 0 and tg() >= (started + dur) then
                return true
            end
        end

        if not self:_is_task_target_valid(task, nil, se_squad) then
            local next_target = pick_next_patrol_target(task, self:_get_current_smart_name(nil, se_squad))
            if not next_target then
                return true
            end
            p.target_sync_next_tg = 0
            return false
        end

        if is_squad_arrived_to_smart(se_squad, task.target) then
            p.hops = (tonumber(p.hops) or 0) + 1
            if p.hops >= (tonumber(p.max_hops) or 3) then
                return true
            end
            local next_target = pick_next_patrol_target(task, self:_get_current_smart_name(nil, se_squad))
            if not next_target then
                return true
            end
            task.target = next_target
            p.target_sync_next_tg = 0
        end
        return false
    end

    return true
end

function Mutants:_apply_task(se_squad, task, predator_phase)
    if not (se_squad and task) then return end
    task.params = type(task.params) == "table" and task.params or {}
    if predator_phase == PREDATOR_PHASE_DAY or predator_phase == PREDATOR_PHASE_NIGHT then
        task.params.predator_phase = predator_phase
    end

    if task.type == "REST_1H" then
        local hold_target = self:_get_current_smart_name(nil, se_squad)
        set_scripted_target(se_squad, hold_target)
        task.params.target_sync_name = nil
        task.params.target_sync_smart_id = nil
        task.params.target_sync_started_tg = nil
        task.params.target_sync_next_tg = nil
        task.params.online_nudge_stage = nil
        task.params.online_nudge_next_tg = nil
        return
    end

    if type(task.target) ~= "string" or task.target == "" then
        return
    end

    local p = task.params
    local now = tg()
    if p.target_sync_name ~= task.target then
        p.target_sync_name = task.target
        p.target_sync_started_tg = nil
        p.target_sync_next_tg = 0
        p.target_sync_due = true
        p.online_last_progress_tg = nil
        p.online_last_gvid = nil
        p.online_nudge_stage = 0
        p.online_nudge_next_tg = nil
    end

    local sid = resolve_target_smart_id(task.target)
    local stgt = se_squad.scripted_target
    local at = tonumber(se_squad.assigned_target_id) or nil
    local ca = tonumber(se_squad.current_action) or nil
    local mismatch = false
    if stgt ~= task.target then
        mismatch = true
    end
    if sid and at and at ~= sid then
        mismatch = true
    end
    if ca == nil then
        mismatch = true
    end

    local needs_sync = mismatch or (tonumber(p.target_sync_started_tg) == nil) or p.target_sync_due == true
    if not needs_sync then
        p.target_sync_next_tg = nil
        p.target_sync_due = nil
        return
    end

    local next_sync_tg = tonumber(p.target_sync_next_tg) or 0
    if now < next_sync_tg then
        return
    end

    if not self:_sync_task_target(se_squad, task, mismatch and "mismatch" or "interval") then
        p.target_sync_next_tg = now + 1000
    else
        p.target_sync_due = nil
    end
end

function Mutants:_refresh_presence_for_live_squad(se_squad, source, entry)
    local sid = tonumber(se_squad and se_squad.id) or nil
    if not sid then
        return nil
    end
    if not read_commander_id(se_squad) then
        return nil
    end
    if type(entry) ~= "table" then
        if zhopa.memory and zhopa.memory.update_squad_snapshot_verified then
            zhopa.memory.update_squad_snapshot_verified(se_squad, sid)
        elseif zhopa.memory and zhopa.memory.update_squad_snapshot then
            zhopa.memory.update_squad_snapshot(se_squad)
        end
        entry = zhopa.memory and zhopa.memory.get_squad_entry and zhopa.memory.get_squad_entry(sid) or nil
    end

    if type(entry) ~= "table" then
        self:_clear_hunt_presence_for_sid(sid)
        return nil
    end

    entry.level = resolve_entry_level(entry, se_squad) or entry.level
    entry.smart_id = se_squad.smart_id
    entry.scripted_target = se_squad.scripted_target
    entry.current_action = se_squad.current_action
    entry.assigned_target_id = se_squad.assigned_target_id

    if is_hunt_enabled() ~= true then
        self:_clear_hunt_presence_for_sid(sid)
        return entry
    end

    local sig = self:_hunt_presence_signature(entry, se_squad)
    local sig_by_sid = self.RUNTIME.presence_signature_by_sid or {}
    self.RUNTIME.presence_signature_by_sid = sig_by_sid
    if sig and sig_by_sid[sid] == sig then
        return entry
    end
    sig_by_sid[sid] = sig

    if self:_is_stalker_presence_entry(entry) then
        self:_process_stalker_presence(sid, entry)
    else
        self:_clear_hunt_presence_for_sid(sid)
    end
    return entry
end

function Mutants:_mark_mutant_dirty_if_managed(se_squad, reason)
    local sid = tonumber(se_squad and se_squad.id) or nil
    if not sid then
        return false
    end
    local entry = self:_refresh_presence_for_live_squad(se_squad, reason)
    if type(entry) ~= "table" or entry.npc_kind ~= "mutant" then
        return false
    end
    if zhopa.memory and zhopa.memory.mark_dirty then
        zhopa.memory.mark_dirty(sid, "task")
    end
    return true
end

function Mutants:_update_squad_tasks(se_squad, ctx)
    if not (zhopa.memory and zhopa.memory.set_task_current and (zhopa.memory.touch_squad_validated or zhopa.memory.get_squad_entry)) then
        return
    end
    if not se_squad then return end
    clear_always_arrived(se_squad)
    if zhopa.runtime_cfg and zhopa.runtime_cfg.get and zhopa.runtime_cfg.get("mutant_sim_enabled", true) == false then
        return
    end
    if not (zhopa.runtime_cfg and zhopa.runtime_cfg.get) and zhopa.config and zhopa.config.get and zhopa.config.get("mutant_sim_enabled", true) == false then
        return
    end

    local entry = nil
    if ctx and ctx.prevalidated == true and se_squad and se_squad.id and zhopa.memory.get_squad_entry then
        entry = zhopa.memory.get_squad_entry(se_squad.id)
    elseif zhopa.memory.touch_squad_validated then
        entry = zhopa.memory.touch_squad_validated(se_squad, false, "mutants")
    end
    if not entry then
        return
    end
    local sid = tonumber(entry.squad_id) or tonumber(se_squad.id)
    if self:_is_stalker_presence_entry(entry) then
        self:_process_stalker_presence(sid, entry)
        return
    end
    self:_clear_hunt_presence_for_sid(sid)
    if entry.npc_kind ~= "mutant" then
        return
    end

    self.RUNTIME.updates = (tonumber(self.RUNTIME.updates) or 0) + 1
    self.RUNTIME.last_update_tg = tg()

    entry.identity_source = entry.identity_source or "mutant_runtime"
    entry.player_id = read_squad_player_id(se_squad) or entry.player_id
    entry.level = resolve_entry_level(entry, se_squad) or entry.level
    entry.smart_id = se_squad.smart_id
    entry.scripted_target = se_squad.scripted_target
    entry.current_action = se_squad.current_action
    entry.assigned_target_id = se_squad.assigned_target_id
    entry.tasks = type(entry.tasks) == "table" and entry.tasks or { prev = nil, current = nil, next = nil }

    local night_now = is_night_now()
    local current = entry.tasks.current
    local force_phase_probe = current and current.type ~= "REST_1H" or false
    local predator_phase = self:_resolve_predator_phase(se_squad, entry, force_phase_probe)
    if not predator_phase and type(current) == "table" and type(current.params) == "table" then
        local task_phase = current.params.predator_phase
        if task_phase == PREDATOR_PHASE_DAY or task_phase == PREDATOR_PHASE_NIGHT then
            predator_phase = task_phase
            entry.predator_phase = task_phase
            entry.predator_phase_source = entry.predator_phase_source or "task.params"
        end
    end
    if is_predator_phase_inactive(predator_phase, night_now) then
        local need_rest = (not current) or current.type ~= "REST_1H"
        if need_rest then
            local rest = build_rest_task()
            rest.params = type(rest.params) == "table" and rest.params or {}
            rest.params.predator_phase = predator_phase
            zhopa.memory.set_task_current(entry.squad_id, rest)
            current = entry.tasks.current or rest
        end
        set_scripted_target(se_squad, self:_get_current_smart_name(entry, se_squad))
        self.RUNTIME.phase_rest_forced_count = (tonumber(self.RUNTIME.phase_rest_forced_count) or 0) + 1
        if predator_phase == PREDATOR_PHASE_DAY then
            self.RUNTIME.phase_rest_forced_night_count = (tonumber(self.RUNTIME.phase_rest_forced_night_count) or 0) + 1
        elseif predator_phase == PREDATOR_PHASE_NIGHT then
            self.RUNTIME.phase_rest_forced_day_count = (tonumber(self.RUNTIME.phase_rest_forced_day_count) or 0) + 1
        end
        self:_log_throttled(
            "phase_rest:" .. tostring(entry.squad_id or 0),
            5000,
            "debug",
            "MUTANT_PHASE_REST sid=%s phase=%s night_now=%s",
            tostring(entry.squad_id or "-"),
            tostring(predator_phase or "-"),
            tostring(night_now == true)
        )
        return
    end

    if (not night_now) and is_surge_active() then
        local rest = build_rest_task()
        zhopa.memory.set_task_current(entry.squad_id, rest)
        set_scripted_target(se_squad, self:_get_current_smart_name(entry, se_squad))
        return
    end

    current = entry.tasks.current

    if night_now then
        if current and current.type == "HUNT" then
            current.params = type(current.params) == "table" and current.params or {}
            if current.params.night_forced ~= true then
                self.RUNTIME.night_forced_count = (tonumber(self.RUNTIME.night_forced_count) or 0) + 1
            end
            current.params.night_forced = true
            current.params.source = current.params.source or "night_force"
        else
            local forced_hunt = self:_build_hunt_task(se_squad, entry, "night_force", true)
            if forced_hunt then
                self.RUNTIME.night_forced_count = (tonumber(self.RUNTIME.night_forced_count) or 0) + 1
                zhopa.memory.set_task_current(entry.squad_id, forced_hunt)
                current = entry.tasks.current or forced_hunt
            else
                self.RUNTIME.night_fallback_rest_count = (tonumber(self.RUNTIME.night_fallback_rest_count) or 0) + 1
                local rest = build_rest_task()
                rest.params = type(rest.params) == "table" and rest.params or {}
                rest.params.source = "night_hunt_wait"
                if predator_phase == PREDATOR_PHASE_DAY or predator_phase == PREDATOR_PHASE_NIGHT then
                    rest.params.predator_phase = predator_phase
                end
                zhopa.memory.set_task_current(entry.squad_id, rest)
                current = entry.tasks.current or rest
            end
        end
    else
        if current and current.type == "HUNT" then
            self.RUNTIME.day_hunt_released_count = (tonumber(self.RUNTIME.day_hunt_released_count) or 0) + 1
            local released = self:_rotate_task(se_squad, entry, current, false)
            zhopa.memory.set_task_current(entry.squad_id, released)
            current = entry.tasks.current or released
        end
    end

    if not current then
        current = self:_pick_first_task(se_squad, entry, night_now)
        zhopa.memory.set_task_current(entry.squad_id, current)
        current = entry.tasks.current or current
    end

    if not self:_is_task_target_valid(current, entry, se_squad) then
        local rebuilt = self:_rotate_task(se_squad, entry, current, night_now) or build_rest_task()
        zhopa.memory.set_task_current(entry.squad_id, rebuilt)
        current = entry.tasks.current or rebuilt
    end

    self:_apply_task(se_squad, current, predator_phase)
    if self:_is_task_completed(se_squad, current, night_now) then
        self.RUNTIME.completions = (tonumber(self.RUNTIME.completions) or 0) + 1
        if current.type == "REST_1H" then
            zhopa.memory.set_task_current(entry.squad_id, nil)
            return
        end
        local next_task = build_rest_task()
        if type(next_task.params) == "table" and (predator_phase == PREDATOR_PHASE_DAY or predator_phase == PREDATOR_PHASE_NIGHT) then
            next_task.params.predator_phase = predator_phase
        end
        zhopa.memory.set_task_current(entry.squad_id, next_task)
        current = entry.tasks.current or next_task
        self:_apply_task(se_squad, current, predator_phase)
    end
end

function Mutants:_reset_presence_runtime()
    self.RUNTIME.hunt_presence_by_level = {}
    self.RUNTIME.hunt_presence_by_sid = {}
    self.RUNTIME.presence_signature_by_sid = {}
    self.RUNTIME.hunt_cache_tg = 0
    self.RUNTIME.hunt_level_smarts_cache = {}
    self.RUNTIME.hunt_level_smarts_rev = {}
    self.RUNTIME.hunt_pass_obj_cache = {}
    self.RUNTIME.hunt_pass_level_cache = {}
    self.RUNTIME.hunt_pass_smart_cache = {}
    self.RUNTIME.hunt_pass_exists_cache = {}
end

function Mutants:_bootstrap_presence_from_board(source)
    local board = get_board()
    local squads = board and board.squads or nil
    if type(squads) ~= "table" then
        return
    end

    local sim = alife and alife() or nil
    if not sim then
        return
    end

    for sid in pairs(squads) do
        sid = tonumber(sid) or nil
        if is_valid_server_id(sid) then
            local ok_obj, se_squad = pcall(function() return sim:object(sid) end)
            se_squad = ok_obj and se_squad or nil
            if se_squad then
                self:_refresh_presence_for_live_squad(se_squad, source or "board_bootstrap")
            else
                self:_clear_hunt_presence_for_sid(sid)
            end
        end
    end
end

local inst = Mutants.new and Mutants.new() or setmetatable({}, Mutants)
if not inst.RUNTIME then
    Mutants.__init(inst)
end

inst.update_squad_tasks = function(se_squad, ctx) return inst:_update_squad_tasks(se_squad, ctx) end
inst.on_actor_first_update = function()
    inst:_reset_presence_runtime()
    inst:_bootstrap_presence_from_board("actor_first_update")
end
inst.on_load_state = function()
    inst:_reset_presence_runtime()
    inst:_bootstrap_presence_from_board("load_state")
end
inst.on_server_entity_register = function(se_obj, type_name)
    if type(type_name) == "string" and type_name == "sim_squad_scripted" then
        inst:_refresh_presence_for_live_squad(se_obj, "server_register")
    elseif type(type_name) == "string" and type_name == "se_smart_terrain" then
        inst:_invalidate_hunt_level_smarts_cache(resolve_smart_level_from_obj(se_obj))
    end
end
inst.on_server_entity_unregister = function(se_obj, type_name)
    if type(type_name) == "string" and type_name == "sim_squad_scripted" then
        inst:_clear_hunt_presence_for_sid(se_obj and se_obj.id or nil)
    elseif type(type_name) == "string" and type_name == "se_smart_terrain" then
        inst:_invalidate_hunt_level_smarts_cache(resolve_smart_level_from_obj(se_obj))
    end
end
inst.wants_smart_update = function(_, ctx)
    return type(ctx) == "table" and type(ctx.level_name) == "string" and ctx.level_name ~= ""
end
inst.on_smart_terrain_update = function(smart, ctx)
    local level_name = type(ctx) == "table" and ctx.level_name or resolve_smart_level_from_obj(smart)
    inst:_invalidate_hunt_level_smarts_cache(level_name)
end
inst.on_squad_first_update = function(squad, entry) return inst:_refresh_presence_for_live_squad(squad, "first_update", entry) end
inst.on_squad_update = function(squad, entry) return inst:_refresh_presence_for_live_squad(squad, "update", entry) end
inst.on_squad_npc_death = function(squad)
    inst:_clear_hunt_presence_for_sid(squad and squad.id or nil)
    return inst:_mark_mutant_dirty_if_managed(squad, "npc_death")
end

zhopa.mutants = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_mutants

-- BEGIN module zhopa_base_filler
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local setmetatable = _G.setmetatable
local tonumber = _G.tonumber
local tostring = _G.tostring
local pairs = _G.pairs
local table_sort = _G.table and _G.table.sort or nil
local math_random = _G.math and _G.math.random or nil
local math_min = _G.math and _G.math.min or nil
local math_max = _G.math and _G.math.max or nil
local math_floor = _G.math and _G.math.floor or nil
local string_find = _G.string and _G.string.find or nil
local string_gsub = _G.string and _G.string.gsub or nil
local string_lower = _G.string and _G.string.lower or nil
local time_global = _G.time_global
local level = _G.level
local db = _G.db
local game_graph = _G.game_graph
local alife = _G.alife
local alife_create = _G.alife_create
local ini_sys = _G.ini_sys
local math_sqrt = _G.math and _G.math.sqrt or nil


local BaseFiller = zhopa.class("BaseFiller")
BaseFiller.__index = BaseFiller

local CAMPER_TOKEN = "_sim_squad_camper_"
local LEGACY_CAMPER_TOKEN = "_base_camper_"
local CAMPER_TIERS = { "novice", "advanced" }
local CAMPER_FACTIONS = {
    "stalker",
    "bandit",
    "duty",
    "freedom",
    "merc",
    "army",
    "ecolog",
    "monolith",
    "csky",
    "renegade",
    "greh",
    "isg",
}

local DEFAULT_DAILY_HOURS = 24
local DEFAULT_NPC_MIN = 5
local DEFAULT_NPC_MAX = 8
local NPC_COUNT_MIN = 1
local NPC_COUNT_MAX = 8
local ACTIVE_CAMPER_COUNT_REFRESH_MS = 30000
local NEAR_ACTOR_BLOCK_DIST_M = 50
local NEAR_ACTOR_BLOCK_DIST_SQR = NEAR_ACTOR_BLOCK_DIST_M * NEAR_ACTOR_BLOCK_DIST_M
local STATE_VERSION = "1.0.1"

local function tg()
    return (time_global and time_global()) or 0
end

local function is_valid_server_id(id)
    id = tonumber(id) or 0
    return id > 0 and id ~= 65535
end

local function loaded_level_name()
    if level and level.name then
        local ok, name = pcall(function() return level.name() end)
        if ok and type(name) == "string" and name ~= "" then
            return name
        end
    end
    return nil
end

local function object_name(obj)
    if type(obj) ~= "table" then
        return nil
    end
    local raw_name = obj.name
    if type(raw_name) == "string" and raw_name ~= "" then
        return raw_name
    end
    local ok_name, res_name = pcall(function()
        return obj:name()
    end)
    if ok_name and type(res_name) == "string" and res_name ~= "" then
        return res_name
    end
    return nil
end

local function release_squad_safe(se_squad, reason)
    local sid = tonumber(se_squad and se_squad.id) or nil
    if not sid then
        return false
    end

    local released = false
    local rel = _G.alife_release_id
    if type(rel) == "function" then
        local ok, res = pcall(function() return rel(sid, reason) end)
        if ok and res ~= false then
            released = true
        end
    end

    if not released then
        local ok_remove, res_remove = pcall(function() return se_squad:remove_squad() end)
        if ok_remove and res_remove ~= false then
            released = true
        end
    end

    if not released then
        local sim = alife and alife() or nil
        if sim and sim.release then
            local ok_release, res_release = pcall(function() return sim:release(se_squad, true) end)
            if ok_release and res_release ~= false then
                released = true
            end
        end
    end

    if zhopa.memory and zhopa.memory.purge_squad_entry then
        zhopa.memory.purge_squad_entry(sid, "spawn_section_mismatch", "base_filler_release")
    end

    return released
end

local function has_game_time()
    return game and game.get_game_time and game.CTime
end

local function ctime_to_table(ct)
    if not (ct and ct.get) then return nil end
    local ok, Y, M, D, h, m, s, ms = pcall(function()
        return ct:get(0, 0, 0, 0, 0, 0, 0)
    end)
    if not ok then return nil end
    return { Y = Y, M = M, D = D, h = h, m = m, s = s, ms = ms }
end

local function ctime_from_table(t)
    if not (has_game_time() and type(t) == "table") then
        return nil
    end
    local ok_new, ct = pcall(function() return game.CTime() end)
    if not (ok_new and ct and ct.set) then
        return nil
    end
    local ok_set = pcall(function()
        ct:set(t.Y, t.M, t.D, t.h, t.m, t.s, t.ms)
    end)
    if not ok_set then
        return nil
    end
    return ct
end

local function game_time_now()
    if not has_game_time() then
        return nil
    end
    local ok, ct = pcall(function() return game.get_game_time() end)
    return ok and ct or nil
end

local function game_time_diff_sec(start_ct)
    local now = game_time_now()
    if not (now and now.diffSec and start_ct) then
        return nil
    end
    local ok, sec = pcall(function() return now:diffSec(start_ct) end)
    return ok and tonumber(sec) or nil
end

local function now_level_name_by_gvid(gvid)
    if not (gvid and alife and game_graph) then
        return nil
    end
    local ok, level_name = pcall(function()
        local gv = game_graph():vertex(gvid)
        if not gv then return nil end
        return alife():level_name(gv:level_id())
    end)
    return ok and level_name or nil
end

local function get_board()
    if SIMBOARD then return SIMBOARD end
    if sim_board and sim_board.get_sim_board then
        local ok, board = pcall(function() return sim_board.get_sim_board() end)
        if ok then return board end
    end
    return nil
end

local function clone_ctime_table(src)
    if type(src) ~= "table" then
        return nil
    end
    local out = {
        Y = tonumber(src.Y),
        M = tonumber(src.M),
        D = tonumber(src.D),
        h = tonumber(src.h),
        m = tonumber(src.m),
        s = tonumber(src.s),
        ms = tonumber(src.ms),
    }
    if out.Y == nil or out.M == nil or out.D == nil or out.h == nil or out.m == nil or out.s == nil or out.ms == nil then
        return nil
    end
    return out
end

local function count_keys(src)
    local count = 0
    if type(src) ~= "table" then
        return count
    end
    for _ in pairs(src) do
        count = count + 1
    end
    return count
end

local function safe_actor_position()
    if not (db and db.actor and db.actor.position) then
        return nil
    end
    local ok, pos = pcall(function() return db.actor:position() end)
    return ok and pos or nil
end

local function safe_smart_position(smart)
    if not smart then
        return nil
    end
    local ok, pos = pcall(function() return smart.position end)
    if ok and pos then
        return pos
    end
    return nil
end

local function safe_distance_sqr(pos_a, pos_b)
    if not (pos_a and pos_b) then
        return nil
    end
    if pos_a.distance_to_sqr then
        local ok, d2 = pcall(function() return pos_a:distance_to_sqr(pos_b) end)
        if ok and tonumber(d2) then
            return tonumber(d2)
        end
    end
    local ax = tonumber(pos_a.x)
    local ay = tonumber(pos_a.y)
    local az = tonumber(pos_a.z)
    local bx = tonumber(pos_b.x)
    local by = tonumber(pos_b.y)
    local bz = tonumber(pos_b.z)
    if not (ax and ay and az and bx and by and bz) then
        return nil
    end
    local dx = ax - bx
    local dy = ay - by
    local dz = az - bz
    return (dx * dx) + (dy * dy) + (dz * dz)
end

local function format_distance_m(d2)
    d2 = tonumber(d2)
    if not d2 then
        return "-"
    end
    if math_sqrt then
        return tostring(math.floor((math_sqrt(d2) * 10) + 0.5) / 10)
    end
    return tostring(d2)
end

local function parse_csv(s)
    if type(s) ~= "string" then return {} end
    local out = {}
    local n = 0
    for token in string.gmatch(s, "([^,]+)") do
        local t = string_gsub(token, "^%s*(.-)%s*$", "%1")
        if t ~= "" then
            n = n + 1
            out[n] = t
        end
    end
    return out
end

local function normalize_community(name)
    if type(name) ~= "string" then return nil end
    local key = string_lower(string_gsub(name, "^%s*(.-)%s*$", "%1"))
    if key == "" then return nil end
    if zhopa.config and zhopa.config.get_faction_alias then
        local alias = zhopa.config.get_faction_alias(key)
        if type(alias) == "string" and alias ~= "" then
            key = string_lower(string_gsub(alias, "^%s*(.-)%s*$", "%1"))
        end
    end
    if key == "dolg" then key = "duty" end
    if key == "killer" then key = "merc" end
    return key
end

local function safe_section(se_squad)
    if not se_squad then return nil end
    if zhopa.safe and zhopa.safe.safe_section then
        return zhopa.safe.safe_section(se_squad)
    end
    local ok, section = pcall(function() return se_squad:section_name() end)
    if ok and type(section) == "string" then
        return section
    end
    return nil
end

local function safe_community(se_obj)
    if not se_obj then return nil end
    local ok, comm = pcall(function() return se_obj:community() end)
    if ok and type(comm) == "string" and comm ~= "" then
        return comm
    end
    ok, comm = pcall(function() return se_obj.community end)
    if ok and type(comm) == "string" and comm ~= "" then
        return comm
    end
    return nil
end

local function is_base_camper_section(section)
    return type(section) == "string"
        and section ~= ""
        and (
            string_find(section, CAMPER_TOKEN, 1, true) ~= nil
            or string_find(section, LEGACY_CAMPER_TOKEN, 1, true) ~= nil
        )
end

local function clear_squad_runtime_target(se_squad)
    if not se_squad then return end
    se_squad.current_action = 0
    se_squad.current_target_id = nil
    se_squad.task_target_id = nil
    se_squad.stay_time = nil
    se_squad.arrive_time = nil
end

local function extract_member_candidate_id(k, v)
    if type(v) == "table" then
        local idv = tonumber(v.id) or tonumber(v.object_id) or tonumber(v.squad_id)
        if idv and idv > 0 then
            return idv
        end
    end
    local id = tonumber(v)
    if id and id > 0 then
        return id
    end
    id = tonumber(k)
    if id and id > 0 then
        return id
    end
    return nil
end

local ACTIVE_SPAWN_OVERRIDE = nil
local ACTIVE_SPAWN_OVERRIDE_ORIGINAL_INI = nil
local INI_SYS_PROXY = nil

local function active_spawn_override_count_range()
    local override = ACTIVE_SPAWN_OVERRIDE
    if type(override) ~= "table" or override.active ~= true then
        return nil, nil
    end
    local min_count = tonumber(override.min_count)
    local max_count = tonumber(override.max_count)
    if not (min_count and max_count) then
        return nil, nil
    end
    return min_count, max_count
end

local function should_override_spawn_count(section_name, key)
    local override = ACTIVE_SPAWN_OVERRIDE
    if type(override) ~= "table" or override.active ~= true then
        return false
    end
    if key ~= "npc_in_squad" then
        return false
    end
    if type(section_name) ~= "string" or section_name == "" then
        return false
    end
    if section_name ~= override.section then
        return false
    end
    return is_base_camper_section(section_name)
end

local function build_ini_sys_proxy()
    if INI_SYS_PROXY then
        return INI_SYS_PROXY
    end

    local proxy = {}
    setmetatable(proxy, {
        __index = function(_, key)
            if key == "r_string_ex" then
                return function(_, section_name, value_key)
                    local original = ACTIVE_SPAWN_OVERRIDE_ORIGINAL_INI or _G.ini_sys or ini_sys
                    if not original then
                        return nil
                    end
                    if should_override_spawn_count(section_name, value_key) then
                        local min_count, max_count = active_spawn_override_count_range()
                        if min_count and max_count then
                            return tostring(min_count) .. "," .. tostring(max_count)
                        end
                    end
                    return original:r_string_ex(section_name, value_key)
                end
            end

            local original = ACTIVE_SPAWN_OVERRIDE_ORIGINAL_INI or _G.ini_sys or ini_sys
            if not original then
                return nil
            end
            local value = original[key]
            if type(value) == "function" then
                return function(_, ...)
                    return value(original, ...)
                end
            end
            return value
        end,
    })

    INI_SYS_PROXY = proxy
    return proxy
end

function BaseFiller:__init()
    self.STATE = {
        version = STATE_VERSION,
        last_fill_gt_by_level = {},
        default_last_fill_gt = nil,
    }
    self.RUNTIME = {
        last_update_tg = 0,
        last_active_count_tg = 0,
        targets_by_level = {},
        target_set_by_level = {},
        target_level_by_name = {},
        dirty_targets_by_level = {},
        dirty_force_spawn_by_level = {},
        dirty_queue_by_level = {},
        dirty_queue_head_by_level = {},
        dirty_queue_tail_by_level = {},
        dirty_level_queue = {},
        dirty_level_set = {},
        dirty_level_head = 1,
        dirty_level_tail = 0,
        smart_to_sid = {},
        sid_to_smart = {},
        cleaned_sids = {},
        initial_fill_done = false,
        disabled_logged = false,
        loaded_from_save = false,
        loaded_state_present = false,
        warn_next_tg_by_key = {},
        spawn_override = {
            active = false,
            section = nil,
            smart_name = nil,
            min_count = nil,
            max_count = nil,
        },
        stats = {
            ticks = 0,
            reconcile_runs = 0,
            targets = 0,
            spawn_attempts = 0,
            spawn_success = 0,
            spawn_failed = 0,
            spawn_no_faction = 0,
            spawn_no_section = 0,
            spawn_section_mismatch = 0,
            spawn_blocked_policy = 0,
            spawn_blocked_actor_near = 0,
            spawn_smart_missing = 0,
            pin_reassert = 0,
            discover_hits = 0,
            active_campers = 0,
        },
    }
    self.SECTIONS_BY_FACTION = {}
    self.AVAILABLE_FACTIONS = {}
end

function BaseFiller:_normalize_npc_count(value, default)
    local n = tonumber(value)
    if not n then
        n = default
    end
    if math_floor then
        n = math_floor(n)
    end
    if math_max then
        n = math_max(NPC_COUNT_MIN, n)
    elseif n < NPC_COUNT_MIN then
        n = NPC_COUNT_MIN
    end
    if math_min then
        n = math_min(NPC_COUNT_MAX, n)
    elseif n > NPC_COUNT_MAX then
        n = NPC_COUNT_MAX
    end
    return n
end

function BaseFiller:_get_spawn_size_range()
    local min_count = self:_normalize_npc_count(
        self:_num_cfg("base_filler_npc_min", DEFAULT_NPC_MIN, NPC_COUNT_MIN),
        DEFAULT_NPC_MIN
    )
    local max_count = self:_normalize_npc_count(
        self:_num_cfg("base_filler_npc_max", DEFAULT_NPC_MAX, NPC_COUNT_MIN),
        DEFAULT_NPC_MAX
    )
    if min_count > max_count then
        min_count, max_count = max_count, min_count
    end
    return min_count, max_count
end

function BaseFiller:_begin_spawn_override(section, smart_name)
    local min_count, max_count = self:_get_spawn_size_range()
    ACTIVE_SPAWN_OVERRIDE = {
        active = true,
        section = section,
        smart_name = smart_name,
        min_count = min_count,
        max_count = max_count,
    }
    ACTIVE_SPAWN_OVERRIDE_ORIGINAL_INI = _G.ini_sys
    self.RUNTIME.spawn_override = {
        active = true,
        section = section,
        smart_name = smart_name,
        min_count = min_count,
        max_count = max_count,
    }
    _G.ini_sys = build_ini_sys_proxy()
end

function BaseFiller:_end_spawn_override()
    local original = ACTIVE_SPAWN_OVERRIDE_ORIGINAL_INI
    ACTIVE_SPAWN_OVERRIDE = nil
    ACTIVE_SPAWN_OVERRIDE_ORIGINAL_INI = nil
    self.RUNTIME.spawn_override = {
        active = false,
        section = nil,
        smart_name = nil,
        min_count = nil,
        max_count = nil,
    }
    _G.ini_sys = original or ini_sys
end

function BaseFiller:_call_with_spawn_override(section, smart_name, fn)
    if type(fn) ~= "function" then
        return false, nil
    end
    self:_begin_spawn_override(section, smart_name)
    local ok, result = pcall(fn)
    self:_end_spawn_override()
    return ok, result
end

function BaseFiller:_state_has_explicit_mark(level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    return type(self.STATE and self.STATE.last_fill_gt_by_level and self.STATE.last_fill_gt_by_level[level_name]) == "table"
end

function BaseFiller:_state_has_default_mark()
    return type(self.STATE and self.STATE.default_last_fill_gt) == "table"
end

function BaseFiller:_get_level_fill_mark(level_name)
    if self:_state_has_explicit_mark(level_name) then
        return self.STATE.last_fill_gt_by_level[level_name], "level"
    end
    if self:_state_has_default_mark() then
        return self.STATE.default_last_fill_gt, "default"
    end
    return nil, nil
end

function BaseFiller:_is_level_refill_due(level_name)
    local hours = self:_num_cfg("base_filler_daily_respawn_game_hours", DEFAULT_DAILY_HOURS, 0.1)
    local last = self:_get_level_fill_mark(level_name)
    if type(last) ~= "table" then
        return true
    end
    local last_ct = ctime_from_table(last)
    if not last_ct then
        return true
    end
    local elapsed = game_time_diff_sec(last_ct)
    if not elapsed then
        return false
    end
    return elapsed >= (hours * 3600)
end

function BaseFiller:_mark_level_fill_now(level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return nil
    end
    local now_gt = game_time_now()
    local stamp = now_gt and ctime_to_table(now_gt) or nil
    self.STATE.last_fill_gt_by_level[level_name] = stamp
    return stamp
end

function BaseFiller:_is_spawn_blocked_near_actor(smart)
    local actor_pos = safe_actor_position()
    if not actor_pos then
        return false, nil
    end
    local smart_pos = safe_smart_position(smart)
    if not smart_pos then
        return false, nil
    end
    local d2 = safe_distance_sqr(actor_pos, smart_pos)
    if not d2 then
        return false, nil
    end
    return d2 < NEAR_ACTOR_BLOCK_DIST_SQR, d2
end

function BaseFiller:_num_cfg(key, default, min_v)
    local value = default
    if zhopa.runtime_cfg and zhopa.runtime_cfg.num then
        return zhopa.runtime_cfg.num(key, value, min_v)
    end
    if zhopa.config and zhopa.config.get then
        local read = zhopa.config.get(key, default)
        if tonumber(read) then
            value = tonumber(read)
        end
    end
    if min_v ~= nil and value < min_v then
        value = min_v
    end
    return value
end

function BaseFiller:_is_enabled()
    if zhopa.runtime_cfg and zhopa.runtime_cfg.get then
        return zhopa.runtime_cfg.get("enabled", true) == true
            and zhopa.runtime_cfg.get("base_filler_enabled", false) ~= false
    end
    if not (zhopa.config and zhopa.config.get) then return true end
    if zhopa.config.get("enabled", true) ~= true then
        return false
    end
    return zhopa.config.get("base_filler_enabled", true) ~= false
end

function BaseFiller:_log_warn(fmt, ...)
    if zhopa.log and zhopa.log.warn then
        zhopa.log.warn("BASE_FILLER", fmt, ...)
    end
end

function BaseFiller:_log_info(fmt, ...)
    if zhopa.log and zhopa.log.info then
        zhopa.log.info("BASE_FILLER", fmt, ...)
    end
end

function BaseFiller:_warn_throttled(key, interval_ms, fmt, ...)
    if type(key) ~= "string" or key == "" then
        self:_log_warn(fmt, ...)
        return
    end
    local now = tg()
    local next_tg = tonumber(self.RUNTIME.warn_next_tg_by_key[key]) or 0
    if now < next_tg then
        return
    end
    self.RUNTIME.warn_next_tg_by_key[key] = now + (tonumber(interval_ms) or 30000)
    self:_log_warn(fmt, ...)
end

function BaseFiller:_section_exists(section)
    if type(section) ~= "string" or section == "" then
        return false
    end
    if ini_sys and ini_sys.section_exist then
        local ok, exists = pcall(function() return ini_sys:section_exist(section) end)
        if ok then
            return exists == true
        end
    end
    return true
end

function BaseFiller:_refresh_sections_index()
    local by_faction = {}
    local available = {}
    for i = 1, #CAMPER_FACTIONS do
        local faction = CAMPER_FACTIONS[i]
        local list = {}
        local n = 0
        for j = 1, #CAMPER_TIERS do
            local tier = CAMPER_TIERS[j]
            local section = faction .. CAMPER_TOKEN .. tier
            if not self:_section_exists(section) then
                section = faction .. LEGACY_CAMPER_TOKEN .. tier
            end
            if self:_section_exists(section) then
                n = n + 1
                list[n] = section
            end
        end
        if n > 0 then
            by_faction[faction] = list
            available[#available + 1] = faction
        end
    end
    self.SECTIONS_BY_FACTION = by_faction
    self.AVAILABLE_FACTIONS = available
end

function BaseFiller:_clear_smart_mapping(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return
    end
    local sid = self.RUNTIME.smart_to_sid[smart_name]
    if sid then
        self.RUNTIME.sid_to_smart[sid] = nil
        self.RUNTIME.cleaned_sids[sid] = nil
    end
    self.RUNTIME.smart_to_sid[smart_name] = nil
end

function BaseFiller:_remember_mapping(smart_name, sid)
    sid = tonumber(sid)
    if type(smart_name) ~= "string" or smart_name == "" or not sid then
        return
    end
    local prev_sid = self.RUNTIME.smart_to_sid[smart_name]
    if prev_sid and prev_sid ~= sid then
        self.RUNTIME.sid_to_smart[prev_sid] = nil
        self.RUNTIME.cleaned_sids[prev_sid] = nil
    end
    local prev_smart = self.RUNTIME.sid_to_smart[sid]
    if prev_smart and prev_smart ~= smart_name then
        self.RUNTIME.smart_to_sid[prev_smart] = nil
    end
    self.RUNTIME.smart_to_sid[smart_name] = sid
    self.RUNTIME.sid_to_smart[sid] = smart_name
end

function BaseFiller:_pick_random_fallback_faction()
    local count = #self.AVAILABLE_FACTIONS
    if count <= 0 then
        return nil
    end
    if math_random then
        return self.AVAILABLE_FACTIONS[math_random(1, count)]
    end
    return self.AVAILABLE_FACTIONS[1]
end

function BaseFiller:_resolve_faction_from_npc_info(smart)
    if not (smart and type(smart.npc_info) == "table") then
        return nil
    end
    local counts = {}
    local best = nil
    local best_count = 0
    for _, info in pairs(smart.npc_info) do
        local se_obj = type(info) == "table" and info.se_obj or nil
        local comm = normalize_community(safe_community(se_obj))
        if comm and self.SECTIONS_BY_FACTION[comm] then
            local c = (counts[comm] or 0) + 1
            counts[comm] = c
            if c > best_count then
                best_count = c
                best = comm
            end
        end
    end
    return best
end

function BaseFiller:_resolve_faction_from_smart_meta(smart)
    if not smart then return nil end
    local candidates = {}
    local n = 0

    if type(smart.faction) == "string" and smart.faction ~= "" then
        n = n + 1
        candidates[n] = smart.faction
    end
    if type(smart.default_faction) == "string" and smart.default_faction ~= "" then
        n = n + 1
        candidates[n] = smart.default_faction
    end
    if type(smart.faction_controlled) == "string" and smart.faction_controlled ~= "" then
        local list = parse_csv(smart.faction_controlled)
        for i = 1, #list do
            n = n + 1
            candidates[n] = list[i]
        end
    end
    if type(smart.respawn_params) == "table" then
        for _, v in pairs(smart.respawn_params) do
            if type(v) == "table" and type(v.faction) == "string" and v.faction ~= "" then
                n = n + 1
                candidates[n] = v.faction
            end
        end
    end

    for i = 1, #candidates do
        local comm = normalize_community(candidates[i])
        if comm and self.SECTIONS_BY_FACTION[comm] then
            return comm
        end
    end
    return nil
end

function BaseFiller:_pick_faction_for_smart(smart)
    local faction = self:_resolve_faction_from_npc_info(smart)
    if faction then return faction end

    faction = self:_resolve_faction_from_smart_meta(smart)
    if faction then return faction end

    return self:_pick_random_fallback_faction()
end

function BaseFiller:_pick_camper_section(faction)
    local list = faction and self.SECTIONS_BY_FACTION[faction] or nil
    local count = list and #list or 0
    if count <= 0 then
        return nil
    end
    if count == 1 or not math_random then
        return list[1]
    end
    return list[math_random(1, count)]
end

function BaseFiller:_is_spawn_target_allowed(smart_name, smart, faction, section)
    if not (zhopa.tasks and zhopa.tasks.is_smart_spawn_allowed) then
        return true, "ok"
    end

    local level_name = nil
    local gvid = smart and tonumber(smart.m_game_vertex_id) or nil
    if gvid then
        level_name = now_level_name_by_gvid(gvid)
    end
    local community = normalize_community(faction)
    local ok, allowed, reason = pcall(
        zhopa.tasks.is_smart_spawn_allowed,
        smart_name,
        community,
        level_name,
        section
    )
    if not ok then
        self:_warn_throttled(
            "spawn_policy_error:" .. tostring(smart_name),
            30000,
            "spawn_policy_error smart=%s err=%s",
            tostring(smart_name),
            tostring(allowed)
        )
        return true, "policy_error"
    end
    if allowed == true then
        return true, tostring(reason or "ok")
    end
    return false, tostring(reason or "policy_reject")
end

function BaseFiller:_refresh_target_stats()
    local total = 0
    for _, list in pairs(self.RUNTIME.targets_by_level or {}) do
        total = total + #list
    end
    self.RUNTIME.stats.targets = total
end

function BaseFiller:_set_level_targets(level_name, list)
    if type(level_name) ~= "string" or level_name == "" then
        return
    end

    local next_list = {}
    local next_set = {}
    for i = 1, #(list or {}) do
        local smart_name = list[i]
        if type(smart_name) == "string" and smart_name ~= "" and next_set[smart_name] ~= true then
            next_set[smart_name] = true
            next_list[#next_list + 1] = smart_name
        end
    end
    if table_sort then
        table_sort(next_list)
    end

    local prev_list = self.RUNTIME.targets_by_level[level_name] or {}
    for i = 1, #prev_list do
        local smart_name = prev_list[i]
        if next_set[smart_name] ~= true then
            self:_drop_target(smart_name)
        end
    end

    if #next_list > 0 then
        self.RUNTIME.targets_by_level[level_name] = next_list
        self.RUNTIME.target_set_by_level[level_name] = next_set
        for i = 1, #next_list do
            self.RUNTIME.target_level_by_name[next_list[i]] = level_name
        end
    else
        self.RUNTIME.targets_by_level[level_name] = nil
        self.RUNTIME.target_set_by_level[level_name] = nil
        self.RUNTIME.dirty_targets_by_level[level_name] = nil
        self.RUNTIME.dirty_force_spawn_by_level[level_name] = nil
        if self.RUNTIME.dirty_queue_by_level then self.RUNTIME.dirty_queue_by_level[level_name] = nil end
        if self.RUNTIME.dirty_queue_head_by_level then self.RUNTIME.dirty_queue_head_by_level[level_name] = nil end
        if self.RUNTIME.dirty_queue_tail_by_level then self.RUNTIME.dirty_queue_tail_by_level[level_name] = nil end
    end

    self:_refresh_target_stats()
end

function BaseFiller:_sync_targets_from_index()
    local cfg = zhopa.config
    local board_index = zhopa.board_index
    local levels = cfg and cfg.get_level_bases_levels and cfg.get_level_bases_levels() or {}
    local seen_levels = {}

    for i = 1, #levels do
        local level_name = levels[i]
        seen_levels[level_name] = true
        local list = board_index and board_index.get_base_smarts and board_index.get_base_smarts(level_name) or {}
        self:_set_level_targets(level_name, list)
    end

    for level_name in pairs(self.RUNTIME.targets_by_level or {}) do
        if seen_levels[level_name] ~= true then
            self:_set_level_targets(level_name, {})
        end
    end
end

function BaseFiller:_mark_all_index_targets_dirty(force_spawn, reason)
    self:_reset_dirty_runtime()
    for level_name, list in pairs(self.RUNTIME.targets_by_level or {}) do
        if #list > 0 then
            for i = 1, #list do
                self:_push_dirty_target(level_name, list[i])
            end
            if force_spawn == true then
                self.RUNTIME.dirty_force_spawn_by_level[level_name] = true
            end
        end
    end
end

function BaseFiller:_drop_target(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    local level_name = self.RUNTIME.target_level_by_name[smart_name]
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end

    local set = self.RUNTIME.target_set_by_level[level_name]
    local list = self.RUNTIME.targets_by_level[level_name]
    if type(set) == "table" then
        set[smart_name] = nil
    end
    if type(list) == "table" then
        local next_list = {}
        for i = 1, #list do
            if list[i] ~= smart_name then
                next_list[#next_list + 1] = list[i]
            end
        end
        list = next_list
    end

    if type(list) == "table" and #list > 0 and type(set) == "table" and next(set) ~= nil then
        self.RUNTIME.targets_by_level[level_name] = list
        self.RUNTIME.target_set_by_level[level_name] = set
    else
        self.RUNTIME.targets_by_level[level_name] = nil
        self.RUNTIME.target_set_by_level[level_name] = nil
        self.RUNTIME.dirty_targets_by_level[level_name] = nil
        self.RUNTIME.dirty_force_spawn_by_level[level_name] = nil
        if self.RUNTIME.dirty_queue_by_level then self.RUNTIME.dirty_queue_by_level[level_name] = nil end
        if self.RUNTIME.dirty_queue_head_by_level then self.RUNTIME.dirty_queue_head_by_level[level_name] = nil end
        if self.RUNTIME.dirty_queue_tail_by_level then self.RUNTIME.dirty_queue_tail_by_level[level_name] = nil end
    end

    self.RUNTIME.target_level_by_name[smart_name] = nil
    self:_clear_smart_mapping(smart_name)
    self:_refresh_target_stats()
    return true
end

function BaseFiller:_smart_is_config_target(smart_name, level_name)
    if not (type(smart_name) == "string" and smart_name ~= "" and type(level_name) == "string" and level_name ~= "") then
        return false
    end
    local list = zhopa.config and zhopa.config.get_level_bases and zhopa.config.get_level_bases(level_name) or {}
    for i = 1, #list do
        if list[i] == smart_name then
            return true
        end
    end
    return false
end

function BaseFiller:_upsert_target_from_smart(smart, reason)
    local smart_name = object_name(smart)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil, false
    end

    local level_name = zhopa.board_index and zhopa.board_index.get_smart_level and zhopa.board_index.get_smart_level(smart_name) or nil
    if type(level_name) ~= "string" or level_name == "" then
        local gvid = smart and tonumber(smart.m_game_vertex_id) or nil
        level_name = gvid and now_level_name_by_gvid(gvid) or nil
    end
    if type(level_name) ~= "string" or level_name == "" then
        return smart_name, false
    end

    if self:_smart_is_config_target(smart_name, level_name) ~= true then
        self:_drop_target(smart_name)
        return smart_name, false
    end

    local prev_level = self.RUNTIME.target_level_by_name[smart_name]
    if prev_level and prev_level ~= level_name then
        self:_drop_target(smart_name)
    end

    local set = self.RUNTIME.target_set_by_level[level_name]
    local list = self.RUNTIME.targets_by_level[level_name]
    if type(set) ~= "table" then
        set = {}
        self.RUNTIME.target_set_by_level[level_name] = set
    end
    if type(list) ~= "table" then
        list = {}
        self.RUNTIME.targets_by_level[level_name] = list
    end

    if set[smart_name] ~= true then
        set[smart_name] = true
        list[#list + 1] = smart_name
        if table_sort then
            table_sort(list)
        end
        self:_refresh_target_stats()
    end
    self.RUNTIME.target_level_by_name[smart_name] = level_name
    return smart_name, true
end

function BaseFiller:_is_target_smart(smart_name)
    local level_name = self.RUNTIME.target_level_by_name[type(smart_name) == "string" and smart_name or ""]
    return type(level_name) == "string"
        and level_name ~= ""
        and type(self.RUNTIME.target_set_by_level[level_name]) == "table"
        and self.RUNTIME.target_set_by_level[level_name][smart_name] == true
end

function BaseFiller:_reset_dirty_runtime()
    self.RUNTIME.dirty_targets_by_level = {}
    self.RUNTIME.dirty_force_spawn_by_level = {}
    self.RUNTIME.dirty_queue_by_level = {}
    self.RUNTIME.dirty_queue_head_by_level = {}
    self.RUNTIME.dirty_queue_tail_by_level = {}
    self.RUNTIME.dirty_level_queue = {}
    self.RUNTIME.dirty_level_set = {}
    self.RUNTIME.dirty_level_head = 1
    self.RUNTIME.dirty_level_tail = 0
end

function BaseFiller:_mark_level_dirty(level_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    self.RUNTIME.dirty_level_set = type(self.RUNTIME.dirty_level_set) == "table" and self.RUNTIME.dirty_level_set or {}
    if self.RUNTIME.dirty_level_set[level_name] == true then
        return true
    end
    self.RUNTIME.dirty_level_queue = type(self.RUNTIME.dirty_level_queue) == "table" and self.RUNTIME.dirty_level_queue or {}
    local tail = (tonumber(self.RUNTIME.dirty_level_tail) or 0) + 1
    self.RUNTIME.dirty_level_tail = tail
    self.RUNTIME.dirty_level_queue[tail] = level_name
    self.RUNTIME.dirty_level_set[level_name] = true
    return true
end

function BaseFiller:_push_dirty_target(level_name, smart_name)
    if type(level_name) ~= "string" or level_name == "" or type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    self.RUNTIME.dirty_targets_by_level = type(self.RUNTIME.dirty_targets_by_level) == "table" and self.RUNTIME.dirty_targets_by_level or {}
    local dirty = self.RUNTIME.dirty_targets_by_level[level_name]
    if type(dirty) ~= "table" then
        dirty = {}
        self.RUNTIME.dirty_targets_by_level[level_name] = dirty
    end
    if dirty[smart_name] == true then
        return self:_mark_level_dirty(level_name)
    end
    dirty[smart_name] = true
    self.RUNTIME.dirty_queue_by_level = type(self.RUNTIME.dirty_queue_by_level) == "table" and self.RUNTIME.dirty_queue_by_level or {}
    local queue = self.RUNTIME.dirty_queue_by_level[level_name]
    if type(queue) ~= "table" then
        queue = {}
        self.RUNTIME.dirty_queue_by_level[level_name] = queue
    end
    local tail_by_level = self.RUNTIME.dirty_queue_tail_by_level
    if type(tail_by_level) ~= "table" then
        tail_by_level = {}
        self.RUNTIME.dirty_queue_tail_by_level = tail_by_level
    end
    local tail = (tonumber(tail_by_level[level_name]) or 0) + 1
    tail_by_level[level_name] = tail
    queue[tail] = smart_name
    return self:_mark_level_dirty(level_name)
end

function BaseFiller:_pop_dirty_level()
    local queue = type(self.RUNTIME.dirty_level_queue) == "table" and self.RUNTIME.dirty_level_queue or {}
    local head = tonumber(self.RUNTIME.dirty_level_head) or 1
    local tail = tonumber(self.RUNTIME.dirty_level_tail) or 0
    while head <= tail do
        local level_name = queue[head]
        queue[head] = nil
        head = head + 1
        self.RUNTIME.dirty_level_head = head
        if type(level_name) == "string" and level_name ~= "" then
            if self.RUNTIME.dirty_level_set then
                self.RUNTIME.dirty_level_set[level_name] = nil
            end
            if type(self.RUNTIME.dirty_targets_by_level) == "table"
                and type(self.RUNTIME.dirty_targets_by_level[level_name]) == "table"
            then
                return level_name
            end
        end
    end
    self.RUNTIME.dirty_level_queue = {}
    self.RUNTIME.dirty_level_set = {}
    self.RUNTIME.dirty_level_head = 1
    self.RUNTIME.dirty_level_tail = 0
    return nil
end

function BaseFiller:_resolve_target_smart_name_from_squad(se_squad)
    if not se_squad then
        return nil
    end

    local mapped = self.RUNTIME.sid_to_smart[tonumber(se_squad.id) or -1]
    if self:_is_target_smart(mapped) then
        return mapped
    end

    local scripted = type(se_squad.scripted_target) == "string" and se_squad.scripted_target or nil
    if self:_is_target_smart(scripted) then
        return scripted
    end

    local smart_id = tonumber(se_squad.smart_id) or nil
    if smart_id and zhopa.board_index and zhopa.board_index.get_smart_name_by_id then
        local smart_name = zhopa.board_index.get_smart_name_by_id(smart_id)
        if self:_is_target_smart(smart_name) then
            return smart_name
        end
    end

    return nil
end

function BaseFiller:_consume_dirty_targets(level_name)
    local out = {}
    local dirty = type(self.RUNTIME.dirty_targets_by_level) == "table" and self.RUNTIME.dirty_targets_by_level[level_name] or nil
    if type(dirty) ~= "table" then
        return out
    end
    local queue = type(self.RUNTIME.dirty_queue_by_level) == "table" and self.RUNTIME.dirty_queue_by_level[level_name] or {}
    local head_by_level = self.RUNTIME.dirty_queue_head_by_level
    if type(head_by_level) ~= "table" then
        head_by_level = {}
        self.RUNTIME.dirty_queue_head_by_level = head_by_level
    end
    local tail_by_level = self.RUNTIME.dirty_queue_tail_by_level or {}
    local head = tonumber(head_by_level[level_name]) or 1
    local tail = tonumber(tail_by_level[level_name]) or 0
    while head <= tail do
        local smart_name = queue[head]
        queue[head] = nil
        head = head + 1
        head_by_level[level_name] = head
        if self:_is_target_smart(smart_name) then
            out[#out + 1] = smart_name
        end
        if type(smart_name) == "string" then
            dirty[smart_name] = nil
        end
    end
    if next(dirty) == nil then
        self.RUNTIME.dirty_targets_by_level[level_name] = nil
        if self.RUNTIME.dirty_queue_by_level then self.RUNTIME.dirty_queue_by_level[level_name] = nil end
        if self.RUNTIME.dirty_queue_head_by_level then self.RUNTIME.dirty_queue_head_by_level[level_name] = nil end
        if self.RUNTIME.dirty_queue_tail_by_level then self.RUNTIME.dirty_queue_tail_by_level[level_name] = nil end
    end
    return out
end

function BaseFiller:_mark_target_dirty(smart_name, force_spawn, reason)
    local level_name = self.RUNTIME.target_level_by_name[type(smart_name) == "string" and smart_name or ""]
    if type(level_name) ~= "string" or level_name == "" or self:_is_target_smart(smart_name) ~= true then
        return false
    end
    self:_push_dirty_target(level_name, smart_name)
    if force_spawn == true then
        self.RUNTIME.dirty_force_spawn_by_level[level_name] = true
    end
    return self:_run_dirty_reconcile(reason or "dirty")
end

function BaseFiller:_pin_squad_to_smart(board, se_squad, smart_name, smart)
    if not (se_squad and type(smart_name) == "string" and smart_name ~= "") then
        return false
    end
    local section = safe_section(se_squad)
    if not is_base_camper_section(section) then
        self:_warn_throttled(
            "pin_non_camper:" .. tostring(se_squad and se_squad.id or "-"),
            15000,
            "pin_skipped reason=non_camper sid=%s smart=%s section=%s",
            tostring(se_squad and se_squad.id or "-"),
            tostring(smart_name),
            tostring(section or "-")
        )
        return false
    end
    board = board or get_board()
    smart = smart or (board and board.smarts_by_names and board.smarts_by_names[smart_name] or nil)
    if not smart then
        return false
    end

    local smart_id = tonumber(smart.id) or nil
    local changed = false

    if se_squad.scripted_target ~= smart_name then
        se_squad.scripted_target = smart_name
        changed = true
    end
    if smart_id and tonumber(se_squad.assigned_target_id) ~= smart_id then
        se_squad.assigned_target_id = smart_id
        changed = true
    end

    clear_squad_runtime_target(se_squad)

    if smart_id and board and board.assign_squad_to_smart then
        local cur_smart = tonumber(se_squad.smart_id) or nil
        if cur_smart ~= smart_id then
            local ok = pcall(function() board:assign_squad_to_smart(se_squad, smart_id) end)
            if ok then
                changed = true
            end
        end
    end

    if changed then
        self.RUNTIME.stats.pin_reassert = (tonumber(self.RUNTIME.stats.pin_reassert) or 0) + 1
    end
    return true
end

function BaseFiller:_sync_memory_for_camper(se_squad, clear_once)
    if not (se_squad and zhopa.memory) then return end

    local sid = tonumber(se_squad.id)
    local touched = sid and zhopa.memory.get_squad_entry and zhopa.memory.get_squad_entry(sid) or nil
    if sid and clear_once and (not self.RUNTIME.cleaned_sids[sid]) then
        if touched and zhopa.memory.clear_tasks then
            zhopa.memory.clear_tasks(sid)
            self.RUNTIME.cleaned_sids[sid] = true
        end
    end
end

function BaseFiller:_get_npc_info(smart, npc_id)
    if not (smart and type(smart.npc_info) == "table") then
        return nil
    end
    local id = tonumber(npc_id)
    if id then
        return smart.npc_info[id] or smart.npc_info[tostring(id)]
    end
    return smart.npc_info[npc_id]
end

function BaseFiller:_resolve_existing_camper(board, smart_name)
    board = board or get_board()
    if not (board and smart_name) then
        self:_clear_smart_mapping(smart_name)
        return nil, nil
    end

    local sim = alife and alife() or nil
    if not sim then
        self:_clear_smart_mapping(smart_name)
        return nil, nil
    end

    local mapped_sid = tonumber(self.RUNTIME.smart_to_sid[smart_name]) or nil
    if is_valid_server_id(mapped_sid) then
        local ok_obj, mapped = pcall(function() return sim:object(mapped_sid) end)
        if ok_obj and mapped and is_base_camper_section(safe_section(mapped)) then
            return mapped, mapped_sid
        end
        self:_clear_smart_mapping(smart_name)
    end

    local smart = board.smarts_by_names and board.smarts_by_names[smart_name] or nil
    local smart_id = smart and tonumber(smart.id) or nil
    local node = smart_id and board.smarts and board.smarts[smart_id] or nil
    if not (node and type(node.squads) == "table") then
        return nil, nil
    end

    local selected = nil
    local selected_sid = nil
    for sid in pairs(node.squads) do
        local id = tonumber(sid) or sid
        if is_valid_server_id(id) then
            local ok_obj, se_squad = pcall(function() return sim:object(id) end)
            if ok_obj and se_squad and is_base_camper_section(safe_section(se_squad)) then
                if not selected_sid then
                    selected = se_squad
                    selected_sid = tonumber(se_squad.id) or tonumber(id)
                end
            end
        end
    end

    if selected_sid then
        self:_remember_mapping(smart_name, selected_sid)
        self.RUNTIME.stats.discover_hits = (tonumber(self.RUNTIME.stats.discover_hits) or 0) + 1
        return selected, selected_sid
    end
    return nil, nil
end

function BaseFiller:_spawn_via_board(board, smart_name, section)
    if not (board and board.create_squad and board.smarts_by_names) then
        return nil
    end
    local smart = board.smarts_by_names[smart_name]
    if not smart then
        return nil
    end
    local ok, squad = self:_call_with_spawn_override(section, smart_name, function()
        return board:create_squad(smart, section)
    end)
    if ok and squad then
        return squad
    end
    return nil
end

function BaseFiller:_spawn_via_utils_obj(smart_name, section)
    if not (utils_obj and utils_obj.create_squad) then
        return nil
    end
    local ok, squad = self:_call_with_spawn_override(section, smart_name, function()
        return utils_obj.create_squad(section, smart_name)
    end)
    if ok and squad then
        return squad
    end
    return nil
end

function BaseFiller:_spawn_via_alife_fallback(board, smart_name, section)
    board = board or get_board()
    if not (board and board.smarts_by_names) then
        return nil
    end
    local smart = board.smarts_by_names[smart_name]
    if not smart then
        return nil
    end

    local ok, squad = self:_call_with_spawn_override(section, smart_name, function()
        local created_squad = nil
        local sim = alife and alife() or nil
        if sim and sim.create then
            local pos = smart.position
            local lvid = smart.m_level_vertex_id
            local gvid = smart.m_game_vertex_id
            local attempts = {
                function() return sim:create(section, pos, lvid, gvid) end,
                function() return sim:create(section, pos, lvid, gvid, 0, 0) end,
                function() return sim:create(section, lvid, gvid, pos) end,
            }
            for i = 1, #attempts do
                local ok_create, created = pcall(attempts[i])
                if ok_create and created then
                    created_squad = created
                    break
                end
            end
        end

        if (not created_squad) and alife_create then
            local ok_create, created = pcall(function()
                return alife_create(section, smart.position, smart.m_level_vertex_id, smart.m_game_vertex_id)
            end)
            if ok_create and created then
                created_squad = created
            end
        end

        if not created_squad then
            return nil
        end

        if created_squad.create_npc then
            pcall(function() created_squad:create_npc(smart) end)
        end
        if board.assign_squad_to_smart then
            pcall(function() board:assign_squad_to_smart(created_squad, smart.id) end)
        end
        return created_squad
    end)
    if ok and squad then
        return squad
    end
    return nil
end

function BaseFiller:_spawn_camper(board, smart_name)
    board = board or get_board()
    if not (board and board.smarts_by_names and board.smarts_by_names[smart_name]) then
        self.RUNTIME.stats.spawn_failed = (tonumber(self.RUNTIME.stats.spawn_failed) or 0) + 1
        self.RUNTIME.stats.spawn_smart_missing = (tonumber(self.RUNTIME.stats.spawn_smart_missing) or 0) + 1
        self:_warn_throttled("spawn_smart_missing:" .. tostring(smart_name), 30000, "spawn_skipped reason=smart_missing smart=%s", tostring(smart_name))
        return nil, "smart_missing"
    end

    local smart = board.smarts_by_names[smart_name]
    local actor_near, actor_dist_sqr = self:_is_spawn_blocked_near_actor(smart)
    if actor_near then
        self.RUNTIME.stats.spawn_failed = (tonumber(self.RUNTIME.stats.spawn_failed) or 0) + 1
        self.RUNTIME.stats.spawn_blocked_actor_near = (tonumber(self.RUNTIME.stats.spawn_blocked_actor_near) or 0) + 1
        self:_warn_throttled(
            "spawn_actor_near:" .. tostring(smart_name),
            10000,
            "spawn_skipped reason=actor_near smart=%s dist=%s limit=%s",
            tostring(smart_name),
            format_distance_m(actor_dist_sqr),
            tostring(NEAR_ACTOR_BLOCK_DIST_M)
        )
        return nil, "actor_near"
    end

    local faction = self:_pick_faction_for_smart(smart)
    if not faction then
        self.RUNTIME.stats.spawn_failed = (tonumber(self.RUNTIME.stats.spawn_failed) or 0) + 1
        self.RUNTIME.stats.spawn_no_faction = (tonumber(self.RUNTIME.stats.spawn_no_faction) or 0) + 1
        self:_warn_throttled("spawn_no_faction:" .. tostring(smart_name), 30000, "spawn_skipped reason=no_faction smart=%s", tostring(smart_name))
        return nil, "no_faction"
    end
    local section = self:_pick_camper_section(faction)
    if not section then
        self.RUNTIME.stats.spawn_failed = (tonumber(self.RUNTIME.stats.spawn_failed) or 0) + 1
        self.RUNTIME.stats.spawn_no_section = (tonumber(self.RUNTIME.stats.spawn_no_section) or 0) + 1
        self:_warn_throttled(
            "spawn_no_section:" .. tostring(smart_name),
            30000,
            "spawn_skipped reason=no_section smart=%s faction=%s",
            tostring(smart_name),
            tostring(faction)
        )
        return nil, "no_section"
    end

    local allowed, policy_reason = self:_is_spawn_target_allowed(smart_name, smart, faction, section)
    if not allowed then
        self.RUNTIME.stats.spawn_failed = (tonumber(self.RUNTIME.stats.spawn_failed) or 0) + 1
        self.RUNTIME.stats.spawn_blocked_policy = (tonumber(self.RUNTIME.stats.spawn_blocked_policy) or 0) + 1
        self:_warn_throttled(
            "spawn_policy_reject:" .. tostring(policy_reason) .. ":" .. tostring(smart_name),
            10000,
            "spawn_skipped reason=policy_%s smart=%s faction=%s section=%s",
            tostring(policy_reason),
            tostring(smart_name),
            tostring(faction),
            tostring(section)
        )
        return nil, "policy_" .. tostring(policy_reason)
    end

    self.RUNTIME.stats.spawn_attempts = (tonumber(self.RUNTIME.stats.spawn_attempts) or 0) + 1

    local squad = self:_spawn_via_board(board, smart_name, section)
    if not squad then
        squad = self:_spawn_via_utils_obj(smart_name, section)
    end
    if not squad then
        squad = self:_spawn_via_alife_fallback(board, smart_name, section)
    end
    if not squad then
        self.RUNTIME.stats.spawn_failed = (tonumber(self.RUNTIME.stats.spawn_failed) or 0) + 1
        self:_log_warn("spawn_failed smart=%s faction=%s section=%s", tostring(smart_name), tostring(faction), tostring(section))
        return nil, "spawn_failed"
    end
    local spawned_section = safe_section(squad)
    if not is_base_camper_section(spawned_section) then
        self.RUNTIME.stats.spawn_failed = (tonumber(self.RUNTIME.stats.spawn_failed) or 0) + 1
        self.RUNTIME.stats.spawn_section_mismatch = (tonumber(self.RUNTIME.stats.spawn_section_mismatch) or 0) + 1
        self:_warn_throttled(
            "spawn_section_mismatch:" .. tostring(smart_name),
            10000,
            "spawn_reject reason=section_mismatch smart=%s sid=%s expected=%s got=%s",
            tostring(smart_name),
            tostring(squad and squad.id or "-"),
            tostring(section),
            tostring(spawned_section or "-")
        )
        release_squad_safe(squad, "zhopa_base_filler_section_mismatch")
        return nil, "section_mismatch"
    end

    self.RUNTIME.stats.spawn_success = (tonumber(self.RUNTIME.stats.spawn_success) or 0) + 1
    local min_count, max_count = self:_get_spawn_size_range()
    self:_log_info("spawn_success sid=%s smart=%s faction=%s section=%s size_range=%s-%s",
        tostring(squad and squad.id or "-"),
        tostring(smart_name),
        tostring(faction),
        tostring(section),
        tostring(min_count),
        tostring(max_count)
    )
    return squad, nil
end

function BaseFiller:_active_camper_count()
    local total = 0
    local sim = alife and alife() or nil
    if not sim then
        return 0
    end
    for sid, smart_name in pairs(self.RUNTIME.sid_to_smart or {}) do
        local id = tonumber(sid)
        if is_valid_server_id(id) and type(smart_name) == "string" then
            local ok, se_squad = pcall(function() return sim:object(id) end)
            if ok and se_squad and is_base_camper_section(safe_section(se_squad)) then
                total = total + 1
            end
        end
    end
    return total
end

function BaseFiller:_reconcile(force_spawn, full_pass, level_name, target_names)
    local board = get_board()
    if not board then
        return
    end
    local now = tg()
    local targets = type(target_names) == "table" and target_names or {}
    local count = #targets
    if count <= 0 then
        self:_warn_throttled(
            "reconcile_no_targets:" .. tostring(level_name or "-"),
            15000,
            "reconcile_skip reason=no_targets level=%s",
            tostring(level_name or "-")
        )
        return
    end

    for idx = 1, count do
        local smart_name = targets[idx]
        local smart = board.smarts_by_names and board.smarts_by_names[smart_name] or nil
        if smart then
            local camper, sid = self:_resolve_existing_camper(board, smart_name)
            if camper and sid then
                self:_remember_mapping(smart_name, sid)
                self:_pin_squad_to_smart(board, camper, smart_name, smart)
                self:_sync_memory_for_camper(camper, true)
            elseif force_spawn then
                local spawned = self:_spawn_camper(board, smart_name)
                if spawned then
                    local spawned_sid = tonumber(spawned.id)
                    self:_remember_mapping(smart_name, spawned_sid)
                    self:_pin_squad_to_smart(board, spawned, smart_name, smart)
                    self:_sync_memory_for_camper(spawned, true)
                end
            else
                self:_clear_smart_mapping(smart_name)
            end
        else
            self:_clear_smart_mapping(smart_name)
        end
    end
    if full_pass or force_spawn or now >= ((tonumber(self.RUNTIME.last_active_count_tg) or 0) + ACTIVE_CAMPER_COUNT_REFRESH_MS) then
        self.RUNTIME.stats.active_campers = self:_active_camper_count()
        self.RUNTIME.last_active_count_tg = now
    end
    self.RUNTIME.stats.reconcile_runs = (tonumber(self.RUNTIME.stats.reconcile_runs) or 0) + 1
end

function BaseFiller:_run_dirty_reconcile(reason)
    if self.RUNTIME.reconcile_running == true then
        self.RUNTIME.reconcile_pending = true
        return false
    end

    self.RUNTIME.reconcile_running = true
    local ok, err = pcall(function()
        repeat
            self.RUNTIME.reconcile_pending = false

            while true do
                local level_name = self:_pop_dirty_level()
                if not level_name then
                    break
                end
                local targets = self:_consume_dirty_targets(level_name)
                if #targets > 0 then
                    local force_spawn = self.RUNTIME.dirty_force_spawn_by_level[level_name] == true
                        or self:_is_level_refill_due(level_name)
                    self.RUNTIME.dirty_force_spawn_by_level[level_name] = nil
                    self:_reconcile(force_spawn, true, level_name, targets)
                    if force_spawn then
                        self:_mark_level_fill_now(level_name)
                    end
                end
            end
        until self.RUNTIME.reconcile_pending ~= true
    end)
    self.RUNTIME.reconcile_running = false
    if not ok then
        error(err)
    end
    return true
end

function BaseFiller:_mark_dirty_from_squad(se_squad, force_spawn, reason)
    if not se_squad then
        return false
    end
    local smart_name = self:_resolve_target_smart_name_from_squad(se_squad)
    if smart_name then
        return self:_mark_target_dirty(smart_name, force_spawn, reason)
    end
    return false
end

function BaseFiller:_mark_dirty_from_smart(smart, force_spawn, reason)
    local smart_name, is_target = self:_upsert_target_from_smart(smart, reason)
    if is_target ~= true then
        if type(smart_name) == "string" and smart_name ~= "" then
            self:_drop_target(smart_name)
        end
        return false
    end
    return self:_mark_target_dirty(smart_name, force_spawn, reason)
end

function BaseFiller:_reactivate_runtime(reason)
    if not self:_is_enabled() then
        return
    end
    self.RUNTIME.targets_by_level = {}
    self.RUNTIME.target_set_by_level = {}
    self.RUNTIME.target_level_by_name = {}
    self:_reset_dirty_runtime()
    self.RUNTIME.smart_to_sid = {}
    self.RUNTIME.sid_to_smart = {}
    self.RUNTIME.cleaned_sids = {}
    self:_refresh_sections_index()
    self:_sync_targets_from_index()
    self:_mark_all_index_targets_dirty(false, reason)
    self:_run_dirty_reconcile(reason or "reactivate")
end

function BaseFiller:_on_first_update()
    local active_level = loaded_level_name() or "-"
    if not self:_is_enabled() then
        if not self.RUNTIME.disabled_logged then
            self:_log_warn("disabled level=%s source=on_first_update", tostring(active_level))
            self.RUNTIME.disabled_logged = true
        end
        return
    end
    self.RUNTIME.disabled_logged = false

    self:_refresh_sections_index()
    self:_sync_targets_from_index()
    self:_log_info(
        "init level=%s targets=%s factions=%s",
        tostring(active_level),
        tostring(self.RUNTIME.stats.targets or 0),
        tostring(#(self.AVAILABLE_FACTIONS or {}))
    )
    if (tonumber(self.RUNTIME.stats.targets) or 0) <= 0 then
        self:_log_warn("targets_empty level=%s", tostring(active_level))
    end
    self:_log_info(
        "init level=%s total_targets=%s levels=%s loaded_from_save=%s",
        tostring(active_level),
        tostring(self.RUNTIME.stats.targets or 0),
        tostring(count_keys(self.RUNTIME.targets_by_level)),
        tostring(self.RUNTIME.loaded_from_save == true)
    )
    self:_mark_all_index_targets_dirty(false, "first_update")
    self:_run_dirty_reconcile("first_update")
    self:_log_info(
        "first_fill_done level=%s spawned=%s failed=%s active=%s",
        tostring(active_level),
        tostring(self.RUNTIME.stats.spawn_success or 0),
        tostring(self.RUNTIME.stats.spawn_failed or 0),
        tostring(self.RUNTIME.stats.active_campers or 0)
    )
    self.RUNTIME.initial_fill_done = true
    self.RUNTIME.last_update_tg = tg()
end

function BaseFiller:_save_state(m_data)
    if not m_data then
        return
    end
    local out = {
        version = STATE_VERSION,
        last_fill_gt_by_level = {},
        default_last_fill_gt = clone_ctime_table(self.STATE and self.STATE.default_last_fill_gt),
    }
    for level_name, mark in pairs(self.STATE and self.STATE.last_fill_gt_by_level or {}) do
        local key = type(level_name) == "string" and level_name or nil
        local stamp = clone_ctime_table(mark)
        if key and key ~= "" and stamp then
            out.last_fill_gt_by_level[key] = stamp
        end
    end
    m_data.zhopa_base_filler_state = out
end

function BaseFiller:_load_state(m_data)
    self.RUNTIME.loaded_from_save = true
    self.RUNTIME.initial_fill_done = false
    self.RUNTIME.targets_by_level = {}
    self.RUNTIME.target_set_by_level = {}
    self.RUNTIME.target_level_by_name = {}
    self:_reset_dirty_runtime()
    self.RUNTIME.smart_to_sid = {}
    self.RUNTIME.sid_to_smart = {}
    self.RUNTIME.cleaned_sids = {}
    self.RUNTIME.reconcile_running = false
    self.RUNTIME.reconcile_pending = false

    local loaded = m_data and m_data.zhopa_base_filler_state or nil
    if type(loaded) == "table" then
        local state = {
            version = STATE_VERSION,
            last_fill_gt_by_level = {},
            default_last_fill_gt = clone_ctime_table(loaded.default_last_fill_gt),
        }
        for level_name, mark in pairs(type(loaded.last_fill_gt_by_level) == "table" and loaded.last_fill_gt_by_level or {}) do
            local key = type(level_name) == "string" and level_name or nil
            local stamp = clone_ctime_table(mark)
            if key and key ~= "" and stamp then
                state.last_fill_gt_by_level[key] = stamp
            end
        end
        self.STATE = state
        self.RUNTIME.loaded_state_present = true
        self:_log_info(
            "load_state restored levels=%s default_mark=%s",
            tostring(count_keys(state.last_fill_gt_by_level)),
            tostring(state.default_last_fill_gt ~= nil)
        )
        return
    end

    self.STATE = {
        version = STATE_VERSION,
        last_fill_gt_by_level = {},
        default_last_fill_gt = nil,
    }
    self.RUNTIME.loaded_state_present = false
    self:_log_info("load_state empty_state=true")
end

local inst = BaseFiller.new and BaseFiller.new() or setmetatable({}, BaseFiller)
if not inst.RUNTIME then
    BaseFiller.__init(inst)
end

inst.on_first_update = function() return inst:_on_first_update() end
inst.save_state = function(m_data) return inst:_save_state(m_data) end
inst.load_state = function(m_data) return inst:_load_state(m_data) end
inst.on_load_state = function() return inst:_reactivate_runtime("load_state") end
inst.on_option_change = function() return inst:_reactivate_runtime("option_change") end
inst.wants_smart_update = function(smart, ctx)
    if inst:_is_enabled() ~= true then
        return false
    end
    local smart_name = type(ctx) == "table" and ctx.name or object_name(smart)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    if inst:_is_target_smart(smart_name) then
        return true
    end
    local level_name = type(ctx) == "table" and ctx.level_name or nil
    return inst:_smart_is_config_target(smart_name, level_name)
end
inst.on_smart_terrain_update = function(smart, ctx) return inst:_mark_dirty_from_smart(smart, false, "smart_update") end
inst.on_server_entity_unregister = function(se_obj)
    local smart_name = object_name(se_obj)
    if inst:_is_target_smart(smart_name) then
        inst:_drop_target(smart_name)
        return
    end
    local sid = tonumber(se_obj and se_obj.id) or nil
    smart_name = sid and inst.RUNTIME.sid_to_smart[sid] or nil
    if sid then
        inst.RUNTIME.sid_to_smart[sid] = nil
    end
    if type(smart_name) == "string" and smart_name ~= "" then
        inst.RUNTIME.smart_to_sid[smart_name] = nil
        inst:_mark_target_dirty(smart_name, false, "server_unregister")
    end
end
inst.is_base_camper_section = function(section) return is_base_camper_section(section) end
inst.on_squad_enter_smart = function(squad) return inst:_mark_dirty_from_squad(squad, false, "enter_smart") end
inst.on_squad_leave_smart = function(squad) return inst:_mark_dirty_from_squad(squad, false, "leave_smart") end
inst.on_squad_after_level_change = function(squad) return inst:_mark_dirty_from_squad(squad, false, "after_level_change") end
inst.on_squad_npc_creation = function(squad) return inst:_mark_dirty_from_squad(squad, false, "npc_creation") end
inst.on_squad_npc_death = function(squad) return inst:_mark_dirty_from_squad(squad, false, "npc_death") end

zhopa.base_filler = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_base_filler

-- BEGIN module zhopa_dynamic_bases
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local setmetatable = _G.setmetatable
local tonumber = _G.tonumber
local tostring = _G.tostring
local pairs = _G.pairs
local string_lower = _G.string and _G.string.lower or nil
local string_gsub = _G.string and _G.string.gsub or nil
local string_find = _G.string and _G.string.find or nil
local table_sort = _G.table and _G.table.sort or nil
local table_concat = _G.table and _G.table.concat or nil
local time_global = _G.time_global
local alife = _G.alife
local game_graph = _G.game_graph
local game_relations = _G.game_relations


local DynamicBases = zhopa.class("DynamicBases")
DynamicBases.__index = DynamicBases

local STATE_VERSION = "1.0.1"
local DYNAMIC_RESPAWN_PREFIX = "faction_controlled_"

local SUPPORTED_FACTIONS = {
    "stalker",
    "bandit",
    "duty",
    "freedom",
    "merc",
    "army",
    "ecolog",
    "monolith",
    "csky",
    "renegade",
    "greh",
    "isg",
}

local ENGINE_BY_ALIAS = {
    stalker = "stalker",
    bandit = "bandit",
    duty = "dolg",
    freedom = "freedom",
    merc = "killer",
    army = "army",
    ecolog = "ecolog",
    monolith = "monolith",
    csky = "csky",
    renegade = "renegade",
    greh = "greh",
    isg = "isg",
}

local ALIAS_BY_ENGINE = {
    stalker = "stalker",
    bandit = "bandit",
    dolg = "duty",
    duty = "duty",
    freedom = "freedom",
    killer = "merc",
    merc = "merc",
    army = "army",
    military = "army",
    ecolog = "ecolog",
    monolith = "monolith",
    csky = "csky",
    renegade = "renegade",
    greh = "greh",
    isg = "isg",
}

local SQUADS_BY_FACTION = {
    army = { "army_sim_squad_novice", "army_sim_squad_advanced", "army_sim_squad_veteran" },
    bandit = { "bandit_sim_squad_novice", "bandit_sim_squad_advanced", "bandit_sim_squad_veteran" },
    csky = { "csky_sim_squad_novice", "csky_sim_squad_advanced", "csky_sim_squad_veteran" },
    dolg = { "duty_sim_squad_novice", "duty_sim_squad_advanced", "duty_sim_squad_veteran" },
    ecolog = { "ecolog_sim_squad_novice", "ecolog_sim_squad_advanced", "ecolog_sim_squad_veteran" },
    freedom = { "freedom_sim_squad_novice", "freedom_sim_squad_advanced", "freedom_sim_squad_veteran" },
    killer = { "merc_sim_squad_novice", "merc_sim_squad_advanced", "merc_sim_squad_veteran" },
    monolith = { "monolith_sim_squad_novice", "monolith_sim_squad_advanced", "monolith_sim_squad_veteran" },
    stalker = { "stalker_sim_squad_novice", "stalker_sim_squad_advanced", "stalker_sim_squad_veteran" },
    renegade = { "renegade_sim_squad_novice", "renegade_sim_squad_advanced", "renegade_sim_squad_veteran" },
    greh = { "greh_sim_squad_novice", "greh_sim_squad_advanced", "greh_sim_squad_veteran" },
    isg = { "isg_sim_squad_novice", "isg_sim_squad_advanced", "isg_sim_squad_veteran" },
}

local function now_level_name_by_gvid(gvid)
    if not (gvid and alife and game_graph) then
        return nil
    end
    local ok, level_name = pcall(function()
        local gv = game_graph():vertex(gvid)
        if not gv then
            return nil
        end
        return alife():level_name(gv:level_id())
    end)
    return ok and level_name or nil
end

local function tg()
    return (time_global and time_global()) or 0
end

local function get_board()
    if SIMBOARD then
        return SIMBOARD
    end
    if sim_board and sim_board.get_sim_board then
        local ok, board = pcall(function() return sim_board.get_sim_board() end)
        if ok then
            return board
        end
    end
    return nil
end

local function object_name(obj)
    if type(obj) ~= "table" then
        return nil
    end
    local raw_name = obj.name
    if type(raw_name) == "string" and raw_name ~= "" then
        return raw_name
    end
    local ok_name, res_name = pcall(function()
        return obj:name()
    end)
    if ok_name and type(res_name) == "string" and res_name ~= "" then
        return res_name
    end
    return nil
end

local function count_keys(src)
    local total = 0
    if type(src) ~= "table" then
        return total
    end
    for _ in pairs(src) do
        total = total + 1
    end
    return total
end

local function clone_list(src)
    if type(src) ~= "table" then
        return nil
    end
    local out = {}
    for i = 1, #src do
        out[i] = src[i]
    end
    return out
end

local function clone_nonempty_list(src)
    local out = clone_list(src)
    if type(out) ~= "table" or #out <= 0 then
        return nil
    end
    return out
end

local function clone_respawn_params(src)
    local out = {}
    if type(src) ~= "table" then
        return out
    end
    for key, value in pairs(src) do
        if type(key) == "string" and type(value) == "table" then
            local entry = {
                num = value.num,
                faction = value.faction,
            }
            local squads = clone_nonempty_list(value.squads)
            local helicopter = clone_nonempty_list(value.helicopter)
            if squads then
                entry.squads = squads
            end
            if helicopter then
                entry.helicopter = helicopter
            end
            out[key] = entry
        end
    end
    return out
end

local function clone_already_spawned(src)
    local out = {}
    if type(src) ~= "table" then
        return out
    end
    for key, value in pairs(src) do
        if type(key) == "string" then
            out[key] = { num = tonumber(type(value) == "table" and value.num or 0) or 0 }
        end
    end
    return out
end

local function clone_original_entry(src)
    if type(src) ~= "table" then
        return nil
    end
    return {
        faction_controlled = src.faction_controlled,
        respawn_params = clone_respawn_params(src.respawn_params),
        already_spawned = clone_already_spawned(src.already_spawned),
    }
end

local function clone_original_by_name(src)
    local out = {}
    if type(src) ~= "table" then
        return out
    end
    for smart_name, original in pairs(src) do
        if type(smart_name) == "string" and smart_name ~= "" then
            local cloned = clone_original_entry(original)
            if cloned then
                out[smart_name] = cloned
            end
        end
    end
    return out
end

local function is_dynamic_respawn_key(key)
    return type(key) == "string"
        and key ~= ""
        and string_find
        and string_find(key, DYNAMIC_RESPAWN_PREFIX, 1, true) == 1
end

local function normalize_alias(name)
    if type(name) ~= "string" then
        return nil
    end
    local key = name
    if string_gsub then
        key = string_gsub(key, "^%s*(.-)%s*$", "%1")
    end
    if string_lower then
        key = string_lower(key)
    end
    if key == "" then
        return nil
    end
    if zhopa.config and zhopa.config.get_faction_alias then
        local alias = zhopa.config.get_faction_alias(key)
        if type(alias) == "string" and alias ~= "" then
            key = string_lower and string_lower(alias) or alias
        end
    end
    return ALIAS_BY_ENGINE[key] or key
end

local function alias_to_engine(alias)
    alias = normalize_alias(alias)
    return alias and ENGINE_BY_ALIAS[alias] or nil
end

local function is_supported_alias(alias)
    return alias ~= nil and ENGINE_BY_ALIAS[alias] ~= nil
end

local function community_alias_from_obj(se_obj)
    if not se_obj then
        return nil
    end
    local raw = nil
    if zhopa.safe and zhopa.safe.safe_community then
        raw = zhopa.safe.safe_community(se_obj)
    else
        local ok_raw, value = pcall(function() return se_obj:community() end)
        raw = ok_raw and value or nil
    end
    return normalize_alias(raw)
end

local function factions_signature(src)
    if type(src) ~= "table" or not table_concat then
        return "-"
    end
    local out = {}
    for alias in pairs(src) do
        if type(alias) == "string" and alias ~= "" then
            out[#out + 1] = alias
        end
    end
    if #out <= 0 then
        return "-"
    end
    if table_sort then
        table_sort(out)
    end
    return table_concat(out, ",")
end

local function collect_live_stalker_factions(smart)
    local factions_present = {}
    local stalker_count = 0
    local last_alias = nil
    if not (smart and type(smart.npc_info) == "table") then
        return factions_present, stalker_count, false, last_alias
    end
    for _, info in pairs(smart.npc_info) do
        local se_obj = type(info) == "table" and info.se_obj or nil
        if se_obj and IsStalker then
            local ok, clsid = pcall(function() return se_obj:clsid() end)
            if ok and IsStalker(nil, clsid) then
                stalker_count = stalker_count + 1
                local alias = community_alias_from_obj(se_obj)
                if is_supported_alias(alias) then
                    factions_present[alias] = true
                    last_alias = alias
                end
            end
        end
    end

    local faction_war = false
    if game_relations and game_relations.is_factions_enemies then
        for a in pairs(factions_present) do
            local engine_a = alias_to_engine(a)
            if engine_a then
                for b in pairs(factions_present) do
                    if a ~= b then
                        local engine_b = alias_to_engine(b)
                        if engine_b then
                            local ok_enemy, hostile = pcall(function()
                                return game_relations.is_factions_enemies(engine_a, engine_b)
                            end)
                            if ok_enemy and hostile == true then
                                faction_war = true
                                break
                            end
                        end
                    end
                end
            end
            if faction_war then
                break
            end
        end
    end

    return factions_present, stalker_count, faction_war, last_alias
end

local function is_base_respawn_smart(smart)
    if not smart then
        return false
    end
    local props = type(smart.props) == "table" and smart.props or nil
    local base = props and tonumber(props.base) or 0
    if base <= 0 then
        return false
    end
    if smart.respawn_point ~= true then
        return false
    end
    return type(smart.respawn_params) == "table"
end

local function key_signature(src)
    if type(src) ~= "table" then
        return "-"
    end
    local keys = {}
    local n = 0
    for key in pairs(src) do
        n = n + 1
        keys[n] = tostring(key)
    end
    if table_sort then
        table_sort(keys)
    end
    if table_concat then
        return table_concat(keys, ",")
    end
    local out = ""
    for i = 1, #keys do
        out = out .. keys[i] .. ","
    end
    return out
end

function DynamicBases:__init()
    self.STATE = {
        version = STATE_VERSION,
    }
    self.RUNTIME = {
        active_enabled = false,
        disabled_logged = false,
        targets = {},
        target_set = {},
        dirty_targets = {},
        dirty_queue = {},
        dirty_queue_head = 1,
        dirty_queue_tail = 0,
        original_by_name = {},
        applied_signature_by_name = {},
        owner_by_name = {},
        stats = {
            ticks = 0,
            targets = 0,
            touched = 0,
            updated = 0,
            owner_changed = 0,
            cleared = 0,
            restored = 0,
            skipped_no_template = 0,
            skipped_ap_owned = 0,
        },
    }
end

function DynamicBases:_is_enabled()
    if zhopa.runtime_cfg and zhopa.runtime_cfg.get then
        return zhopa.runtime_cfg.get("enabled", true) == true
            and zhopa.runtime_cfg.get("dynamic_bases_enabled", false) == true
    end
    if not (zhopa.config and zhopa.config.get) then return false end
    if zhopa.config.get("enabled", true) ~= true then
        return false
    end
    return zhopa.config.get("dynamic_bases_enabled", false) == true
end

function DynamicBases:_num_cfg(key, default, min_v)
    local value = default
    if zhopa.runtime_cfg and zhopa.runtime_cfg.num then
        return zhopa.runtime_cfg.num(key, value, min_v)
    end
    if zhopa.config and zhopa.config.get then
        local read = zhopa.config.get(key, default)
        if tonumber(read) then
            value = tonumber(read)
        end
    end
    if min_v ~= nil and value < min_v then
        value = min_v
    end
    return value
end

function DynamicBases:_log_info(fmt, ...)
    if zhopa.log and zhopa.log.info then
        zhopa.log.info("DYNAMIC_BASES", fmt, ...)
    end
end

function DynamicBases:_log_warn(fmt, ...)
    if zhopa.log and zhopa.log.warn then
        zhopa.log.warn("DYNAMIC_BASES", fmt, ...)
    end
end

function DynamicBases:_capture_original(smart_name, smart)
    if type(smart_name) ~= "string" or smart_name == "" or not smart then
        return
    end
    if self.RUNTIME.original_by_name[smart_name] ~= nil then
        return
    end
    self.RUNTIME.original_by_name[smart_name] = {
        faction_controlled = smart.faction_controlled,
        respawn_params = clone_respawn_params(smart.respawn_params),
        already_spawned = clone_already_spawned(smart.already_spawned),
    }
    self.RUNTIME.stats.touched = count_keys(self.RUNTIME.original_by_name)
end

function DynamicBases:_restore_all()
    local board = get_board()
    if not (board and board.smarts_by_names) then
        self.RUNTIME.original_by_name = {}
        self.RUNTIME.applied_signature_by_name = {}
        self.RUNTIME.owner_by_name = {}
        self.RUNTIME.stats.touched = 0
        return
    end

    local restored = 0
    for smart_name, original in pairs(self.RUNTIME.original_by_name) do
        local smart = board.smarts_by_names[smart_name]
        if smart and type(original) == "table" then
            smart.faction_controlled = original.faction_controlled
            smart.respawn_params = clone_respawn_params(original.respawn_params)
            smart.already_spawned = clone_already_spawned(original.already_spawned)
            restored = restored + 1
        end
    end

    self.RUNTIME.original_by_name = {}
    self.RUNTIME.applied_signature_by_name = {}
    self.RUNTIME.owner_by_name = {}
    self.RUNTIME.stats.restored = (tonumber(self.RUNTIME.stats.restored) or 0) + restored
    self.RUNTIME.stats.touched = 0
    self:_log_info("restored count=%s", tostring(restored))
end

function DynamicBases:_resolve_num_template(smart_name, smart)
    local original = self.RUNTIME.original_by_name[smart_name]
    local params = original and original.respawn_params or smart and smart.respawn_params or nil
    if type(params) ~= "table" then
        return nil
    end
    for _, value in pairs(params) do
        if type(value) == "table" and value.num ~= nil then
            return value.num
        end
    end
    return nil
end

function DynamicBases:_refresh_target_list()
    local targets = {}
    for smart_name in pairs(self.RUNTIME.target_set or {}) do
        targets[#targets + 1] = smart_name
    end
    if table_sort then
        table_sort(targets)
    end
    self.RUNTIME.targets = targets
    self.RUNTIME.stats.targets = #targets
end

function DynamicBases:_restore_target(smart_name, smart)
    local original = self.RUNTIME.original_by_name[smart_name]
    if smart and type(original) == "table" then
        smart.faction_controlled = original.faction_controlled
        smart.respawn_params = clone_respawn_params(original.respawn_params)
        smart.already_spawned = clone_already_spawned(original.already_spawned)
        self.RUNTIME.stats.restored = (tonumber(self.RUNTIME.stats.restored) or 0) + 1
    end
    self.RUNTIME.original_by_name[smart_name] = nil
    self.RUNTIME.applied_signature_by_name[smart_name] = nil
    self.RUNTIME.owner_by_name[smart_name] = nil
    self.RUNTIME.dirty_targets[smart_name] = nil
    self.RUNTIME.stats.touched = count_keys(self.RUNTIME.original_by_name)
end

function DynamicBases:_forget_target(smart_name, restore_current)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    if self.RUNTIME.target_set[smart_name] ~= true then
        self:_restore_target(smart_name, nil)
        return false
    end

    local smart = nil
    if restore_current == true then
        local board = get_board()
        smart = board and board.smarts_by_names and board.smarts_by_names[smart_name] or nil
    end

    self.RUNTIME.target_set[smart_name] = nil
    self:_restore_target(smart_name, smart)
    self:_refresh_target_list()
    return true
end

function DynamicBases:_sync_targets_from_index()
    local board_index = zhopa.board_index
    if not (board_index and board_index.get_known_smart_levels and board_index.get_respawn_base_smarts) then
        self.RUNTIME.targets = {}
        self.RUNTIME.target_set = {}
        self.RUNTIME.stats.targets = 0
        return
    end

    local next_set = {}
    local levels = board_index.get_known_smart_levels() or {}
    for i = 1, #levels do
        local level_name = levels[i]
        local list = board_index.get_respawn_base_smarts(level_name) or {}
        for j = 1, #list do
            local smart_name = list[j]
            if type(smart_name) == "string" and smart_name ~= "" then
                next_set[smart_name] = true
            end
        end
    end

    for smart_name in pairs(self.RUNTIME.target_set or {}) do
        if next_set[smart_name] ~= true then
            self:_forget_target(smart_name, true)
        end
    end

    self.RUNTIME.target_set = next_set
    self:_refresh_target_list()
end

function DynamicBases:_resolve_effective_owner_alias(smart)
    local raw_faction = smart and smart.faction or nil
    local owner = normalize_alias(raw_faction)
    local factions_present, stalker_count, faction_war, live_alias = collect_live_stalker_factions(smart)
    if stalker_count <= 0 then
        return nil, "no_stalker_presence", stalker_count, factions_signature(factions_present), raw_faction
    end
    if is_supported_alias(owner) and factions_present[owner] == true then
        return owner, "smart.faction", stalker_count, factions_signature(factions_present), raw_faction
    end
    if not faction_war and is_supported_alias(live_alias) then
        return live_alias, "live_presence", stalker_count, factions_signature(factions_present), raw_faction
    end
    if faction_war then
        return nil, "faction_war", stalker_count, factions_signature(factions_present), raw_faction
    end
    return nil, "unsupported_or_nil_faction", stalker_count, factions_signature(factions_present), raw_faction
end

function DynamicBases:_collect_allowed_factions(owner_alias)
    local out = {}
    local owner_engine = alias_to_engine(owner_alias)
    if not owner_engine then
        return out
    end

    for i = 1, #SUPPORTED_FACTIONS do
        local alias = SUPPORTED_FACTIONS[i]
        local engine = alias_to_engine(alias)
        if engine then
            if engine == owner_engine then
                out[#out + 1] = engine
            elseif game_relations and game_relations.is_factions_friends then
                local ok_f, friends = pcall(function()
                    return game_relations.is_factions_friends(owner_engine, engine)
                end)
                local enemies = false
                if game_relations.is_factions_enemies then
                    local ok_e, hostile = pcall(function()
                        return game_relations.is_factions_enemies(owner_engine, engine)
                    end)
                    enemies = ok_e and hostile == true or false
                end
                if ok_f and friends == true and enemies ~= true then
                    out[#out + 1] = engine
                end
            end
        end
    end

    if table_sort then
        table_sort(out)
    end
    return out
end

function DynamicBases:_build_respawn_params(owner_alias, num_template)
    local params = {}
    if not (owner_alias and num_template ~= nil) then
        return params
    end

    local allowed = self:_collect_allowed_factions(owner_alias)
    for i = 1, #allowed do
        local faction = allowed[i]
        local squads = SQUADS_BY_FACTION[faction]
        if squads and #squads > 0 then
            local key = "faction_controlled_" .. faction
            params[key] = {
                num = num_template,
                squads = clone_list(squads),
                faction = faction,
            }
        end
    end
    return params
end

function DynamicBases:_rebuild_respawn_params(existing, params)
    local out = {}
    for key, value in pairs(type(existing) == "table" and existing or {}) do
        if type(key) == "string" and type(value) == "table" and not is_dynamic_respawn_key(key) then
            local entry = {
                num = value.num,
                faction = value.faction,
            }
            local squads = clone_nonempty_list(value.squads)
            local helicopter = clone_nonempty_list(value.helicopter)
            if squads then
                entry.squads = squads
            end
            if helicopter then
                entry.helicopter = helicopter
            end
            out[key] = entry
        end
    end

    for key, value in pairs(type(params) == "table" and params or {}) do
        if type(key) == "string" and type(value) == "table" then
            local entry = {
                num = value.num,
                faction = value.faction,
            }
            local squads = clone_nonempty_list(value.squads)
            local helicopter = clone_nonempty_list(value.helicopter)
            if squads then
                entry.squads = squads
            end
            if helicopter then
                entry.helicopter = helicopter
            end
            out[key] = entry
        end
    end

    return out
end

function DynamicBases:_rebuild_already_spawned(existing, params)
    local out = {}
    for key, value in pairs(type(existing) == "table" and existing or {}) do
        if type(key) == "string" then
            out[key] = { num = tonumber(type(value) == "table" and value.num or 0) or 0 }
        end
    end
    for key in pairs(params or {}) do
        local num = tonumber(type(existing) == "table" and existing[key] and existing[key].num or 0) or 0
        out[key] = { num = num }
    end
    return out
end

function DynamicBases:_is_target_smart(smart_name)
    return type(smart_name) == "string"
        and smart_name ~= ""
        and type(self.RUNTIME.target_set) == "table"
        and self.RUNTIME.target_set[smart_name] == true
end

function DynamicBases:_upsert_target_from_smart(smart, source)
    local smart_name = object_name(smart)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil, false
    end

    if not is_base_respawn_smart(smart) then
        self:_forget_target(smart_name, true)
        return smart_name, false
    end

    if self.RUNTIME.target_set[smart_name] ~= true then
        self.RUNTIME.target_set[smart_name] = true
        self:_refresh_target_list()
    end
    return smart_name, true
end

function DynamicBases:_resolve_target_smart_name_from_squad(se_squad)
    if not se_squad then
        return nil
    end

    local scripted = type(se_squad.scripted_target) == "string" and se_squad.scripted_target or nil
    if self:_is_target_smart(scripted) then
        return scripted
    end

    local smart_id = tonumber(se_squad.smart_id) or nil
    if smart_id and zhopa.board_index and zhopa.board_index.get_smart_name_by_id then
        local smart_name = zhopa.board_index.get_smart_name_by_id(smart_id)
        if self:_is_target_smart(smart_name) then
            return smart_name
        end
    end

    return nil
end

function DynamicBases:_consume_dirty_targets()
    local out = {}
    local dirty = type(self.RUNTIME.dirty_targets) == "table" and self.RUNTIME.dirty_targets or {}
    local queue = type(self.RUNTIME.dirty_queue) == "table" and self.RUNTIME.dirty_queue or {}
    local head = tonumber(self.RUNTIME.dirty_queue_head) or 1
    local tail = tonumber(self.RUNTIME.dirty_queue_tail) or 0
    while head <= tail do
        local smart_name = queue[head]
        queue[head] = nil
        head = head + 1
        self.RUNTIME.dirty_queue_head = head
        if self:_is_target_smart(smart_name) then
            out[#out + 1] = smart_name
        end
        if type(smart_name) == "string" then
            dirty[smart_name] = nil
        end
    end
    self.RUNTIME.dirty_targets = dirty
    if next(dirty) == nil then
        self.RUNTIME.dirty_queue = {}
        self.RUNTIME.dirty_queue_head = 1
        self.RUNTIME.dirty_queue_tail = 0
    end
    return out
end

function DynamicBases:_mark_target_dirty(smart_name, reason)
    if not self:_is_target_smart(smart_name) then
        return false
    end
    self.RUNTIME.dirty_targets = type(self.RUNTIME.dirty_targets) == "table" and self.RUNTIME.dirty_targets or {}
    if self.RUNTIME.dirty_targets[smart_name] ~= true then
        local tail = (tonumber(self.RUNTIME.dirty_queue_tail) or 0) + 1
        self.RUNTIME.dirty_queue_tail = tail
        self.RUNTIME.dirty_queue = type(self.RUNTIME.dirty_queue) == "table" and self.RUNTIME.dirty_queue or {}
        self.RUNTIME.dirty_queue[tail] = smart_name
    end
    self.RUNTIME.dirty_targets[smart_name] = true
    return self:_run_dirty_reconcile(reason or "dirty")
end

function DynamicBases:_process_smart(board, smart_name)
    local smart = board and board.smarts_by_names and board.smarts_by_names[smart_name] or nil
    if not is_base_respawn_smart(smart) then
        return
    end
    self:_capture_original(smart_name, smart)

    local owner_alias, owner_source, stalker_count, factions_sig, raw_faction = self:_resolve_effective_owner_alias(smart)
    local prev_owner = self.RUNTIME.owner_by_name[smart_name]
    if prev_owner ~= owner_alias then
        self.RUNTIME.owner_by_name[smart_name] = owner_alias
        self.RUNTIME.stats.owner_changed = (tonumber(self.RUNTIME.stats.owner_changed) or 0) + 1
    end

    local num_template = self:_resolve_num_template(smart_name, smart)
    if owner_alias and num_template == nil then
        self.RUNTIME.stats.skipped_no_template = (tonumber(self.RUNTIME.stats.skipped_no_template) or 0) + 1
        self:_log_warn("skip_no_template smart=%s owner=%s", tostring(smart_name), tostring(owner_alias))
        return
    end

    local params = self:_build_respawn_params(owner_alias, num_template)
    local signature = tostring(owner_alias or "none") .. "|" .. key_signature(params)
    if self.RUNTIME.applied_signature_by_name[smart_name] == signature then
        return
    end

    smart.faction_controlled = nil
    smart.respawn_params = self:_rebuild_respawn_params(smart.respawn_params, params)
    smart.already_spawned = self:_rebuild_already_spawned(smart.already_spawned, params)
    self.RUNTIME.applied_signature_by_name[smart_name] = signature
    self.RUNTIME.stats.updated = (tonumber(self.RUNTIME.stats.updated) or 0) + 1
    if owner_alias == nil then
        self.RUNTIME.stats.cleared = (tonumber(self.RUNTIME.stats.cleared) or 0) + 1
    end

    if owner_alias == nil or owner_source ~= "smart.faction" then
        self:_log_info(
            "apply smart=%s owner=%s groups=%s source=%s stalkers=%s factions=%s raw=%s",
            tostring(smart_name),
            tostring(owner_alias or "none"),
            tostring(count_keys(params)),
            tostring(owner_source or "-"),
            tostring(stalker_count or 0),
            tostring(factions_sig or "-"),
            tostring(raw_faction or "-")
        )
    else
        self:_log_info(
            "apply smart=%s owner=%s groups=%s",
            tostring(smart_name),
            tostring(owner_alias),
            tostring(count_keys(params))
        )
    end
end

function DynamicBases:_run_dirty_reconcile(reason)
    if self.RUNTIME.reconcile_running == true then
        self.RUNTIME.reconcile_pending = true
        return false
    end

    self.RUNTIME.reconcile_running = true
    local ok, err = pcall(function()
        repeat
            self.RUNTIME.reconcile_pending = false

    if not self:_is_enabled() then
        if self.RUNTIME.active_enabled == true then
            self:_restore_all()
        end
        self.RUNTIME.active_enabled = false
        if not self.RUNTIME.disabled_logged then
            self:_log_info("disabled")
            self.RUNTIME.disabled_logged = true
        end
        return
    end

    self.RUNTIME.disabled_logged = false
    self.RUNTIME.active_enabled = true
    self.RUNTIME.stats.ticks = (tonumber(self.RUNTIME.stats.ticks) or 0) + 1

    local board = get_board()
    local targets = self:_consume_dirty_targets()
    if #targets <= 0 then
        return
    end
    for i = 1, #targets do
        self:_process_smart(board, targets[i])
    end
        until self.RUNTIME.reconcile_pending ~= true
    end)
    self.RUNTIME.reconcile_running = false
    if not ok then
        error(err)
    end
    return true
end

function DynamicBases:_reactivate_runtime(reason)
    if not self:_is_enabled() then
        if self.RUNTIME.active_enabled == true then
            self:_restore_all()
        end
        self.RUNTIME.active_enabled = false
        return
    end
    self.RUNTIME.disabled_logged = false
    self.RUNTIME.active_enabled = true
    self:_sync_targets_from_index()
    self.RUNTIME.dirty_targets = {}
    self.RUNTIME.dirty_queue = {}
    self.RUNTIME.dirty_queue_head = 1
    self.RUNTIME.dirty_queue_tail = 0
    for i = 1, #(self.RUNTIME.targets or {}) do
        local smart_name = self.RUNTIME.targets[i]
        if self:_is_target_smart(smart_name) then
            local tail = (tonumber(self.RUNTIME.dirty_queue_tail) or 0) + 1
            self.RUNTIME.dirty_queue_tail = tail
            self.RUNTIME.dirty_queue[tail] = smart_name
            self.RUNTIME.dirty_targets[smart_name] = true
        end
    end
    self:_run_dirty_reconcile(reason or "reactivate")
end

function DynamicBases:_on_first_update()
    self:_reactivate_runtime("first_update")
end

function DynamicBases:_save_state(m_data)
    if not m_data then
        return
    end
    m_data.zhopa_dynamic_bases_state = {
        version = STATE_VERSION,
        original_by_name = clone_original_by_name(self.RUNTIME.original_by_name),
    }
end

function DynamicBases:_load_state(m_data)
    local loaded = m_data and m_data.zhopa_dynamic_bases_state or nil
    self.STATE = {
        version = type(loaded) == "table" and loaded.version or STATE_VERSION,
    }
    self.RUNTIME.targets = {}
    self.RUNTIME.target_set = {}
    self.RUNTIME.dirty_targets = {}
    self.RUNTIME.dirty_queue = {}
    self.RUNTIME.dirty_queue_head = 1
    self.RUNTIME.dirty_queue_tail = 0
    self.RUNTIME.original_by_name = clone_original_by_name(type(loaded) == "table" and loaded.original_by_name or nil)
    self.RUNTIME.applied_signature_by_name = {}
    self.RUNTIME.owner_by_name = {}
    self.RUNTIME.active_enabled = false
    self.RUNTIME.disabled_logged = false
    self.RUNTIME.stats.touched = count_keys(self.RUNTIME.original_by_name)
    self.RUNTIME.reconcile_running = false
    self.RUNTIME.reconcile_pending = false
end

local inst = DynamicBases.new and DynamicBases.new() or setmetatable({}, DynamicBases)
if not inst.RUNTIME then
    DynamicBases.__init(inst)
end

local function mark_dynamic_base_from_squad(squad, reason)
    local smart_name = inst:_resolve_target_smart_name_from_squad(squad)
    if smart_name then
        return inst:_mark_target_dirty(smart_name, reason)
    end
    return false
end

inst.on_first_update = function() return inst:_on_first_update() end
inst.save_state = function(m_data) return inst:_save_state(m_data) end
inst.load_state = function(m_data) return inst:_load_state(m_data) end
inst.on_load_state = function() return inst:_reactivate_runtime("load_state") end
inst.on_option_change = function() return inst:_reactivate_runtime("option_change") end
inst.wants_smart_update = function(smart, ctx)
    if inst:_is_enabled() ~= true then
        return false
    end
    local smart_name = type(ctx) == "table" and ctx.name or object_name(smart)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    return inst:_is_target_smart(smart_name) or is_base_respawn_smart(smart)
end
inst.on_smart_terrain_update = function(smart, ctx)
    local smart_name, keep = inst:_upsert_target_from_smart(smart, "smart_update")
    if keep and smart_name then
        return inst:_mark_target_dirty(smart_name, "smart_update")
    end
    return false
end
inst.on_server_entity_unregister = function(se_obj)
    local smart_name = object_name(se_obj)
    if inst:_is_target_smart(smart_name) then
        inst:_forget_target(smart_name, false)
        return
    end
    smart_name = inst:_resolve_target_smart_name_from_squad(se_obj)
    if smart_name then
        return inst:_mark_target_dirty(smart_name, "server_unregister")
    end
    return false
end
inst.get_effective_owner = function(smart) return inst:_resolve_effective_owner_alias(smart) end
inst.on_squad_enter_smart = function(squad) return mark_dynamic_base_from_squad(squad, "enter_smart") end
inst.on_squad_leave_smart = function(squad) return mark_dynamic_base_from_squad(squad, "leave_smart") end
inst.on_squad_after_level_change = function(squad) return mark_dynamic_base_from_squad(squad, "after_level_change") end
inst.on_squad_npc_creation = function(squad) return mark_dynamic_base_from_squad(squad, "npc_creation") end
inst.on_squad_npc_death = function(squad) return mark_dynamic_base_from_squad(squad, "npc_death") end

zhopa.dynamic_bases = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_dynamic_bases

-- BEGIN module zhopa_service_filler
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local setmetatable = _G.setmetatable
local tonumber = _G.tonumber
local tostring = _G.tostring
local pairs = _G.pairs
local string_lower = _G.string and _G.string.lower or nil
local string_gsub = _G.string and _G.string.gsub or nil
local string_find = _G.string and _G.string.find or nil
local string_match = _G.string and _G.string.match or nil
local string_sub = _G.string and _G.string.sub or nil
local table_sort = _G.table and _G.table.sort or nil
local table_concat = _G.table and _G.table.concat or nil
local time_global = _G.time_global
local level = _G.level
local db = _G.db
local game = _G.game
local game_relations = _G.game_relations
local game_graph = _G.game_graph
local alife = _G.alife
local ini_sys = _G.ini_sys


local ServiceFiller = zhopa.class("ServiceFiller")
ServiceFiller.__index = ServiceFiller

local STATE_VERSION = "1.0.1"
local DEFAULT_RESPAWN_GAME_HOURS = 6
