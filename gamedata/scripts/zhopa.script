local function tg()
    return (time_global and time_global()) or 0
end

local function get_board()
    if SIMBOARD then
        return SIMBOARD
    end
    if sim_board and sim_board.get_sim_board then
        local ok, board = pcall(function() return sim_board.get_sim_board() end)
        if ok then
            return board
        end
    end
    return nil
end

local function count_keys(src)
    local total = 0
    if type(src) ~= "table" then
        return total
    end
    for _ in pairs(src) do
        total = total + 1
    end
    return total
end

local function object_name(obj)
    if type(obj) ~= "table" then
        return nil
    end
    local raw_name = obj.name
    if type(raw_name) == "string" and raw_name ~= "" then
        return raw_name
    end
    local ok_name, res_name = pcall(function()
        return obj:name()
    end)
    if ok_name and type(res_name) == "string" and res_name ~= "" then
        return res_name
    end
    return nil
end

local function normalize_alias(name)
    if type(name) ~= "string" then
        return nil
    end
    local key = name
    if string_gsub then
        key = string_gsub(key, "^%s*(.-)%s*$", "%1")
    end
    if string_lower then
        key = string_lower(key)
    end
    if key == "" then
        return nil
    end
    if zhopa.config and zhopa.config.get_faction_alias then
        local alias = zhopa.config.get_faction_alias(key)
        if type(alias) == "string" and alias ~= "" then
            key = string_lower and string_lower(alias) or alias
        end
    end
    return ALIAS_BY_ENGINE[key] or key
end

local function alias_to_engine(alias)
    alias = normalize_alias(alias)
    return alias and ENGINE_BY_ALIAS[alias] or nil
end

local function has_game_time()
    return game and game.get_game_time and game.CTime
end

local function ctime_to_table(ct)
    if not (ct and ct.get) then
        return nil
    end
    local ok, Y, M, D, h, m, s, ms = pcall(function()
        return ct:get(0, 0, 0, 0, 0, 0, 0)
    end)
    if not ok then
        return nil
    end
    return { Y = Y, M = M, D = D, h = h, m = m, s = s, ms = ms }
end

local function ctime_from_table(t)
    if not (has_game_time() and type(t) == "table") then
        return nil
    end
    local ok_new, ct = pcall(function() return game.CTime() end)
    if not (ok_new and ct and ct.set) then
        return nil
    end
    local ok_set = pcall(function()
        ct:set(t.Y, t.M, t.D, t.h, t.m, t.s, t.ms)
    end)
    if not ok_set then
        return nil
    end
    return ct
end

local function game_time_now()
    if not has_game_time() then
        return nil
    end
    local ok, ct = pcall(function() return game.get_game_time() end)
    return ok and ct or nil
end

local function game_time_diff_sec(start_ct)
    local now = game_time_now()
    if not (now and now.diffSec and start_ct) then
        return nil
    end
    local ok, sec = pcall(function() return now:diffSec(start_ct) end)
    return ok and tonumber(sec) or nil
end

local function clone_ctime_table(src)
    if type(src) ~= "table" then
        return nil
    end
    local out = {
        Y = tonumber(src.Y),
        M = tonumber(src.M),
        D = tonumber(src.D),
        h = tonumber(src.h),
        m = tonumber(src.m),
        s = tonumber(src.s),
        ms = tonumber(src.ms),
    }
    if out.Y == nil or out.M == nil or out.D == nil or out.h == nil or out.m == nil or out.s == nil or out.ms == nil then
        return nil
    end
    return out
end

local function safe_section(obj)
    if not obj then
        return nil
    end
    if zhopa.safe and zhopa.safe.safe_section then
        return zhopa.safe.safe_section(obj)
    end
    local ok, section = pcall(function() return obj:section_name() end)
    if ok and type(section) == "string" then
        return section
    end
    return nil
end

local function is_base_smart(smart)
    if not smart then
        return false
    end
    local props = type(smart.props) == "table" and smart.props or nil
    return (props and tonumber(props.base) or 0) > 0
end

local function is_service_section(section)
    return type(section) == "string" and string_find and string_find(section, SERVICE_TOKEN, 1, true) ~= nil
end

local function section_role(section)
    if not is_service_section(section) or not string_find or not string_sub then
        return nil
    end
    local pos = string_find(section, SERVICE_TOKEN, 1, true)
    if not pos then
        return nil
    end
    local role = string_sub(section, pos + #SERVICE_TOKEN)
    if role == "trader" or role == "barman" or role == "tech" or role == "guide" or role == "medic" or role == "leader" then
        if DISABLED_SERVICE_ROLES[role] == true then
            return nil
        end
        return role
    end
    return nil
end

local function section_owner_alias(section)
    if not is_service_section(section) or not string_find or not string_sub then
        return nil
    end
    local pos = string_find(section, SERVICE_TOKEN, 1, true)
    if not pos or pos <= 1 then
        return nil
    end
    return normalize_alias(string_sub(section, 1, pos - 1))
end

local function read_ini_string_from(ini, section, key)
    if not (ini and type(section) == "string" and section ~= "" and type(key) == "string" and key ~= "") then
        return nil
    end
    local ok_exist, has_line = pcall(function()
        return ini:section_exist(section) and ini:line_exist(section, key)
    end)
    if not (ok_exist and has_line) then
        return nil
    end
    local ok_value, value = pcall(function()
        return ini:r_string(section, key)
    end)
    if ok_value and type(value) == "string" and value ~= "" then
        return value
    end
    return nil
end

local function read_ini_string(job_or_section, key, smart)
    local section = type(job_or_section) == "table" and job_or_section.section or job_or_section
    local ini = type(job_or_section) == "table" and job_or_section.ltx or nil
    local value = read_ini_string_from(ini, section, key)
    if value ~= nil then
        return value
    end
    if smart then
        value = read_ini_string_from(smart.ltx, section, key)
        if value ~= nil then
            return value
        end
        value = read_ini_string_from(smart.ini, section, key)
        if value ~= nil then
            return value
        end
    end
    return read_ini_string_from(ini_sys, section, key)
end

local function contains_token(haystack, needle)
    if not (string_find and type(haystack) == "string" and type(needle) == "string") then
        return false
    end
    return string_find(haystack, needle, 1, true) ~= nil
end

local function extract_check_npc_name_token(expr)
    if not (string_match and type(expr) == "string" and expr ~= "") then
        return nil
    end
    local token = string_match(expr, "check_npc_name%(([^)]+)%)")
    if type(token) ~= "string" or token == "" then
        return nil
    end
    if string_gsub then
        token = string_gsub(token, "^%s*(.-)%s*$", "%1")
    end
    if token == "" then
        return nil
    end
    return token
end

local function role_from_level_spot(level_spot)
    if type(level_spot) ~= "string" then
        return nil
    end
    local spot = string_lower and string_lower(level_spot) or level_spot
    return LEVEL_SPOT_TO_ROLE[spot]
end

local function classify_provider_job_role(job_or_section, smart)
    local section = type(job_or_section) == "table" and job_or_section.section or job_or_section
    if type(section) ~= "string" or section == "" then
        return nil
    end

    local cache_key = section
    local cached = JOB_ROLE_CACHE[cache_key]
    if cached ~= nil then
        return cached ~= JOB_ROLE_NONE and cached or nil
    end

    local s = string_lower and string_lower(section) or section
    local suitable = read_ini_string(job_or_section, "suitable", smart)
    local suitable_l = string_lower and type(suitable) == "string" and string_lower(suitable) or suitable
    local level_spot = read_ini_string(job_or_section, "level_spot", smart)
    local trade_ltx = read_ini_string(job_or_section, "trade", smart)
    local role = nil

    if contains_token(s, "beh_trade_job") or contains_token(s, "beh_tech_job") or contains_token(s, "beh_medic_job") then
        JOB_ROLE_CACHE[cache_key] = JOB_ROLE_NONE
        return nil
    end

    if contains_token(s, "trade_slot") or contains_token(s, "tech_slot") then
        JOB_ROLE_CACHE[cache_key] = JOB_ROLE_NONE
        return nil
    end

    if contains_token(suitable_l, "npc_has_items_to_sell") or contains_token(suitable_l, "npc_has_tech_items") then
        JOB_ROLE_CACHE[cache_key] = JOB_ROLE_NONE
        return nil
    end

    if contains_token(suitable_l, "check_npc_trader") then
        role = "trader"
    elseif contains_token(suitable_l, "check_npc_mechanic") then
        role = "tech"
    elseif contains_token(suitable_l, "check_npc_medic") then
        role = "medic"
    elseif contains_token(suitable_l, "check_npc_barman") then
        role = "barman"
    end

    if not role and not suitable_l then
        role = role_from_level_spot(level_spot)
    end

    if not role and contains_token(s, "guide") then
        role = "guide"
    end

    if not role and (
        contains_token(s, "leader")
        or contains_token(s, "commander")
        or contains_token(s, "boss")
        or contains_token(s, "chief")
    ) then
        role = "leader"
    end

    if not role and type(level_spot) == "string" then
        local spot = string_lower and string_lower(level_spot) or level_spot
        if spot == "quest_npc" then
            if contains_token(s, "guide") then
                role = "guide"
            else
                role = "leader"
            end
        end
    end

    if not role and type(trade_ltx) == "string" and trade_ltx ~= "" then
        if contains_token(s, "mechanic") then
            role = "tech"
        elseif contains_token(s, "trader") then
            role = "trader"
        elseif contains_token(s, "medic") then
            role = "medic"
        elseif contains_token(s, "barman") or contains_token(s, "cook") or contains_token(s, "povar") then
            role = "barman"
        end
    end

    JOB_ROLE_CACHE[cache_key] = role or JOB_ROLE_NONE
    return role
end

local function classify_job_role(job_or_section, smart)
    return classify_provider_job_role(job_or_section, smart)
end

local function safe_community_alias(se_obj)
    if not se_obj then
        return nil
    end
    local raw = nil
    if zhopa.safe and zhopa.safe.safe_community then
        raw = zhopa.safe.safe_community(se_obj)
    else
        local ok_raw, value = pcall(function() return se_obj:community() end)
        raw = ok_raw and value or nil
    end
    return normalize_alias(raw)
end

local function factions_signature(src)
    if type(src) ~= "table" or not table_concat then
        return "-"
    end
    local out = {}
    for alias in pairs(src) do
        if type(alias) == "string" and alias ~= "" then
            out[#out + 1] = alias
        end
    end
    if #out <= 0 then
        return "-"
    end
    if table_sort then
        table_sort(out)
    end
    return table_concat(out, ",")
end

local function detect_faction_war(factions_present)
    local faction_war = false
    if game_relations and game_relations.is_factions_enemies then
        for a in pairs(factions_present) do
            local engine_a = alias_to_engine(a)
            if engine_a then
                for b in pairs(factions_present) do
                    if a ~= b then
                        local engine_b = alias_to_engine(b)
                        if engine_b then
                            local ok_enemy, hostile = pcall(function()
                                return game_relations.is_factions_enemies(engine_a, engine_b)
                            end)
                            if ok_enemy and hostile == true then
                                faction_war = true
                                break
                            end
                        end
                    end
                end
            end
            if faction_war then
                break
            end
        end
    end
    return faction_war
end

local function collect_live_stalker_factions(smart, is_stalker_info_fn)
    local factions_present = {}
    local stalker_count = 0
    local last_alias = nil
    if not (smart and type(smart.npc_info) == "table") then
        return factions_present, stalker_count, false, last_alias
    end
    for _, info in pairs(smart.npc_info) do
        if is_stalker_info_fn(info) then
            stalker_count = stalker_count + 1
            local alias = safe_community_alias(type(info) == "table" and info.se_obj or nil)
            if alias and ENGINE_BY_ALIAS[alias] then
                factions_present[alias] = true
                last_alias = alias
            end
        end
    end

    return factions_present, stalker_count, detect_faction_war(factions_present), last_alias
end

local function extract_member_candidate_id(k, v)
    if type(v) == "table" then
        local idv = tonumber(v.id) or tonumber(v.object_id) or tonumber(v.squad_id)
        if idv and idv > 0 then
            return idv
        end
    end
    local id = tonumber(v)
    if id and id > 0 then
        return id
    end
    id = tonumber(k)
    if id and id > 0 then
        return id
    end
    return nil
end

local function now_level_name_by_gvid(gvid)
    if not (gvid and alife and game_graph) then
        return nil
    end
    local ok, level_name = pcall(function()
        local gv = game_graph():vertex(gvid)
        if not gv then
            return nil
        end
        return alife():level_name(gv:level_id())
    end)
    return ok and level_name or nil
end

function ServiceFiller:__init()
    self.STATE = {
        version = STATE_VERSION,
        last_fill_gt_by_smart = {},
    }
    self.RUNTIME = {
        targets = {},
        target_set = {},
        dirty_targets = {},
        dirty_queue = {},
        dirty_queue_head = 1,
        dirty_queue_tail = 0,
        applied_signature_by_smart = {},
        skip_retry_tg_by_smart = {},
        pending_spawn_by_smart_role = {},
        pin_signature_by_sid = {},
        warfare_ignore_installed = false,
        active_enabled = false,
        disabled_logged = false,
        stats = {
            ticks = 0,
            reconcile_runs = 0,
            targets = 0,
            processed = 0,
            spawn_attempts = 0,
            spawn_success = 0,
            spawn_failed = 0,
            spawn_no_owner = 0,
            spawn_empty_base = 0,
            spawn_no_section = 0,
            spawn_policy_reject = 0,
            pin_runs = 0,
            pin_assign = 0,
            pin_reset = 0,
        },
    }
end

function ServiceFiller:_is_enabled()
    if zhopa.runtime_cfg and zhopa.runtime_cfg.get then
        return zhopa.runtime_cfg.get("enabled", true) == true
            and zhopa.runtime_cfg.get("service_filler_enabled", false) == true
    end
    if not (zhopa.config and zhopa.config.get) then return false end
    if zhopa.config.get("enabled", true) ~= true then
        return false
    end
    return zhopa.config.get("service_filler_enabled", false) == true
end

function ServiceFiller:_num_cfg(key, default, min_v)
    local value = default
    if zhopa.runtime_cfg and zhopa.runtime_cfg.num then
        return zhopa.runtime_cfg.num(key, value, min_v)
    end
    if zhopa.config and zhopa.config.get then
        local read = zhopa.config.get(key, default)
        if tonumber(read) then
            value = tonumber(read)
        end
    end
    if min_v ~= nil and value < min_v then
        value = min_v
    end
    return value
end

function ServiceFiller:_log_info(fmt, ...)
    if zhopa.log and zhopa.log.info then
        zhopa.log.info("SERVICE_FILLER", fmt, ...)
    end
end

function ServiceFiller:_log_warn(fmt, ...)
    if zhopa.log and zhopa.log.warn then
        zhopa.log.warn("SERVICE_FILLER", fmt, ...)
    end
end

function ServiceFiller:_section_exists(section)
    if type(section) ~= "string" or section == "" then
        return false
    end
    if ini_sys and ini_sys.section_exist then
        local ok, exists = pcall(function() return ini_sys:section_exist(section) end)
        if ok then
            return exists == true
        end
    end
    return true
end

function ServiceFiller:_service_section(alias, role)
    if type(alias) ~= "string" or type(role) ~= "string" then
        return nil
    end
    if DISABLED_SERVICE_ROLES[role] == true then
        return nil
    end
    local section = alias .. SERVICE_TOKEN .. role
    if self:_section_exists(section) then
        return section
    end
    return nil
end

function ServiceFiller:_get_npc_info(smart, npc_id)
    if not (smart and type(smart.npc_info) == "table") then
        return nil
    end
    local id = tonumber(npc_id)
    if id then
        return smart.npc_info[id] or smart.npc_info[tostring(id)]
    end
    return smart.npc_info[npc_id]
end

function ServiceFiller:_is_stalker_info(info)
    local se_obj = type(info) == "table" and info.se_obj or nil
    if not (se_obj and IsStalker) then
        return false
    end
    local ok, clsid = pcall(function() return se_obj:clsid() end)
    return ok and IsStalker(nil, clsid) or false
end

function ServiceFiller:_resolve_owner_alias(smart, live_scan)
    if not smart then
        return nil, "no_smart", 0, "-", nil
    end
    local dynamic_enabled = false
    if zhopa.runtime_cfg and zhopa.runtime_cfg.get then
        dynamic_enabled = zhopa.runtime_cfg.get("dynamic_bases_enabled", false) == true
    elseif zhopa.config and zhopa.config.get then
        dynamic_enabled = zhopa.config.get("dynamic_bases_enabled", false) == true
    end
    if dynamic_enabled == true then
        if zhopa.dynamic_bases and zhopa.dynamic_bases.get_effective_owner then
            return zhopa.dynamic_bases.get_effective_owner(smart)
        end
    end

    local raw_faction = smart.faction
    local alias = normalize_alias(raw_faction)
    local factions_present = type(live_scan) == "table" and type(live_scan.factions_present) == "table" and live_scan.factions_present or nil
    local stalker_count = type(live_scan) == "table" and tonumber(live_scan.stalker_count) or nil
    local faction_war = type(live_scan) == "table" and live_scan.faction_war == true or nil
    local live_alias = type(live_scan) == "table" and live_scan.live_alias or nil
    if not factions_present then
        factions_present, stalker_count, faction_war, live_alias =
            collect_live_stalker_factions(smart, function(info) return self:_is_stalker_info(info) end)
    end
    stalker_count = tonumber(stalker_count) or 0
    if stalker_count <= 0 then
        return nil, "no_stalker_presence", stalker_count, factions_signature(factions_present), raw_faction
    end
    if alias and ENGINE_BY_ALIAS[alias] and factions_present[alias] == true then
        return alias, "smart.faction", stalker_count, factions_signature(factions_present), raw_faction
    end
    if not faction_war and live_alias and ENGINE_BY_ALIAS[live_alias] then
        return live_alias, "live_presence", stalker_count, factions_signature(factions_present), raw_faction
    end
    if faction_war then
        return nil, "faction_war", stalker_count, factions_signature(factions_present), raw_faction
    end
    return nil, "unsupported_or_nil_faction", stalker_count, factions_signature(factions_present), raw_faction
end

function ServiceFiller:_scan_live_population_roles(smart)
    local out = {
        occupied = false,
        live_roles = {},
        factions_present = {},
        stalker_count = 0,
        faction_war = false,
        live_alias = nil,
    }
    if not (smart and type(smart.npc_info) == "table") then
        return out
    end
    local sim = alife and alife() or nil
    local squad_section_by_gid = {}
    for _, info in pairs(smart.npc_info) do
        if self:_is_stalker_info(info) then
            local se_obj = type(info) == "table" and info.se_obj or nil
            out.stalker_count = out.stalker_count + 1
            local alias = safe_community_alias(se_obj)
            if alias and ENGINE_BY_ALIAS[alias] then
                out.factions_present[alias] = true
                out.live_alias = alias
            end
            local group_id = se_obj and tonumber(se_obj.group_id) or nil
            if group_id and group_id > 0 and group_id ~= 65535 and sim then
                local squad_section = squad_section_by_gid[group_id]
                if squad_section == nil then
                    local ok_squad, se_squad = pcall(function() return sim:object(group_id) end)
                    squad_section = ok_squad and se_squad and safe_section(se_squad) or false
                    squad_section_by_gid[group_id] = squad_section
                end
                if squad_section then
                    if not is_service_section(squad_section) then
                        out.occupied = true
                    end
                else
                    out.occupied = true
                end
            else
                if not is_service_section(safe_section(se_obj)) then
                    out.occupied = true
                end
            end
            local job = type(info.job) == "table" and info.job or nil
            local role = job and classify_job_role(job, smart) or nil
            if role then
                out.live_roles[role] = true
            else
                out.occupied = true
            end
        end
    end
    out.faction_war = detect_faction_war(out.factions_present)
    return out
end

function ServiceFiller:_smart_has_non_service_population(smart, live_scan)
    if type(live_scan) == "table" then
        return live_scan.occupied == true
    end
    return self:_scan_live_population_roles(smart).occupied == true
end

function ServiceFiller:_skip_retry_ready(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return true
    end
    local next_tg = self.RUNTIME and self.RUNTIME.skip_retry_tg_by_smart and self.RUNTIME.skip_retry_tg_by_smart[smart_name] or nil
    if next_tg == nil then
        return true
    end
    if tg() >= tonumber(next_tg) then
        self.RUNTIME.skip_retry_tg_by_smart[smart_name] = nil
        return true
    end
    return false
end

function ServiceFiller:_clear_skip_retry(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return
    end
    if self.RUNTIME and self.RUNTIME.skip_retry_tg_by_smart then
        self.RUNTIME.skip_retry_tg_by_smart[smart_name] = nil
    end
end

function ServiceFiller:_set_skip_retry(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil
    end
    local next_tg = tg() + DEFAULT_SKIP_RETRY_MS
    self.RUNTIME.skip_retry_tg_by_smart[smart_name] = next_tg
    return next_tg
end

function ServiceFiller:_ensure_warfare_ignore()
    local ignore_tbl = type(ignore) == "table" and ignore or nil
    local warfare_tbl = type(warfare) == "table" and warfare or nil
    local warfare_ignore = warfare_tbl and type(warfare_tbl.ignore) == "table" and warfare_tbl.ignore or nil
    if not ignore_tbl and not warfare_ignore then
        self.RUNTIME.warfare_ignore_installed = false
        return false
    end

    for i = 1, #FACTIONS do
        local alias = FACTIONS[i]
        for j = 1, #ROLES do
            local section = alias .. SERVICE_TOKEN .. ROLES[j]
            if self:_section_exists(section) then
                if ignore_tbl then
                    ignore_tbl[section] = true
                end
                if warfare_ignore then
                    warfare_ignore[section] = true
                end
            end
        end
    end

    self.RUNTIME.warfare_ignore_installed = true
    return true
end

function ServiceFiller:_pending_bucket(smart_name, create)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil
    end
    local all = self.RUNTIME and self.RUNTIME.pending_spawn_by_smart_role or nil
    if type(all) ~= "table" then
        return nil
    end
    local bucket = all[smart_name]
    if bucket == nil and create == true then
        bucket = {}
        all[smart_name] = bucket
    end
    return type(bucket) == "table" and bucket or nil
end

function ServiceFiller:_get_pending_spawn(smart_name, role)
    local bucket = self:_pending_bucket(smart_name, false)
    if not (bucket and type(role) == "string" and role ~= "") then
        return nil
    end
    local pending = bucket[role]
    if type(pending) ~= "table" then
        return nil
    end
    if tg() >= (tonumber(pending.expires_tg) or 0) then
        self:_clear_pending_spawn(smart_name, role)
        return nil
    end
    return pending
end

function ServiceFiller:_set_pending_spawn(smart_name, role, sid, owner_alias)
    if type(role) ~= "string" or role == "" then
        return nil
    end
    local bucket = self:_pending_bucket(smart_name, true)
    if not bucket then
        return nil
    end
    local now = tg()
    local pending = {
        sid = tonumber(sid) or nil,
        owner = normalize_alias(owner_alias),
        spawn_tg = now,
        expires_tg = now + DEFAULT_PENDING_SPAWN_MS,
    }
    bucket[role] = pending
    return pending
end

function ServiceFiller:_clear_pending_spawn(smart_name, role)
    local bucket = self:_pending_bucket(smart_name, false)
    if not (bucket and type(role) == "string" and role ~= "") then
        return
    end
    bucket[role] = nil
    if next(bucket) == nil then
        self.RUNTIME.pending_spawn_by_smart_role[smart_name] = nil
    end
end

function ServiceFiller:_resolve_holder_squad(holder)
    if type(holder) ~= "table" then
        return nil
    end
    if holder.squad then
        return holder.squad
    end
    local sid = tonumber(holder.sid)
    if not (is_valid_server_id(sid) and alife) then
        return nil
    end
    local sim = alife()
    if not sim then
        return nil
    end
    local ok, se_squad = pcall(function() return sim:object(sid) end)
    if ok and se_squad then
        return se_squad
    end
    return nil
end

function ServiceFiller:_pin_service_squad(board, smart_name, smart, owner_alias, role, se_squad)
    if not (board and smart and se_squad and type(smart_name) == "string" and smart_name ~= "") then
        return false
    end
    local section = safe_section(se_squad)
    if not section or section_role(section) ~= role then
        return false
    end
    if section_owner_alias(section) ~= owner_alias then
        return false
    end

    local smart_id = tonumber(smart.id) or nil
    if not smart_id then
        return false
    end

    local sid = tonumber(se_squad.id) or nil
    local pin_signature = tostring(smart_id) .. "|" .. tostring(smart_name) .. "|" .. tostring(owner_alias or "-") .. "|" .. tostring(role or "-")
    if sid
        and self.RUNTIME.pin_signature_by_sid
        and self.RUNTIME.pin_signature_by_sid[sid] == pin_signature
        and se_squad.scripted_target == smart_name
        and tonumber(se_squad.assigned_target_id) == smart_id
        and tonumber(se_squad.smart_id) == smart_id
        and se_squad.current_action == 0
        and se_squad.registered_with_warfare == false
        and se_squad.rush_to_target == false
    then
        return false
    end

    self.RUNTIME.stats.pin_runs = (tonumber(self.RUNTIME.stats.pin_runs) or 0) + 1

    local changed = false
    if se_squad.scripted_target ~= smart_name then
        se_squad.scripted_target = smart_name
        changed = true
    end
    if tonumber(se_squad.assigned_target_id) ~= smart_id then
        se_squad.assigned_target_id = smart_id
        changed = true
    end
    if se_squad.current_target_id ~= nil then
        se_squad.current_target_id = nil
        changed = true
    end
    if se_squad.current_action ~= 0 then
        se_squad.current_action = 0
        changed = true
    end
    if se_squad.task_target_id ~= nil then
        se_squad.task_target_id = nil
        changed = true
    end
    if se_squad.stay_time ~= nil then
        se_squad.stay_time = nil
        changed = true
    end
    if se_squad.arrive_time ~= nil then
        se_squad.arrive_time = nil
        changed = true
    end
    if se_squad.__lock ~= nil then
        se_squad.__lock = nil
        changed = true
    end
    if se_squad.registered_with_warfare ~= false then
        se_squad.registered_with_warfare = false
        changed = true
    end
    if se_squad.checked_with_warfare ~= nil then
        se_squad.checked_with_warfare = nil
        changed = true
    end
    if se_squad.rush_to_target ~= false then
        se_squad.rush_to_target = false
        changed = true
    end

    if tonumber(se_squad.smart_id) ~= smart_id and board.assign_squad_to_smart then
        local ok_assign = pcall(function() board:assign_squad_to_smart(se_squad, smart_id) end)
        if ok_assign then
            self.RUNTIME.stats.pin_assign = (tonumber(self.RUNTIME.stats.pin_assign) or 0) + 1
            changed = true
        end
    end

    if changed then
        self.RUNTIME.stats.pin_reset = (tonumber(self.RUNTIME.stats.pin_reset) or 0) + 1
    end
    if sid and self.RUNTIME.pin_signature_by_sid then
        self.RUNTIME.pin_signature_by_sid[sid] = pin_signature
    end
    return changed
end

function ServiceFiller:_sync_pending_for_role(board, smart_name, smart, role, owner_alias, holder, filled)
    local pending = self:_get_pending_spawn(smart_name, role)
    if not pending then
        return false
    end

    if type(owner_alias) ~= "string" or owner_alias == "" or pending.owner ~= owner_alias then
        self:_clear_pending_spawn(smart_name, role)
        return false
    end
    if filled == true then
        self:_clear_pending_spawn(smart_name, role)
        return false
    end
    if holder and holder.owner == owner_alias then
        self:_clear_pending_spawn(smart_name, role)
        return false
    end
    if tg() >= (tonumber(pending.expires_tg) or 0) then
        self:_clear_pending_spawn(smart_name, role)
        return false
    end

    local se_squad = nil
    local sid = tonumber(pending.sid)
    if is_valid_server_id(sid) and alife then
        local sim = alife()
        if sim then
            local ok, value = pcall(function() return sim:object(sid) end)
            if ok and value then
                se_squad = value
            end
        end
    end
    if not se_squad then
        self:_clear_pending_spawn(smart_name, role)
        return false
    end

    local section = safe_section(se_squad)
    if not section or section_role(section) ~= role or section_owner_alias(section) ~= owner_alias then
        self:_clear_pending_spawn(smart_name, role)
        return false
    end

    self:_pin_service_squad(board, smart_name, smart, owner_alias, role, se_squad)
    return true
end

function ServiceFiller:_collect_allowed_roles(smart)
    local out = {}
    local jobs = smart and smart.stalker_jobs or nil
    if type(jobs) ~= "table" then
        return out
    end
    for i = 1, #jobs do
        local job = jobs[i]
        local role = classify_job_role(job, smart)
        if role and DISABLED_SERVICE_ROLES[role] ~= true then
            out[role] = true
        end
    end
    return out
end

function ServiceFiller:_get_task_proxy_seed(npc)
    if not (npc and npc.id and db and db.storage and alife) then
        return nil
    end

    local ok_id, id = pcall(function() return tonumber(npc:id()) end)
    if not (ok_id and is_valid_server_id(id)) then
        return nil
    end

    local st = db.storage[id]
    if type(st) ~= "table" then
        return nil
    end

    local sim = alife()
    if not sim then
        return nil
    end

    local ok_se, se_obj = pcall(function() return sim:object(id) end)
    if not (ok_se and se_obj) then
        return nil
    end

    local role = self:_service_member_descriptor(se_obj)
    if role ~= "medic" and role ~= "barman" and role ~= "leader" then
        return nil
    end

    local section_logic = type(st.section_logic) == "string" and st.section_logic or nil
    local ini = st.ini
    local seed = section_logic and read_ini_string_from(ini, section_logic, "task_section") or nil
    if not seed then
        local suitable = section_logic and read_ini_string_from(ini, section_logic, "suitable") or nil
        seed = extract_check_npc_name_token(suitable)
    end

    if type(seed) ~= "string" or seed == "" then
        return nil
    end

    return seed, role, section_logic
end

function ServiceFiller:_collect_existing_service_squads(board, smart)
    local out = {}
    local smart_id = smart and tonumber(smart.id) or nil
    local node = smart_id and board and board.smarts and board.smarts[smart_id] or nil
    local sim = alife and alife() or nil
    if not (node and type(node.squads) == "table" and sim) then
        return out
    end
    for sid in pairs(node.squads) do
        local id = tonumber(sid) or sid
        if is_valid_server_id(id) then
            local ok_obj, se_squad = pcall(function() return sim:object(id) end)
            if ok_obj and se_squad then
                local section = safe_section(se_squad)
                local role = section_role(section)
                if role and out[role] == nil then
                    out[role] = {
                        squad = se_squad,
                        sid = tonumber(se_squad.id) or tonumber(id),
                        section = section,
                        owner = section_owner_alias(section),
                    }
                end
            end
        end
    end
    return out
end

function ServiceFiller:_collect_existing_service_members(smart)
    local out = {}
    if not (smart and type(smart.npc_info) == "table") then
        return out
    end

    for _, info in pairs(smart.npc_info) do
        local se_obj = type(info) == "table" and info.se_obj or nil
        if self:_is_stalker_info(info) and se_obj then
            local role, owner, squad_section = self:_service_member_descriptor(se_obj)
            if role and out[role] == nil then
                out[role] = {
                    sid = tonumber(se_obj.group_id) or nil,
                    section = squad_section,
                    owner = owner,
                    member_id = tonumber(se_obj.id) or nil,
                }
            end
        end
    end

    return out
end

function ServiceFiller:_collect_existing_service_roles(board, smart)
    local out = self:_collect_existing_service_squads(board, smart)
    local by_member = self:_collect_existing_service_members(smart)
    for role, holder in pairs(by_member) do
        if out[role] == nil then
            out[role] = holder
        end
    end
    return out
end

function ServiceFiller:_service_member_descriptor(se_obj)
    if not se_obj then
        return nil, nil, nil
    end

    local squad_section = nil
    local group_id = tonumber(se_obj.group_id) or nil
    local sim = alife and alife() or nil
    if group_id and group_id > 0 and group_id ~= 65535 and sim then
        local ok_squad, se_squad = pcall(function() return sim:object(group_id) end)
        if ok_squad and se_squad then
            squad_section = safe_section(se_squad)
        end
    end

    if not squad_section then
        squad_section = safe_section(se_obj)
    end

    if not squad_section then
        return nil, nil, nil
    end

    return section_role(squad_section), section_owner_alias(squad_section), squad_section
end

function ServiceFiller:_role_has_live_job_owner(smart, role, live_scan)
    if DISABLED_SERVICE_ROLES[role] == true then
        return false
    end
    if type(live_scan) == "table" then
        return type(live_scan.live_roles) == "table" and live_scan.live_roles[role] == true or false
    end
    if not (smart and type(smart.npc_info) == "table") then
        return false
    end
    for _, info in pairs(smart.npc_info) do
        if self:_is_stalker_info(info) then
            local job = type(info.job) == "table" and info.job or nil
            if job and classify_job_role(job, smart) == role then
                return true
            end
        end
    end
    return false
end

function ServiceFiller:_is_spawn_target_allowed(smart_name, smart, faction, section)
    if not (zhopa.tasks and zhopa.tasks.is_smart_spawn_allowed) then
        return true, "ok"
    end

    local level_name = nil
    local gvid = smart and tonumber(smart.m_game_vertex_id) or nil
    if gvid then
        level_name = now_level_name_by_gvid(gvid)
    end
    local ok, allowed, reason = pcall(
        zhopa.tasks.is_smart_spawn_allowed,
        smart_name,
        faction,
        level_name,
        section
    )
    if not ok then
        return true, "policy_error"
    end
    if allowed == true then
        return true, tostring(reason or "ok")
    end
    return false, tostring(reason or "policy_reject")
end

function ServiceFiller:_spawn_via_board(board, smart_name, section)
    if not (board and board.create_squad and board.smarts_by_names) then
        return nil
    end
    local smart = board.smarts_by_names[smart_name]
    if not smart then
        return nil
    end
    local ok, squad = pcall(function() return board:create_squad(smart, section) end)
    if ok and squad then
        return squad
    end
    return nil
end

function ServiceFiller:_spawn_service_squad(board, smart_name, smart, owner_alias, role)
    local section = self:_service_section(owner_alias, role)
    if not section then
        self.RUNTIME.stats.spawn_no_section = (tonumber(self.RUNTIME.stats.spawn_no_section) or 0) + 1
        self:_log_warn(
            "spawn_no_section smart=%s owner=%s role=%s",
            tostring(smart_name),
            tostring(owner_alias or "-"),
            tostring(role or "-")
        )
        return nil, "no_section"
    end

    local allowed, reason = self:_is_spawn_target_allowed(smart_name, smart, owner_alias, section)
    if not allowed then
        self.RUNTIME.stats.spawn_policy_reject = (tonumber(self.RUNTIME.stats.spawn_policy_reject) or 0) + 1
        self:_log_warn(
            "spawn_policy_reject smart=%s owner=%s role=%s section=%s reason=%s",
            tostring(smart_name),
            tostring(owner_alias or "-"),
            tostring(role or "-"),
            tostring(section or "-"),
            tostring(reason or "-")
        )
        return nil, reason
    end

    self.RUNTIME.stats.spawn_attempts = (tonumber(self.RUNTIME.stats.spawn_attempts) or 0) + 1

    local squad = self:_spawn_via_board(board, smart_name, section)
    if not squad then
        self.RUNTIME.stats.spawn_failed = (tonumber(self.RUNTIME.stats.spawn_failed) or 0) + 1
        self:_log_warn(
            "spawn_failed smart=%s owner=%s role=%s section=%s",
            tostring(smart_name),
            tostring(owner_alias or "-"),
            tostring(role or "-"),
            tostring(section or "-")
        )
        return nil, "spawn_failed"
    end

    self.RUNTIME.stats.spawn_success = (tonumber(self.RUNTIME.stats.spawn_success) or 0) + 1
    self:_log_info(
        "spawn_success sid=%s smart=%s owner=%s role=%s section=%s",
        tostring(squad and squad.id or "-"),
        tostring(smart_name),
        tostring(owner_alias),
        tostring(role),
        tostring(section)
    )
    return squad, nil
end

function ServiceFiller:_get_fill_mark(smart_name)
    return self.STATE and self.STATE.last_fill_gt_by_smart and self.STATE.last_fill_gt_by_smart[smart_name] or nil
end

function ServiceFiller:_is_due(smart_name)
    local hours = self:_num_cfg("service_filler_respawn_game_hours", DEFAULT_RESPAWN_GAME_HOURS, 0.1)
    local last = self:_get_fill_mark(smart_name)
    if type(last) ~= "table" then
        return true
    end
    local last_ct = ctime_from_table(last)
    if not last_ct then
        return true
    end
    local elapsed = game_time_diff_sec(last_ct)
    if not elapsed then
        return false
    end
    return elapsed >= (hours * 3600)
end

function ServiceFiller:_mark_now(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil
    end
    local now_gt = game_time_now()
    local stamp = now_gt and ctime_to_table(now_gt) or nil
    self.STATE.last_fill_gt_by_smart[smart_name] = stamp
    return stamp
end

function ServiceFiller:_refresh_target_stats()
    self.RUNTIME.stats.targets = #(self.RUNTIME.targets or {})
end

function ServiceFiller:_sync_targets_from_index()
    local board_index = zhopa.board_index
    local levels = board_index and board_index.get_known_smart_levels and board_index.get_known_smart_levels() or {}
    local prev_targets = self.RUNTIME.targets or {}
    local targets = {}
    local target_set = {}

    for i = 1, #levels do
        local level_name = levels[i]
        local list = board_index and board_index.get_base_smarts and board_index.get_base_smarts(level_name) or {}
        for j = 1, #list do
            local smart_name = list[j]
            if type(smart_name) == "string" and smart_name ~= "" and target_set[smart_name] ~= true then
                target_set[smart_name] = true
                targets[#targets + 1] = smart_name
            end
        end
    end

    if table_sort then
        table_sort(targets)
    end

    for i = 1, #prev_targets do
        local smart_name = prev_targets[i]
        if target_set[smart_name] ~= true then
            self.RUNTIME.dirty_targets[smart_name] = nil
            self.RUNTIME.skip_retry_tg_by_smart[smart_name] = nil
            self.RUNTIME.pending_spawn_by_smart_role[smart_name] = nil
            self.RUNTIME.applied_signature_by_smart[smart_name] = nil
        end
    end

    self.RUNTIME.targets = targets
    self.RUNTIME.target_set = target_set
    self:_refresh_target_stats()
end

function ServiceFiller:_remove_target(smart_name)
    if not self:_is_target_smart(smart_name) then
        return false
    end
    self.RUNTIME.target_set[smart_name] = nil
    local next_targets = {}
    local src = self.RUNTIME.targets or {}
    for i = 1, #src do
        if src[i] ~= smart_name then
            next_targets[#next_targets + 1] = src[i]
        end
    end
    self.RUNTIME.targets = next_targets
    if type(self.RUNTIME.dirty_targets) == "table" then
        self.RUNTIME.dirty_targets[smart_name] = nil
    end
    self.RUNTIME.skip_retry_tg_by_smart[smart_name] = nil
    self.RUNTIME.pending_spawn_by_smart_role[smart_name] = nil
    self.RUNTIME.applied_signature_by_smart[smart_name] = nil
    self:_refresh_target_stats()
    return true
end

function ServiceFiller:_should_target_smart(smart_name, smart)
    if type(smart_name) ~= "string" or smart_name == "" or not is_base_smart(smart) then
        return false
    end
    local level_name = zhopa.board_index and zhopa.board_index.get_smart_level and zhopa.board_index.get_smart_level(smart_name) or nil
    if type(level_name) ~= "string" or level_name == "" then
        local gvid = smart and tonumber(smart.m_game_vertex_id) or nil
        level_name = gvid and now_level_name_by_gvid(gvid) or nil
    end
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    local allowed = zhopa.board_index and zhopa.board_index.get_base_smarts and zhopa.board_index.get_base_smarts(level_name) or {}
    for i = 1, #allowed do
        if allowed[i] == smart_name then
            return true
        end
    end
    return false
end

function ServiceFiller:_upsert_target_from_smart(smart)
    local smart_name = object_name(smart)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil, false
    end
    if self:_should_target_smart(smart_name, smart) ~= true then
        self:_remove_target(smart_name)
        return smart_name, false
    end
    if self.RUNTIME.target_set[smart_name] ~= true then
        self.RUNTIME.target_set[smart_name] = true
        self.RUNTIME.targets[#self.RUNTIME.targets + 1] = smart_name
        if table_sort then
            table_sort(self.RUNTIME.targets)
        end
        self:_refresh_target_stats()
    end
    return smart_name, true
end

function ServiceFiller:_is_target_smart(smart_name)
    return type(smart_name) == "string"
        and smart_name ~= ""
        and type(self.RUNTIME.target_set) == "table"
        and self.RUNTIME.target_set[smart_name] == true
end

function ServiceFiller:_resolve_target_smart_name_from_squad(se_squad)
    if not se_squad then
        return nil
    end

    local scripted = type(se_squad.scripted_target) == "string" and se_squad.scripted_target or nil
    if self:_is_target_smart(scripted) then
        return scripted
    end

    local smart_id = tonumber(se_squad.smart_id) or nil
    if smart_id and zhopa.board_index and zhopa.board_index.get_smart_name_by_id then
        local smart_name = zhopa.board_index.get_smart_name_by_id(smart_id)
        if self:_is_target_smart(smart_name) then
            return smart_name
        end
    end

    return nil
end

function ServiceFiller:_consume_dirty_targets()
    local out = {}
    local dirty = type(self.RUNTIME.dirty_targets) == "table" and self.RUNTIME.dirty_targets or {}
    local queue = type(self.RUNTIME.dirty_queue) == "table" and self.RUNTIME.dirty_queue or {}
    local head = tonumber(self.RUNTIME.dirty_queue_head) or 1
    local tail = tonumber(self.RUNTIME.dirty_queue_tail) or 0
    while head <= tail do
        local smart_name = queue[head]
        queue[head] = nil
        head = head + 1
        self.RUNTIME.dirty_queue_head = head
        if self:_is_target_smart(smart_name) then
            out[#out + 1] = smart_name
        end
        if type(smart_name) == "string" then
            dirty[smart_name] = nil
        end
    end
    self.RUNTIME.dirty_targets = dirty
    if next(dirty) == nil then
        self.RUNTIME.dirty_queue = {}
        self.RUNTIME.dirty_queue_head = 1
        self.RUNTIME.dirty_queue_tail = 0
    end
    return out
end

function ServiceFiller:_mark_target_dirty(smart_name, reason)
    if not self:_is_target_smart(smart_name) then
        return false
    end
    self.RUNTIME.dirty_targets = type(self.RUNTIME.dirty_targets) == "table" and self.RUNTIME.dirty_targets or {}
    if self.RUNTIME.dirty_targets[smart_name] ~= true then
        local tail = (tonumber(self.RUNTIME.dirty_queue_tail) or 0) + 1
        self.RUNTIME.dirty_queue_tail = tail
        self.RUNTIME.dirty_queue = type(self.RUNTIME.dirty_queue) == "table" and self.RUNTIME.dirty_queue or {}
        self.RUNTIME.dirty_queue[tail] = smart_name
    end
    self.RUNTIME.dirty_targets[smart_name] = true
    return self:_run_dirty_reconcile(reason or "dirty")
end

function ServiceFiller:_mark_all_index_targets_dirty(reason)
    self.RUNTIME.dirty_targets = {}
    self.RUNTIME.dirty_queue = {}
    self.RUNTIME.dirty_queue_head = 1
    self.RUNTIME.dirty_queue_tail = 0
    for i = 1, #(self.RUNTIME.targets or {}) do
        local smart_name = self.RUNTIME.targets[i]
        if self:_is_target_smart(smart_name) then
            local tail = (tonumber(self.RUNTIME.dirty_queue_tail) or 0) + 1
            self.RUNTIME.dirty_queue_tail = tail
            self.RUNTIME.dirty_queue[tail] = smart_name
            self.RUNTIME.dirty_targets[smart_name] = true
        end
    end
    return true
end

function ServiceFiller:_has_pending_spawn_for_smart(smart_name)
    local pending = type(self.RUNTIME.pending_spawn_by_smart_role) == "table"
        and self.RUNTIME.pending_spawn_by_smart_role[smart_name]
        or nil
    return type(pending) == "table" and next(pending) ~= nil
end

function ServiceFiller:_build_process_signature(smart_name, owner_alias, factions_sig, occupied, allowed_roles_count, existing_count, stalker_count)
    return tostring(smart_name or "-")
        .. "|" .. tostring(owner_alias or "-")
        .. "|" .. tostring(factions_sig or "-")
        .. "|" .. tostring(occupied == true)
        .. "|" .. tostring(tonumber(allowed_roles_count) or 0)
        .. "|" .. tostring(tonumber(existing_count) or 0)
        .. "|" .. tostring(tonumber(stalker_count) or 0)
end

function ServiceFiller:_process_smart(board, smart_name)
    local smart = board and board.smarts_by_names and board.smarts_by_names[smart_name] or nil
    if self:_should_target_smart(smart_name, smart) ~= true then
        self:_remove_target(smart_name)
        return
    end

    local allowed_roles = self:_collect_allowed_roles(smart)
    local existing = self:_collect_existing_service_roles(board, smart)
    local live_scan = self:_scan_live_population_roles(smart)
    local owner_alias, owner_source, stalker_count, factions_sig, raw_faction = self:_resolve_owner_alias(smart, live_scan)
    local occupied = self:_smart_has_non_service_population(smart, live_scan)
    local allowed_roles_count = count_keys(allowed_roles)
    local existing_count = count_keys(existing)
    local signature = self:_build_process_signature(
        smart_name,
        owner_alias,
        factions_sig,
        occupied,
        allowed_roles_count,
        existing_count,
        stalker_count
    )
    local due = self:_is_due(smart_name)
    if self.RUNTIME.applied_signature_by_smart[smart_name] == signature
        and due ~= true
        and self:_has_pending_spawn_for_smart(smart_name) ~= true
    then
        return
    end
    self.RUNTIME.applied_signature_by_smart[smart_name] = signature

    if owner_alias then
        for role, holder in pairs(existing) do
            if allowed_roles[role] == true and holder and holder.owner == owner_alias then
                local se_squad = self:_resolve_holder_squad(holder)
                if se_squad then
                    self:_pin_service_squad(board, smart_name, smart, owner_alias, role, se_squad)
                end
                self:_clear_pending_spawn(smart_name, role)
            end
        end
    end

    if not due then
        return
    end

    if not self:_skip_retry_ready(smart_name) then
        return
    end

    if not owner_alias then
        self.RUNTIME.stats.spawn_no_owner = (tonumber(self.RUNTIME.stats.spawn_no_owner) or 0) + 1
        self:_log_info(
            "skip_no_owner smart=%s occupied=%s roles=%s existing=%s source=%s stalkers=%s factions=%s raw=%s",
            tostring(smart_name),
            tostring(occupied),
            tostring(allowed_roles_count),
            tostring(existing_count),
            tostring(owner_source or "-"),
            tostring(stalker_count or 0),
            tostring(factions_sig or "-"),
            tostring(raw_faction or "-")
        )
        self:_set_skip_retry(smart_name)
        return
    end

    if not occupied then
        self.RUNTIME.stats.spawn_empty_base = (tonumber(self.RUNTIME.stats.spawn_empty_base) or 0) + 1
        self:_log_info(
            "skip_empty_base smart=%s owner=%s roles=%s existing=%s source=%s stalkers=%s factions=%s raw=%s",
            tostring(smart_name),
            tostring(owner_alias),
            tostring(allowed_roles_count),
            tostring(existing_count),
            tostring(owner_source or "-"),
            tostring(stalker_count or 0),
            tostring(factions_sig or "-"),
            tostring(raw_faction or "-")
        )
        self:_set_skip_retry(smart_name)
        return
    end

    for i = 1, #ROLES do
        local role = ROLES[i]
        if allowed_roles[role] == true then
            local holder = existing[role]
            local filled = self:_role_has_live_job_owner(smart, role, live_scan)
            if self:_sync_pending_for_role(board, smart_name, smart, role, owner_alias, holder, filled) then
                filled = true
            end
            if not filled and (not holder or holder.owner ~= owner_alias) then
                local squad = self:_spawn_service_squad(board, smart_name, smart, owner_alias, role)
                if squad then
                    local new_section = safe_section(squad)
                    local new_holder = {
                        squad = squad,
                        sid = tonumber(squad.id),
                        section = new_section,
                        owner = section_owner_alias(new_section),
                    }
                    existing[role] = new_holder
                    self:_pin_service_squad(board, smart_name, smart, owner_alias, role, squad)
                    self:_set_pending_spawn(smart_name, role, squad and squad.id or nil, owner_alias)
                end
            end
        end
    end

    self:_clear_skip_retry(smart_name)
    self:_mark_now(smart_name)
end

function ServiceFiller:_on_first_update()
    self:_reactivate_runtime("first_update")
end

function ServiceFiller:_run_dirty_reconcile(reason)
    if self.RUNTIME.reconcile_running == true then
        self.RUNTIME.reconcile_pending = true
        return false
    end

    self.RUNTIME.reconcile_running = true
    local ok, err = pcall(function()
        repeat
            self.RUNTIME.reconcile_pending = false

            if not self:_is_enabled() then
                self.RUNTIME.active_enabled = false
                if not self.RUNTIME.disabled_logged then
                    self:_log_info("disabled")
                    self.RUNTIME.disabled_logged = true
                end
                return
            end

            self.RUNTIME.active_enabled = true
            self.RUNTIME.disabled_logged = false
            if not self.RUNTIME.warfare_ignore_installed then
                self:_ensure_warfare_ignore()
            end

            self.RUNTIME.stats.ticks = (tonumber(self.RUNTIME.stats.ticks) or 0) + 1

            local board = get_board()
            local targets = self:_consume_dirty_targets()
            if #targets > 0 then
                for i = 1, #targets do
                    self.RUNTIME.stats.processed = (tonumber(self.RUNTIME.stats.processed) or 0) + 1
                    self:_process_smart(board, targets[i])
                end
                self.RUNTIME.stats.reconcile_runs = (tonumber(self.RUNTIME.stats.reconcile_runs) or 0) + 1
            end
        until self.RUNTIME.reconcile_pending ~= true
    end)
    self.RUNTIME.reconcile_running = false
    if not ok then
        error(err)
    end
    return true
end

function ServiceFiller:_mark_dirty_from_squad(se_squad, reason)
    local smart_name = self:_resolve_target_smart_name_from_squad(se_squad)
    if smart_name then
        return self:_mark_target_dirty(smart_name, reason)
    end
    return false
end

function ServiceFiller:_mark_dirty_from_smart(smart, reason)
    local smart_name, is_target = self:_upsert_target_from_smart(smart)
    if is_target == true then
        return self:_mark_target_dirty(smart_name, reason)
    end
    return false
end

function ServiceFiller:_reactivate_runtime(reason)
    if not self:_is_enabled() then
        self.RUNTIME.active_enabled = false
        return
    end
    self.RUNTIME.active_enabled = true
    self.RUNTIME.disabled_logged = false
    self:_ensure_warfare_ignore()
    self:_sync_targets_from_index()
    self:_mark_all_index_targets_dirty(reason)
    self:_run_dirty_reconcile(reason or "reactivate")
end

function ServiceFiller:_save_state(m_data)
    if not m_data then
        return
    end
    local out = {
        version = STATE_VERSION,
        last_fill_gt_by_smart = {},
    }
    for smart_name, mark in pairs(self.STATE and self.STATE.last_fill_gt_by_smart or {}) do
        local key = type(smart_name) == "string" and smart_name or nil
        local stamp = clone_ctime_table(mark)
        if key and key ~= "" and stamp then
            out.last_fill_gt_by_smart[key] = stamp
        end
    end
    m_data.zhopa_service_filler_state = out
end

function ServiceFiller:_load_state(m_data)
    local loaded = m_data and m_data.zhopa_service_filler_state or nil
    self.STATE = {
        version = STATE_VERSION,
        last_fill_gt_by_smart = {},
    }
    if type(loaded) == "table" then
        for smart_name, mark in pairs(type(loaded.last_fill_gt_by_smart) == "table" and loaded.last_fill_gt_by_smart or {}) do
            local key = type(smart_name) == "string" and smart_name or nil
            local stamp = clone_ctime_table(mark)
            if key and key ~= "" and stamp then
                self.STATE.last_fill_gt_by_smart[key] = stamp
            end
        end
    end
    self.RUNTIME.targets = {}
    self.RUNTIME.target_set = {}
    self.RUNTIME.dirty_targets = {}
    self.RUNTIME.dirty_queue = {}
    self.RUNTIME.dirty_queue_head = 1
    self.RUNTIME.dirty_queue_tail = 0
    self.RUNTIME.applied_signature_by_smart = {}
    self.RUNTIME.skip_retry_tg_by_smart = {}
    self.RUNTIME.pending_spawn_by_smart_role = {}
    self.RUNTIME.pin_signature_by_sid = {}
    self.RUNTIME.warfare_ignore_installed = false
    self.RUNTIME.active_enabled = false
    self.RUNTIME.disabled_logged = false
    self.RUNTIME.reconcile_running = false
    self.RUNTIME.reconcile_pending = false
end

local inst = ServiceFiller.new and ServiceFiller.new() or setmetatable({}, ServiceFiller)
if not inst.RUNTIME then
    ServiceFiller.__init(inst)
end

inst.on_first_update = function() return inst:_on_first_update() end
inst.save_state = function(m_data) return inst:_save_state(m_data) end
inst.load_state = function(m_data) return inst:_load_state(m_data) end
inst.on_load_state = function() return inst:_reactivate_runtime("load_state") end
inst.on_option_change = function() return inst:_reactivate_runtime("option_change") end
inst.wants_smart_update = function(smart, ctx)
    if inst:_is_enabled() ~= true then
        return false
    end
    local smart_name = type(ctx) == "table" and ctx.name or object_name(smart)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    return inst:_is_target_smart(smart_name) or inst:_should_target_smart(smart_name, smart)
end
inst.on_smart_terrain_update = function(smart, ctx) return inst:_mark_dirty_from_smart(smart, "smart_update") end
inst.on_server_entity_unregister = function(se_obj, type_name)
    local smart_name = object_name(se_obj)
    if inst:_is_target_smart(smart_name) then
        inst:_remove_target(smart_name)
        return
    end
    if type(type_name) == "string" and type_name == "sim_squad_scripted" then
        inst:_mark_dirty_from_squad(se_obj, "server_unregister")
        return
    end
    local smart_id = tonumber(se_obj and se_obj.smart_id) or nil
    smart_name = smart_id and zhopa.board_index and zhopa.board_index.get_smart_name_by_id and zhopa.board_index.get_smart_name_by_id(smart_id) or nil
    if smart_name then
        inst:_mark_target_dirty(smart_name, "server_unregister")
    end
end
inst.is_service_section = function(section) return is_service_section(section) end
inst.get_task_proxy_seed = function(npc) return inst:_get_task_proxy_seed(npc) end
inst.on_squad_enter_smart = function(squad) return inst:_mark_dirty_from_squad(squad, "enter_smart") end
inst.on_squad_leave_smart = function(squad) return inst:_mark_dirty_from_squad(squad, "leave_smart") end
inst.on_squad_after_level_change = function(squad) return inst:_mark_dirty_from_squad(squad, "after_level_change") end
inst.on_squad_npc_creation = function(squad) return inst:_mark_dirty_from_squad(squad, "npc_creation") end
inst.on_squad_npc_death = function(squad) return inst:_mark_dirty_from_squad(squad, "npc_death") end

zhopa.service_filler = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_service_filler

-- BEGIN module zhopa_axr_task_patch
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local pairs = _G.pairs
local setmetatable = _G.setmetatable
local tostring = _G.tostring

local Patch = {
    RUNTIME = {
        patched = false,
        originals = {},
    }
}

local function log_info(fmt, ...)
    if zhopa.log and zhopa.log.info then
        zhopa.log.info("AXR_TASK_PATCH", fmt, ...)
    end
end

local function get_proxy_seed(npc)
    if not (npc and zhopa.service_filler and zhopa.service_filler.get_task_proxy_seed) then
        return nil, nil
    end
    local ok, seed, role = pcall(zhopa.service_filler.get_task_proxy_seed, npc)
    if not ok or type(seed) ~= "string" or seed == "" then
        return nil, nil
    end
    return seed, role
end

local function make_proxy_npc(npc, seed)
    local proxy = {
        __npc = npc,
        __seed = seed,
    }

    proxy.id = function()
        return npc:id()
    end

    proxy.section = function()
        return seed
    end

    proxy.name = function()
        return seed
    end

    return setmetatable(proxy, {
        __index = function(_, key)
            local value = npc[key]
            if type(value) == "function" then
                return function(_, ...)
                    return value(npc, ...)
                end
            end
            return value
        end
    })
end

local function build_proxy(npc, is_sim)
    local seed, role = get_proxy_seed(npc)
    if not seed then
        return npc, is_sim, nil
    end
    return make_proxy_npc(npc, seed), false, role
end

local function wrap_triple(fn_name)
    if not (axr_task_manager and type(axr_task_manager[fn_name]) == "function") then
        return
    end
    if Patch.RUNTIME.originals[fn_name] then
        return
    end

    local original = axr_task_manager[fn_name]
    Patch.RUNTIME.originals[fn_name] = original
    axr_task_manager[fn_name] = function(npc, arg2, is_sim)
        local proxied_npc, proxied_is_sim = build_proxy(npc, is_sim)
        return original(proxied_npc, arg2, proxied_is_sim)
    end
end

local function wrap_pair(fn_name)
    if not (axr_task_manager and type(axr_task_manager[fn_name]) == "function") then
        return
    end
    if Patch.RUNTIME.originals[fn_name] then
        return
    end

    local original = axr_task_manager[fn_name]
    Patch.RUNTIME.originals[fn_name] = original
    axr_task_manager[fn_name] = function(npc, is_sim)
        local proxied_npc, proxied_is_sim = build_proxy(npc, is_sim)
        return original(proxied_npc, proxied_is_sim)
    end
end

function Patch.apply()
    if Patch.RUNTIME.patched == true then
        return true
    end
    if not axr_task_manager then
        return false
    end

    local triple_wrappers = {
        "drx_sl_generate_random_sl_task",
        "drx_sl_generate_change_factions_task",
        "get_first_available_task",
        "drx_sl_get_mechanic_task",
    }

    local pair_wrappers = {
        "drx_sl_get_finished_task",
        "drx_sl_get_finished_cf_task",
        "drx_sl_set_finished_task_complete",
        "drx_sl_set_finished_cf_task_complete",
        "get_first_finished_task",
        "set_finished_task_complete",
        "npc_give_first_available_ordered_task",
        "generate_available_tasks",
        "generate_ongoing_tasks",
        "generate_finished_tasks",
    }

    for i = 1, #triple_wrappers do
        wrap_triple(triple_wrappers[i])
    end
    for i = 1, #pair_wrappers do
        wrap_pair(pair_wrappers[i])
    end

    Patch.RUNTIME.patched = true
    log_info("applied functions=%s", tostring(#triple_wrappers + #pair_wrappers))
    return true
end

zhopa.axr_task_patch = Patch
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_axr_task_patch

-- BEGIN module zhopa_loot
zhopa_bundle_module = function()
zhopa = zhopa or {}

local function tg()
    return (time_global and time_global()) or 0
end

local function cfg_get(key, default)
    if not (zhopa.config and zhopa.config.get) then return default end
    local ok, v = pcall(zhopa.config.get, key, default)
    if ok then return v end
    return default
end

local function cfg_num(key, default, min_v)
    local v = tonumber(cfg_get(key, default)) or tonumber(default) or 0
    if min_v ~= nil and v < min_v then
        v = min_v
    end
    return v
end

local function cfg_bool(key, default)
    local v = cfg_get(key, default)
    if v == true or v == false then
        return v
    end
    if tonumber(v) ~= nil then
        return tonumber(v) ~= 0
    end
    if type(v) == "string" then
        if v == "true" then return true end
        if v == "false" then return false end
    end
    return default == true
end


local LOOT_CFG_SNAPSHOT_TTL_MS = 1000
local LOOT_OVERRIDE_THROTTLE_MS = 1500
local LOOT_PASSIVE_CLEANUP_STRIDE_MS = 1000
local QUEST_CORPSE_CLUSTER_RADIUS_M = 20
local QUEST_CORPSE_FLAG = "zhopa_quest_corpse"
local VANILLA_DEATH_DROPPED_FLAG = "death_dropped"
local LOOT_TIMER_NS = "zhopa_loot"
local LOOT_SERVICE_TIMER = "service"
local LOOT_SERVER_OBJECT_CACHE_MS = 250
local LOOT_PROTECTED_SYNC_BUDGET = 512

local inst = {
    RUNTIME = {
        saved_npc_loot_distance = nil,
        loot_distance_overridden = false,
        corpse_events = {},
        corpse_ids = {},
        corpse_index = {},
        corpse_queue = {},
        corpse_head = 1,
        corpse_tail = 0,
        corpse_size = 0,
        item_events = {},
        item_ids = {},
        item_index = {},
        item_queue = {},
        item_head = 1,
        item_tail = 0,
        item_size = 0,
        last_cleanup_tg = 0,
        last_surge_seen_tg = 0,
        surge_cache_active = false,
        surge_cache_next_tg = 0,
        cfg_snapshot = nil,
        cfg_snapshot_next_tg = 0,
        loot_override_next_tg = 0,
        rioc_patch_applied = false,
        quest_corpse_pending = {},
        quest_corpse_full_sync = false,
        quest_corpse_service_next_tg = 0,
        quest_corpse_sync_cursor = nil,
        server_object_cache = {},
        server_object_cache_next_tg = 0,
        quest_corpse_cluster_next_tg_by_id = {},
    }
}

local remove_event_id
local sync_protected_corpse_lootability
local is_protected_corpse
local mark_nearby_corpses_protected
local run_loot_service
local schedule_loot_service

local function loot_timers_available()
    return zhopa and zhopa.timers and type(zhopa.timers.schedule) == "function"
end

local function on_loot_service_timer()
    if run_loot_service then
        run_loot_service(tg(), false)
    end
end

schedule_loot_service = function(delay_ms)
    if not loot_timers_available() then
        return false
    end
    local delay = tonumber(delay_ms) or 0
    if delay < 0 then delay = 0 end
    return zhopa.timers.schedule(LOOT_TIMER_NS, LOOT_SERVICE_TIMER, delay, on_loot_service_timer)
end

local function apply_actor_loot_distance_override(enabled)
    if not (ui_options and ui_options.get and ui_options.set) then return end
    if tg() <= 0 then return end
    if not (db and db.actor and db.actor.alive) then return end
    local ok_alive, alive = pcall(function() return db.actor:alive() end)
    if not (ok_alive and alive) then return end

    if enabled == true then
        if inst.RUNTIME.loot_distance_overridden == true then return end
        local ok, cur = pcall(function() return ui_options.get("gameplay/general/npc_loot_distance") end)
        if ok then
            inst.RUNTIME.saved_npc_loot_distance = cur
        end
        pcall(function() ui_options.set("gameplay/general/npc_loot_distance", 0) end)
        inst.RUNTIME.loot_distance_overridden = true
        return
    end

    if inst.RUNTIME.loot_distance_overridden ~= true then return end
    if inst.RUNTIME.saved_npc_loot_distance ~= nil then
        pcall(function() ui_options.set("gameplay/general/npc_loot_distance", inst.RUNTIME.saved_npc_loot_distance) end)
    end
    inst.RUNTIME.loot_distance_overridden = false
end

local function should_run()
    return cfg_bool("enabled", true) and cfg_bool("loot_enabled", true)
end

local function quest_corpse_protection_enabled()
    return cfg_bool("enabled", true) and cfg_bool("loot_protect_quest_corpses_enabled", true)
end

local function get_server_object(id)
    id = tonumber(id) or 0
    if id <= 0 or id == 65535 then
        return nil
    end

    local now = tg()
    local cache = inst.RUNTIME.server_object_cache
    if type(cache) ~= "table" or now >= (tonumber(inst.RUNTIME.server_object_cache_next_tg) or 0) then
        cache = {}
        inst.RUNTIME.server_object_cache = cache
        inst.RUNTIME.server_object_cache_next_tg = now + LOOT_SERVER_OBJECT_CACHE_MS
    elseif cache[id] ~= nil then
        return cache[id] or nil
    end

    local storage = db and db.storage and db.storage[id]
    if storage and storage.object then
        cache[id] = storage.object
        return storage.object
    end

    if level and level.object_by_id then
        local ok_obj, obj = pcall(function()
            return level.object_by_id(id)
        end)
        if ok_obj and obj then
            cache[id] = obj
            return obj
        end
    end

    if alife_object then
        local ok_obj, obj = pcall(function()
            return alife_object(id)
        end)
        if ok_obj and obj then
            cache[id] = obj
            return obj
        end
    end

    cache[id] = false
    return nil
end

local function object_id(obj)
    return tonumber(obj and obj.id and (type(obj.id) == "function" and obj:id() or obj.id)) or nil
end

local function object_name(obj)
    if not obj then
        return nil
    end
    if type(obj.name) == "function" then
        local ok, name = pcall(function()
            return obj:name()
        end)
        if ok and type(name) == "string" and name ~= "" then
            return name
        end
    end
    return nil
end

local function object_section(obj)
    if not obj then
        return nil
    end

    if type(obj.section_name) == "function" then
        local ok, sect = pcall(function()
            return obj:section_name()
        end)
        if ok and type(sect) == "string" and sect ~= "" then
            return sect
        end
    end

    if type(obj.section) == "function" then
        local ok, sect = pcall(function()
            return obj:section()
        end)
        if ok and type(sect) == "string" and sect ~= "" then
            return sect
        end
    end

    return nil
end

local function object_position(obj)
    if zhopa.safe and zhopa.safe.safe_position then
        return zhopa.safe.safe_position(obj)
    end
    if not obj then
        return nil
    end
    if type(obj.position) == "function" then
        local ok, pos = pcall(function()
            return obj:position()
        end)
        if ok and pos then
            return pos
        end
    end
    return nil
end

local function is_dead_object(obj)
    if not obj then
        return false
    end

    if type(obj.is_entity_alive) == "function" then
        local ok, entity_alive = pcall(function()
            return obj:is_entity_alive()
        end)
        if ok and entity_alive == false then
            return false
        end
    end

    local is_valid_type = false
    pcall(function()
        if IsStalker and IsStalker(obj) then is_valid_type = true end
        if IsMonster and IsMonster(obj) then is_valid_type = true end
        if obj.clsid and clsid and obj:clsid() == clsid.script_actor then is_valid_type = true end
    end)
    if not is_valid_type then
        return false
    end

    if type(obj.alive) ~= "function" then
        return false
    end

    local ok, alive = pcall(function()
        return obj:alive()
    end)
    return ok and alive == false
end

local function is_quest_item_object(obj)
    if not obj then
        return false
    end

    if type(obj.IsQuestItem) == "function" then
        local ok, res = pcall(function()
            return obj:IsQuestItem()
        end)
        if ok and res ~= nil then
            return res == true
        end
    end

    local section = object_section(obj)
    if not section then
        return false
    end

    if SYS_GetParam then
        local ok, res = pcall(function()
            return SYS_GetParam(1, section, "quest_item")
        end)
        if ok and res ~= nil then
            return res == true
        end
    end

    if ini_sys and ini_sys.r_bool_ex then
        local ok, res = pcall(function()
            return ini_sys:r_bool_ex(section, "quest_item", false)
        end)
        if ok then
            return res == true
        end
    end

    return false
end

local function apply_corpse_valuable_loot(id, can_loot)
    id = tonumber(id) or 0
    if id <= 0 or id == 65535 then
        return false
    end
    if not (xr_corpse_detection and xr_corpse_detection.set_valuable_loot) then
        return false
    end
    return pcall(function()
        xr_corpse_detection.set_valuable_loot(id, can_loot == true)
    end)
end

local function corpse_has_save_flag(id, key)
    id = tonumber(id) or 0
    if id <= 0 or id == 65535 then
        return false
    end
    if type(key) ~= "string" or key == "" then
        return false
    end

    if not (alife_storage_manager and alife_storage_manager.get_state) then
        return false
    end

    local m_data = alife_storage_manager.get_state()
    local se_object = m_data and m_data.se_object or nil
    if type(se_object) ~= "table" then
        return false
    end

    local data = se_object[id]
    return data and data[key] == true or false
end

local function corpse_save_flagged(id)
    return corpse_has_save_flag(id, QUEST_CORPSE_FLAG) == true
end

local function corpse_has_death_dropped_flag(id, name)
    id = tonumber(id) or 0
    if id <= 0 or id == 65535 then
        return false
    end

    if corpse_has_save_flag(id, VANILLA_DEATH_DROPPED_FLAG) then
        return true
    end

    local loaded = false
    if se_load_var then
        local ok, res = pcall(function()
            return se_load_var(id, name, VANILLA_DEATH_DROPPED_FLAG)
        end)
        if ok then
            loaded = (res == true or tostring(res) == "true" or tonumber(res) == 1)
        end
    end
    return loaded == true
end

local function corpse_has_quest_item(corpse)
    if not corpse then
        return false
    end

    if type(corpse.cast_InventoryOwner) == "function" then
        local ok_cast, inv_owner = pcall(function()
            return corpse:cast_InventoryOwner()
        end)
        if not (ok_cast and inv_owner) then
            return false
        end
    end

    local found = false
    local function inspect(_, item)
        if found or not item then
            return
        end
        if is_quest_item_object(item) then
            found = true
        end
    end

    local ok = pcall(function()
        if corpse.iterate_inventory then
            corpse:iterate_inventory(inspect, corpse)
        elseif corpse.inventory_for_each then
            corpse:inventory_for_each(function(item)
                inspect(nil, item)
            end)
        end
    end)

    if not ok then
        return false
    end

    return found == true
end

local function is_inventory_owner_object(obj)
    if not obj then
        return false
    end
    if type(obj.cast_InventoryOwner) ~= "function" then
        return false
    end
    local ok, inv_owner = pcall(function()
        return obj:cast_InventoryOwner()
    end)
    return ok and inv_owner ~= nil
end

local function queue_quest_corpse_candidate(id, reason, now)
    id = tonumber(id) or 0
    if id <= 0 or id == 65535 then
        return false
    end

    now = tonumber(now) or tg()
    local pending = inst.RUNTIME.quest_corpse_pending
    if type(pending) ~= "table" then
        pending = {}
        inst.RUNTIME.quest_corpse_pending = pending
    end

    local entry = pending[id]
    if not entry then
        entry = {
            reason = reason or "-",
            next_tg = now,
            expires_tg = now + cfg_num("loot_quest_corpse_retry_ttl_ms", 15000, 1000),
            attempts = 0,
        }
        pending[id] = entry
    else
        entry.reason = reason or entry.reason or "-"
        entry.next_tg = math.min(tonumber(entry.next_tg) or now, now)
        entry.expires_tg = math.max(tonumber(entry.expires_tg) or 0, now + cfg_num("loot_quest_corpse_retry_ttl_ms", 15000, 1000))
    end

    schedule_loot_service(0)
    return true
end

local function service_quest_corpse_candidates(now)
    now = tonumber(now) or tg()
    local next_tg = tonumber(inst.RUNTIME.quest_corpse_service_next_tg) or 0
    if now < next_tg and inst.RUNTIME.quest_corpse_full_sync ~= true then
        return
    end
    inst.RUNTIME.quest_corpse_service_next_tg = now + cfg_num("loot_quest_corpse_service_ms", 250, 0)

    if inst.RUNTIME.quest_corpse_full_sync == true then
        inst.RUNTIME.quest_corpse_full_sync = false
        sync_protected_corpse_lootability()
    end

    local pending = inst.RUNTIME.quest_corpse_pending
    if type(pending) ~= "table" then
        return
    end

    local max_runs = 8
    local ran = 0
    local stale = {}

    for id, entry in pairs(pending) do
        if ran >= max_runs then
            break
        end

        local pid = tonumber(id) or 0
        local next_tg = tonumber(entry and entry.next_tg) or 0
        local expires_tg = tonumber(entry and entry.expires_tg) or 0

        if pid <= 0 then
            stale[#stale + 1] = id
        elseif expires_tg > 0 and now > expires_tg then
            stale[#stale + 1] = id
        elseif now >= next_tg then
            local corpse = get_server_object(pid)
            local corpse_name = corpse and object_name(corpse) or nil
            local before = corpse_save_flagged(pid) == true or corpse_has_death_dropped_flag(pid, corpse_name) == true
            local changed = sync_protected_corpse_lootability(pid) == true
            local protected = false
            if corpse then
                protected = is_protected_corpse(corpse) == true
            else
                protected = corpse_save_flagged(pid) == true or corpse_has_death_dropped_flag(pid) == true
            end

            entry.attempts = (tonumber(entry.attempts) or 0) + 1
            if changed == true or protected == true or before == true then
                stale[#stale + 1] = id
            else
                entry.next_tg = now + 1000
            end
            ran = ran + 1
        end
    end

    for _, id in ipairs(stale) do
        pending[id] = nil
    end
end

local function mark_protected_corpse(corpse, reason, skip_cluster)
    if not quest_corpse_protection_enabled() then
        return false
    end
    if not corpse then
        return false
    end

    local id = object_id(corpse)
    local name = object_name(corpse)
    if not id or id <= 0 or id == 65535 then
        return false
    end

    se_save_var(id, name, QUEST_CORPSE_FLAG, true)
    apply_corpse_valuable_loot(id, false)

    if inst and inst.has_corpse_event_id and inst.has_corpse_event_id(id) then
        remove_event_id("corpse", id)
    end

    if skip_cluster ~= true then
        mark_nearby_corpses_protected(corpse, tostring(reason or "quest_corpse") .. "_cluster")
    end

    return true
end

local function mark_protected_corpse_id(id, reason)
    if not quest_corpse_protection_enabled() then
        return false
    end

    id = tonumber(id) or 0
    if id <= 0 or id == 65535 then
        return false
    end

    local corpse = get_server_object(id)
    if corpse then
        return mark_protected_corpse(corpse, reason or "id")
    end

    se_save_var(id, nil, QUEST_CORPSE_FLAG, true)
    apply_corpse_valuable_loot(id, false)

    if inst and inst.has_corpse_event_id and inst.has_corpse_event_id(id) then
        remove_event_id("corpse", id)
    end

    return true
end

mark_nearby_corpses_protected = function(anchor_corpse, reason)
    if not quest_corpse_protection_enabled() then
        return 0
    end
    if not (level and level.iterate_nearest) then
        return 0
    end
    if not anchor_corpse then
        return 0
    end

    local anchor_id = object_id(anchor_corpse) or 0
    local anchor_pos = object_position(anchor_corpse)
    if anchor_id <= 0 or not anchor_pos then
        return 0
    end
    local now = tg()
    local next_by_id = inst.RUNTIME.quest_corpse_cluster_next_tg_by_id
    if type(next_by_id) ~= "table" then
        next_by_id = {}
        inst.RUNTIME.quest_corpse_cluster_next_tg_by_id = next_by_id
    end
    if now < (tonumber(next_by_id[anchor_id]) or 0) then
        return 0
    end
    next_by_id[anchor_id] = now + 1000

    local marked = 0
    level.iterate_nearest(anchor_pos, QUEST_CORPSE_CLUSTER_RADIUS_M, function(obj)
        if not obj then
            return false
        end

        local obj_id = object_id(obj) or 0
        if obj_id <= 0 or obj_id == anchor_id then
            return false
        end
        if not is_dead_object(obj) then
            return false
        end
        if not is_inventory_owner_object(obj) then
            return false
        end

        if mark_protected_corpse(obj, reason or "cluster", true) == true then
            marked = marked + 1
        end
        return false
    end)

    return marked
end

sync_protected_corpse_lootability = function(id)
    if not (alife_storage_manager and alife_storage_manager.get_state) then
        return false
    end

    local enable = quest_corpse_protection_enabled()
    local changed = false
    if id ~= nil then
        id = tonumber(id) or nil
        if id then
            local corpse = get_server_object(id)
            local corpse_name = corpse and object_name(corpse) or nil
            local save_flagged = corpse_save_flagged(id) == true
            local death_dropped = corpse_has_death_dropped_flag(id, corpse_name) == true
            local live_quest_item = corpse and corpse_has_quest_item(corpse) == true
            if enable == true and corpse and live_quest_item then
                mark_protected_corpse(corpse, "sync_quest_item")
                return true
            end
            if save_flagged or death_dropped then
                apply_corpse_valuable_loot(id, not enable)
                if enable == true and corpse then
                    mark_protected_corpse(corpse, "sync_id")
                end
                changed = true
            end
        end
        return changed
    end

    local m_data = alife_storage_manager.get_state()
    local se_object = m_data and m_data.se_object or nil
    if type(se_object) ~= "table" then
        return false
    end

    local cursor = inst.RUNTIME.quest_corpse_sync_cursor
    local processed = 0
    local completed = false
    while processed < LOOT_PROTECTED_SYNC_BUDGET do
        local ok_next, sid, data = pcall(next, se_object, cursor)
        if not ok_next then
            cursor = nil
            ok_next, sid, data = pcall(next, se_object, nil)
        end
        if not (ok_next and sid ~= nil) then
            cursor = nil
            completed = true
            break
        end
        cursor = sid
        if data and data[QUEST_CORPSE_FLAG] == true then
            apply_corpse_valuable_loot(sid, not enable)
            changed = true
        elseif data and data[VANILLA_DEATH_DROPPED_FLAG] == true then
            apply_corpse_valuable_loot(sid, not enable)
            if enable == true then
                local obj = db and db.storage and db.storage[sid] and db.storage[sid].object or nil
                if obj then
                    mark_protected_corpse(obj, "sync_death_dropped")
                end
            end
            changed = true
        elseif enable == true and db and db.storage and db.storage[sid] and db.storage[sid].object then
            local obj = db.storage[sid].object
            local obj_name = object_name(obj)
            local death_dropped = corpse_has_death_dropped_flag(sid, obj_name)
            local live_quest_item = corpse_has_quest_item(obj)
            if death_dropped then
                mark_protected_corpse(obj, "sync_marker_scan")
                changed = true
            elseif is_dead_object(obj) and live_quest_item then
                mark_protected_corpse(obj, "sync_scan")
                changed = true
            end
        end
        processed = processed + 1
    end
    if completed == true then
        inst.RUNTIME.quest_corpse_sync_cursor = nil
        inst.RUNTIME.quest_corpse_full_sync = false
    else
        inst.RUNTIME.quest_corpse_sync_cursor = cursor
        inst.RUNTIME.quest_corpse_full_sync = true
        schedule_loot_service(cfg_num("loot_quest_corpse_service_ms", 250, 0))
    end
    return changed
end

local function patch_recover_item_on_corpse()
    if inst.RUNTIME.rioc_patch_applied == true then
        return true
    end

    local status = rawget(_G, "status_recover_item_on_corpse")
    local kill = rawget(_G, "kill_if_online")
    if type(status) ~= "table" or type(status[0]) ~= "function" or type(kill) ~= "function" then
        return false
    end

    local orig_kill = kill
    _G.kill_if_online = function(id)
        if corpse_has_death_dropped_flag(id) then
            mark_protected_corpse_id(id, "rioc_kill_if_online")
        end
        return orig_kill(id)
    end

    inst.RUNTIME.rioc_patch_applied = true
    return true
end

is_protected_corpse = function(corpse)
    if not quest_corpse_protection_enabled() then
        return false
    end
    if not corpse or not is_dead_object(corpse) then
        return false
    end

    local id = object_id(corpse)
    if corpse_save_flagged(id) then
        return true
    end

    if corpse_has_death_dropped_flag(id, object_name(corpse)) then
        return true
    end

    return corpse_has_quest_item(corpse) == true
end

local function is_protected_corpse_id(id)
    if not quest_corpse_protection_enabled() then
        return false
    end
    if corpse_save_flagged(id) then
        return true
    end
    return corpse_has_death_dropped_flag(id) == true
end

local function get_update_cfg(now)
    local snapshot = inst.RUNTIME.cfg_snapshot
    local next_tg = tonumber(inst.RUNTIME.cfg_snapshot_next_tg) or 0
    if type(snapshot) == "table" and now < next_tg then
        return snapshot
    end

    snapshot = {
        loot_enabled = cfg_bool("enabled", true) and cfg_bool("loot_enabled", true),
        loot_disable_near_actor_limit = cfg_bool("loot_disable_near_actor_limit", true),
        loot_collect_during_surge = cfg_bool("loot_collect_during_surge", false),
    }
    inst.RUNTIME.cfg_snapshot = snapshot
    inst.RUNTIME.cfg_snapshot_next_tg = now + LOOT_CFG_SNAPSHOT_TTL_MS
    return snapshot
end

local function has_quest_corpse_work()
    if inst.RUNTIME.quest_corpse_full_sync == true then
        return true
    end
    return type(inst.RUNTIME.quest_corpse_pending) == "table" and next(inst.RUNTIME.quest_corpse_pending) ~= nil
end

local function apply_actor_loot_distance_override_throttled(now, enabled, force)
    local next_tg = tonumber(inst.RUNTIME.loot_override_next_tg) or 0
    if force ~= true and now < next_tg then
        return
    end
    apply_actor_loot_distance_override(enabled == true)
    inst.RUNTIME.loot_override_next_tg = now + LOOT_OVERRIDE_THROTTLE_MS
end

local function event_ttl_s()
    return cfg_num("loot_event_ttl_s", 180, 0)
end

local function is_surge_active_now()
    local xc = _G.xr_conditions
    local xf = xc and xc.surge_started or nil
    if type(xf) == "function" then
        local ok, res = pcall(xf)
        if ok and res == true then return true, false end
        if ok and res == false then return false, false end
    end

    local fallback_used = false

    local f = _G.surge_started
    if type(f) == "function" then
        fallback_used = true
        local ok, res = pcall(f)
        if ok and res == true then return true, fallback_used end
        if ok and res == false then return false, fallback_used end
    end

    local psm = _G.psi_storm_manager
    if psm and type(psm.is_loaded) == "function" and type(psm.is_started) == "function" then
        fallback_used = true
        local okL, loaded = pcall(function() return psm.is_loaded() end)
        if okL and loaded == true then
            local okS, started = pcall(function() return psm.is_started() end)
            if okS and started == true then return true, fallback_used end
        end
    end

    local sm = _G.surge_manager
    if sm and type(sm.is_loaded) == "function" and type(sm.is_started) == "function" then
        fallback_used = true
        local okL, loaded = pcall(function() return sm.is_loaded() end)
        if okL and loaded == true then
            local okS, started = pcall(function() return sm.is_started() end)
            if okS and started == true then return true, fallback_used end
        end
    end

    if _G.level and type(_G.level.is_surge) == "function" then
        fallback_used = true
        local ok, res = pcall(function() return _G.level.is_surge() end)
        if ok and res == true then return true, fallback_used end
    end

    return false, fallback_used
end

local function is_surge_active_cached()
    local now = tg()
    local cache_ms = cfg_num("surge_check_cache_ms", 250, 0)
    if now < (tonumber(inst.RUNTIME.surge_cache_next_tg) or 0) then
        return inst.RUNTIME.surge_cache_active == true
    end

    local active, fallback_used = is_surge_active_now()
    inst.RUNTIME.surge_cache_active = active == true
    inst.RUNTIME.surge_cache_next_tg = now + cache_ms

    if fallback_used and zhopa.log and zhopa.log.warn then
        zhopa.log.warn("LOOT", "SURGE_CHECK_FALLBACK source=loot")
    end
    return active == true
end

local function should_collect_events_now(now)
    if cfg_bool("loot_collect_during_surge", false) then
        return true
    end

    if is_surge_active_cached() then
        inst.RUNTIME.last_surge_seen_tg = now
        return false
    end

    local grace_ms = cfg_num("loot_collect_after_surge_grace_ms", 120000, 0)
    if grace_ms <= 0 then
        return true
    end

    local last = tonumber(inst.RUNTIME.last_surge_seen_tg) or 0
    if last > 0 and now < (last + grace_ms) then
        return false
    end
    return true
end

local function clear_store(kind)
    inst.RUNTIME[kind .. "_events"] = {}
    inst.RUNTIME[kind .. "_ids"] = {}
    inst.RUNTIME[kind .. "_index"] = {}
    inst.RUNTIME[kind .. "_queue"] = {}
    inst.RUNTIME[kind .. "_head"] = 1
    inst.RUNTIME[kind .. "_tail"] = 0
    inst.RUNTIME[kind .. "_size"] = 0
end

local function clear_events_all()
    clear_store("corpse")
    clear_store("item")
end

remove_event_id = function(kind, id)
    local events = inst.RUNTIME[kind .. "_events"]
    if events[id] == nil then return false end

    events[id] = nil
    local ids = inst.RUNTIME[kind .. "_ids"]
    local index = inst.RUNTIME[kind .. "_index"]
    local pos = tonumber(index[id])
    if pos and ids[pos] ~= nil then
        local last_pos = #ids
        local moved = ids[last_pos]
        ids[pos] = moved
        ids[last_pos] = nil
        index[id] = nil
        if moved ~= nil then
            index[moved] = pos
        end
    else
        index[id] = nil
    end

    local size_key = kind .. "_size"
    local sz = tonumber(inst.RUNTIME[size_key]) or 0
    if sz > 0 then
        inst.RUNTIME[size_key] = sz - 1
    else
        inst.RUNTIME[size_key] = 0
    end
    return true
end

local function add_event_id(kind, id, now)
    local events = inst.RUNTIME[kind .. "_events"]
    local ids = inst.RUNTIME[kind .. "_ids"]
    local index = inst.RUNTIME[kind .. "_index"]
    local queue = inst.RUNTIME[kind .. "_queue"]

    if events[id] == nil then
        ids[#ids + 1] = id
        index[id] = #ids
        local size_key = kind .. "_size"
        inst.RUNTIME[size_key] = (tonumber(inst.RUNTIME[size_key]) or 0) + 1
    end

    events[id] = now
    local tail_key = kind .. "_tail"
    local tail = (tonumber(inst.RUNTIME[tail_key]) or 0) + 1
    inst.RUNTIME[tail_key] = tail
    queue[tail] = { id = id, tg = now }
end

local function queue_tail_key(kind)
    return tostring(kind or "") .. "_tail"
end

local function compact_queue(kind)
    local queue_key = kind .. "_queue"
    local head_key = kind .. "_head"
    local tail_key = queue_tail_key(kind)
    local queue = inst.RUNTIME[queue_key]
    local head = tonumber(inst.RUNTIME[head_key]) or 1
    local tail = tonumber(inst.RUNTIME[tail_key]) or 0
    if head <= 1 then return end
    if head < 256 and head <= (tail / 2) then return end

    local compacted = {}
    for i = head, tail do
        compacted[#compacted + 1] = queue[i]
    end
    inst.RUNTIME[queue_key] = compacted
    inst.RUNTIME[head_key] = 1
    inst.RUNTIME[tail_key] = #compacted
end

local function peek_head_entry(kind)
    local queue_key = kind .. "_queue"
    local head_key = kind .. "_head"
    local tail_key = queue_tail_key(kind)
    local queue = inst.RUNTIME[queue_key]
    local head = tonumber(inst.RUNTIME[head_key]) or 1
    local tail = tonumber(inst.RUNTIME[tail_key]) or 0

    while head <= tail do
        local entry = queue[head]
        if entry and type(entry.id) == "number" and type(entry.tg) == "number" then
            inst.RUNTIME[head_key] = head
            return entry, head
        end
        queue[head] = nil
        head = head + 1
    end

    inst.RUNTIME[head_key] = head
    return nil, nil
end

local function pop_head_entry(kind, remove_current)
    local queue_key = kind .. "_queue"
    local head_key = kind .. "_head"
    local queue = inst.RUNTIME[queue_key]
    local entry, head = peek_head_entry(kind)
    if not entry then return nil end

    queue[head] = nil
    inst.RUNTIME[head_key] = head + 1

    if remove_current then
        local events = inst.RUNTIME[kind .. "_events"]
        if events[entry.id] == entry.tg then
            remove_event_id(kind, entry.id)
        end
    end
    return entry
end

local function event_counts()
    local corpses = tonumber(inst.RUNTIME.corpse_size) or 0
    local items = tonumber(inst.RUNTIME.item_size) or 0
    return corpses, items, (corpses + items)
end

local function event_caps()
    local total = cfg_num("loot_event_cap_total", 1200, 1)
    local corpses = cfg_num("loot_event_cap_corpses", 800, 0)
    local items = cfg_num("loot_event_cap_items", 800, 0)
    return total, corpses, items
end

local function trim_oldest(kind)
    local removed = pop_head_entry(kind, true)
    compact_queue(kind)
    return removed ~= nil
end

local function trim_oldest_any()
    local c_entry = peek_head_entry("corpse")
    local i_entry = peek_head_entry("item")
    if not c_entry and not i_entry then
        return false
    end
    if c_entry and i_entry then
        if c_entry.tg <= i_entry.tg then
            return trim_oldest("corpse")
        end
        return trim_oldest("item")
    end
    if c_entry then return trim_oldest("corpse") end
    return trim_oldest("item")
end

local function log_backlog(reason)
    local cap_total, cap_corpses, cap_items = event_caps()
    local corpses, items, total = event_counts()
    if zhopa.log and zhopa.log.warn then
        zhopa.log.warn(
            "LOOT",
            "BACKLOG corpses=%s items=%s total=%s cap_total=%s cap_corpse=%s cap_item=%s reason=%s",
            tostring(corpses),
            tostring(items),
            tostring(total),
            tostring(cap_total),
            tostring(cap_corpses),
            tostring(cap_items),
            tostring(reason or "-")
        )
    end
end

local function enforce_caps()
    local cap_total, cap_corpses, cap_items = event_caps()
    local corpses, items, total = event_counts()
    local trimmed = false

    while corpses > cap_corpses do
        if not trim_oldest("corpse") then break end
        trimmed = true
        corpses, items, total = event_counts()
    end
    while items > cap_items do
        if not trim_oldest("item") then break end
        trimmed = true
        corpses, items, total = event_counts()
    end
    while total > cap_total do
        if not trim_oldest_any() then break end
        trimmed = true
        corpses, items, total = event_counts()
    end

    if trimmed then
        log_backlog("cap_trim")
    end
end

local function cleanup_events(now)
    local ttl_ms = event_ttl_s() * 1000
    local budget = 256
    if ttl_ms <= 0 then
        clear_events_all()
        inst.RUNTIME.last_cleanup_tg = now
        return
    end

    local cutoff = now - ttl_ms
    local processed = 0
    while processed < budget do
        local c_entry = peek_head_entry("corpse")
        local i_entry = peek_head_entry("item")
        local kind = nil
        local entry = nil

        if c_entry and i_entry then
            if c_entry.tg <= i_entry.tg then
                kind = "corpse"
                entry = c_entry
            else
                kind = "item"
                entry = i_entry
            end
        elseif c_entry then
            kind = "corpse"
            entry = c_entry
        elseif i_entry then
            kind = "item"
            entry = i_entry
        else
            break
        end

        if not (entry and entry.tg and entry.tg < cutoff) then
            break
        end

        pop_head_entry(kind, true)
        processed = processed + 1
    end

    compact_queue("corpse")
    compact_queue("item")
    enforce_caps()
    inst.RUNTIME.last_cleanup_tg = now
end

local function has_pending_events()
    return (tonumber(inst.RUNTIME.corpse_size) or 0) > 0
        or (tonumber(inst.RUNTIME.item_size) or 0) > 0
end

local function maybe_cleanup_runtime(now, force)
    now = tonumber(now) or tg()
    local cfg = get_update_cfg(now)
    if cfg.loot_enabled == false then
        apply_actor_loot_distance_override_throttled(now, false, true)
        inst.RUNTIME.last_cleanup_tg = now
        return false
    end

    apply_actor_loot_distance_override_throttled(now, cfg.loot_disable_near_actor_limit, force == true)

    if not cfg.loot_collect_during_surge and is_surge_active_cached() then
        inst.RUNTIME.last_surge_seen_tg = now
    end

    if force == true or (has_pending_events() and now >= ((tonumber(inst.RUNTIME.last_cleanup_tg) or 0) + LOOT_PASSIVE_CLEANUP_STRIDE_MS)) then
        cleanup_events(now)
    end
    if has_pending_events() then
        schedule_loot_service(LOOT_PASSIVE_CLEANUP_STRIDE_MS)
    end
    return true
end

run_loot_service = function(now, force)
    now = tonumber(now) or tg()
    if inst.RUNTIME.rioc_patch_applied ~= true then
        patch_recover_item_on_corpse()
    end
    service_quest_corpse_candidates(now)
    maybe_cleanup_runtime(now, force == true)
    if has_quest_corpse_work() or has_pending_events() then
        schedule_loot_service(LOOT_PASSIVE_CLEANUP_STRIDE_MS)
    end
end

local function unlock_corpse(corpse)
    if not corpse then return end
    pcall(function()
        if corpse.deadbody_can_take then corpse:deadbody_can_take(true) end
        if corpse.deadbody_closed then corpse:deadbody_closed(false) end
    end)
end

function inst.on_npc_death(victim, who)
    if not should_run() then return end
    if not victim then return end
    local now = tg()
    local ok_id, id = pcall(function() return victim:id() end)
    if not (ok_id and type(id) == "number") then return end
    queue_quest_corpse_candidate(id, "npc_death", now)
    if should_collect_events_now(now) then
        add_event_id("corpse", id, now)
        enforce_caps()
        maybe_cleanup_runtime(now, false)
    else
        schedule_loot_service(LOOT_PASSIVE_CLEANUP_STRIDE_MS)
    end
    if cfg_bool("loot_unlock_corpses", true) then
        unlock_corpse(victim)
    end
end

function inst.on_server_entity_register(se_obj, type_name)
    if not should_run() then return end
    if not se_obj then return end

    if is_quest_item_object(se_obj) then
        queue_quest_corpse_candidate(se_obj.parent_id, "quest_item_parent", tg())
        return
    end

    local id = object_id(se_obj)
    local name = object_name(se_obj)
    if id and (is_dead_object(se_obj) or corpse_save_flagged(id) or corpse_has_death_dropped_flag(id, name) or corpse_has_quest_item(se_obj)) then
        queue_quest_corpse_candidate(id, "server_register", tg())
    end
end

function inst.on_npc_item_drop(npc, item)
    if not should_run() then return end
    if not item then return end
    local now = tg()
    local ok_id, id = pcall(function() return item:id() end)
    if not (ok_id and type(id) == "number") then return end
    if should_collect_events_now(now) then
        add_event_id("item", id, now)
        enforce_caps()
        maybe_cleanup_runtime(now, false)
    else
        schedule_loot_service(LOOT_PASSIVE_CLEANUP_STRIDE_MS)
    end
end

function inst.on_actor_item_drop(item)
    if not should_run() then return end
    if not item then return end
    local now = tg()
    local ok_id, id = pcall(function() return item:id() end)
    if not (ok_id and type(id) == "number") then return end
    if should_collect_events_now(now) then
        add_event_id("item", id, now)
        enforce_caps()
        maybe_cleanup_runtime(now, false)
    else
        schedule_loot_service(LOOT_PASSIVE_CLEANUP_STRIDE_MS)
    end
end

function inst.on_game_start()
    inst.RUNTIME.quest_corpse_full_sync = true
    inst.RUNTIME.quest_corpse_sync_cursor = nil
    run_loot_service(tg(), true)
    schedule_loot_service(LOOT_PASSIVE_CLEANUP_STRIDE_MS)
end

function inst.on_load_state()
    inst.RUNTIME.quest_corpse_full_sync = true
    inst.RUNTIME.quest_corpse_sync_cursor = nil
    run_loot_service(tg(), false)
    schedule_loot_service(LOOT_PASSIVE_CLEANUP_STRIDE_MS)
end

function inst.on_npc_update()
    run_loot_service(tg(), false)
end

function inst.on_option_change()
    inst.RUNTIME.quest_corpse_full_sync = true
    inst.RUNTIME.quest_corpse_sync_cursor = nil
    run_loot_service(tg(), true)
    schedule_loot_service(LOOT_PASSIVE_CLEANUP_STRIDE_MS)
end

function inst.needs_npc_update()
    if loot_timers_available() then
        return false
    end
    return inst.RUNTIME.rioc_patch_applied ~= true or has_quest_corpse_work() or has_pending_events()
end

function inst.is_recent_item_id(id)
    return inst.RUNTIME.item_events[id] ~= nil
end

function inst.has_corpse_event_id(id)
    return inst.RUNTIME.corpse_events[id] ~= nil
end

function inst.get_corpse_event_ids()
    return inst.RUNTIME.corpse_ids
end

function inst.get_item_event_ids()
    return inst.RUNTIME.item_ids
end

function inst.is_protected_corpse(corpse)
    return is_protected_corpse(corpse) == true
end

function inst.is_protected_corpse_id(id)
    return is_protected_corpse_id(id) == true
end

function inst.sync_protected_corpse_lootability(id)
    return sync_protected_corpse_lootability(id) == true
end

function inst.mark_protected_corpse_id(id, reason)
    return mark_protected_corpse_id(id, reason) == true
end

function inst.should_skip_event_scan()
    if not should_run() then return true end
    return should_collect_events_now(tg()) ~= true
end

zhopa.loot = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_loot

-- BEGIN module zhopa_loot_patch
zhopa_bundle_module = function()
zhopa = zhopa or {}

local LootPatch = {
    RUNTIME = {
        patched = false,
        gather_items_patched = false,
        corpse_loot_call_patched = false,
        corpse_loot_call_orig = nil,
        next_retry_tg = 0,
        loot_patch_cfg_snapshot = nil,
        loot_patch_cfg_next_tg = 0,
    }
}

local EVENT_SCAN_COOLDOWN_MS = 250
local PATCH_RETRY_COOLDOWN_MS = 1000
local LOOT_PATCH_CFG_SNAPSHOT_MS = 1000
local LOOT_PATCH_TIMER_NS = "zhopa_loot_patch"
local LOOT_PATCH_RETRY_TIMER = "retry"

local maybe_retry_apply

local function loot_patch_timers_available()
    return zhopa and zhopa.timers and type(zhopa.timers.schedule) == "function"
end

local function on_loot_patch_retry_timer()
    if maybe_retry_apply then
        maybe_retry_apply()
    end
end

local function schedule_loot_patch_retry(delay_ms)
    if not loot_patch_timers_available() then
        return false
    end
    local delay = tonumber(delay_ms) or PATCH_RETRY_COOLDOWN_MS
    if delay < 0 then delay = 0 end
    return zhopa.timers.schedule(LOOT_PATCH_TIMER_NS, LOOT_PATCH_RETRY_TIMER, delay, on_loot_patch_retry_timer)
end

local function cfg(key, def)
    if not (zhopa.config and zhopa.config.get) then return def end
    local ok, v = pcall(zhopa.config.get, key, def)
    if ok then return v end
    return def
end

local function cfg_num(key, def, min_v)
    local v = tonumber(cfg(key, def)) or tonumber(def) or 0
    if min_v ~= nil and v < min_v then
        v = min_v
    end
    return v
end

local function tg()
    return (time_global and time_global()) or 0
end

local function get_loot_patch_cfg()
    local now = tg()
    local snapshot = LootPatch.RUNTIME.loot_patch_cfg_snapshot
    if type(snapshot) == "table" and now < (tonumber(LootPatch.RUNTIME.loot_patch_cfg_next_tg) or 0) then
        return snapshot
    end

    local item_detect_m = cfg_num("loot_items_detect_dist_m", 35, 0)
    local scan_m = cfg_num("loot_scan_radius_m", 35, 0)
    local corpse_m = cfg_num("loot_corpse_detect_dist_m", 35, 0)
    snapshot = {
        loot_items_enabled = cfg("loot_items_enabled", false) == true,
        max_memory = cfg_num("loot_patch_max_memory_size", 48, 8),
        item_detect_sqr = item_detect_m * item_detect_m,
        scan_sqr = scan_m * scan_m,
        corpse_sqr = corpse_m * corpse_m,
    }
    LootPatch.RUNTIME.loot_patch_cfg_snapshot = snapshot
    LootPatch.RUNTIME.loot_patch_cfg_next_tg = now + LOOT_PATCH_CFG_SNAPSHOT_MS
    return snapshot
end

local function log_debug(fmt, ...)
    if zhopa.log and zhopa.log.debug then
        zhopa.log.debug("LOOT_PATCH", fmt, ...)
    end
end


local function should_skip_event_scan(loot)
    if not loot then return true end
    if type(loot.should_skip_event_scan) == "function" then
        local ok, res = pcall(loot.should_skip_event_scan)
        if ok and res == true then
            return true
        end
    end
    return false
end

local function quest_corpse_protection_enabled()
    return cfg("loot_protect_quest_corpses_enabled", true) ~= false
end

local function object_id(obj)
    if not obj then
        return nil
    end
    if type(obj.id) == "function" then
        local ok, id = pcall(function()
            return obj:id()
        end)
        if ok then
            return tonumber(id) or nil
        end
    end
    return tonumber(obj.id) or nil
end

local function is_protected_corpse(corpse, corpse_id)
    if not quest_corpse_protection_enabled() then
        return false
    end

    local loot = zhopa.loot
    if loot then
        if corpse and type(loot.is_protected_corpse) == "function" then
            local ok, res = pcall(loot.is_protected_corpse, corpse)
            if ok and res == true then
                return true
            end
        end
        if corpse_id ~= nil and type(loot.is_protected_corpse_id) == "function" then
            local ok, res = pcall(loot.is_protected_corpse_id, corpse_id)
            if ok and res == true then
                return true
            end
        end
    end

    return false
end

local function clear_corpse_detection_state(st)
    if not st then
        return
    end

    local selected_id = st.selected_corpse_id
    if selected_id and db and db.storage and db.storage[selected_id] then
        db.storage[selected_id].corpse_already_selected = nil
    end
    st.selected_corpse_id = nil
    st.state = nil
    st.vertex_id = nil
    st.vertex_position = nil
    st.nearest_corpse_dist = nil
    st.nearest_corpse_vertex = nil
    st.nearest_corpse_position = nil
    st.nearest_id = nil
    st.nearest_state = nil
    st.index = 1
    st.__stimer = nil
    st.mutant_analysed = nil
end

local function patch_get_all_from_corpse()
    if LootPatch.RUNTIME.corpse_loot_call_patched == true then
        return true
    end

    local xr = rawget(_G, "xr_corpse_detection")
    local orig = xr and xr.get_all_from_corpse or rawget(_G, "get_all_from_corpse")
    if type(orig) ~= "function" then
        log_debug("PATCH_GET_ALL_FROM_CORPSE_WAIT")
        return false
    end
    if LootPatch.RUNTIME.corpse_loot_call_orig == orig then
        LootPatch.RUNTIME.corpse_loot_call_patched = true
        log_debug("PATCH_GET_ALL_FROM_CORPSE_ALREADY")
        return true
    end

    log_debug("PATCH_GET_ALL_FROM_CORPSE_APPLY")
    LootPatch.RUNTIME.corpse_loot_call_orig = orig
    local wrapped = function(npc)
        local npc_id = npc and npc.id and npc:id() or nil
        local st = npc_id and db and db.storage and db.storage[npc_id] and db.storage[npc_id].corpse_detection or nil
        local corpse_id = st and st.selected_corpse_id or nil
        local corpse = corpse_id and db and db.storage and db.storage[corpse_id] and db.storage[corpse_id].object
            or corpse_id and level and level.object_by_id and level.object_by_id(corpse_id)
        local protected = corpse_id and is_protected_corpse(corpse, corpse_id) or false
        log_debug(
            "GET_ALL_FROM_CORPSE_CALL npc_id=%s corpse_id=%s protected=%s corpse=%s",
            tostring(npc_id or "-"),
            tostring(corpse_id or "-"),
            tostring(protected == true),
            tostring(corpse ~= nil)
        )
        if protected == true then
            clear_corpse_detection_state(st)
            return false
        end
        return orig(npc)
    end
    if xr then
        xr.get_all_from_corpse = wrapped
    else
        _G.get_all_from_corpse = wrapped
    end
    LootPatch.RUNTIME.corpse_loot_call_patched = true
    log_debug("PATCH_GET_ALL_FROM_CORPSE_OK")
    return true
end

local function patch_xr_gather_items()
    if LootPatch.RUNTIME.gather_items_patched == true then return true end
    local mod = rawget(_G, "xr_gather_items")
    local cls = mod and mod.eva_gather_itm or rawget(_G, "eva_gather_itm")
    if not (cls and cls.find_valid_item) then return false end
    if cls.__zhopa_loot_patched == true then
        LootPatch.RUNTIME.gather_items_patched = true
        return true
    end

    local orig_find = cls.find_valid_item
    local uv = {}
    if debug and debug.getupvalue then
        for i = 1, 80 do
            local name, val = debug.getupvalue(orig_find, i)
            if not name then break end
            uv[name] = val
        end
    end

    local function near_actor(obj)
        if not (ui_options and ui_options.get and db and db.actor and db.actor.position and obj and obj.position) then
            return false
        end
        local dist = tonumber(ui_options.get("gameplay/general/npc_loot_distance"))
        if dist and dist > 0 then
            return db.actor:position():distance_to(obj:position()) < dist
        end
        return false
    end

    cls.find_valid_item = function(self)
        local ok, vanilla_res = pcall(orig_find, self)
        if not ok then
            return false
        end
        if vanilla_res == true then
            return true
        end

        local patch_cfg = get_loot_patch_cfg()
        if patch_cfg.loot_items_enabled ~= true then
            return false
        end

        local loot = zhopa.loot
        if not (loot and loot.get_item_event_ids and loot.is_recent_item_id) then
            return false
        end
        if should_skip_event_scan(loot) then
            return false
        end

        if self.st.cstackprevent then
            return false
        end

        if self.st.selected_id then
            local se_itm = self.st.selected_id ~= 0 and self.st.selected_id ~= 65535 and alife_object(self.st.selected_id)
            if se_itm and se_itm.parent_id == 65535 then
                local itm = level.object_by_id(se_itm.id)
                if itm and not near_actor(itm) then
                    return true
                end
            end
            if uv.Items then
                uv.Items[self.st.selected_id] = nil
            end
            self.st.selected_id = nil
        end

        local now = tg()
        self.st.__dtimer = not self.st.__dtimer and now + EVENT_SCAN_COOLDOWN_MS or self.st.__dtimer
        if now < self.st.__dtimer then
            return false
        end
        self.st.__dtimer = nil

        local loot_table = uv.UseCorpseLootTable ~= true and uv.LootTable or (rawget(_G, "xr_corpse_detection") and _G.xr_corpse_detection.lootable_table)
        if not loot_table then
            return false
        end

        if not self.st.index then
            self.st.index = 1
        end

        if not self.st.memory then
            self.st.memory = {}
        end

        local npc = self.object
        local max_memory = tonumber(patch_cfg.max_memory) or 48
        local size = #self.st.memory
        if size > max_memory then
            for i = size, max_memory + 1, -1 do
                self.st.memory[i] = nil
            end
            size = max_memory
        end

        local corpse_hint = false
        local corpse_sqr = tonumber(patch_cfg.corpse_sqr) or 0
        local corpse_ids = loot.get_corpse_event_ids and loot.get_corpse_event_ids() or nil
        local corpse_pool_n = corpse_ids and #corpse_ids or 0
        if corpse_pool_n > 0 and corpse_sqr > 0 then
            local corpse_scan_budget = math.max(16, max_memory * 2)
            if corpse_scan_budget > corpse_pool_n then
                corpse_scan_budget = corpse_pool_n
            end
            local idx = tonumber(self.st.__zhopa_corpse_pool_cursor) or corpse_pool_n
            for _ = 1, corpse_scan_budget do
                if idx < 1 then
                    idx = corpse_pool_n
                end
                local corpse_id = corpse_ids[idx]
                idx = idx - 1
                local corpse = corpse_id and db and db.storage and db.storage[corpse_id] and db.storage[corpse_id].object
                if corpse and corpse:alive() ~= true and not is_protected_corpse(corpse, corpse_id) then
                    if npc:position():distance_to_sqr(corpse:position()) < corpse_sqr then
                        corpse_hint = true
                        break
                    end
                end
            end
            self.st.__zhopa_corpse_pool_cursor = idx
        end

        if size == 0 then
            self.st.cstackprevent = true

            local max_item_dist_sqr = tonumber(patch_cfg.item_detect_sqr) or 0

            local max_items = max_memory - #self.st.memory
            if max_items < 0 then max_items = 0 end
            local added = 0

            local scan_sqr = tonumber(patch_cfg.scan_sqr) or 0
            local item_ids = loot.get_item_event_ids and loot.get_item_event_ids() or nil
            local item_pool_n = item_ids and #item_ids or 0
            if item_pool_n > 0 and max_items > 0 then
                local scan_budget = math.max(32, max_items * 8)
                if scan_budget > item_pool_n then
                    scan_budget = item_pool_n
                end
                local idx = tonumber(self.st.__zhopa_item_pool_cursor) or item_pool_n
                for _ = 1, scan_budget do
                    if added >= max_items then
                        break
                    end
                    if idx < 1 then
                        idx = item_pool_n
                    end
                    local id = item_ids[idx]
                    idx = idx - 1
                    local se_itm = id and alife_object and alife_object(id) or nil
                    if se_itm and se_itm.parent_id == 65535 then
                        local itm = level.object_by_id(id)
                        if itm then
                            local ok_sect, sect = pcall(function() return itm:section() end)
                            if ok_sect and sect and loot_table[sect] ~= nil and not near_actor(itm) then
                                local dist = npc:position():distance_to_sqr(itm:position())
                                local limit_sqr = scan_sqr > 0 and scan_sqr or max_item_dist_sqr
                                if dist < limit_sqr then
                                    self.st.memory[#self.st.memory + 1] = id
                                    added = added + 1
                                end
                            end
                        end
                    end
                end
                self.st.__zhopa_item_pool_cursor = idx
            end

            self.st.cstackprevent = nil

            size = #self.st.memory
            if size == 0 then
                return false
            end
        end

        if size == 0 or self.st.index > size then
            if self.st.nearest_id and uv.Items and uv.Items[self.st.nearest_id] == nil and (not game_setup.is_world_item(self.st.nearest_id)) then
                if self.st.selected_id and uv.Items[self.st.selected_id] then
                    uv.Items[self.st.selected_id] = nil
                end
                self.st.selected_id = self.st.nearest_id
                self.st.vid = self.st.nearest_vid
                self.st.vid_pos = self.st.nearest_pos
                uv.Items[self.st.selected_id] = npc:id()
                self.st.stage = 1

                self.st.nearest_dist = nil
                self.st.nearest_vid = nil
                self.st.nearest_pos = nil
                self.st.nearest_id = nil

                self.st.index = 1

                local be = npc:best_enemy()
                local dist = npc:position():distance_to(self.st.vid_pos)
                if be or dist < uv.RunDist then
                    self.st.state = uv.StateWalk
                else
                    self.st.state = uv.StateRun
                end
                return true
            end

            self.st.index = 1
            self.st.nearest_dist = nil
            self.st.nearest_vid = nil
            self.st.nearest_pos = nil
            self.st.nearest_id = nil
            if empty_table then
                empty_table(self.st.memory)
            else
                self.st.memory = {}
            end
            return false
        end

        local itm_id = self.st.memory[self.st.index]
        self.st.index = self.st.index + 1

        local itm = itm_id and itm_id ~= 0 and itm_id ~= 65535 and level.object_by_id(itm_id)
        local se_itm = itm and loot_table[itm:section()] and uv.Items and uv.Items[itm_id] == nil and alife_object(itm_id)

        if not (se_itm and se_itm.parent_id == 65535) then
            return false
        end

        if get_object_story_id(itm_id) then
            return false
        end

        if npc:best_enemy() then
            if not IsWeapon(itm) then
                return false
            end
            if IsWeapon(npc:active_item()) then
                return false
            end
        end

        if IsArtefact(nil, se_itm:clsid()) then
            if not uv.ArtifactDectection then
                return false
            end

            if xr_logic.pick_section_from_condlist(db.actor, npc, self.st.gather_artefact_items_enabled) == "false" then
                return false
            end

            local squad = get_object_squad(npc)
            local squad_community = squad and squad.player_id or character_community(npc)

            if not (uv.ArtifactCommunities and uv.ArtifactCommunities[squad_community]) then
                return false
            end
        else
            if not npc:see(itm) then
                if cfg("loot_items_allow_unseen", false) ~= true and corpse_hint ~= true then
                    return false
                end
                if corpse_hint ~= true and not loot.is_recent_item_id(itm_id) then
                    return false
                end
            end
        end

        local itm_pos = itm:position()
        local dist = npc:position():distance_to_sqr(itm_pos)

        local max_item_dist_sqr = tonumber(patch_cfg.item_detect_sqr) or 0
        local max_detect_sqr = uv.MaxDetectDistance or max_item_dist_sqr
        if max_item_dist_sqr > 0 then
            max_detect_sqr = math.min(max_detect_sqr, max_item_dist_sqr)
        end

        if (self.st.nearest_dist == nil or dist < self.st.nearest_dist) and (dist < max_detect_sqr) then
            local vid = level.vertex_id(itm_pos)
            if level.vertex_position(vid):distance_to_sqr(itm_pos) > 16 then
                vid = itm:level_vertex_id()
            end

            if npc:accessible(vid) and level.vertex_position(vid):distance_to_sqr(itm_pos) <= 15 then
                self.st.nearest_dist = dist
                self.st.nearest_vid = vid
                self.st.nearest_pos = itm_pos
                self.st.nearest_id = itm_id
            end
        end

        return false
    end

    cls.__zhopa_loot_patched = true
    LootPatch.RUNTIME.gather_items_patched = true
    return true
end

function LootPatch.apply()
    local loot_items_enabled = cfg("loot_items_enabled", false) == true
    local assist_ready = loot_items_enabled ~= true or LootPatch.RUNTIME.gather_items_patched == true
    if LootPatch.RUNTIME.patched == true and assist_ready == true then return true end

    log_debug("APPLY_ATTEMPT")
    local gather_ok = patch_xr_gather_items() == true
    local loot_call_ok = patch_get_all_from_corpse() == true
    LootPatch.RUNTIME.gather_items_patched = gather_ok
    LootPatch.RUNTIME.corpse_loot_call_patched = loot_call_ok
    LootPatch.RUNTIME.patched = loot_call_ok

    if zhopa.loot and zhopa.loot.sync_protected_corpse_lootability then
        pcall(zhopa.loot.sync_protected_corpse_lootability)
    end

    log_debug(
        "APPLY_RESULT gather=%s loot_call=%s patched=%s",
        tostring(gather_ok),
        tostring(loot_call_ok),
        tostring(LootPatch.RUNTIME.patched == true)
    )

    return LootPatch.RUNTIME.patched == true
end

maybe_retry_apply = function()
    local loot_items_enabled = cfg("loot_items_enabled", false) == true
    local assist_ready = loot_items_enabled ~= true or LootPatch.RUNTIME.gather_items_patched == true
    if LootPatch.RUNTIME.patched == true and assist_ready == true then
        return true
    end

    local now = tg()
    local next_retry_tg = tonumber(LootPatch.RUNTIME.next_retry_tg) or 0
    if now < next_retry_tg then
        return false
    end

    LootPatch.RUNTIME.next_retry_tg = now + PATCH_RETRY_COOLDOWN_MS
    log_debug("APPLY_RETRY now=%s", tostring(now))
    local ok = LootPatch.apply() == true
    if ok ~= true then
        schedule_loot_patch_retry(PATCH_RETRY_COOLDOWN_MS)
    end
    return ok
end

function LootPatch.on_game_start()
    schedule_loot_patch_retry(PATCH_RETRY_COOLDOWN_MS)
    return true
end

function LootPatch.on_actor_first_update()
    return maybe_retry_apply()
end

function LootPatch.on_load_state()
    LootPatch.RUNTIME.loot_patch_cfg_snapshot = nil
    LootPatch.RUNTIME.loot_patch_cfg_next_tg = 0
    return maybe_retry_apply()
end

function LootPatch.on_option_change()
    LootPatch.RUNTIME.loot_patch_cfg_snapshot = nil
    LootPatch.RUNTIME.loot_patch_cfg_next_tg = 0
    return maybe_retry_apply()
end

function LootPatch.on_server_entity_register(se_obj)
    if se_obj ~= nil then
        maybe_retry_apply()
    end
end

function LootPatch.on_npc_update()
    return maybe_retry_apply()
end

function LootPatch.needs_npc_update()
    if loot_patch_timers_available() then
        return false
    end
    local loot_items_enabled = cfg("loot_items_enabled", false) == true
    local assist_ready = loot_items_enabled ~= true or LootPatch.RUNTIME.gather_items_patched == true
    if LootPatch.RUNTIME.patched == true and assist_ready == true then
        return false
    end
    return tg() >= (tonumber(LootPatch.RUNTIME.next_retry_tg) or 0)
end

zhopa.loot_patch = LootPatch
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_loot_patch

-- BEGIN module zhopa_fast_trading
zhopa_bundle_module = function()
zhopa = zhopa or {}
zhopa.fast_trading = zhopa.fast_trading or {}

local fast_trading = zhopa.fast_trading

local _G = _G
local pcall = _G.pcall
local tonumber = _G.tonumber
local tostring = _G.tostring
local type = _G.type
local pairs = _G.pairs
local next = _G.next
local time_global = _G.time_global

local function tg()
    return (time_global and time_global()) or 0
end

local function cfg_get(key, default)
    if not (zhopa.config and zhopa.config.get) then return default end
    local ok, v = pcall(zhopa.config.get, key, default)
    if ok then return v end
    return default
end

local function cfg_num(key, default, min_v)
    local v = tonumber(cfg_get(key, default)) or tonumber(default) or 0
    if min_v ~= nil and v < min_v then
        v = min_v
    end
    return v
end

local function cfg_bool(key, default)
    local v = cfg_get(key, default)
    if v == true or v == false then
        return v
    end
    if tonumber(v) ~= nil then
        return tonumber(v) ~= 0
    end
    if type(v) == "string" then
        if v == "true" then return true end
        if v == "false" then return false end
    end
    return default == true
end

local function is_enabled()
    return cfg_bool("fast_trading_enabled", true)
end

local function get_delay_ms()
    return cfg_num("fast_trading_delay_ms", 500, 0)
end

local function get_cooldown_ms()
    return cfg_num("fast_trading_cooldown_ms", 60000, 0)
end

-- Cache for trigger prefixes
local trigger_prefixes_cache = nil
local trigger_prefixes_cache_tg = 0
local TRIGGER_CACHE_TTL = 5000 -- 5 seconds

local function get_trigger_prefixes()
    local now = tg()
    if trigger_prefixes_cache and (now - trigger_prefixes_cache_tg) < TRIGGER_CACHE_TTL then
        return trigger_prefixes_cache
    end

    trigger_prefixes_cache = {}
    trigger_prefixes_cache_tg = now

    -- Try to get section from config
    if zhopa.config and zhopa.config.get_section_set then
        local ok, set = pcall(zhopa.config.get_section_set, "fast_trade_triggers")
        if ok and type(set) == "table" then
            for prefix, v in pairs(set) do
                if v == true or v == "true" or tonumber(v) == 1 then
                    trigger_prefixes_cache[#trigger_prefixes_cache + 1] = prefix
                end
            end
        end
    end

    -- Fallback: default to af_ if empty
    if #trigger_prefixes_cache == 0 then
        trigger_prefixes_cache = { "af_" }
    end

    return trigger_prefixes_cache
end

local function matches_trigger_prefix(section)
    if type(section) ~= "string" then return false end
    local prefixes = get_trigger_prefixes()
    for i = 1, #prefixes do
        local prefix = prefixes[i]
        if string.sub(section, 1, #prefix) == prefix then
            return true
        end
    end
    return false
end

local function is_valid_server_id(id)
    id = tonumber(id) or 0
    return id > 0 and id ~= 65535
end

local function safe_alife_object(sim, id)
    if not (sim and is_valid_server_id(id)) then
        return nil
    end
    local ok_obj, se_obj = pcall(function() return sim:object(id) end)
    if not ok_obj then
        return nil
    end
    return se_obj
end

local function get_squad_by_npc_id(npc_id)
    npc_id = tonumber(npc_id) or 0
    if not is_valid_server_id(npc_id) then return nil end

    if zhopa.trade and type(zhopa.trade.resolve_squad_id_from_npc_id) == "function" then
        local ok_sid, squad_id = pcall(zhopa.trade.resolve_squad_id_from_npc_id, npc_id)
        squad_id = ok_sid and tonumber(squad_id) or nil
        if is_valid_server_id(squad_id) then
            local af = _G.alife and _G.alife()
            if af then
                local se_squad = safe_alife_object(af, squad_id)
                if se_squad then
                    return se_squad, squad_id
                end
            end
        end
    end

    local alife = _G.alife and _G.alife()
    if not alife then return nil end

    local se_npc = safe_alife_object(alife, npc_id)
    if not se_npc then return nil end

    local ok_sid, squad_id = pcall(function() return se_npc.group_id end)
    squad_id = ok_sid and tonumber(squad_id) or nil
    if not is_valid_server_id(squad_id) then
        local ok_sid_fn, squad_id_fn = pcall(function() return se_npc:group_id() end)
        squad_id = ok_sid_fn and tonumber(squad_id_fn) or nil
    end
    if not is_valid_server_id(squad_id) then
        return nil
    end

    local se_squad = safe_alife_object(alife, squad_id)
    if not se_squad then return nil end

    return se_squad, squad_id
end

local function is_squad_under_zhopa(se_squad, squad_id)
    if not (zhopa.memory and zhopa.memory.get_squad_entry) then return false end
    local entry = zhopa.memory.get_squad_entry(squad_id)
    return entry ~= nil
end

local function is_surge_active()
    local xc = _G.xr_conditions
    local xf = xc and xc.surge_started or nil
    if not xf then
        local ok, result = pcall(function()
            local ss = _G.surge_manager and _G.surge_manager.get_surge()
            return ss and ss.started == true
        end)
        return ok and result == true
    end
    local ok, result = pcall(xf)
    return ok and result == true
end

local function get_surge_lock(squad_id)
    if zhopa.memory and zhopa.memory.get_surge_lock then
        return zhopa.memory.get_surge_lock(squad_id) == true
    end
    return false
end

local function has_sellable_items(npc_obj, npc_id)
    if not npc_obj then return false end

    -- First check vanilla/ZHOPA storage flag (set by trade intent bridge)
    local st = _G.db and _G.db.storage and _G.db.storage[npc_id] or nil
    if st and st.has_items_to_sell == true then
        return true
    end

    -- Fallback: check trade_items table
    if st and type(st.trade_items) == "table" and next(st.trade_items) ~= nil then
        return true
    end

    -- Direct inventory check using trigger prefixes from config
    local ok_inv, inv = pcall(function() return npc_obj:inventory() end)
    if ok_inv and inv then
        local ok_count, count = pcall(function() return inv:count() end)
        if ok_count and tonumber(count) and count > 0 then
            for i = 0, count - 1 do
                local ok_item, item = pcall(function() return inv:item(i) end)
                if ok_item and item then
                    local ok_sec, sec = pcall(function() return item:section() end)
                    if ok_sec and type(sec) == "string" then
                        -- Check against configured trigger prefixes
                        if matches_trigger_prefix(sec) then
                            return true
                        end
                    end
                end
            end
        end
    end

    return false
end

local function can_start_trade_from_entry(entry)
    if not entry then
        return false
    end

    if zhopa.tasks and type(zhopa.tasks._can_assign_trade_task) == "function" then
        local ok, allowed = pcall(zhopa.tasks._can_assign_trade_task, entry, "fast_trading")
        if ok then
            return allowed == true
        end
    end

    local current = entry.tasks and entry.tasks.current or nil
    local prev = entry.tasks and entry.tasks.prev or nil
    if (current and current.type == "TRADE") or (prev and prev.type == "TRADE") then
        return false
    end
    return true
end

local function trigger_fast_trade(se_squad, squad_id, npc_id, item_section)
    if not (se_squad and squad_id) then return false end

    local entry = zhopa.memory and zhopa.memory.get_squad_entry(squad_id)
    if not entry then return false end

    if not can_start_trade_from_entry(entry) then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("FAST_TRADE", "validation_skip sid=%s reason=%s",
                tostring(squad_id), "trade_repeat_block")
        end
        return false
    end

    local current = entry.tasks and entry.tasks.current
    if current and current.type == "ARTEFACT" and current.params and current.params.fast_trade_block == true then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("FAST_TRADE", "validation_skip sid=%s reason=%s",
                tostring(squad_id), "artefact_pickup_lock")
        end
        return false
    end
    if current and current.type == "TRADE" then
        if zhopa.log and zhopa.log.warn then
            zhopa.log.warn("FAST_TRADE", "already_in_trade sid=%s", tostring(squad_id))
        end
        return false
    end

    if zhopa.log and zhopa.log.info then
        zhopa.log.info("FAST_TRADE", "trigger sid=%s npc_id=%s item=%s prev_task=%s",
            tostring(squad_id),
            tostring(npc_id),
            tostring(item_section or "-"),
            tostring(current and current.type or "-")
        )
    end

    if current then
        current.params = current.params or {}
        current.params.fast_trade_trigger = true
        current.params.fast_trade_retry_next_tg = tg()
    else
        fast_trading.RUNTIME.pending_by_squad[squad_id] = {
            npc_id = tonumber(npc_id) or nil,
            item_section = item_section,
            requested_tg = tg(),
        }
    end

    if zhopa.memory and zhopa.memory.mark_dirty then
        zhopa.memory.mark_dirty(squad_id, "task")
    end

    fast_trading.RUNTIME.active_trades[squad_id] = {
        started_tg = tg()
    }

    return true
end

fast_trading.RUNTIME = {
    pending_checks = {},
    active_trades = {},
    cooldowns = {},
    pending_by_squad = {},
}

local function clear_pending_check(npc_id)
    npc_id = tonumber(npc_id) or nil
    if not npc_id then return end
    fast_trading.RUNTIME.pending_checks[npc_id] = nil
end

local function clear_cooldown(squad_id)
    squad_id = tonumber(squad_id) or nil
    if not squad_id then return end
    fast_trading.RUNTIME.cooldowns[squad_id] = nil
end

local function schedule_pending_check(npc_id, delay_ms)
    if not (zhopa.timers and zhopa.timers.schedule) then
        return false
    end
    return zhopa.timers.schedule("zhopa_fast_trading", "pending_" .. tostring(npc_id), delay_ms, function(id)
        fast_trading.process_check(id)
    end, npc_id)
end

local function schedule_cooldown_clear(squad_id, delay_ms)
    if not (zhopa.timers and zhopa.timers.schedule) then
        return false
    end
    return zhopa.timers.schedule("zhopa_fast_trading", "cooldown_" .. tostring(squad_id), delay_ms, function(id)
        clear_cooldown(id)
    end, squad_id)
end

function fast_trading.process_check(npc_id, data)
    if not npc_id then return end
    data = data or fast_trading.RUNTIME.pending_checks[tonumber(npc_id) or npc_id]
    if not data then return end

    clear_pending_check(npc_id)

    local se_squad, squad_id = get_squad_by_npc_id(npc_id)
    if not (se_squad and squad_id) then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("FAST_TRADE", "validation_skip npc_id=%s reason=%s",
                tostring(npc_id), "squad_not_found")
        end
        return
    end

    if not is_squad_under_zhopa(se_squad, squad_id) then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("FAST_TRADE", "validation_skip sid=%s reason=%s",
                tostring(squad_id), "not_under_zhopa")
        end
        return
    end

    if is_surge_active() then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("FAST_TRADE", "validation_skip sid=%s reason=%s",
                tostring(squad_id), "surge")
        end
        return
    end

    if get_surge_lock(squad_id) then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("FAST_TRADE", "validation_skip sid=%s reason=%s",
                tostring(squad_id), "surge_lock")
        end
        return
    end

    local now = tg()
    local cooldowns = fast_trading.RUNTIME.cooldowns
    local cd_tg = tonumber(cooldowns[squad_id]) or 0
    if now < cd_tg then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("FAST_TRADE", "validation_skip sid=%s reason=%s",
                tostring(squad_id), "cooldown")
        end
        return
    end

    local ok_level, npc_obj = pcall(function()
        return _G.level and _G.level.object_by_id and _G.level.object_by_id(npc_id)
    end)
    if not (ok_level and npc_obj) then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("FAST_TRADE", "validation_skip sid=%s reason=%s",
                tostring(squad_id), "npc_offline")
        end
        return
    end

    if not has_sellable_items(npc_obj, npc_id) then
        if zhopa.log and zhopa.log.debug then
            zhopa.log.debug("FAST_TRADE", "validation_skip sid=%s reason=%s",
                tostring(squad_id), "no_sellable")
        end
        return
    end

    if trigger_fast_trade(se_squad, squad_id, npc_id, data.item_section) then
        local cooldown_ms = get_cooldown_ms()
        cooldowns[squad_id] = now + cooldown_ms
        schedule_cooldown_clear(squad_id, cooldown_ms)
    end
end

function fast_trading.on_npc_item_take(npc, item)
    if not is_enabled() then return end
    if not (npc and item) then return end

    local ok_id, npc_id = pcall(function() return npc:id() end)
    if not (ok_id and tonumber(npc_id)) then return end

    local st = _G.db and _G.db.storage and _G.db.storage[npc_id]
    if st and (tonumber(st.zhopa_axr_item_take_suppress) or 0) > 0 then
        return
    end

    local ok_sec, item_section = pcall(function() return item:section() end)
    item_section = ok_sec and item_section or nil

    -- Early filter: only register if item matches trigger prefixes
    if item_section and not matches_trigger_prefix(item_section) then
        return
    end

    local now = tg()
    local delay_ms = get_delay_ms()
    local scheduled_tg = now + delay_ms

    fast_trading.RUNTIME.pending_checks[npc_id] = {
        scheduled_tg = scheduled_tg,
        item_section = item_section,
        added_tg = now
    }
    schedule_pending_check(npc_id, delay_ms)
end

function fast_trading.on_trade_completed(squad_id, result)
    squad_id = tonumber(squad_id)
    if not squad_id then return nil end

    local entry = zhopa.memory and zhopa.memory.get_squad_entry(squad_id)
    local active = fast_trading.RUNTIME.active_trades[squad_id]
    if not active then
        return nil
    end

    fast_trading.RUNTIME.active_trades[squad_id] = nil

    if not entry then
        if zhopa.log and zhopa.log.warn then
            zhopa.log.warn("FAST_TRADE", "cleanup_skip sid=%s reason=%s",
                tostring(squad_id), "entry_not_found")
        end
        return nil
    end
    if zhopa.log and zhopa.log.info then
        zhopa.log.info("FAST_TRADE", "cleanup sid=%s trade_result=%s",
            tostring(squad_id),
            tostring(result)
        )
    end

    if zhopa.memory and zhopa.memory.mark_dirty then
        zhopa.memory.mark_dirty(squad_id, "task")
    end

    return nil
end

function fast_trading.consume_pending_trigger(squad_id)
    squad_id = tonumber(squad_id) or nil
    if not squad_id then
        return nil
    end
    local pending = fast_trading.RUNTIME.pending_by_squad[squad_id]
    fast_trading.RUNTIME.pending_by_squad[squad_id] = nil
    if type(pending) ~= "table" then
        return nil
    end
    return pending
end

function fast_trading.on_load_state()
    fast_trading.reset_cache()
end

function fast_trading.on_option_change()
    fast_trading.reset_cache()
end

function fast_trading.reset_cache()
    trigger_prefixes_cache = nil
    trigger_prefixes_cache_tg = 0
    fast_trading.RUNTIME.pending_checks = {}
    fast_trading.RUNTIME.active_trades = {}
    fast_trading.RUNTIME.cooldowns = {}
    fast_trading.RUNTIME.pending_by_squad = {}
    if zhopa.timers and zhopa.timers.clear then
        zhopa.timers.clear("zhopa_fast_trading")
    end
end
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_fast_trading

-- BEGIN module zhopa_debug_hud
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local setmetatable = _G.setmetatable
local tonumber = _G.tonumber
local tostring = _G.tostring
local time_global = _G.time_global
local pairs = _G.pairs
local next = _G.next
local alife = _G.alife


local DebugHud = zhopa.class("DebugHud")
DebugHud.__index = DebugHud

local DEFAULT_SPOT_ICON = "item_kit"
local MUTANT_SPOT_ICON = "circle_zombied"
local LOGIC_MAX_AGE_MS = 90000
local SPOT_CONFLICT_LOG_INTERVAL_MS = 10000
local COMMUNITY_SPOT_TYPES = {
    stalker = "warfare_stalker_spot",
    bandit = "warfare_bandit_spot",
    csky = "warfare_csky_spot",
    army = "warfare_army_spot",
    freedom = "warfare_freedom_spot",
    duty = "warfare_duty_spot",
    dolg = "warfare_duty_spot",
    ecolog = "warfare_ecolog_spot",
    merc = "warfare_killer_spot",
    killer = "warfare_killer_spot",
    monolith = "warfare_monolith_spot",
    greh = "warfare_greh_spot",
    renegade = "warfare_renegade_spot",
    isg = "warfare_isg_spot",
}

local function tg()
    return (time_global and time_global()) or 0
end

local function is_valid_server_id(id)
    id = tonumber(id) or 0
    return id > 0 and id ~= 65535
end

local function has_game_time()
    return game and game.get_game_time and game.CTime
end

local function ctime_from_table(t)
    if not (has_game_time() and t and type(t) == "table") then return nil end
    local ok_new, ct = pcall(function() return game.CTime() end)
    if not (ok_new and ct and ct.set) then return nil end
    local ok_set = pcall(function()
        ct:set(t.Y, t.M, t.D, t.h, t.m, t.s, t.ms)
    end)
    if not ok_set then return nil end
    return ct
end

local function game_time_now()
    if not has_game_time() then return nil end
    local ok, ct = pcall(function() return game.get_game_time() end)
    return ok and ct or nil
end

local function game_time_diff_sec(start_ct)
    local now = game_time_now()
    if not (now and now.diffSec and start_ct) then return nil end
    local ok, sec = pcall(function() return now:diffSec(start_ct) end)
    sec = ok and tonumber(sec) or nil
    return sec
end

local function fmt_mmss(total_sec)
    local math_floor = math.floor
    local string_format = string.format
    local s = tonumber(total_sec) or 0
    if s < 0 then s = 0 end
    local m = math_floor(s / 60)
    local r = math_floor(s % 60)
    return string_format("%02d:%02d", m, r)
end

local function task_type_for_display(task_type)
    if type(task_type) ~= "string" or task_type == "" then
        return tostring(task_type)
    end

    local lower = string.lower(task_type)
    if lower == "smart task: control" then
        return "SMART TASK: CONTROL"
    end
    if lower == "smart task: go to control" then
        return "SMART TASK: GO TO CONTROL"
    end

    return task_type
end

function DebugHud:__init()
    self.RUNTIME = {
        shown = {},
        disabled_cleared = false,
        enabled_cached = nil,
        enabled_prev = false,
        owned_spots_by_id = {},
        spot_conflict_log_next_tg = 0,
    }
end

function DebugHud:_read_enabled()
    if zhopa.runtime_cfg and zhopa.runtime_cfg.get then
        return zhopa.runtime_cfg.get("debug_hud_enabled", false) == true
    end
    if not (zhopa.config and zhopa.config.get) then return false end
    return zhopa.config.get("debug_hud_enabled", false) == true
end

function DebugHud:_refresh_enabled_cache()
    local enabled = self:_read_enabled() == true
    if self.RUNTIME then
        self.RUNTIME.enabled_cached = enabled
    end
    return enabled
end

function DebugHud:_is_enabled()
    local rt = self.RUNTIME
    if rt and rt.enabled_cached ~= nil then
        return rt.enabled_cached == true
    end
    return self:_refresh_enabled_cache() == true
end

function DebugHud:_remove_spot(id)
    if not id then return end
    id = tonumber(id)
    if not id then return end
    local spot_type = self.RUNTIME and self.RUNTIME.owned_spots_by_id and self.RUNTIME.owned_spots_by_id[id] or nil
    if type(spot_type) ~= "string" or spot_type == "" then return end
    if level and level.map_remove_object_spot then
        pcall(function() level.map_remove_object_spot(id, spot_type) end)
    end
    if self.RUNTIME and self.RUNTIME.owned_spots_by_id then
        self.RUNTIME.owned_spots_by_id[id] = nil
    end
    if self.RUNTIME and self.RUNTIME.shown then
        self.RUNTIME.shown[id] = nil
    end
end

function DebugHud:_warn_spot_conflict(id, spot_type)
    local now = tg()
    local next_tg = tonumber(self.RUNTIME and self.RUNTIME.spot_conflict_log_next_tg) or 0
    if now < next_tg then return end
    self.RUNTIME.spot_conflict_log_next_tg = now + SPOT_CONFLICT_LOG_INTERVAL_MS
    if zhopa.log and zhopa.log.warn then
        zhopa.log.warn("HUD", "skip non-owned map spot id=%s type=%s", tostring(id), tostring(spot_type or DEFAULT_SPOT_ICON))
    end
end

function DebugHud:_spot_icon_for_entry(entry)
    if type(entry) ~= "table" then
        return DEFAULT_SPOT_ICON
    end
    if entry.npc_kind == "mutant" then
        return MUTANT_SPOT_ICON
    end

    local community = type(entry.community) == "string" and entry.community or nil
    if community and zhopa.config and zhopa.config.get_faction_alias then
        community = zhopa.config.get_faction_alias(community) or community
    end
    if community and COMMUNITY_SPOT_TYPES[community] then
        return COMMUNITY_SPOT_TYPES[community]
    end
    return DEFAULT_SPOT_ICON
end

function DebugHud:_add_spot(id, spot_type, hint)
    if not (level and level.map_add_object_spot) then return end
    if not id then return end
    id = tonumber(id)
    if not is_valid_server_id(id) then return false end
    if type(spot_type) ~= "string" or spot_type == "" then
        spot_type = DEFAULT_SPOT_ICON
    end

    local can_track = false
    if alife then
        local ok_sim, sim = pcall(function() return alife() end)
        if ok_sim and sim then
            local ok_obj, obj = pcall(function() return sim:object(id) end)
            if ok_obj and obj then
                can_track = true
            end
        end
    end
    if not can_track and level and level.object_by_id then
        local ok_lvl, lvl_obj = pcall(function() return level.object_by_id(id) end)
        if ok_lvl and lvl_obj then
            can_track = true
        end
    end
    if not can_track then
        self:_remove_spot(id)
        return false
    end

    local owned_type = self.RUNTIME and self.RUNTIME.owned_spots_by_id and self.RUNTIME.owned_spots_by_id[id] or nil
    if type(owned_type) == "string" and owned_type ~= spot_type then
        self:_remove_spot(id)
        owned_type = nil
    end

    if type(owned_type) == "string" then
        if level.map_has_object_spot then
            local ok_has_owned, has_owned = pcall(function() return level.map_has_object_spot(id, owned_type) end)
            if not ok_has_owned then
                return false
            end
            if has_owned == 0 then
                self.RUNTIME.owned_spots_by_id[id] = nil
                owned_type = nil
            end
        end
    end

    if type(owned_type) == "string" then
        if level.map_change_spot_hint then
            pcall(function() level.map_change_spot_hint(id, owned_type, hint or "") end)
        end
        return true
    end

    if level.map_has_object_spot then
        local ok_has, has = pcall(function() return level.map_has_object_spot(id, spot_type) end)
        if not ok_has then
            return false
        end
        if has ~= 0 then
            self:_warn_spot_conflict(id, spot_type)
            return false
        end
    end

    local ok_add = pcall(function() level.map_add_object_spot(id, spot_type, hint or "") end)
    if not ok_add then
        return false
    end
    if level.map_change_spot_hint then
        pcall(function() level.map_change_spot_hint(id, spot_type, hint or "") end)
    end
    if self.RUNTIME and self.RUNTIME.owned_spots_by_id then
        self.RUNTIME.owned_spots_by_id[id] = spot_type
    end
    return true
end

function DebugHud:_build_hint(e)
    local tostring = tostring
    local string_format = string.format
    local section = e and e.section or nil
    local bridge_prefix = ""
    local is_base_camper = false
    if zhopa.base_filler and zhopa.base_filler.is_base_camper_section then
        is_base_camper = zhopa.base_filler.is_base_camper_section(section) == true
    elseif type(section) == "string" then
        is_base_camper = string.find(section, "_sim_squad_camper_", 1, true) ~= nil
            or string.find(section, "_base_camper_", 1, true) ~= nil
    end
    local camper_prefix = bridge_prefix .. (is_base_camper and "BASE_CAMPER | " or "")
    local cur = e and e.tasks and e.tasks.current or nil
    if not cur then
        return string_format("ZHOPA: %sNO_TASK | lvl=%s | tgt=%s | smid=%s | act=%s | atid=%s | sec=%s | com=%s | ok=%s",
            camper_prefix,
            tostring(e and e.level or "-"),
            tostring(e and e.scripted_target or "-"),
            tostring(e and e.smart_id or "-"),
            tostring(e and e.current_action or "-"),
            tostring(e and e.assigned_target_id or "-"),
            tostring(e and e.section or "-"),
            tostring(e and e.community or "-"),
            tostring(e and e.allowed == true)
        )
    end
    local tgt = cur.target and tostring(cur.target) or "-"
    local task_type = task_type_for_display(cur.type)
    if cur.type == "REST_1H" then
        local p = cur.params or {}
        local left = nil
        local started_gt = ctime_from_table(p.started_at_gt)
        local dur_gs = tonumber(p.duration_game_sec)
        if started_gt and dur_gs and dur_gs > 0 then
            local elapsed = game_time_diff_sec(started_gt) or 0
            left = dur_gs - elapsed
        else
            local started = tonumber(p.started_at_tg) or 0
            local dur = tonumber(p.duration_ms) or 0
            left = ((started + dur) - tg()) / 1000
        end
        return string_format("ZHOPA: %s%s | left=%s | lvl=%s | stgt=%s | smid=%s | act=%s | atid=%s | sec=%s | com=%s | ok=%s",
            camper_prefix,
            tostring(task_type),
            fmt_mmss(left),
            tostring(e and e.level or "-"),
            tostring(e and e.scripted_target or "-"),
            tostring(e and e.smart_id or "-"),
            tostring(e and e.current_action or "-"),
            tostring(e and e.assigned_target_id or "-"),
            tostring(e and e.section or "-"),
            tostring(e and e.community or "-"),
            tostring(e and e.allowed == true)
        )
    end
    return string_format("ZHOPA: %s%s -> %s | lvl=%s | stgt=%s | smid=%s | act=%s | atid=%s | sec=%s | com=%s | ok=%s",
        camper_prefix,
        tostring(task_type),
        tgt,
        tostring(e and e.level or "-"),
        tostring(e and e.scripted_target or "-"),
        tostring(e and e.smart_id or "-"),
        tostring(e and e.current_action or "-"),
        tostring(e and e.assigned_target_id or "-"),
        tostring(e and e.section or "-"),
        tostring(e and e.community or "-"),
        tostring(e and e.allowed == true)
    )
end

function DebugHud:_clear_all()
    local owned = self.RUNTIME.owned_spots_by_id or {}
    for id in pairs(owned) do
        self:_remove_spot(id)
    end
    self.RUNTIME.owned_spots_by_id = {}
    self.RUNTIME.shown = {}
end

function DebugHud:_on_load_state()
    if not self:_refresh_enabled_cache() then return end
    self.RUNTIME.disabled_cleared = false
    self:_clear_all()
end

function DebugHud:_on_save_state()
    if not self:_refresh_enabled_cache() then return end
    if zhopa.log and zhopa.log.info then
        zhopa.log.info("HUD", "debug_hud pre-save cleanup")
    end
    self:_clear_all()
end

function DebugHud:_refresh_spot_for_id(id, entry)
    id = tonumber(id) or nil
    if not id then
        return false
    end

    if not self:_is_enabled() then
        self:_remove_spot(id)
        return false
    end

    local mem = zhopa.memory
    entry = type(entry) == "table" and entry or (mem and mem.get_squad_entry and mem.get_squad_entry(id) or nil)
    if type(entry) ~= "table" then
        self:_remove_spot(id)
        return false
    end

    local hint = self:_build_hint(entry)
    local spot_type = self:_spot_icon_for_entry(entry)
    if self:_add_spot(id, spot_type, hint) then
        self.RUNTIME.shown[id] = true
        return true
    end
    self.RUNTIME.shown[id] = nil
    return false
end

function DebugHud:_refresh_all_from_memory(reason)
    if not self:_is_enabled() then
        self:_clear_all()
        return
    end

    self.RUNTIME.disabled_cleared = false
    local mem = zhopa.memory
    local state = mem and mem.get_state and mem.get_state() or nil
    local squads = state and state.squads or nil
    if type(squads) ~= "table" then
        self:_clear_all()
        return
    end

    local seen = {}
    for sid, entry in pairs(squads) do
        local id = tonumber(sid) or tonumber(type(entry) == "table" and entry.squad_id) or nil
        if id and self:_refresh_spot_for_id(id, entry) then
            seen[id] = true
        end
    end

    for id in pairs(self.RUNTIME.shown or {}) do
        if not seen[id] then
            self:_remove_spot(id)
        end
    end
    self.RUNTIME.shown = seen
end

function DebugHud:_on_option_change()
    local enabled = self:_refresh_enabled_cache()
    if not enabled then
        self:_clear_all()
        self.RUNTIME.disabled_cleared = true
        self.RUNTIME.enabled_prev = false
        return
    end
    if self.RUNTIME.enabled_prev ~= true then
        self:_refresh_all_from_memory("option_enable")
    end
    self.RUNTIME.enabled_prev = true
end

local inst = DebugHud.new and DebugHud.new() or setmetatable({}, DebugHud)
if not inst.RUNTIME then
    DebugHud.__init(inst)
end

inst.on_load_state = function() return inst:_on_load_state() end
inst.on_save_state = function() return inst:_on_save_state() end

local function hud_hot_enabled()
    return inst.RUNTIME and inst.RUNTIME.enabled_cached == true
end

local function refresh_squad_spot_if_hot(squad)
    if not hud_hot_enabled() then
        return
    end
    inst:_refresh_spot_for_id(squad and squad.id or nil, nil)
end

inst.on_actor_first_update = function()
    inst.RUNTIME.enabled_prev = inst:_refresh_enabled_cache() == true
    inst:_refresh_all_from_memory("first_update")
end
inst.on_load_state = function()
    inst.RUNTIME.enabled_prev = inst:_refresh_enabled_cache() == true
    inst:_refresh_all_from_memory("load_state")
end
inst.on_option_change = function() return inst:_on_option_change() end
inst.on_task_current_changed = function(payload)
    if not hud_hot_enabled() then
        return
    end
    local squad_id = payload and payload.squad_id or nil
    inst:_refresh_spot_for_id(squad_id, nil)
end
inst.on_server_entity_unregister = function(se_obj)
    if not hud_hot_enabled() then
        return
    end
    inst:_remove_spot(se_obj and se_obj.id or nil)
end
inst.on_squad_first_update = function(squad) return refresh_squad_spot_if_hot(squad) end
inst.on_squad_update = function(squad) return refresh_squad_spot_if_hot(squad) end
inst.on_squad_after_level_change = function(squad) return refresh_squad_spot_if_hot(squad) end
inst.on_squad_npc_death = function(squad) return refresh_squad_spot_if_hot(squad) end

zhopa.debug_hud = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_debug_hud

-- BEGIN module smart_service_slot_doctor
zhopa_bundle_module = function()
zhopa = zhopa or {}
zhopa.smart_service_slot_doctor = zhopa.smart_service_slot_doctor or {}

local type = _G.type
local pcall = _G.pcall
local pairs = _G.pairs
local ipairs = _G.ipairs
local tostring = _G.tostring
local tonumber = _G.tonumber
local time_global = _G.time_global
local io = _G.io
local math_floor = math.floor
local table_sort = table.sort
local db = _G.db
local level = _G.level
local alife = _G.alife
local load_var = _G.load_var
local utils_data = _G.utils_data
local utils_obj = _G.utils_obj

local inst = zhopa.smart_service_slot_doctor

local SCAN_COOLDOWN_MS = 250
local ACTION_COOLDOWN_MS = 2000
local NO_SERVICE_SCAN_COOLDOWN_MS = 60000
local POST_COMPLETE_EXIT_VERIFY_MS = 3000
local POST_COMPLETE_TRADE_TO_TECH_VERIFY_MS = 10000
local POST_TECH_UNKNOWN_GRACE_MS = 10000
local POST_TECH_UNKNOWN_STALL_MS = 15000
local POST_TECH_UNKNOWN_WATCH_MAX_MS = 45000
local POST_TECH_NPC_UPDATE_CHECK_MS = 500
local STATE_FLUSH_UPDATES = 5
local INGRESS_WATCH_SMARTS = {
    jup_a6 = true,
}
local INGRESS_NO_PROGRESS_MS = {
    trade = 25000,
    tech = 35000,
}
local INGRESS_OCCUPIED_BONUS_MS = {
    trade = 10000,
    tech = 15000,
}

local RULES = {
    {
        name = "trade",
        fragment = "_beh_trade_job_",
        slot_prefix = "logic@",
        active_prefix = "beh@",
        no_progress_ms = 20000,
        has_intent = function(st)
            if not st then
                return false
            end
            if st.has_items_to_sell == true then
                return true
            end
            local t = st.trade_items
            if type(t) ~= "table" then
                return false
            end
            for _, v in pairs(t) do
                if (tonumber(v) or 0) > 0 then
                    return true
                end
            end
            return false
        end,
    },
    {
        name = "tech",
        fragment = "_beh_tech_job_",
        slot_prefix = "logic@",
        active_prefix = "beh@",
        no_progress_ms = 60000,
        has_intent = function(st)
            if not st then
                return false
            end
            if st.has_tech_items == true then
                return true
            end
            local t = st.tech_items
            if type(t) ~= "table" then
                return false
            end
            for _, v in pairs(t) do
                if (tonumber(v) or 0) > 0 then
                    return true
                end
            end
            return false
        end,
    },
}

local resolve_issue_with_flush
local arm_post_tech_watch
local get_service_rule_by_active_section

local RUNTIME = {
    ready = false,
    smart_next_scan_tg = {},
    non_service_next_scan_tg = {},
    smart_diag_next_tg = {},
    smart_skip_diag_next_tg = {},
    smart_rule_cache = {},
    smart_seen = {},
    by_npc = {},
    by_smart = {},
    completed_watch_by_npc = {},
    completed_watch_by_smart = {},
    progress_by_npc = {},
    progress_by_smart = {},
    post_tech_watch_by_npc = {},
    post_tech_watch_by_smart = {},
    ingress_by_npc = {},
    ingress_by_smart = {},
}

local function now()
    return (time_global and time_global()) or 0
end

local function reset_runtime()
    RUNTIME.smart_next_scan_tg = {}
    RUNTIME.non_service_next_scan_tg = {}
    RUNTIME.smart_diag_next_tg = {}
    RUNTIME.smart_skip_diag_next_tg = {}
    RUNTIME.smart_rule_cache = {}
    RUNTIME.smart_seen = {}
    RUNTIME.by_npc = {}
    RUNTIME.by_smart = {}
    RUNTIME.completed_watch_by_npc = {}
    RUNTIME.completed_watch_by_smart = {}
    RUNTIME.progress_by_npc = {}
    RUNTIME.progress_by_smart = {}
    RUNTIME.post_tech_watch_by_npc = {}
    RUNTIME.post_tech_watch_by_smart = {}
    RUNTIME.ingress_by_npc = {}
    RUNTIME.ingress_by_smart = {}
end

local function set_smart_bucket_entry(bucket_name, smart_id, npc_id, enabled)
    smart_id = tonumber(smart_id) or nil
    npc_id = tonumber(npc_id) or nil
    if not (smart_id and npc_id) then
        return false
    end
    local by_smart = RUNTIME[bucket_name]
    if type(by_smart) ~= "table" then
        by_smart = {}
        RUNTIME[bucket_name] = by_smart
    end
    local bucket = by_smart[smart_id]
    if enabled == true then
        if type(bucket) ~= "table" then
            bucket = {}
            by_smart[smart_id] = bucket
        end
        bucket[npc_id] = true
        return true
    end
    if type(bucket) == "table" then
        bucket[npc_id] = nil
        if next(bucket) == nil then
            by_smart[smart_id] = nil
        end
    end
    return true
end

local function set_indexed_runtime_state(map_name, bucket_name, npc_id, state)
    npc_id = tonumber(npc_id) or nil
    if not npc_id then
        return false
    end
    local map = RUNTIME[map_name]
    if type(map) ~= "table" then
        map = {}
        RUNTIME[map_name] = map
    end
    local prev = map[npc_id]
    if prev and prev.smart_id ~= (state and state.smart_id) then
        set_smart_bucket_entry(bucket_name, prev.smart_id, npc_id, false)
    end
    if type(state) == "table" then
        map[npc_id] = state
        set_smart_bucket_entry(bucket_name, state.smart_id, npc_id, true)
    else
        map[npc_id] = nil
    end
    return true
end

local function clear_indexed_runtime_state(map_name, bucket_name, npc_id)
    npc_id = tonumber(npc_id) or nil
    if not npc_id then
        return false
    end
    local map = RUNTIME[map_name]
    local prev = type(map) == "table" and map[npc_id] or nil
    if prev then
        set_smart_bucket_entry(bucket_name, prev.smart_id, npc_id, false)
        map[npc_id] = nil
    end
    return true
end

local function mark_runtime_ready()
    RUNTIME.ready = true
    reset_runtime()
end

local function get_logger()
    local log = zhopa and zhopa.log
    if type(log) ~= "table" then
        return nil
    end
    return log
end

local function current_level_name()
    if not (level and type(level.name) == "function") then
        return "-"
    end
    local ok, res = pcall(level.name)
    if ok and type(res) == "string" and res ~= "" then
        return res
    end
    return "-"
end

local function append_fallback_log(level_name, line)
    if not (io and io.open) then
        return
    end
    local f = io.open("zhopa.log", "a")
    if not f then
        return
    end
    f:write(string.format("[%d][%s][SERVICE_DOCTOR] %s\n", now(), tostring(level_name or "INFO"), tostring(line or "")))
    f:close()
end

local function log_with(level_name, fmt, ...)
    local line = nil
    if select("#", ...) > 0 then
        local ok_fmt, res = pcall(string.format, tostring(fmt), ...)
        line = ok_fmt and res or tostring(fmt)
    else
        line = tostring(fmt)
    end
    line = string.format("level=%s %s", tostring(current_level_name()), tostring(line))

    local log = get_logger()
    if log and type(log[level_name]) == "function" then
        local ok = pcall(log[level_name], "SERVICE_DOCTOR", line)
        if ok then
            return
        end
    end
    append_fallback_log(string.upper(tostring(level_name or "INFO")), line)
    if type(printf) == "function" then
        pcall(printf, "[SERVICE_DOCTOR] %s", line)
    end
end

local function log_info(fmt, ...)
    log_with("info", fmt, ...)
end

local function log_warn(fmt, ...)
    log_with("warn", fmt, ...)
end

local function log_smart_skip(smart, reason)
    return
end

local function starts_with(str, prefix)
    return type(str) == "string" and type(prefix) == "string" and str:sub(1, #prefix) == prefix
end

local function string_has(str, fragment)
    return type(str) == "string" and type(fragment) == "string" and string.find(str, fragment, 1, true) ~= nil
end

local function is_alive_object(obj)
    if not obj then
        return false
    end
    if type(obj.alive) ~= "function" then
        return true
    end
    local ok, res = pcall(obj.alive, obj)
    return ok and res == true
end

local function get_level_object(id)
    if not (level and level.object_by_id and id) then
        return nil
    end
    local ok, obj = pcall(level.object_by_id, id)
    if ok then
        return obj
    end
    return nil
end

local function get_live_object(id)
    if not id then
        return nil
    end
    local st = db and db.storage and db.storage[id] or nil
    local obj = st and st.object or get_level_object(id)
    if is_alive_object(obj) then
        return obj
    end
    return nil
end

local function normalize_id(id)
    id = tonumber(id) or 0
    if id <= 0 or id == 65535 then
        return nil
    end
    return id
end

local function resolve_squad_id_from_npc_id(npc_id)
    npc_id = normalize_id(npc_id)
    if not npc_id then
        return nil
    end

    if zhopa and zhopa.trade and type(zhopa.trade.resolve_squad_id_from_npc_id) == "function" then
        local ok_sid, sid = pcall(zhopa.trade.resolve_squad_id_from_npc_id, npc_id)
        sid = ok_sid and normalize_id(sid) or nil
        if sid then
            return sid
        end
    end

    if not alife then
        return nil
    end
    local sim = alife()
    if not sim then
        return nil
    end

    local ok_obj, se_npc = pcall(function() return sim:object(npc_id) end)
    if not (ok_obj and se_npc) then
        return nil
    end

    local ok_sid, sid = pcall(function() return se_npc.group_id end)
    sid = ok_sid and normalize_id(sid) or nil
    if sid then
        return sid
    end

    local ok_sid_fn, sid_fn = pcall(function() return se_npc:group_id() end)
    sid_fn = ok_sid_fn and normalize_id(sid_fn) or nil
    if sid_fn then
        return sid_fn
    end

    return nil
end

local function get_current_squad_task_for_npc(npc_id)
    if not (zhopa and zhopa.memory and type(zhopa.memory.get_squad_entry) == "function") then
        return nil, nil, false
    end

    local squad_id = resolve_squad_id_from_npc_id(npc_id)
    if not squad_id then
        return nil, nil, false
    end

    local entry = zhopa.memory.get_squad_entry(squad_id)
    if type(entry) ~= "table" then
        return squad_id, nil, false
    end

    local task = entry.tasks and entry.tasks.current or nil
    return squad_id, task, true
end

local function resolve_current_smart_for_npc_id(npc_id)
    npc_id = normalize_id(npc_id)
    if not npc_id or not alife then
        return nil, nil
    end

    local sim = alife()
    if not sim then
        return nil, nil
    end

    local ok_obj, se_npc = pcall(function() return sim:object(npc_id) end)
    if not (ok_obj and se_npc) then
        return nil, nil
    end

    local smart_id = nil
    local ok_sid, raw_sid = pcall(function() return se_npc.m_smart_terrain_id end)
    smart_id = ok_sid and normalize_id(raw_sid) or nil
    if not smart_id then
        local ok_sid_fn, sid_fn = pcall(function() return se_npc:m_smart_terrain_id() end)
        smart_id = ok_sid_fn and normalize_id(sid_fn) or nil
    end
    if not smart_id then
        return nil, nil
    end

    local ok_smart, smart = pcall(function() return sim:object(smart_id) end)
    if not (ok_smart and smart) then
        return smart_id, nil
    end
    return smart_id, smart
end

local function safe_position(obj)
    if not (obj and type(obj.position) == "function") then
        return nil
    end
    local ok, pos = pcall(obj.position, obj)
    if ok then
        return pos
    end
    return nil
end

local function safe_current_point_index(obj)
    if not (obj and type(obj.get_current_point_index) == "function") then
        return nil
    end
    local ok, idx = pcall(obj.get_current_point_index, obj)
    if ok then
        return tonumber(idx) or nil
    end
    return nil
end

local function safe_path_index(obj)
    if not (obj and load_var) then
        return nil
    end
    local ok, idx = pcall(load_var, obj, "path_index", nil)
    if ok then
        return tonumber(idx) or nil
    end
    return nil
end

local function section_to_logic_from_active(active_section)
    if not starts_with(active_section, "beh@") then
        return nil
    end
    return "logic@" .. active_section:sub(5)
end

local function active_section_matches_rule(rule, active_section)
    return starts_with(active_section, rule.active_prefix) and string_has(active_section, rule.fragment)
end

local function slot_section_matches_rule(rule, slot_section)
    return starts_with(slot_section, rule.slot_prefix) and string_has(slot_section, rule.fragment)
end

local function get_smart_name(smart)
    if not (smart and type(smart.name) == "function") then
        return tostring(smart and smart.id or "nil")
    end
    local ok, name = pcall(smart.name, smart)
    if ok and type(name) == "string" and name ~= "" then
        return name
    end
    return tostring(smart and smart.id or "nil")
end

local function get_rule_cache_for_smart(smart)
    local smart_id = tonumber(smart and smart.id) or nil
    if not smart_id then
        return nil
    end
    local cached = RUNTIME.smart_rule_cache[smart_id]
    if cached then
        return cached
    end

    local cache = {
        service_slots = {},
        has_service_slots = false,
    }

    local jobs = smart and smart.stalker_jobs
    if type(jobs) == "table" then
        for i = 1, #jobs do
            local job = jobs[i]
            local section = job and job.section or nil
            if type(section) == "string" then
                for _, rule in ipairs(RULES) do
                    if slot_section_matches_rule(rule, section) then
                        cache.service_slots[section] = {
                            rule = rule,
                            section = section,
                        }
                        cache.has_service_slots = true
                        break
                    end
                end
            end
        end
    end

    RUNTIME.smart_rule_cache[smart_id] = cache
    return cache
end

local function find_job_by_section(smart, section)
    if not (smart and section and type(smart.find_job_by_section) == "function") then
        return nil
    end
    local ok, job = pcall(smart.find_job_by_section, smart, section)
    if ok then
        return job
    end
    return nil
end

local function clear_job_idle(job)
    if type(job) == "table" then
        job.idle = nil
    end
end

local function build_smart_snapshot(smart)
    local smart_id = tonumber(smart and smart.id) or nil
    if not smart_id then
        return nil
    end

    local cache = get_rule_cache_for_smart(smart)
    if not (cache and cache.has_service_slots) then
        return nil
    end

    local snapshot = {
        smart = smart,
        smart_id = smart_id,
        smart_name = get_smart_name(smart),
        entries = {},
        service_slots = {},
    }

    local npc_info = smart.npc_info
    if type(npc_info) == "table" then
        for id, info in pairs(npc_info) do
            local nid = tonumber(id) or nil
            if nid then
                local st = db and db.storage and db.storage[nid] or nil
                local obj = st and st.object or get_live_object(nid)
                local job = info and info.job or nil
                local active_section = st and st.active_section or nil
                local active_scheme = st and st.active_scheme or nil
                snapshot.entries[nid] = {
                    id = nid,
                    info = info,
                    st = st,
                    obj = obj,
                    job = job,
                    job_section = job and job.section or nil,
                    active_section = active_section,
                    active_scheme = active_scheme,
                    active_rule = get_service_rule_by_active_section and get_service_rule_by_active_section(active_section) or nil,
                    path_index = (active_scheme == "beh") and safe_path_index(obj) or nil,
                    current_point_index = safe_current_point_index(obj),
                    position = safe_position(obj),
                }
            end
        end
    end

    for slot_section, slot_cache in pairs(cache.service_slots) do
        local owner_id = smart.npc_by_job_section and tonumber(smart.npc_by_job_section[slot_section]) or nil
        snapshot.service_slots[slot_section] = {
            section = slot_section,
            rule = slot_cache.rule,
            owner_id = owner_id,
            owner = owner_id and snapshot.entries[owner_id] or nil,
            job = find_job_by_section(smart, slot_section),
        }
    end

    return snapshot
end

get_service_rule_by_active_section = function(active_section)
    for _, rule in ipairs(RULES) do
        if active_section_matches_rule(rule, active_section) then
            return rule
        end
    end
    return nil
end

local function clear_runtime_state_for_npc(npc_id)
    npc_id = tonumber(npc_id) or nil
    if npc_id then
        clear_indexed_runtime_state("by_npc", "by_smart", npc_id)
        clear_indexed_runtime_state("completed_watch_by_npc", "completed_watch_by_smart", npc_id)
        clear_indexed_runtime_state("progress_by_npc", "progress_by_smart", npc_id)
        clear_indexed_runtime_state("post_tech_watch_by_npc", "post_tech_watch_by_smart", npc_id)
        clear_indexed_runtime_state("ingress_by_npc", "ingress_by_smart", npc_id)
    end
end

local function clear_runtime_state_for_smart(smart_id)
    smart_id = tonumber(smart_id) or nil
    if not smart_id then
        return
    end
    RUNTIME.smart_next_scan_tg[smart_id] = nil
    RUNTIME.non_service_next_scan_tg[smart_id] = nil
    RUNTIME.smart_rule_cache[smart_id] = nil
    local buckets = {
        { map = "by_npc", bucket = "by_smart" },
        { map = "completed_watch_by_npc", bucket = "completed_watch_by_smart" },
        { map = "progress_by_npc", bucket = "progress_by_smart" },
        { map = "post_tech_watch_by_npc", bucket = "post_tech_watch_by_smart" },
        { map = "ingress_by_npc", bucket = "ingress_by_smart" },
    }
    for i = 1, #buckets do
        local spec = buckets[i]
        local by_smart = RUNTIME[spec.bucket]
        local bucket = type(by_smart) == "table" and by_smart[smart_id] or nil
        if type(bucket) == "table" then
            local ids = {}
            for npc_id in pairs(bucket) do
                ids[#ids + 1] = npc_id
            end
            for j = 1, #ids do
                clear_indexed_runtime_state(spec.map, spec.bucket, ids[j])
            end
        end
    end
end

local function quantize_coord(v)
    local n = tonumber(v)
    if not n then
        return "-"
    end
    return tostring(math_floor(n * 5 + 0.5) / 5)
end

local function quantize_coord_coarse(v)
    local n = tonumber(v)
    if not n then
        return "-"
    end
    return tostring(math_floor(n + 0.5))
end

local function stable_table_fingerprint(t)
    if type(t) ~= "table" then
        return "-"
    end
    local keys = {}
    local only_key = nil
    for k, v in pairs(t) do
        if v ~= nil then
            only_key = k
            keys[#keys + 1] = {
                raw = k,
                sort = tostring(k),
            }
        end
    end
    if #keys == 0 then
        return "-"
    end
    if #keys == 1 then
        return tostring(only_key) .. "=" .. tostring(t[only_key] or 0)
    end
    table_sort(keys, function(a, b)
        return a.sort < b.sort
    end)
    local parts = {}
    for i = 1, #keys do
        local item = keys[i]
        parts[#parts + 1] = tostring(item.sort) .. "=" .. tostring(t[item.raw] or 0)
    end
    return table.concat(parts, ";")
end

local function safe_money(obj)
    if not (obj and type(obj.money) == "function") then
        return "-"
    end
    local ok, value = pcall(obj.money, obj)
    if ok then
        return tostring(tonumber(value) or value or "-")
    end
    return "-"
end

local function safe_best_weapon(obj)
    if not (obj and type(obj.best_weapon) == "function") then
        return nil
    end
    local ok, wpn = pcall(obj.best_weapon, obj)
    if ok and wpn then
        return wpn
    end
    return nil
end

local function safe_item_section(item)
    if not (item and type(item.section) == "function") then
        return "-"
    end
    local ok, sec = pcall(item.section, item)
    if ok and sec then
        return tostring(sec)
    end
    return "-"
end

local function safe_installed_upgrades_fingerprint(item)
    if not (item and utils_item and type(utils_item.get_upgrades_installed) == "function") then
        return "-"
    end
    local ok, installed = pcall(utils_item.get_upgrades_installed, item, nil, true)
    if not (ok and type(installed) == "table") then
        return "-"
    end
    return stable_table_fingerprint(installed)
end

local function build_progress_signature(entry, rule)
    local st = entry and entry.st or nil
    local obj = entry and entry.obj or nil
    local base = table.concat({
        tostring(rule and rule.name or "-"),
        tostring(entry and entry.active_section or "-"),
        tostring(entry and entry.job_section or "-"),
        safe_money(obj),
    }, "|")

    if rule and rule.name == "trade" then
        return base .. "|seller=" .. tostring(entry and entry.info and entry.info.job and entry.info.job.seller_id or "-")
            .. "|items=" .. stable_table_fingerprint(st and st.trade_items)
    end

    local wpn = safe_best_weapon(obj)
    return base
        .. "|mechanic=" .. tostring(entry and entry.info and entry.info.job and entry.info.job.mechanic_id or "-")
        .. "|items=" .. stable_table_fingerprint(st and st.tech_items)
        .. "|weapon=" .. safe_item_section(wpn)
        .. "|upgrades=" .. safe_installed_upgrades_fingerprint(wpn)
end

local function build_post_tech_signature(npc, info, st)
    local pos = safe_position(npc)
    local job = info and info.job or nil
    return table.concat({
        tostring(st and st.active_section or "-"),
        tostring(st and st.active_scheme or "-"),
        tostring(job and job.section or "-"),
        tostring(safe_current_point_index(npc) or "-"),
        tostring(safe_path_index(npc) or "-"),
        quantize_coord(pos and pos.x),
        quantize_coord(pos and pos.y),
        quantize_coord(pos and pos.z),
    }, "|")
end

local function is_ingress_watch_smart(snapshot)
    return type(snapshot) == "table" and INGRESS_WATCH_SMARTS[tostring(snapshot.smart_name or "")] == true
end

local function get_service_slot_for_rule(snapshot, rule)
    if not (type(snapshot) == "table" and type(snapshot.service_slots) == "table" and type(rule) == "table") then
        return nil, nil
    end
    for slot_section, slot in pairs(snapshot.service_slots) do
        if slot and slot.rule == rule then
            return slot_section, slot
        end
    end
    return nil, nil
end

local function build_ingress_signature(entry, slot_owner_id)
    local pos = entry and entry.position or nil
    return table.concat({
        tostring(entry and entry.active_section or "-"),
        tostring(entry and entry.active_scheme or "-"),
        tostring(entry and entry.job_section or "-"),
        tostring(slot_owner_id or "-"),
        quantize_coord_coarse(pos and pos.x),
        quantize_coord_coarse(pos and pos.y),
        quantize_coord_coarse(pos and pos.z),
    }, "|")
end

local function choose_ingress_rule(snapshot, entry)
    if not (type(snapshot) == "table" and type(entry) == "table") then
        return nil
    end

    local active_rule = get_service_rule_by_active_section(entry.active_section)
    if active_rule then
        return nil
    end

    local job_section = entry.job_section
    if type(job_section) == "string" then
        for _, rule in ipairs(RULES) do
            if slot_section_matches_rule(rule, job_section) and rule.has_intent(entry.st) == true then
                return rule
            end
        end
    end

    local trade_intent = RULES[1] and RULES[1].has_intent(entry.st) == true or false
    local tech_intent = RULES[2] and RULES[2].has_intent(entry.st) == true or false

    if trade_intent and not tech_intent then
        return RULES[1]
    end
    if tech_intent and not trade_intent then
        return RULES[2]
    end
    if trade_intent and tech_intent then
        return RULES[1]
    end
    return nil
end

local function maybe_arm_departed_post_tech_watch(snapshot, npc_id, state, tg)
    if type(state) ~= "table" or state.rule_name ~= "tech" then
        return
    end
    if state.last_intent ~= true then
        return
    end
    if (tg - (tonumber(state.first_seen_tg) or tg)) < POST_COMPLETE_EXIT_VERIFY_MS then
        return
    end
    if RUNTIME.completed_watch_by_npc[npc_id] ~= nil then
        return
    end
    if RUNTIME.post_tech_watch_by_npc[npc_id] ~= nil then
        return
    end

    local entry = snapshot.entries[npc_id]
    local npc = entry and entry.obj or get_live_object(npc_id)
    if not is_alive_object(npc) then
        return
    end

    arm_post_tech_watch(npc, snapshot.smart, "departed_tech_with_live_intent", tg)
end

local function refresh_progress_tracking(snapshot)
    local tg = now()
    local active_service_ids = {}

    for npc_id, entry in pairs(snapshot.entries) do
        if entry.active_section and entry.active_scheme == "beh" then
            local rule = entry.active_rule or get_service_rule_by_active_section(entry.active_section)
            if rule then
                active_service_ids[npc_id] = true
                local signature = build_progress_signature(entry, rule)
                local state = RUNTIME.progress_by_npc[npc_id]
                if not state
                    or state.smart_id ~= snapshot.smart_id
                    or state.rule_name ~= rule.name
                    or state.active_section ~= entry.active_section
                    or state.slot_section ~= tostring(entry.job_section or "-")
                then
                    set_indexed_runtime_state("progress_by_npc", "progress_by_smart", npc_id, {
                        smart_id = snapshot.smart_id,
                        rule_name = rule.name,
                        active_section = entry.active_section,
                        slot_section = tostring(entry.job_section or "-"),
                        last_signature = signature,
                        last_progress_tg = tg,
                        last_seen_tg = tg,
                        first_seen_tg = tg,
                        last_intent = rule.has_intent(entry.st) == true,
                    })
                else
                    state.last_seen_tg = tg
                    state.last_intent = rule.has_intent(entry.st) == true
                    if state.last_signature ~= signature then
                        state.last_signature = signature
                        state.last_progress_tg = tg
                    end
                end
            end
        end
    end

    local progress_bucket = RUNTIME.progress_by_smart and RUNTIME.progress_by_smart[snapshot.smart_id] or nil
    local progress_ids = {}
    for npc_id in pairs(progress_bucket or {}) do
        progress_ids[#progress_ids + 1] = npc_id
    end
    for i = 1, #progress_ids do
        local npc_id = progress_ids[i]
        local state = RUNTIME.progress_by_npc[npc_id]
        if state and state.smart_id == snapshot.smart_id and active_service_ids[npc_id] ~= true then
            maybe_arm_departed_post_tech_watch(snapshot, npc_id, state, tg)
            clear_indexed_runtime_state("progress_by_npc", "progress_by_smart", npc_id)
        end
    end
end

local function refresh_ingress_tracking(snapshot)
    local tg = now()
    local active_ids = {}
    local ingress_enabled = is_ingress_watch_smart(snapshot)

    if ingress_enabled then
        for npc_id, entry in pairs(snapshot.entries) do
            local rule = choose_ingress_rule(snapshot, entry)
            if rule then
                local _, slot = get_service_slot_for_rule(snapshot, rule)
                local slot_owner_id = slot and tonumber(slot.owner_id) or nil
                local signature = build_ingress_signature(entry, slot_owner_id)
                local state = RUNTIME.ingress_by_npc[npc_id]
                active_ids[npc_id] = true

                if not state
                    or state.smart_id ~= snapshot.smart_id
                    or state.rule_name ~= rule.name
                then
                    set_indexed_runtime_state("ingress_by_npc", "ingress_by_smart", npc_id, {
                        smart_id = snapshot.smart_id,
                        smart_name = snapshot.smart_name,
                        rule_name = rule.name,
                        last_signature = signature,
                        last_progress_tg = tg,
                        last_seen_tg = tg,
                        first_seen_tg = tg,
                        slot_owner_id = slot_owner_id,
                    })
                else
                    state.last_seen_tg = tg
                    state.slot_owner_id = slot_owner_id
                    if state.last_signature ~= signature then
                        state.last_signature = signature
                        state.last_progress_tg = tg
                    end
                end
            end
        end
    end

    local ingress_bucket = RUNTIME.ingress_by_smart and RUNTIME.ingress_by_smart[snapshot.smart_id] or nil
    local ingress_ids = {}
    for npc_id in pairs(ingress_bucket or {}) do
        ingress_ids[#ingress_ids + 1] = npc_id
    end
    for i = 1, #ingress_ids do
        local npc_id = ingress_ids[i]
        local state = RUNTIME.ingress_by_npc[npc_id]
        if state and state.smart_id == snapshot.smart_id and active_ids[npc_id] ~= true then
            clear_indexed_runtime_state("ingress_by_npc", "ingress_by_smart", npc_id)
        end
    end
end

local function sanitize_service_slots(snapshot)
    local changed = false
    for slot_section, slot in pairs(snapshot.service_slots) do
        local owner_id = slot.owner_id
        if owner_id then
            local owner = slot.owner
            local owner_info = owner and owner.info or nil
            local owner_job_section = owner and owner.job_section or nil
            local owner_obj = owner and owner.obj or nil
            local invalid = false

            if not owner_info then
                invalid = true
            elseif owner_job_section ~= slot_section then
                invalid = true
            elseif not is_alive_object(owner_obj) then
                invalid = true
            end

            if invalid then
                if snapshot.smart.npc_by_job_section then
                    snapshot.smart.npc_by_job_section[slot_section] = nil
                end
                clear_job_idle(slot.job)
                changed = true
                snapshot.service_slots[slot_section].owner_id = nil
                snapshot.service_slots[slot_section].owner = nil
            end
        end
    end
    return changed
end

local function make_post_complete_issue(snapshot, entry, rule, slot_section, linked, watch)
    return {
        kind = "service_post_complete_stuck",
        smart = snapshot.smart,
        smart_id = snapshot.smart_id,
        smart_name = snapshot.smart_name,
        rule = rule,
        npc_id = entry.id,
        entry = entry,
        slot_section = slot_section,
        linked = linked == true,
        active_section = entry.active_section,
        active_scheme = entry.active_scheme,
        watch = watch,
    }
end

local function make_orphan_issue(snapshot, entry, rule, slot_section, linked, squad_id, current_task)
    return {
        kind = "service_orphaned",
        smart = snapshot.smart,
        smart_id = snapshot.smart_id,
        smart_name = snapshot.smart_name,
        rule = rule,
        npc_id = entry.id,
        entry = entry,
        slot_section = slot_section,
        linked = linked == true,
        active_section = entry.active_section,
        active_scheme = entry.active_scheme,
        squad_id = squad_id,
        current_task = current_task,
    }
end

local function make_no_progress_issue(snapshot, entry, rule, slot_section, linked, stalled_ms)
    return {
        kind = "service_no_progress",
        smart = snapshot.smart,
        smart_id = snapshot.smart_id,
        smart_name = snapshot.smart_name,
        rule = rule,
        npc_id = entry.id,
        entry = entry,
        slot_section = slot_section,
        linked = linked == true,
        active_section = entry.active_section,
        active_scheme = entry.active_scheme,
        stalled_ms = stalled_ms,
    }
end

local function make_ingress_issue(snapshot, entry, rule, slot_section, linked, stalled_ms, slot_owner_id)
    return {
        kind = "service_ingress_stuck",
        smart = snapshot.smart,
        smart_id = snapshot.smart_id,
        smart_name = snapshot.smart_name,
        rule = rule,
        npc_id = entry.id,
        entry = entry,
        slot_section = slot_section,
        linked = linked == true,
        active_section = entry.active_section,
        active_scheme = entry.active_scheme,
        stalled_ms = stalled_ms,
        slot_owner_id = slot_owner_id,
    }
end

local function clear_completed_watch(npc_id)
    npc_id = tonumber(npc_id) or nil
    if npc_id then
        clear_indexed_runtime_state("completed_watch_by_npc", "completed_watch_by_smart", npc_id)
    end
end

local function clear_post_tech_watch(npc_id)
    npc_id = tonumber(npc_id) or nil
    if npc_id then
        clear_indexed_runtime_state("post_tech_watch_by_npc", "post_tech_watch_by_smart", npc_id)
    end
end

local function arm_completed_watch(npc, smart, kind, status, reason)
    if status ~= "completed" then
        return false
    end
    if not (npc and type(npc.id) == "function") then
        return false
    end

    local npc_id = tonumber(npc:id()) or nil
    local smart_id = tonumber(smart and smart.id) or nil
    if not (npc_id and smart_id) then
        return false
    end

    local st = db and db.storage and db.storage[npc_id] or nil
    local expect = "exit"
    if tostring(kind) == "trade" and RULES[2] and RULES[2].has_intent(st) then
        expect = "tech_or_exit"
    end

    set_indexed_runtime_state("completed_watch_by_npc", "completed_watch_by_smart", npc_id, {
        npc_id = npc_id,
        smart_id = smart_id,
        smart_name = get_smart_name(smart),
        kind = tostring(kind or "-"),
        expect = expect,
        reason = tostring(reason or "-"),
        armed_tg = now(),
    })

    return true
end

arm_post_tech_watch = function(npc, smart, reason, left_service_tg)
    if not (npc and type(npc.id) == "function") then
        return false
    end

    local npc_id = tonumber(npc:id()) or nil
    local smart_id = tonumber(smart and smart.id) or nil
    if not (npc_id and smart_id) then
        return false
    end

    local st = db and db.storage and db.storage[npc_id] or nil
    local info = smart and smart.npc_info and smart.npc_info[npc_id] or nil
    local tg = now()
    local watch = RUNTIME.post_tech_watch_by_npc[npc_id]

    if watch and watch.smart_id ~= smart_id then
        watch = nil
    end

    if not watch then
        watch = {
            npc_id = npc_id,
            smart_id = smart_id,
            smart_name = get_smart_name(smart),
            armed_tg = tg,
            reason = tostring(reason or "-"),
            left_service_tg = left_service_tg,
            last_signature = build_post_tech_signature(npc, info, st),
            last_progress_tg = tg,
        }
        set_indexed_runtime_state("post_tech_watch_by_npc", "post_tech_watch_by_smart", npc_id, watch)
    else
        watch.smart_name = get_smart_name(smart)
        watch.reason = tostring(reason or watch.reason or "-")
        if left_service_tg and not watch.left_service_tg then
            watch.left_service_tg = left_service_tg
        end
        watch.last_signature = build_post_tech_signature(npc, info, st)
        watch.last_progress_tg = tg
    end

    return true
end

local function arm_post_tech_unknown_watch(npc, smart, kind, status, reason)
    if not (status == "completed" and tostring(kind) == "tech") then
        return false
    end
    return arm_post_tech_watch(npc, smart, reason, nil)
end

local function detect_post_complete_issues(snapshot, issued)
    local issues = {}
    local tg = now()

    local bucket = RUNTIME.completed_watch_by_smart and RUNTIME.completed_watch_by_smart[snapshot.smart_id] or nil
    local ids = {}
    for npc_id in pairs(bucket or {}) do
        ids[#ids + 1] = npc_id
    end
    for i = 1, #ids do
        local npc_id = ids[i]
        local watch = RUNTIME.completed_watch_by_npc[npc_id]
        if watch and watch.smart_id == snapshot.smart_id then
            local entry = snapshot.entries[npc_id]
            if not (entry and entry.st and entry.active_section and entry.active_scheme == "beh") then
                clear_completed_watch(npc_id)
            else
                local active_rule = entry.active_rule or get_service_rule_by_active_section(entry.active_section)
                local slot_section = entry.job_section
                if active_rule and not slot_section_matches_rule(active_rule, slot_section) then
                    slot_section = section_to_logic_from_active(entry.active_section)
                end
                local slot = slot_section and snapshot.service_slots[slot_section] or nil
                local linked_owner_id = slot and slot.owner_id or nil
                local verify_ms = watch.expect == "tech_or_exit" and POST_COMPLETE_TRADE_TO_TECH_VERIFY_MS or POST_COMPLETE_EXIT_VERIFY_MS

                if (tg - (tonumber(watch.armed_tg) or tg)) < verify_ms then
                    -- wait for vanilla to transition out of service or into tech
                elseif watch.kind == "trade" then
                    if active_rule == nil then
                        clear_completed_watch(npc_id)
                    elseif watch.expect == "tech_or_exit" then
                        if active_rule.name == "trade" then
                            issues[#issues + 1] = make_post_complete_issue(snapshot, entry, active_rule, slot_section, linked_owner_id == npc_id, watch)
                            issued[npc_id] = true
                        else
                            clear_completed_watch(npc_id)
                        end
                    elseif active_rule.name == "trade" or active_rule.name == "tech" then
                        issues[#issues + 1] = make_post_complete_issue(snapshot, entry, active_rule, slot_section, linked_owner_id == npc_id, watch)
                        issued[npc_id] = true
                    else
                        clear_completed_watch(npc_id)
                    end
                elseif watch.kind == "tech" then
                    if active_rule == nil then
                        clear_completed_watch(npc_id)
                    else
                        issues[#issues + 1] = make_post_complete_issue(snapshot, entry, active_rule, slot_section, linked_owner_id == npc_id, watch)
                        issued[npc_id] = true
                    end
                else
                    clear_completed_watch(npc_id)
                end
            end
        end
    end

    return issues
end

local function detect_orphan_service_issues(snapshot, issued)
    local issues = {}

    if not (zhopa and zhopa.memory and type(zhopa.memory.get_squad_entry) == "function") then
        return issues
    end

    for npc_id, entry in pairs(snapshot.entries) do
        if issued[npc_id] ~= true and entry.active_section and entry.active_scheme == "beh" then
            local rule = entry.active_rule or get_service_rule_by_active_section(entry.active_section)
            if rule then
                local slot_section = entry.job_section
                if not slot_section_matches_rule(rule, slot_section) then
                    slot_section = section_to_logic_from_active(entry.active_section)
                end
                local slot = slot_section and snapshot.service_slots[slot_section] or nil
                local linked = slot and slot.owner_id == npc_id or false
                local squad_id, current_task, has_memory_entry = get_current_squad_task_for_npc(npc_id)

                if has_memory_entry
                    and squad_id
                    and rule.name == "trade"
                    and (type(current_task) ~= "table" or current_task.type ~= "TRADE" or current_task.target ~= snapshot.smart_name)
                then
                    issues[#issues + 1] = make_orphan_issue(snapshot, entry, rule, slot_section, linked, squad_id, current_task)
                    issued[npc_id] = true
                end
            end
        end
    end

    return issues
end

local function detect_no_progress_issues(snapshot, issued)
    local issues = {}
    local tg = now()

    for npc_id, entry in pairs(snapshot.entries) do
        if issued[npc_id] ~= true and entry.active_section and entry.active_scheme == "beh" then
            local rule = entry.active_rule or get_service_rule_by_active_section(entry.active_section)
            if rule and RUNTIME.completed_watch_by_npc[npc_id] == nil then
                local slot_section = entry.job_section
                if not slot_section_matches_rule(rule, slot_section) then
                    slot_section = section_to_logic_from_active(entry.active_section)
                end
                local slot = slot_section and snapshot.service_slots[slot_section] or nil
                local linked = slot and slot.owner_id == npc_id or false
                local progress = RUNTIME.progress_by_npc[npc_id]
                local stalled_ms = tg - (tonumber(progress and progress.last_progress_tg) or tg)
                local limit_ms = tonumber(rule.no_progress_ms) or 0
                if progress and stalled_ms >= limit_ms then
                    issues[#issues + 1] = make_no_progress_issue(snapshot, entry, rule, slot_section, linked, stalled_ms)
                    issued[npc_id] = true
                end
            end
        end
    end

    return issues
end

local function detect_ingress_issues(snapshot, issued)
    local issues = {}
    local tg = now()

    if not is_ingress_watch_smart(snapshot) then
        return issues
    end

    for npc_id, entry in pairs(snapshot.entries) do
        if issued[npc_id] ~= true then
            local progress = RUNTIME.ingress_by_npc[npc_id]
            if progress and progress.smart_id == snapshot.smart_id then
                local rule = choose_ingress_rule(snapshot, entry)
                if rule and progress.rule_name == rule.name then
                    local slot_section, slot = get_service_slot_for_rule(snapshot, rule)
                    local slot_owner_id = slot and tonumber(slot.owner_id) or nil
                    local linked = slot_owner_id == npc_id
                    local stalled_ms = tg - (tonumber(progress.last_progress_tg) or tg)
                    local limit_ms = tonumber(INGRESS_NO_PROGRESS_MS[rule.name]) or 0
                    if slot_owner_id and slot_owner_id ~= npc_id then
                        limit_ms = limit_ms + (tonumber(INGRESS_OCCUPIED_BONUS_MS[rule.name]) or 0)
                    end
                    if stalled_ms >= limit_ms then
                        issues[#issues + 1] = make_ingress_issue(snapshot, entry, rule, slot_section, linked, stalled_ms, slot_owner_id)
                        issued[npc_id] = true
                    end
                end
            end
        end
    end

    return issues
end

local function detect_cleanup_issues(snapshot)
    local issues = {}
    local issued = {}

    local post_complete_issues = detect_post_complete_issues(snapshot, issued)
    for i = 1, #post_complete_issues do
        issues[#issues + 1] = post_complete_issues[i]
    end

    local orphan_issues = detect_orphan_service_issues(snapshot, issued)
    for i = 1, #orphan_issues do
        issues[#issues + 1] = orphan_issues[i]
    end

    local ingress_issues = detect_ingress_issues(snapshot, issued)
    for i = 1, #ingress_issues do
        issues[#issues + 1] = ingress_issues[i]
    end

    local no_progress_issues = detect_no_progress_issues(snapshot, issued)
    for i = 1, #no_progress_issues do
        issues[#issues + 1] = no_progress_issues[i]
    end

    return issues, issued
end

local function ensure_state(issue)
    local tg = now()
    local npc_id = issue.npc_id
    local issue_key = table.concat({
        issue.kind,
        issue.rule and issue.rule.name or "-",
        tostring(issue.slot_section or "-"),
        tostring(issue.active_section or "-"),
    }, "|")

    local state = RUNTIME.by_npc[npc_id]
    if not state or state.issue_key ~= issue_key then
        state = {
            issue_key = issue_key,
            smart_id = issue.smart_id,
            first_seen_tg = tg,
            last_seen_tg = tg,
            last_action_tg = 0,
        }
        set_indexed_runtime_state("by_npc", "by_smart", npc_id, state)
        log_info(
            "issue_seen kind=%s smart=%s npc=%s id=%s rule=%s linked=%s slot=%s active=%s",
            tostring(issue.kind),
            tostring(issue.smart_name),
            issue.entry and issue.entry.obj and issue.entry.obj:name() or tostring(issue.npc_id),
            tostring(issue.npc_id),
            issue.rule and issue.rule.name or "?",
            tostring(issue.linked),
            tostring(issue.slot_section),
            tostring(issue.active_section)
        )
        return state, true
    end

    if state.smart_id ~= issue.smart_id then
        set_smart_bucket_entry("by_smart", state.smart_id, npc_id, false)
        state.smart_id = issue.smart_id
        set_smart_bucket_entry("by_smart", state.smart_id, npc_id, true)
    else
        state.smart_id = issue.smart_id
    end
    state.last_seen_tg = tg
    return state, false
end

local function flush_npc_runtime_state(issue)
    local entry = issue and issue.entry or nil
    local npc = entry and entry.obj or nil
    local st = entry and entry.st or nil
    if not is_alive_object(npc) then
        return false, "no_live_npc"
    end

    local npc_id = issue and issue.npc_id or nil
    local state_mgr = st and st.state_mgr or nil

    if type(npc.clear_animations) == "function" then
        pcall(npc.clear_animations, npc)
    end

    if type(npc.inactualize_patrol_path) == "function" then
        pcall(npc.inactualize_patrol_path, npc)
    end

    if utils_obj and type(utils_obj.send_to_nearest_accessible_vertex) == "function" and type(npc.level_vertex_id) == "function" then
        local ok_lvid, lvid = pcall(npc.level_vertex_id, npc)
        if ok_lvid and lvid then
            pcall(utils_obj.send_to_nearest_accessible_vertex, npc, lvid, "smart_service_slot_doctor")
        end
    end

    if state_mgr then
        local animation = state_mgr.animation
        if animation and type(animation.set_state) == "function" then
            pcall(animation.set_state, animation, nil, true)
            if type(animation.set_control) == "function" then
                pcall(animation.set_control, animation)
            end
        end

        local animstate = state_mgr.animstate
        if animstate and type(animstate.set_state) == "function" then
            pcall(animstate.set_state, animstate, nil, true)
            if type(animstate.set_control) == "function" then
                pcall(animstate.set_control, animstate)
            end
        end

        if type(state_mgr.set_state) == "function" then
            pcall(state_mgr.set_state, state_mgr, "idle", nil, nil, nil, {fast_set = true})
        end

        if type(state_mgr.update) == "function" then
            for _ = 1, STATE_FLUSH_UPDATES do
                pcall(state_mgr.update, state_mgr)
            end
        end
    end

    log_warn(
        "state_flush smart=%s npc=%s id=%s kind=%s rule=%s active=%s",
        tostring(issue and issue.smart_name or "-"),
        entry and entry.obj and entry.obj:name() or tostring(npc_id),
        tostring(npc_id),
        tostring(issue and issue.kind or "-"),
        issue and issue.rule and issue.rule.name or "?",
        tostring(issue and issue.active_section or "-")
    )

    return true, nil
end

resolve_issue_with_flush = function(issue, tag)
    local tg = now()
    local state, _ = ensure_state(issue)

    if tg < ((tonumber(state.last_action_tg) or 0) + ACTION_COOLDOWN_MS) then
        return
    end

    state.last_action_tg = tg

    local ok_flush, reason = flush_npc_runtime_state(issue)
    if not ok_flush then
        log_warn(
            "state_flush_failed smart=%s id=%s kind=%s rule=%s reason=%s slot=%s active=%s tag=%s",
            issue.smart_name,
            tostring(issue.npc_id),
            tostring(issue.kind or "-"),
            issue.rule and issue.rule.name or "?",
            tostring(reason),
            tostring(issue.slot_section),
            tostring(issue.active_section),
            tostring(tag or "-")
        )
    end
end

local function resolve_service_post_complete_stuck(issue)
    resolve_issue_with_flush(issue, "post_complete")
end

local function resolve_service_orphaned_issue(issue)
    clear_completed_watch(issue.npc_id)
    resolve_issue_with_flush(issue, "orphaned")
end

local function resolve_service_no_progress_issue(issue)
    resolve_issue_with_flush(issue, "no_progress")
end

local function resolve_service_ingress_stuck_issue(issue)
    resolve_issue_with_flush(issue, "ingress")
end

local RESOLVERS = {
    service_post_complete_stuck = resolve_service_post_complete_stuck,
    service_orphaned = resolve_service_orphaned_issue,
    service_ingress_stuck = resolve_service_ingress_stuck_issue,
    service_no_progress = resolve_service_no_progress_issue,
}

local function clear_resolved_states(snapshot, issued)
    local current_ids = {}
    for npc_id in pairs(snapshot.entries) do
        current_ids[npc_id] = true
    end

    local bucket = RUNTIME.by_smart and RUNTIME.by_smart[snapshot.smart_id] or nil
    local ids = {}
    for npc_id in pairs(bucket or {}) do
        ids[#ids + 1] = npc_id
    end
    for i = 1, #ids do
        local npc_id = ids[i]
        local state = RUNTIME.by_npc[npc_id]
        if state and state.smart_id == snapshot.smart_id and current_ids[npc_id] and issued[npc_id] ~= true then
            clear_indexed_runtime_state("by_npc", "by_smart", npc_id)
        end
    end
end

local function process_smart(smart)
    if RUNTIME.ready ~= true then
        return
    end

    local smart_id = tonumber(smart and smart.id) or nil
    if not smart_id then
        return
    end
    if smart.disabled then
        log_smart_skip(smart, "disabled")
        return
    end
    if smart.is_on_actor_level ~= true then
        log_smart_skip(smart, "not_actor_level")
        return
    end

    local tg = now()
    if tg < (tonumber(RUNTIME.non_service_next_scan_tg[smart_id]) or 0) then
        return
    end
    local rule_cache = get_rule_cache_for_smart(smart)
    if not (rule_cache and rule_cache.has_service_slots == true) then
        RUNTIME.non_service_next_scan_tg[smart_id] = tg + NO_SERVICE_SCAN_COOLDOWN_MS
        log_smart_skip(smart, "no_service_slots")
        return
    end

    if tg < (tonumber(RUNTIME.smart_next_scan_tg[smart_id]) or 0) then
        return
    end
    RUNTIME.smart_next_scan_tg[smart_id] = tg + SCAN_COOLDOWN_MS

    local snapshot = build_smart_snapshot(smart)
    if not snapshot then
        log_smart_skip(smart, "no_snapshot")
        return
    end

    sanitize_service_slots(snapshot)
    refresh_progress_tracking(snapshot)
    refresh_ingress_tracking(snapshot)

    local issues, issued = detect_cleanup_issues(snapshot)
    for i = 1, #issues do
        local issue = issues[i]
        local resolver = RESOLVERS[issue.kind]
        if resolver then
            resolver(issue)
        end
    end

    clear_resolved_states(snapshot, issued)
end

local function on_actor_first_update()
    mark_runtime_ready()
end

local function on_load_state()
    mark_runtime_ready()
end

local function on_server_entity_unregister(se_obj, type_name)
    local id = se_obj and tonumber(se_obj.id) or nil
    if id then
        clear_runtime_state_for_npc(id)
    end
    if type_name == "se_smart_terrain" and id then
        clear_runtime_state_for_smart(id)
    end
end

local function wants_smart_update(smart, ctx)
    if RUNTIME.ready ~= true then
        return false
    end
    if type(ctx) == "table" then
        if ctx.disabled == true or ctx.is_on_actor_level ~= true then
            return false
        end
        if not tonumber(ctx.id) then
            return false
        end
    end
    return true
end

local function on_smart_terrain_update(smart)
    process_smart(smart)
end

local function on_npc_update(npc)
    if RUNTIME.ready ~= true then
        return
    end
    if not (npc and type(npc.id) == "function") then
        return
    end

    local npc_id = tonumber(npc:id()) or nil
    local watch = npc_id and RUNTIME.post_tech_watch_by_npc[npc_id] or nil
    if not watch then
        return
    end

    local tg = now()
    if tg < (tonumber(watch.next_check_tg) or 0) then
        return
    end
    watch.next_check_tg = tg + POST_TECH_NPC_UPDATE_CHECK_MS

    if not is_alive_object(npc) then
        clear_post_tech_watch(npc_id)
        return
    end

    if (tg - (tonumber(watch.armed_tg) or tg)) > POST_TECH_UNKNOWN_WATCH_MAX_MS then
        clear_post_tech_watch(npc_id)
        return
    end

    local st = db and db.storage and db.storage[npc_id] or nil
    if not st then
        clear_post_tech_watch(npc_id)
        return
    end

    local smart_id, smart = resolve_current_smart_for_npc_id(npc_id)
    if smart_id and watch.smart_id and smart_id ~= watch.smart_id then
        clear_post_tech_watch(npc_id)
        return
    end
    if not (smart and smart.npc_info and smart.npc_info[npc_id]) then
        return
    end

    local info = smart.npc_info[npc_id]
    local active_section = st.active_section
    local active_scheme = st.active_scheme
    local in_service_tech = active_scheme == "beh" and get_service_rule_by_active_section(active_section) == RULES[2]

    local signature = build_post_tech_signature(npc, info, st)
    if watch.last_signature ~= signature then
        watch.last_signature = signature
        watch.last_progress_tg = tg
    end

    if in_service_tech then
        return
    end

    if not watch.left_service_tg then
        watch.left_service_tg = tg
        watch.last_progress_tg = tg
        return
    end

    if (tg - watch.left_service_tg) < POST_TECH_UNKNOWN_GRACE_MS then
        return
    end
    if (tg - (tonumber(watch.last_progress_tg) or tg)) < POST_TECH_UNKNOWN_STALL_MS then
        return
    end

    local issue = {
        kind = "post_tech_unknown_scheme",
        smart = smart,
        smart_id = tonumber(smart.id) or watch.smart_id,
        smart_name = get_smart_name(smart),
        rule = RULES[2],
        npc_id = npc_id,
        entry = {
            id = npc_id,
            info = info,
            st = st,
            obj = npc,
            job = info and info.job or nil,
            job_section = info and info.job and info.job.section or nil,
            active_section = active_section,
            active_scheme = active_scheme,
        },
        slot_section = info and info.job and info.job.section or nil,
        linked = info and info.job and smart.npc_by_job_section and smart.npc_by_job_section[info.job.section] == npc_id or false,
        active_section = active_section,
        active_scheme = active_scheme,
        stalled_ms = tg - (tonumber(watch.last_progress_tg) or tg),
    }

    resolve_issue_with_flush(issue, "post_tech_unknown")
    clear_post_tech_watch(npc_id)
end

function inst.on_axr_service_result(npc, smart, kind, status, reason)
    arm_completed_watch(npc, smart, kind, status, reason)
    arm_post_tech_unknown_watch(npc, smart, kind, status, reason)
end

function inst.needs_npc_update()
    return RUNTIME.ready == true
        and type(RUNTIME.post_tech_watch_by_npc) == "table"
        and next(RUNTIME.post_tech_watch_by_npc) ~= nil
end

inst.on_actor_first_update = on_actor_first_update
inst.on_load_state = on_load_state
inst.on_server_entity_unregister = on_server_entity_unregister
inst.wants_smart_update = wants_smart_update
inst.on_smart_terrain_update = on_smart_terrain_update
inst.on_npc_update = on_npc_update
zhopa.smart_service_slot_doctor = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module smart_service_slot_doctor

function zhopa.on_game_start()
    zhopa_require_external("axr_trade_manager")

    if zhopa.loot and zhopa.loot.on_game_start then
        zhopa.loot.on_game_start()
    end

    if zhopa.loot_patch and zhopa.loot_patch.on_game_start then
        zhopa.loot_patch.on_game_start()
    end

    if zhopa.npc_faction_override and zhopa.npc_faction_override.on_game_start then
        zhopa.npc_faction_override.on_game_start()
    end

    if zhopa.heli_guard_patch and zhopa.heli_guard_patch.on_game_start then
        zhopa.heli_guard_patch.on_game_start()
    end

    if axr_trade_manager and axr_trade_manager.on_game_start then
        axr_trade_manager.on_game_start()
    end

    if zhopa.core and zhopa.core.on_game_start then
        zhopa.core.on_game_start()
    end
end
