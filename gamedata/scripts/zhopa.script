zhopa = zhopa or {}

zhopa.version = "1.0.1"

local function zhopa_require_external(name)
    local ok = pcall(require, name)
    return ok
end

-- Monolithic runtime bundle. Keep axr_trade_manager.script and zhopa_mcm.script separate.

local zhopa_bundle_module
-- BEGIN module zhopa_oop
zhopa_bundle_module = function()
zhopa = zhopa or {}

function zhopa.class(name)
    local cls = {}
    cls.__index = cls
    cls.__name = name or "class"

    function cls.new(...)
        local self = setmetatable({}, cls)
        if self.__init then
            self:__init(...)
        end
        return self
    end

    return cls
end
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_oop

-- BEGIN module zhopa_switches
zhopa_bundle_module = function()
zhopa = zhopa or {}
zhopa.switches = zhopa.switches or {}

local s = zhopa.switches

s.core = true
s.safe = true
s.log = true
s.config = true
s.timers = true
s.board_index = true
s.memory = true
s.story_psy_watchdog = true
s.story_events = true
s.smart_tasks = true
s.tasks = true
s.mutants = true
s.base_filler = true
s.dynamic_bases = true
s.service_filler = true
s.axr_task_patch = true
s.npc_faction_override = true
s.debug_hud = true
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_switches


-- BEGIN module zhopa_timers
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local setmetatable = _G.setmetatable
local tonumber = _G.tonumber
local tostring = _G.tostring
local unpack = _G.unpack
local CreateTimeEvent = _G.CreateTimeEvent
local RemoveTimeEvent = _G.RemoveTimeEvent


local Timers = zhopa.class("Timers")
Timers.__index = Timers

local function make_key(ns, name)
    return tostring(ns or "zhopa") .. "|" .. tostring(name or "")
end

local function safe_call(module, fn, ...)
    local ok, res = pcall(fn, ...)
    if ok then
        return true, res
    end
    if zhopa and zhopa.log and zhopa.log.error then
        zhopa.log.error("TIMERS", "%s failed: %s", tostring(module or "timer"), tostring(res))
    end
    return false, res
end

function Timers:__init()
    self.entries = {}
end

function Timers:_dispatch(ns, name, ...)
    local key = make_key(ns, name)
    local entry = self.entries[key]
    if not entry then
        return true
    end

    self.entries[key] = nil
    if tonumber(entry.argc) and tonumber(entry.argc) > 0 then
        safe_call(key, entry.fn, unpack(entry.args or {}, 1, tonumber(entry.argc) or 0))
    else
        safe_call(key, entry.fn)
    end
    return true
end

function Timers:_schedule(ns, name, delay_ms, fn, ...)
    if type(name) ~= "string" or name == "" then return false end
    if type(fn) ~= "function" then return false end

    local key = make_key(ns, name)
    self:_cancel(ns, name)
    local delay = tonumber(delay_ms) or 0
    if delay < 0 then delay = 0 end
    local delay_sec = delay / 1000
    local argc = select("#", ...)
    local args = argc > 0 and {...} or nil

    self.entries[key] = {
        ns = ns,
        name = name,
        fn = fn,
        args = args,
        argc = argc,
    }

    if CreateTimeEvent then
        local ok = pcall(CreateTimeEvent, tostring(ns or "zhopa"), name, delay_sec, self._dispatch, self, ns, name)
        if ok then
            return true
        end
    end

    self.entries[key] = nil
    if argc > 0 then
        return safe_call(key, fn, unpack(args or {}, 1, argc))
    end
    return safe_call(key, fn)
end

function Timers:_cancel(ns, name)
    local key = make_key(ns, name)
    self.entries[key] = nil
    if RemoveTimeEvent then
        return pcall(RemoveTimeEvent, tostring(ns or "zhopa"), name)
    end
    return true
end

function Timers:_reschedule(ns, name, delay_ms, fn, ...)
    return self:_schedule(ns, name, delay_ms, fn, ...)
end

function Timers:_has(ns, name)
    return self.entries[make_key(ns, name)] ~= nil
end

function Timers:_clear(ns)
    local targets = {}
    if ns == nil then
        for _, entry in pairs(self.entries) do
            if type(entry) == "table" and entry.name ~= nil then
                targets[#targets + 1] = {
                    ns = entry.ns,
                    name = entry.name,
                }
            end
        end
    else
        local prefix = tostring(ns) .. "|"
        for key, entry in pairs(self.entries) do
            if string.sub(key, 1, #prefix) == prefix and type(entry) == "table" and entry.name ~= nil then
                targets[#targets + 1] = {
                    ns = entry.ns,
                    name = entry.name,
                }
            end
        end
    end
    for i = 1, #targets do
        self:_cancel(targets[i].ns, targets[i].name)
    end
    return true
end

local inst = Timers.new and Timers.new() or setmetatable({}, Timers)
if not inst.entries then
    Timers.__init(inst)
end

inst.schedule = function(ns, name, delay_ms, fn, ...) return inst:_schedule(ns, name, delay_ms, fn, ...) end
inst.cancel = function(ns, name) return inst:_cancel(ns, name) end
inst.reschedule = function(ns, name, delay_ms, fn, ...) return inst:_reschedule(ns, name, delay_ms, fn, ...) end
inst.has = function(ns, name) return inst:_has(ns, name) end
inst.clear = function(ns) return inst:_clear(ns) end

zhopa.timers = inst
end; zhopa_bundle_module(); zhopa_bundle_module = nil
-- END module zhopa_timers

-- BEGIN module zhopa_core
zhopa_bundle_module = function()
zhopa = zhopa or {}

local type = _G.type
local pcall = _G.pcall
local setmetatable = _G.setmetatable
local tonumber = _G.tonumber
local tostring = _G.tostring
local alife = _G.alife
local game_graph = _G.game_graph
local time_global = _G.time_global


local Core = zhopa.class("Core")
Core.__index = Core

local function can_run(name)
    local sw = zhopa.switches
    if not sw then return false end
    if sw.core ~= true then return false end
    if name == nil then return true end
    return sw[name] == true
end

local function safe_call(tag, fn, ...)
    local safe = zhopa.safe
    if safe and safe.safe_call then
        return safe.safe_call(tag, fn, ...)
    end
    local ok, res = pcall(fn, ...)
    return ok, res
end

local function master_enabled_now()
    local runtime_cfg = zhopa and zhopa.runtime_cfg
    if runtime_cfg and runtime_cfg.get then
        return runtime_cfg.get("enabled", true) == true
    end
    local cfg = zhopa.config
    if not (cfg and cfg.get) then
        return true
    end
    local ok, enabled = safe_call("zhopa.config.get(enabled)", cfg.get, "enabled", true)
    if not ok then
        return true
    end
    return enabled == true
end

local function runtime_enabled_now()
    local core = zhopa and zhopa.core
    if core and core.is_enabled then
        local ok, enabled = pcall(core.is_enabled)
        if ok then
            return enabled == true
        end
    end
    return master_enabled_now() == true
end

local GVID_LEVEL_CACHE_MS = 1000
local gvid_level_cache = {}

local function now_level_name_by_gvid(gvid)
    gvid = tonumber(gvid) or nil
    if not (gvid and alife and game_graph) then
        return nil
    end
    local now = (time_global and time_global()) or 0
    local cached = gvid_level_cache[gvid]
    if type(cached) == "table" and now <= (tonumber(cached.tg) or 0) + GVID_LEVEL_CACHE_MS then
        return cached.value
    end
    local ok, res = pcall(function()
        local gg = game_graph()
        if not gg then
            return nil
        end
        local gv = gg:vertex(gvid)
        if not gv then
            return nil
        end
        local sim = alife()
        if not sim then
            return nil
        end
        return sim:level_name(gv:level_id())
    end)
    if ok and type(res) == "string" and res ~= "" then
        gvid_level_cache[gvid] = { value = res, tg = now }
        return res
    end
    gvid_level_cache[gvid] = { value = nil, tg = now }
    return nil
end

local ACTOR_LEVEL_CACHE_MS = 500
local actor_level_cache_value = nil
local actor_level_cache_tg = -1

local function current_actor_level_name()
    local now = (time_global and time_global()) or 0
    if actor_level_cache_tg >= 0 and now <= (actor_level_cache_tg + ACTOR_LEVEL_CACHE_MS) then
        return actor_level_cache_value
    end
    actor_level_cache_tg = now
    actor_level_cache_value = nil
    if not alife then
        return nil
    end
    local ok, res = pcall(function()
        local sim = alife()
        local actor = sim and sim:actor() or nil
        if not actor then
            return nil
        end
        return now_level_name_by_gvid(tonumber(actor.m_game_vertex_id) or 0)
    end)
    if ok and type(res) == "string" and res ~= "" then
        actor_level_cache_value = res
        return res
    end
    return nil
end

local OFFLEVEL_SKIP_CFG_CACHE_MS = 1000

local function read_offlevel_squad_update_skip_count()
    local runtime_cfg = zhopa and zhopa.runtime_cfg
    if runtime_cfg and runtime_cfg.num then
        return runtime_cfg.num("offlevel_squad_update_skip_count", 0, 0, 10)
    end
    local cfg = zhopa.config
    if not (cfg and cfg.get) then
        return 0
    end
    local ok, value = safe_call(
        "zhopa.config.get(offlevel_squad_update_skip_count)",
        cfg.get,
        "offlevel_squad_update_skip_count",
        0
    )
    if not ok then
        return 0
    end
    value = tonumber(value) or 0
    if value < 0 then
        return 0
    end
    if value > 10 then
        return 10
    end
    return value
end


local PREVALIDATED_CTX = { prevalidated = true }
local debug_hud_enabled
local debug_hud_enabled_value = false
local route_cache = {}
local NO_DELTA_SQUAD_TICK_MS = 1000

local function update_memory_snapshot(squad, source)
    if not (squad and zhopa.memory) then
        return nil
    end
    local sid = tonumber(squad.id) or nil
    if not sid then
        return nil
    end
    if zhopa.memory.upsert_snapshot then
        local ok_upsert, entry, changed = safe_call("memory.upsert_snapshot", zhopa.memory.upsert_snapshot, squad, source or "callback")
        if ok_upsert then
            return entry, changed == true
        end
    end
    if zhopa.memory.update_squad_snapshot_verified then
        safe_call("memory.update_squad_snapshot_verified", zhopa.memory.update_squad_snapshot_verified, squad, sid)
    elseif zhopa.memory.update_squad_snapshot then
        safe_call("memory.update_squad_snapshot", zhopa.memory.update_squad_snapshot, squad)
    end
    return zhopa.memory.get_squad_entry and zhopa.memory.get_squad_entry(sid) or nil, true
end

local function call_module_method(switch_name, module_name, method_name, tag, ...)
    if switch_name and can_run(switch_name) ~= true then
        return false
    end
    local module = zhopa and zhopa[module_name] or nil
    local fn = module and module[method_name] or nil
    if type(fn) ~= "function" then
        return false
    end
    safe_call(tag or (tostring(module_name) .. "." .. tostring(method_name)), fn, ...)
    return true
end

local function call_module_method_fast(switch_name, module_name, method_name, tag, ...)
    if switch_name and can_run(switch_name) ~= true then
        return false
    end
    local module = zhopa and zhopa[module_name] or nil
    local fn = module and module[method_name] or nil
    if type(fn) ~= "function" then
        return false
    end
    local ok, err = pcall(fn, ...)
    if not ok and zhopa and zhopa.log and zhopa.log.error then
        zhopa.log.error("CORE", "%s failed: %s", tostring(tag or (tostring(module_name) .. "." .. tostring(method_name))), tostring(err))
    end
    return ok == true
end

local function call_bound_method_fast(cache_key, switch_name, module_name, method_name, tag, ...)
    if switch_name and can_run(switch_name) ~= true then
        return false
    end
    local cached = route_cache[cache_key]
    if cached == nil then
        local module = zhopa and zhopa[module_name] or nil
        local fn = module and module[method_name] or nil
        cached = type(fn) == "function" and fn or false
        route_cache[cache_key] = cached
    end
    if type(cached) ~= "function" then
        return false
    end
    local ok, err = pcall(cached, ...)
    if not ok and zhopa and zhopa.log and zhopa.log.error then
        zhopa.log.error("CORE", "%s failed: %s", tostring(tag or (tostring(module_name) .. "." .. tostring(method_name))), tostring(err))
    end
    return ok == true
end

local function clear_route_cache()
    route_cache = {}
end

local function read_object_name(obj)
    if not obj then
        return nil
    end
    local raw_name = obj.name
    if type(raw_name) == "string" and raw_name ~= "" then
        return raw_name
    end
    local ok_name, res_name = pcall(function()
        return obj:name()
    end)
    if ok_name and type(res_name) == "string" and res_name ~= "" then
        return res_name
    end
    return nil
end

local function build_smart_update_ctx(smart)
    local smart_name = read_object_name(smart)
    local level_name = now_level_name_by_gvid(tonumber(smart and smart.m_game_vertex_id) or 0)
    if (type(level_name) ~= "string" or level_name == "") and smart_name and zhopa.board_index and zhopa.board_index.get_smart_level then
        level_name = zhopa.board_index.get_smart_level(smart_name)
    end
    local actor_level = current_actor_level_name()
    return {
        name = smart_name,
        id = tonumber(smart and smart.id) or nil,
        level_name = level_name,
        is_on_actor_level = (level_name ~= nil and actor_level ~= nil and level_name == actor_level),
        disabled = smart and smart.disabled == true or false,
    }
end

local function wants_smart_update(module_name, smart, ctx)
    local module = zhopa and zhopa[module_name] or nil
    local wants = module and module.wants_smart_update or nil
    if type(wants) ~= "function" then
        return true
    end
    local ok, res = pcall(wants, smart, ctx)
    if ok then
        return res == true
    end
    if zhopa and zhopa.log and zhopa.log.error then
        zhopa.log.error("CORE", "%s.wants_smart_update failed: %s", tostring(module_name), tostring(res))
    end
    return true
end

local function dispatch_direct_squad_fsm(squad, source, entry)
    if squad and zhopa.memory and zhopa.memory.is_protected_squad then
        local ok_protected, protected = safe_call(
            "memory.is_protected_squad",
            zhopa.memory.is_protected_squad,
            squad
        )
        if ok_protected and protected == true then
            return false
        end
    end
    if type(entry) ~= "table" then
        entry = update_memory_snapshot(squad, source)
    end
    if type(entry) ~= "table" then
        return false
    end
    if can_run("story_events") and zhopa.story_events and zhopa.story_events.update_squad_tasks then
        local ok_story, handled = safe_call(
            "story_events.update_squad_tasks",
            zhopa.story_events.update_squad_tasks,
            squad,
            PREVALIDATED_CTX
        )
        if ok_story and handled == true then
            return true
        end
    end
    if can_run("smart_tasks") and zhopa.smart_tasks and zhopa.smart_tasks.update_squad_tasks then
        local ok_smart, handled = safe_call(
            "smart_tasks.update_squad_tasks",
            zhopa.smart_tasks.update_squad_tasks,
            squad,
            PREVALIDATED_CTX
        )
        if ok_smart and handled == true then
            return true
        end
    end
    if entry.npc_kind == "mutant" then
        if zhopa.mutants and zhopa.mutants.update_squad_tasks then
            safe_call("mutants.update_squad_tasks", zhopa.mutants.update_squad_tasks, squad, PREVALIDATED_CTX)
            return true
        end
        if zhopa.tasks and zhopa.tasks.update_squad_tasks then
            safe_call("tasks.update_squad_tasks", zhopa.tasks.update_squad_tasks, squad, PREVALIDATED_CTX)
            return true
        end
        return false
    end
    if zhopa.tasks and zhopa.tasks.update_squad_tasks then
        safe_call("tasks.update_squad_tasks", zhopa.tasks.update_squad_tasks, squad, PREVALIDATED_CTX)
        return true
    end
    return false
end

local function route_squad_first_update(squad, entry)
    call_module_method("board_index", "board_index", "on_squad_first_update", "board_index.on_squad_first_update", squad)
    call_module_method("mutants", "mutants", "on_squad_first_update", "mutants.on_squad_first_update", squad, entry)
    if debug_hud_enabled and debug_hud_enabled() then
        call_module_method("debug_hud", "debug_hud", "on_squad_first_update", "debug_hud.on_squad_first_update", squad)
    end
end

local function route_squad_update(squad, entry, changed)
    call_bound_method_fast("board_index.on_squad_update", "board_index", "board_index", "on_squad_update", "board_index.on_squad_update", squad, entry, changed)
    call_bound_method_fast("mutants.on_squad_update", "mutants", "mutants", "on_squad_update", "mutants.on_squad_update", squad, entry, changed)
    if debug_hud_enabled and debug_hud_enabled() then
        call_bound_method_fast("debug_hud.on_squad_update", "debug_hud", "debug_hud", "on_squad_update", "debug_hud.on_squad_update", squad, entry, changed)
    end
end

local function route_squad_npc_creation(squad, npc, smart)
    call_module_method("npc_faction_override", "npc_faction_override", "on_squad_npc_creation", "npc_faction_override.on_squad_npc_creation", squad, npc, smart)
    call_module_method("base_filler", "base_filler", "on_squad_npc_creation", "base_filler.on_squad_npc_creation", squad, npc, smart)
    call_module_method("dynamic_bases", "dynamic_bases", "on_squad_npc_creation", "dynamic_bases.on_squad_npc_creation", squad, npc, smart)
    call_module_method("service_filler", "service_filler", "on_squad_npc_creation", "service_filler.on_squad_npc_creation", squad, npc, smart)
end

local function route_squad_npc_death(squad, npc, killer_npc, killer_squad)
    call_module_method("npc_faction_override", "npc_faction_override", "on_squad_npc_death", "npc_faction_override.on_squad_npc_death", squad, npc, killer_npc, killer_squad)
    call_module_method("memory", "memory", "on_squad_npc_death", "memory.on_squad_npc_death", squad, npc, killer_npc, killer_squad)
    call_module_method("mutants", "mutants", "on_squad_npc_death", "mutants.on_squad_npc_death", squad, npc, killer_npc, killer_squad)
    call_module_method("base_filler", "base_filler", "on_squad_npc_death", "base_filler.on_squad_npc_death", squad, npc, killer_npc, killer_squad)
    call_module_method("dynamic_bases", "dynamic_bases", "on_squad_npc_death", "dynamic_bases.on_squad_npc_death", squad, npc, killer_npc, killer_squad)
    call_module_method("service_filler", "service_filler", "on_squad_npc_death", "service_filler.on_squad_npc_death", squad, npc, killer_npc, killer_squad)
    if debug_hud_enabled and debug_hud_enabled() then
        call_module_method("debug_hud", "debug_hud", "on_squad_npc_death", "debug_hud.on_squad_npc_death", squad, npc, killer_npc, killer_squad)
    end
end

local function route_squad_enter_smart(squad, smart, entry)
    call_module_method("board_index", "board_index", "on_squad_enter_smart", "board_index.on_squad_enter_smart", squad, smart)
    call_module_method("smart_tasks", "smart_tasks", "on_squad_enter_smart", "smart_tasks.on_squad_enter_smart", squad, smart, entry)
    call_module_method("base_filler", "base_filler", "on_squad_enter_smart", "base_filler.on_squad_enter_smart", squad, smart)
    call_module_method("dynamic_bases", "dynamic_bases", "on_squad_enter_smart", "dynamic_bases.on_squad_enter_smart", squad, smart)
    call_module_method("service_filler", "service_filler", "on_squad_enter_smart", "service_filler.on_squad_enter_smart", squad, smart)
end

local function route_squad_leave_smart(squad, smart, entry)
    call_module_method("board_index", "board_index", "on_squad_leave_smart", "board_index.on_squad_leave_smart", squad, smart)
    call_module_method("smart_tasks", "smart_tasks", "on_squad_leave_smart", "smart_tasks.on_squad_leave_smart", squad, smart, entry)
    call_module_method("base_filler", "base_filler", "on_squad_leave_smart", "base_filler.on_squad_leave_smart", squad, smart)
    call_module_method("dynamic_bases", "dynamic_bases", "on_squad_leave_smart", "dynamic_bases.on_squad_leave_smart", squad, smart)
    call_module_method("service_filler", "service_filler", "on_squad_leave_smart", "service_filler.on_squad_leave_smart", squad, smart)
end

local function route_squad_after_level_change(squad, old_level, new_level, entry)
    call_module_method("board_index", "board_index", "on_squad_after_level_change", "board_index.on_squad_after_level_change", squad, old_level, new_level)
    call_module_method("story_psy_watchdog", "story_psy_watchdog", "on_squad_after_level_change", "story_psy_watchdog.on_squad_after_level_change", squad, old_level, new_level, entry)
    call_module_method("base_filler", "base_filler", "on_squad_after_level_change", "base_filler.on_squad_after_level_change", squad, old_level, new_level)
    call_module_method("dynamic_bases", "dynamic_bases", "on_squad_after_level_change", "dynamic_bases.on_squad_after_level_change", squad, old_level, new_level)
    call_module_method("service_filler", "service_filler", "on_squad_after_level_change", "service_filler.on_squad_after_level_change", squad, old_level, new_level)
    if debug_hud_enabled and debug_hud_enabled() then
        call_module_method("debug_hud", "debug_hud", "on_squad_after_level_change", "debug_hud.on_squad_after_level_change", squad, old_level, new_level)
    end
end

local function route_actor_first_update()
    call_module_method("board_index", "board_index", "on_actor_first_update", "board_index.on_actor_first_update")
    call_module_method("npc_faction_override", "npc_faction_override", "on_actor_first_update", "npc_faction_override.on_actor_first_update")
    call_module_method("memory", "memory", "on_actor_first_update", "memory.on_actor_first_update")
    call_module_method("story_psy_watchdog", "story_psy_watchdog", "on_actor_first_update", "story_psy_watchdog.on_actor_first_update")
    call_module_method("story_events", "story_events", "on_actor_first_update", "story_events.on_actor_first_update")
    call_module_method("smart_tasks", "smart_tasks", "on_actor_first_update", "smart_tasks.on_actor_first_update")
    call_module_method("mutants", "mutants", "on_actor_first_update", "mutants.on_actor_first_update")
    call_module_method(nil, "loot_patch", "on_actor_first_update", "loot_patch.on_actor_first_update")
