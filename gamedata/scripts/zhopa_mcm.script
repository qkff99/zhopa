-- Standalone MCM adapter. Runtime code lives in zhopa.script.
local type = _G.type
local pcall = _G.pcall
local table_insert = _G.table.insert

local function ensure_schema()
    if zhopa and zhopa.mcm_schema then
        return zhopa.mcm_schema
    end
    if type(_G.zhopa_mcm_schema) == "table" then
        return _G.zhopa_mcm_schema
    end

    local req = _G.require
    if type(req) == "function" then
        pcall(req, "zhopa_mcm_schema")
    end

    if zhopa and zhopa.mcm_schema then
        return zhopa.mcm_schema
    end
    if type(_G.zhopa_mcm_schema) == "table" then
        return _G.zhopa_mcm_schema
    end
    return nil
end

local function clone_table(src)
    local out = {}
    for k, v in pairs(src) do
        out[k] = v
    end
    return out
end

local function make_option(schema, key)
    local meta = schema and schema.options and schema.options[key] or nil
    if type(meta) ~= "table" then
        return nil
    end

    local node = clone_table(meta)
    node.id = key
    node.hint = node.hint or ("zhopa_" .. key)
    return node
end

local function make_group(schema, group)
    local gr = {
        { id = group.id .. "_title", type = "title", text = group.text, align = "l" },
        { id = group.id .. "_divider", type = "line" },
    }

    for i = 1, #group.options do
        local node = make_option(schema, group.options[i])
        if node then
            table_insert(gr, node)
        end
    end

    return {
        id = group.id,
        sh = true,
        text = group.text,
        gr = gr,
    }
end

local function make_panel(schema, panel)
    local gr = {
        { id = panel.id .. "_slide", type = "slide", link = "ui_options_slider_player", text = panel.text, size = { 512, 50 }, spacing = 20 },
    }
    for i = 1, #panel.groups do
        local group = make_group(schema, panel.groups[i])
        for j = 1, #group.gr do
            table_insert(gr, group.gr[j])
        end
    end
    return {
        id = panel.id,
        sh = true,
        text = panel.text,
        gr = gr,
    }
end

function on_mcm_load()
    local schema = ensure_schema()
    local op = { id = "zhopa", sh = false, gr = {} }

    if type(schema) ~= "table" or type(schema.panels) ~= "table" or #schema.panels == 0 then
        op.gr[1] = {
            id = "general",
            sh = true,
            text = "ui_mcm_zhopa_panel_general",
            gr = {
                { id = "general_slide", type = "slide", link = "ui_options_slider_player", text = "ui_mcm_menu_zhopa", size = { 512, 50 }, spacing = 20 },
            },
        }
        return op
    end

    for i = 1, #schema.panels do
        table_insert(op.gr, make_panel(schema, schema.panels[i]))
    end

    return op
end
