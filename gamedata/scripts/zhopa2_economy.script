local no_trade_comm = {
	zombied = true,
	army = true,
	monolith = true,
	greh = true,
	isg = true,
}

local trade_ini = nil
local trade_buy_sell_cache = nil
local original_npc_has_items_to_sell = nil
local original_trade_job_sell_items = nil
local original_trade_job_give_id = nil
