	TRADE_SCAN_INTERVAL_MS = 3000,
	AUTO_TRADE_COOLDOWN_MS = 30000,
	SMART_TRADE_QUEUE_SLOT_MS = 60000,
	MED_BANDAGE_KEEP = 3,
	MEDKIT_KEEP = 3,
	OTHER_MED_KEEP = 1,
	GRENADE_KEEP = 2,
	FOOD_KEEP = 1,
	DRINK_KEEP = 1,
	NPC_SELL_FACTOR = 0.5,
	NPC_BUY_FACTOR = 1.0,
	DEFAULT_BUY_ITEM_EXPONENT = 2.25,
	AUTO_TRADE_MIN_MINOR_SELL_VALUE = 1000,
	ROLE_NONE = "__none",
	TRADE_BUY_SELL_PATH = "items\\trade\\gulag_job_trade_buy_sell.ltx",
	AMMO_BUY_MIN = 3,
}
M.TRADE_EVENT_BUFFER_MAX = 50
M.TRADE_ROUTE_VALUE_WEIGHT_STEP = 5000
M.TRADE_ROUTE_MAX_VALUE_BONUS = 75
