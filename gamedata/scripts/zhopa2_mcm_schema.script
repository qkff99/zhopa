	},
	{
		id = "tasks",
		text = "ui_mcm_zhopa2_panel_tasks",
		["groups"] = {
			{ id = "roam", text = "ui_mcm_zhopa2_group_roam", options = { "explore_enabled", "populate_enabled", "base_camping_enabled", "patrol_enabled", "night_rest_enabled", "stalker_hunt_enabled", "artefact_enabled" } },
			{ id = "weights", text = "ui_mcm_zhopa2_group_weights", options = { "stalker_explore_weight", "stalker_populate_weight", "stalker_patrol_weight", "stalker_hunt_weight", "stalker_artefact_weight", "stalker_trade_weight" } },
			{ id = "timing", text = "ui_mcm_zhopa2_group_timing", options = { "rest_duration_game_hours", "patrol_duration_game_hours", "rest_fallback_stay_min_sec", "rest_fallback_stay_max_sec" } },
			{ id = "targeting", text = "ui_mcm_zhopa2_group_targeting", options = { "target_sync_enabled", "online_intent_enforce_enabled", "revenge_enabled", "revenge_actor_enabled", "revenge_actor_chance", "hunt_offline_combat_enabled", "hunt_offline_combat_interval_sec", "hunt_offline_combat_distance" } },
		},
	},
	{
		id = "mutants",
		text = "ui_mcm_zhopa2_panel_mutants",
		["groups"] = {
			{ id = "movement", text = "ui_mcm_zhopa2_group_mutants_movement", options = { "mutant_explore_enabled", "mutant_hunt_enabled", "mutant_patrol_enabled" } },
			{ id = "weights", text = "ui_mcm_zhopa2_group_weights", options = { "mutant_hunt_weight", "mutant_patrol_weight", "mutant_explore_weight" } },
			{ id = "timing", text = "ui_mcm_zhopa2_group_mutants_timing", options = { "mutant_rest_duration_game_hours", "mutant_patrol_duration_game_hours" } },
		},
	},
}

local PATH_BY_KEY = {}

for i = 1, #PANELS do
	local panel = PANELS[i]
	for j = 1, #panel.groups do
		local group = panel.groups[j]
		for k = 1, #group.options do
			local key = group.options[k]
			PATH_BY_KEY[key] = "zhopa2/" .. panel.id .. "/" .. key
		end
	end
end

function get_path(key)
	return PATH_BY_KEY[key]
end

function get_option(key)
	return OPTION_DEFS[key]
end

MCM_SCHEMA.options = OPTION_DEFS
MCM_SCHEMA.panels = PANELS
MCM_SCHEMA.path_by_key = PATH_BY_KEY
MCM_SCHEMA.get_path = get_path
MCM_SCHEMA.get_option = get_option
_G.zhopa2_mcm_schema = MCM_SCHEMA
