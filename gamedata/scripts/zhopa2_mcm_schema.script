local PANELS = {
	{
		id = "general",
		text = "ui_mcm_zhopa2_panel_general",
		["groups"] = {
			{ id = "core", text = "ui_mcm_zhopa2_group_core", options = { "enabled", "stalker_movement_enabled", "mutant_movement_enabled", "debug_hud_enabled" } },
			{ id = "systems", text = "ui_mcm_zhopa2_group_systems", options = { "service_filler_enabled", "loot_enabled", "loot_offline_enabled", "loot_offline_real_enabled", "artefact_offline_enabled", "trade_enabled", "npc_sell_price_multiplier" } },
			{ id = "save_cleanup", text = "ui_mcm_zhopa2_group_save_cleanup", options = { "legacy_save_cleanup_enabled", "legacy_save_cleanup_dry_run", "legacy_save_cleanup_remove_zhopa2_state" } },
