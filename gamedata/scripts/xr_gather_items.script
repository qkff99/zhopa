-- ZHOPA2 BEGIN: targeted artifact gather tuning constants.
local ZHOPA2_ARTIFACT_PICKUP_DIST = 2
local ZHOPA2_ARTIFACT_APPROACH_MAX_DIST = 12
local ZHOPA2_ARTIFACT_APPROACH_REACHED_DIST_SQR = 2.25
local ZHOPA2_APPROACH_NPC_MIN_DIST_SQR = 1
local ZHOPA2_APPROACH_CHECK_MS = 1500
local ZHOPA2_APPROACH_BAD_TICKS = 3
local ZHOPA2_APPROACH_PROGRESS_EPS_SQR = 0.25
local ZHOPA2_APPROACH_FORWARD_STEPS = {4, 8, 12, 18, 25, 35, 50}
local ZHOPA2_ARTIFACT_SCAN_MS = 3500
local ZHOPA2_ARTIFACT_SCAN_STAGE = 5
-- ZHOPA2 END

-- ZHOPA2 BEGIN: optional looting extension over vanilla item gathering.
local function zhopa2_debug_print_enabled()
	local cfg = rawget(_G, "zhopa2_cfg")
	if not cfg and require then
		pcall(require, "zhopa2_cfg")
		cfg = rawget(_G, "zhopa2_cfg")
	end
	return cfg and type(cfg.get_bool) == "function" and cfg.get_bool("debug_hud_enabled", false) == true
end

local function zhopa2_loot_mod()
	local mod = rawget(_G, "zhopa2_loot")
	if not mod and require then
		pcall(require, "zhopa2_loot")
		mod = rawget(_G, "zhopa2_loot")
	end
	return mod
end

local function zhopa2_loot_active(npc)
	local mod = zhopa2_loot_mod()
	return mod and type(mod.should_manage_looter) == "function" and mod.should_manage_looter(npc) == true
end

local function zhopa2_loot_globally_enabled()
	local mod = zhopa2_loot_mod()
	return mod and type(mod.enabled) == "function" and mod.enabled() == true
end

local function zhopa2_can_take_section(npc, item, section)
	local mod = zhopa2_loot_mod()
	if not (mod and type(mod.can_take_section) == "function") then
		return false
	end
	return mod.can_take_section(section, item, npc) == true
end

local function zhopa2_event_item_ids()
	local mod = zhopa2_loot_mod()
	if mod and type(mod.recent_item_ids) == "function" then
		return mod.recent_item_ids()
	end
	return nil
end

local function zhopa2_targeted_item_ids(npc)
	local mod = zhopa2_loot_mod()
	if mod and type(mod.targeted_item_ids_for_npc) == "function" then
		return mod.targeted_item_ids_for_npc(npc)
	end
	return nil
end

local function zhopa2_item_targeted_for_npc(npc, item_id, ids)
	item_id = tonumber(item_id)
	local st
	if npc and db and db.storage then
		st = db.storage[npc:id()] and db.storage[npc:id()].gather_items
	end
	if st and tonumber(st.zhopa2_targeted_item_id) and (not item_id or tonumber(st.zhopa2_targeted_item_id) == item_id) then
		return true
	end
	ids = ids or zhopa2_targeted_item_ids(npc)
	if not ids then
		return false
	end
	if not item_id then
		return #ids > 0
	end
	for i = 1, #ids do
		if tonumber(ids[i]) == item_id then
			return true
		end
	end
	return false
end

local function zhopa2_item_clsid(item)
	if not (item and type(item.clsid) == "function") then
		return nil
	end
	local ok, cls = pcall(item.clsid, item)
	return ok and cls or nil
end

local function zhopa2_is_recent_item_id(item_id)
	local mod = zhopa2_loot_mod()
	if mod and type(mod.is_recent_item_id) == "function" then
		return mod.is_recent_item_id(item_id) == true
	end
	return false
end

local function zhopa2_item_detect_dist_sqr()
	local mod = zhopa2_loot_mod()
	if mod and type(mod.item_detect_dist_sqr) == "function" then
		return mod.item_detect_dist_sqr()
	end
	return 2500
end

local function zhopa2_record_loot(npc, item, reason)
	local mod = zhopa2_loot_mod()
	if mod and type(mod.record_loot) == "function" then
		return mod.record_loot(npc, nil, item, nil, reason)
	end
	return false
end

local function zhopa2_should_skip_overweight(npc)
	return not zhopa2_loot_active(npc)
end

local function zhopa2_should_skip_condlist(npc)
	return not zhopa2_loot_active(npc)
end

local function zhopa2_add_gather_precondition(manager, action_id)
	if not (manager and action_id) then
		return false
	end
	local ok = pcall(function()
		local action = manager:action(action_id)
		action:add_precondition(world_property(evaid, false))
	end)
	return ok == true
end

class "zhopa2_evaluator_camper_end_for_gather" (property_evaluator)
function zhopa2_evaluator_camper_end_for_gather:__init(name) super (nil, name)
end

function zhopa2_evaluator_camper_end_for_gather:evaluate()
	local npc = self.object
	local root = npc and db and db.storage and db.storage[npc:id()]
	if root and root.corpse_detection and root.corpse_detection.selected_corpse_id then
		return false
	end
	if npc and type(IsWounded) == "function" and IsWounded(npc) then
		return false
	end
	local st = root and root.gather_items
	if st and st.selected_id and zhopa2_item_targeted_for_npc(npc, st.selected_id) then
		return true
	end
	local camper_st = root and root.camper
	if camper_st and xr_logic and xr_logic.is_active then
		return not xr_logic.is_active(npc, camper_st)
	end
	return not (root and root.active_scheme == "camper")
end

local function zhopa2_apply_camper_end_override(manager)
	if not (manager and xr_evaluators_id and xr_evaluators_id.stohe_camper_base) then
		return false
	end
	local evaluator_id = xr_evaluators_id.stohe_camper_base + 1
	pcall(function()
		manager:remove_evaluator(evaluator_id)
	end)
	local ok = pcall(function()
		manager:add_evaluator(evaluator_id, zhopa2_evaluator_camper_end_for_gather("zhopa2_camper_end_for_gather"))
	end)
	return ok == true
end

local function zhopa2_job_action_key(root)
	if not root then
		return "-"
	end
	return tostring(root.active_scheme or "-")
		.. "|" .. tostring(root.active_section or "-")
		.. "|" .. tostring(root.job_ini or root.ini_filename or "-")
		.. "|" .. tostring(root.stype or "-")
end

local function zhopa2_suspend_active_scheme_for_targeted_gather(npc, st)
	if not (npc and st and db and db.storage and xr_logic and xr_logic.activate_by_section) then
		return false
	end
	if st.zhopa2_logic_suspended == true then
		return true
	end
	local root = db.storage[npc:id()]
	if not (root and root.active_scheme == "camper" and root.ini) then
		return false
	end
	st.zhopa2_logic_suspended = true
	st.zhopa2_restore_gulag_name = root.gulag_name
	local ok = pcall(function()
		xr_logic.activate_by_section(npc, root.ini, "nil", root.gulag_name, false)
	end)
	if not ok then
		st.zhopa2_logic_suspended = nil
		st.zhopa2_restore_gulag_name = nil
		return false
	end
	return true
end

local function zhopa2_restore_active_scheme_after_targeted_gather(npc, st)
	if not (npc and st and st.zhopa2_logic_suspended == true and db and db.storage and xr_logic and xr_logic.activate_by_section) then
		return false
	end
	st.zhopa2_logic_suspended = nil
	local root = db.storage[npc:id()]
	local ini = root and root.ini or nil
	local gulag_name = st.zhopa2_restore_gulag_name or (root and root.gulag_name)
	st.zhopa2_restore_gulag_name = nil
	if not ini then
		return false
	end
	local ok = pcall(function()
		xr_logic.activate_by_section(npc, ini, nil, gulag_name, false)
	end)
	return ok == true
end

local function zhopa2_apply_job_preconditions(npc, st)
	if not (npc and st and db and db.storage and xr_actions_id) then
		return false
	end
	local root = db.storage[npc:id()]
	local manager = npc:motivation_action_manager()
	if not (root and manager) then
		return false
	end
	local key = zhopa2_job_action_key(root)
	local now = time_global and time_global() or 0
	local precondition_cached = st.zhopa2_gather_precondition_key == key
	local precondition_retry_due = not precondition_cached
		or now <= 0
		or ((now - (tonumber(st.zhopa2_gather_precondition_time) or 0)) > 1000)
	local camper_override_cached = root.active_scheme ~= "camper" or st.zhopa2_camper_end_override_key == key
	if precondition_cached and camper_override_cached and not precondition_retry_due then
		return true
	end
	local action_added = false
	if precondition_retry_due then
		action_added = zhopa2_add_gather_precondition(manager, xr_actions_id.stohe_camper_base and xr_actions_id.stohe_camper_base + 1) or action_added
		action_added = zhopa2_add_gather_precondition(manager, xr_actions_id.smartcover_action) or action_added
		action_added = zhopa2_add_gather_precondition(manager, xr_actions_id.smartcover_action and xr_actions_id.smartcover_action + 2) or action_added
		action_added = zhopa2_add_gather_precondition(manager, xr_actions_id.stohe_cover_base and xr_actions_id.stohe_cover_base + 1) or action_added
		if xr_campfire_point and xr_campfire_point.actid then
			action_added = zhopa2_add_gather_precondition(manager, xr_campfire_point.actid) or action_added
		end
		if rawget(_G, "beh_actid") then
			action_added = zhopa2_add_gather_precondition(manager, beh_actid) or action_added
		end
		if action_added then
			st.zhopa2_gather_precondition_key = key
			st.zhopa2_gather_precondition_time = now
		end
	end
	local camper_override_added = false
	if root.active_scheme == "camper" and st.zhopa2_camper_end_override_key ~= key and zhopa2_apply_camper_end_override(manager) then
		st.zhopa2_camper_end_override_key = key
		camper_override_added = true
	end
	return action_added or precondition_cached or camper_override_added
end
-- ZHOPA2 END

